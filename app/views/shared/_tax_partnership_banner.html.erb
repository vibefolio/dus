<!-- Tax Partnership Banner (Shared Partial) -->
<section class="section" style="background: #f8faf9; border-top: 1px solid #e8f5ee; border-bottom: 1px solid #e8f5ee;">
  <div class="container">
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 48px; flex-wrap: wrap;">
      <div style="flex: 1; min-width: 280px;">
        <div style="display: inline-flex; align-items: center; gap: 8px; background: #e8f5ee; padding: 6px 14px; border-radius: 50px; font-size: 12px; font-weight: 700; color: #00a859; margin-bottom: 16px;">
          메이저텍스 × 디어스 파트너십
        </div>
        <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; margin-bottom: 12px; word-break: keep-all; line-height: 1.3; color: #111;">
          세무기장도 필요하신가요?
        </h2>
        <p style="color: #6b7280; font-size: 16px; line-height: 1.7; word-break: keep-all; margin-bottom: 24px;">
          홈페이지와 세무회계를 한 번에 해결하세요.<br>
          파트너십 할인으로 초기 개발비 30% + 유지관리비 최대 3만원 할인.
        </p>
        <%= link_to majortax_path, style: "display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: #00a859; color: white; font-weight: 700; border-radius: 9999px; text-decoration: none; font-size: 15px; transition: all 0.3s;", class: "btn-cta-primary" do %>
          합리적인 요금제 확인하기
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
        <% end %>
      </div>
      <div style="display: flex; align-items: center; gap: 24px; flex-shrink: 0;">
        <div style="text-align: center; padding: 44px 52px; background: white; border-radius: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.06);">
          <div style="font-size: 14px; color: #9ca3af; margin-bottom: 10px;">세무회계 전문</div>
          <div style="font-size: 22px; font-weight: 900; color: #111;">메이저텍스</div>
        </div>
        <div style="font-size: 32px; color: #d1d5db; font-weight: 300;">+</div>
        <div style="text-align: center; padding: 44px 52px; background: white; border-radius: 24px; border: 1.5px solid #c8ecd8; box-shadow: 0 4px 20px rgba(0,168,89,0.08);">
          <div style="font-size: 14px; color: #9ca3af; margin-bottom: 10px;">웹앱 개발 전문</div>
          <div style="font-size: 22px; font-weight: 900; color: #00a859;">디어스</div>
        </div>
      </div>
    </div>
  </div>
</section>
