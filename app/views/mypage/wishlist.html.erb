<% content_for :title, "위시리스트 - 디어스" %>

<div class="min-h-screen bg-gray-50 section-premium">
  <div class="max-w-6xl mx-auto px-4 md:px-6">

    <!-- 헤더 -->
    <div class="mb-8 reveal">
      <span class="eyebrow mb-3">Wishlist</span>
      <h1 class="text-3xl font-bold text-gray-900 mt-2 mb-2" style="letter-spacing: -0.02em; word-break: keep-all;">위시리스트</h1>
      <p class="text-gray-500" style="word-break: keep-all;">마음에 드는 템플릿을 저장하고 관리하세요</p>
    </div>

    <!-- 탭 메뉴 -->
    <div class="card-premium mb-8 reveal">
      <div class="bg-white rounded-[calc(2rem-0.375rem)] overflow-x-auto">
        <div class="flex min-w-max md:min-w-0">
          <%= link_to mypage_path, class: "flex-1 px-3 md:px-6 py-3.5 md:py-4 text-center font-medium text-gray-400 hover:text-[#00a859] text-sm md:text-base whitespace-nowrap", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
            대시보드
          <% end %>
          <%= link_to mypage_orders_path, class: "flex-1 px-3 md:px-6 py-3.5 md:py-4 text-center font-medium text-gray-400 hover:text-[#00a859] text-sm md:text-base whitespace-nowrap", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
            주문 내역
          <% end %>
          <%= link_to mypage_wishlist_path, class: "flex-1 px-3 md:px-6 py-3.5 md:py-4 text-center font-medium border-b-2 border-[#00a859] text-[#00a859] text-sm md:text-base whitespace-nowrap", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
            위시리스트
          <% end %>
        </div>
      </div>
    </div>

    <% if @liked_templates.any? %>
      <!-- 템플릿 그리드 -->
      <div class="grid md:grid-cols-3 gap-5">
        <% @liked_templates.each_with_index do |template, i| %>
          <div class="card-premium group reveal-stagger" style="animation-delay: <%= i * 80 %>ms;">
            <div class="card-premium-inner !p-0 overflow-hidden">
              <!-- 썸네일 -->
              <div class="relative aspect-video overflow-hidden bg-gray-100">
                <% if template.pc_thumbnail_url.present? %>
                  <%= image_tag template.pc_thumbnail_url, class: "w-full h-full object-cover group-hover:scale-105", loading: "lazy", decoding: "async", style: "transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);" %>
                <% else %>
                  <div class="w-full h-full bg-gradient-to-br from-[#00a859]/10 to-[#00d670]/10"></div>
                <% end %>

                <!-- 좋아요 버튼 -->
                <%= button_to design_template_toggle_like_path(template), method: :post, data: { turbo: false }, class: "absolute top-3 right-3 w-9 h-9 bg-white/90 backdrop-blur-sm rounded-full shadow-lg flex items-center justify-center hover:bg-red-50", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); border: none; cursor: pointer;" do %>
                  <svg class="w-4 h-4 text-red-500 fill-current" viewBox="0 0 24 24">
                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                  </svg>
                <% end %>
              </div>

              <!-- 정보 -->
              <div class="p-5">
                <h3 class="font-bold text-gray-900 mb-1.5 line-clamp-1"><%= template.title %></h3>
                <p class="text-sm text-gray-500 mb-4 line-clamp-2"><%= template.description %></p>

                <div class="flex items-center justify-between">
                  <div class="text-xl font-bold text-[#00a859]">
                    <%= number_to_currency(template.price, unit: '₩', precision: 0) %>
                  </div>
                  <%= button_to "장바구니 담기", add_to_cart_path(design_template_id: template.id), method: :post, data: { turbo: false }, class: "px-4 py-2.5 bg-[#00a859] text-white text-sm rounded-full hover:bg-[#008a47] font-medium", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); border: none; cursor: pointer;" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- 빈 상태 -->
      <div class="card-premium reveal">
        <div class="card-premium-inner text-center py-16">
          <svg class="w-16 h-16 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          <h2 class="text-xl font-bold text-gray-900 mb-2" style="letter-spacing: -0.02em;">위시리스트가 비어있습니다</h2>
          <p class="text-gray-500 mb-6 text-sm">마음에 드는 템플릿을 찾아 저장해보세요</p>
          <%= link_to design_templates_path, class: "btn-supanova btn-supanova-primary inline-flex bg-gradient-to-r from-[#00a859] to-[#00d670] text-white !px-6 !py-3", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
            템플릿 둘러보기
            <span class="arrow"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>
