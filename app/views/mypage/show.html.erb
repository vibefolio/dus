<% content_for :title, "마이페이지 - 디어스" %>

<div class="min-h-screen bg-gray-50 section-premium">
  <div class="max-w-6xl mx-auto px-4 md:px-6">

    <!-- 프로필 헤더 -->
    <div class="card-premium mb-8 reveal">
      <div class="card-premium-inner">
        <div class="flex flex-col md:flex-row items-center md:items-center gap-4 md:gap-6">
          <!-- 아바타 -->
          <div class="relative">
            <% if @user.image.present? %>
              <%= image_tag @user.image, class: "w-20 h-20 md:w-24 md:h-24 rounded-full object-cover ring-4 ring-[#00a859]/10" %>
            <% else %>
              <div class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-gradient-to-br from-[#00a859] to-[#00d670] flex items-center justify-center text-white text-2xl md:text-3xl font-bold ring-4 ring-[#00a859]/10">
                <%= @user.name&.first&.upcase || @user.email.first.upcase %>
              </div>
            <% end %>
          </div>

          <!-- 사용자 정보 -->
          <div class="flex-1 text-center md:text-left">
            <h1 class="text-xl md:text-2xl font-bold text-gray-900 mb-1" style="letter-spacing: -0.02em;">
              <%= @user.name || @user.email.split('@').first %>님
            </h1>
            <p class="text-sm md:text-base text-gray-500 mb-3 truncate"><%= @user.email %></p>
            <%= link_to edit_mypage_path, class: "inline-flex items-center gap-2 rounded-full px-5 py-2.5 bg-[#00a859] text-white text-sm font-medium", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
              프로필 수정
              <span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
              </span>
            <% end %>
          </div>

          <!-- 통계 (모바일) -->
          <div class="flex md:hidden gap-8 w-full justify-center pt-4 border-t border-gray-100">
            <div class="text-center">
              <div class="text-2xl font-bold text-[#00a859]"><%= @orders.count %></div>
              <div class="text-xs text-gray-500 mt-0.5">주문</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-[#00a859]"><%= @liked_templates.count %></div>
              <div class="text-xs text-gray-500 mt-0.5">위시리스트</div>
            </div>
          </div>

          <!-- 통계 (데스크탑) -->
          <div class="hidden md:flex gap-8">
            <div class="text-center">
              <div class="text-2xl font-bold text-[#00a859]"><%= @orders.count %></div>
              <div class="text-xs text-gray-500 mt-0.5">주문</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-[#00a859]"><%= @liked_templates.count %></div>
              <div class="text-xs text-gray-500 mt-0.5">위시리스트</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 탭 메뉴 -->
    <div class="card-premium mb-8 reveal">
      <div class="bg-white rounded-[calc(2rem-0.375rem)] overflow-x-auto">
        <div class="flex min-w-max md:min-w-0">
          <%= link_to mypage_path, class: "flex-1 px-3 md:px-6 py-3.5 md:py-4 text-center font-medium border-b-2 border-[#00a859] text-[#00a859] text-sm md:text-base whitespace-nowrap", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
            대시보드
          <% end %>
          <%= link_to mypage_orders_path, class: "flex-1 px-3 md:px-6 py-3.5 md:py-4 text-center font-medium text-gray-400 hover:text-[#00a859] text-sm md:text-base whitespace-nowrap", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
            주문 내역
          <% end %>
          <%= link_to mypage_wishlist_path, class: "flex-1 px-3 md:px-6 py-3.5 md:py-4 text-center font-medium text-gray-400 hover:text-[#00a859] text-sm md:text-base whitespace-nowrap", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
            위시리스트
          <% end %>
        </div>
      </div>
    </div>

    <!-- 내 사이트 관리 -->
    <div class="card-premium mb-8 reveal">
      <div class="card-premium-inner">
        <div class="flex items-center justify-between mb-6">
          <div>
            <span class="eyebrow mb-2">My Sites</span>
            <h2 class="text-xl font-bold text-gray-900 mt-2" style="letter-spacing: -0.02em;">내 사이트 관리</h2>
          </div>
          <% if @user.agency_owner? || @user.agency_admin? || @user.super_admin? %>
            <%= link_to admin_root_path, class: "inline-flex items-center gap-1.5 text-sm text-[#00a859] font-semibold hover:text-[#008a47]", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" do %>
              관리자 패널
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <% end %>
          <% end %>
        </div>

        <% if @owned_agencies.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% @owned_agencies.each_with_index do |agency, i| %>
              <div class="card-premium reveal-stagger" style="animation-delay: <%= i * 80 %>ms;">
                <div class="card-premium-inner !p-5">
                  <div class="flex justify-between items-start mb-4">
                    <span class="eyebrow"><%= agency.active? ? "운영 중" : "준비 중" %></span>
                    <span class="text-xs text-gray-400"><%= agency.created_at.strftime('%Y.%m.%d') %></span>
                  </div>
                  <h3 class="font-bold text-gray-900 text-lg mb-1"><%= agency.name %></h3>
                  <p class="text-[#00a859] text-sm font-medium mb-4"><%= agency.subdomain %>.designd.co.kr</p>
                  <div class="flex gap-2">
                    <%= link_to "사이트 방문", "http://#{agency.subdomain}.designd.co.kr", target: "_blank", class: "flex-1 text-center py-2.5 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" %>
                    <%= link_to "통계/관리", admin_agency_path(agency), class: "flex-1 text-center py-2.5 bg-[#00a859] text-white rounded-full text-sm font-medium hover:bg-[#008a47]", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-10 text-gray-400 bg-gray-50/50 rounded-2xl border border-dashed border-gray-200">
            <p class="mb-2">아직 보유한 사이트가 없습니다.</p>
            <%= link_to "템플릿 둘러보기", design_templates_path, class: "text-[#00a859] font-semibold hover:underline" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 상담 내역 -->
    <div class="card-premium mb-8 reveal">
      <div class="card-premium-inner">
        <div class="flex items-center justify-between mb-6">
          <div>
            <span class="eyebrow mb-2">Consultations</span>
            <h2 class="text-xl font-bold text-gray-900 mt-2" style="letter-spacing: -0.02em;">상담 내역</h2>
          </div>
        </div>

        <% if @quotes.any? %>
          <div class="space-y-3">
            <% @quotes.each do |quote| %>
              <div class="p-4 rounded-xl bg-gray-50/80 hover:bg-gray-50 border border-gray-100" style="transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);">
                <div class="flex justify-between items-start">
                  <div>
                    <div class="flex items-center gap-2 mb-1">
                      <span class="font-medium text-gray-900"><%= quote.project_type %></span>
                      <span class="text-xs text-gray-300">|</span>
                      <span class="text-sm text-gray-400"><%= quote.created_at.strftime('%Y.%m.%d') %></span>
                    </div>
                    <p class="text-gray-500 text-sm line-clamp-1"><%= quote.message %></p>
                  </div>
                  <span class="px-3 py-1 text-xs font-medium rounded-full <%= quote.status == 'pending' ? 'bg-amber-50 text-amber-600' : 'bg-[#00a859]/10 text-[#00a859]' %>">
                    <%= quote.status == 'pending' ? '접수완료' : '처리완료' %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 text-gray-400 bg-gray-50/50 rounded-xl">
            <p>상담 내역이 없습니다.</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 최근 주문 + 위시리스트 -->
    <div class="grid md:grid-cols-2 gap-6">
      <!-- 최근 주문 -->
      <div class="card-premium reveal">
        <div class="card-premium-inner">
          <div class="flex items-center justify-between mb-6">
            <div>
              <span class="eyebrow mb-2">Recent Orders</span>
              <h2 class="text-lg font-bold text-gray-900 mt-2" style="letter-spacing: -0.02em;">최근 주문</h2>
            </div>
            <%= link_to "전체보기", mypage_orders_path, class: "text-sm text-[#00a859] font-medium hover:text-[#008a47]", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" %>
          </div>

          <% if @orders.any? %>
            <div class="space-y-3">
              <% @orders.each do |order| %>
                <div class="p-4 rounded-xl bg-gray-50/80 border border-gray-100" style="transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);">
                  <div class="flex justify-between items-start mb-2">
                    <div>
                      <div class="font-medium text-gray-900">주문 #<%= order.id %></div>
                      <div class="text-sm text-gray-400"><%= order.created_at.strftime('%Y년 %m월 %d일') %></div>
                    </div>
                    <span class="px-3 py-1 bg-[#00a859]/10 text-[#00a859] text-xs font-medium rounded-full">
                      <%= order.status || '완료' %>
                    </span>
                  </div>
                  <div class="text-lg font-bold text-[#00a859]">
                    <%= number_to_currency(order.total_amount || 0, unit: '₩', precision: 0) %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-10 text-gray-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              <p class="text-sm">아직 주문 내역이 없습니다</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- 위시리스트 -->
      <div class="card-premium reveal">
        <div class="card-premium-inner">
          <div class="flex items-center justify-between mb-6">
            <div>
              <span class="eyebrow mb-2">Wishlist</span>
              <h2 class="text-lg font-bold text-gray-900 mt-2" style="letter-spacing: -0.02em;">위시리스트</h2>
            </div>
            <%= link_to "전체보기", mypage_wishlist_path, class: "text-sm text-[#00a859] font-medium hover:text-[#008a47]", style: "transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);" %>
          </div>

          <% if @liked_templates.any? %>
            <div class="grid grid-cols-2 gap-3">
              <% @liked_templates.first(4).each do |template| %>
                <div class="group relative overflow-hidden rounded-xl border border-gray-100 hover:border-[#00a859]/30" style="transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);">
                  <% if template.pc_thumbnail_url.present? %>
                    <%= image_tag template.pc_thumbnail_url, class: "w-full h-28 object-cover", loading: "lazy", decoding: "async" %>
                  <% else %>
                    <div class="w-full h-28 bg-gradient-to-br from-[#00a859]/10 to-[#00d670]/10"></div>
                  <% end %>
                  <div class="p-3">
                    <div class="text-sm font-medium text-gray-900 truncate"><%= template.title %></div>
                    <div class="text-xs text-gray-500"><%= number_to_currency(template.price, unit: '₩', precision: 0) %></div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-10 text-gray-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
              <p class="text-sm">위시리스트가 비어있습니다</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- 빠른 링크 -->
    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <% [
        { path: design_templates_path, icon: "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z", title: "템플릿 둘러보기", desc: "새로운 디자인 발견" },
        { path: cart_path, icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z", title: "장바구니", desc: "담긴 상품 확인" },
        { path: contact_path, icon: "M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z", title: "문의하기", desc: "궁금한 점 물어보기" }
      ].each_with_index do |link, i| %>
        <%= link_to link[:path], class: "card-premium group reveal-stagger", style: "animation-delay: #{i * 80}ms;" do %>
          <div class="card-premium-inner !p-5 flex items-center gap-4">
            <div class="w-11 h-11 bg-[#00a859]/10 rounded-xl flex items-center justify-center group-hover:bg-[#00a859]/15" style="transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);">
              <svg class="w-5 h-5 text-[#00a859]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= link[:icon] %>"/>
              </svg>
            </div>
            <div>
              <div class="font-medium text-gray-900 text-sm"><%= link[:title] %></div>
              <div class="text-xs text-gray-400"><%= link[:desc] %></div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

  </div>
</div>
