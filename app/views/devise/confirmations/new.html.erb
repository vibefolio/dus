<% content_for :title, "이메일 인증 - 디어스" %>

<div style="min-height: calc(100vh - 80px); display: flex; align-items: center; justify-content: center; background: #f9fafb; padding: 20px;">
  <!-- Double-Bezel Card (Outer Shell) -->
  <div class="card-premium" style="width: 100%; max-width: 440px;">
    <!-- Double-Bezel Card (Inner Core) -->
    <div class="card-premium-inner" style="padding: 40px;">

      <div style="text-align: center; margin-bottom: 30px;">
        <!-- Eyebrow Tag -->
        <span class="eyebrow" style="margin-bottom: 16px; display: inline-block;">Email Confirmation</span>
        <h2 style="font-size: 28px; font-weight: 800; color: #111; margin-bottom: 8px; letter-spacing: -0.02em; line-height: 1.3;">이메일 인증</h2>
        <p style="color: #6b7280; font-size: 15px; word-break: keep-all;">인증 메일을 다시 받으시려면<br>이메일 주소를 입력해주세요.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, data: { turbo: false } }) do |f| %>

        <!-- Error Messages -->
        <% if resource.errors.any? %>
          <div style="background-color: #fef2f2; color: #dc2626; padding: 12px; border-radius: 12px; font-size: 14px; margin-bottom: 20px; border: 1px solid #fee2e2;">
            <ul style="list-style: disc; margin-left: 20px;">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div style="margin-bottom: 30px;">
          <%= f.label :email, "이메일 주소", style: "display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 8px;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@email.com", value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email), style: "width: 100%; padding: 14px 16px; border: 1px solid #e5e7eb; border-radius: 14px; font-size: 15px; background: #f9fafb; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); font-family: var(--font-display);", class: "form-input" %>
        </div>

        <div style="margin-bottom: 24px;">
          <%= f.submit "인증 메일 재발송", style: "width: 100%; padding: 16px; background: var(--color-primary); color: white; font-weight: 700; border: none; border-radius: 9999px; cursor: pointer; font-size: 16px; font-family: var(--font-display); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);", class: "btn-login-submit" %>
        </div>
      <% end %>

      <div style="text-align: center; margin-top: 24px; padding-top: 24px; border-top: 1px solid #f3f4f6;">
        <p style="font-size: 14px; color: #6b7280;">
          로그인 페이지로 돌아가기
          <%= link_to "로그인", new_session_path(resource_name), style: "color: var(--color-primary); font-weight: 600; text-decoration: none; margin-left: 4px;" %>
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .form-input:focus {
    outline: none;
    border-color: var(--color-primary) !important;
    background: white !important;
    box-shadow: 0 0 0 4px rgba(0, 168, 89, 0.08);
  }
  .btn-login-submit:hover {
    background: var(--color-primary-dark) !important;
    transform: scale(1.02);
    box-shadow: 0 8px 24px -4px rgba(0, 168, 89, 0.3);
  }
  .btn-login-submit:active {
    transform: scale(0.98);
  }
</style>
