<% content_for :title, "계정 설정 - 디어스" %>

<div style="min-height: calc(100vh - 80px); display: flex; align-items: center; justify-content: center; background: #f9fafb; padding: 20px;">
  <!-- Double-Bezel Card (Outer Shell) -->
  <div class="card-premium" style="width: 100%; max-width: 440px;">
    <!-- Double-Bezel Card (Inner Core) -->
    <div class="card-premium-inner" style="padding: 40px;">

      <div style="text-align: center; margin-bottom: 30px;">
        <!-- Eyebrow Tag -->
        <span class="eyebrow" style="margin-bottom: 16px; display: inline-block;">Account Settings</span>
        <h2 style="font-size: 28px; font-weight: 800; color: #111; margin-bottom: 8px; letter-spacing: -0.02em; line-height: 1.3;">계정 설정</h2>
        <p style="color: #6b7280; font-size: 15px; word-break: keep-all;">비밀번호를 변경하거나 계정을 관리하세요.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, data: { turbo: false } }) do |f| %>

        <!-- Error Messages -->
        <% if resource.errors.any? %>
          <div style="background-color: #fef2f2; color: #dc2626; padding: 12px; border-radius: 12px; font-size: 14px; margin-bottom: 20px; border: 1px solid #fee2e2;">
            <ul style="list-style: disc; margin-left: 20px;">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div style="margin-bottom: 20px;">
          <%= f.label :email, "이메일", style: "display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 8px;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", style: "width: 100%; padding: 14px 16px; border: 1px solid #e5e7eb; border-radius: 14px; font-size: 15px; background: #f0f0f0; cursor: not-allowed; font-family: var(--font-display);", disabled: false %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div style="background-color: #fffbeb; color: #b45309; padding: 12px; border-radius: 12px; font-size: 14px; margin-bottom: 20px; border: 1px solid #fef3c7;">
            현재 인증 대기 중인 이메일: <%= resource.unconfirmed_email %>
          </div>
        <% end %>

        <div style="margin-bottom: 20px;">
          <%= f.label :password, "새 비밀번호", style: "display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 8px;" %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "변경하지 않으려면 비워두세요", style: "width: 100%; padding: 14px 16px; border: 1px solid #e5e7eb; border-radius: 14px; font-size: 15px; background: #f9fafb; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); font-family: var(--font-display);", class: "form-input" %>
          <% if @minimum_password_length %>
            <p style="font-size: 12px; color: #9ca3af; margin-top: 6px;">* 최소 <%= @minimum_password_length %>자 이상</p>
          <% end %>
        </div>

        <div style="margin-bottom: 20px;">
          <%= f.label :password_confirmation, "새 비밀번호 확인", style: "display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 8px;" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "새 비밀번호를 다시 입력해주세요", style: "width: 100%; padding: 14px 16px; border: 1px solid #e5e7eb; border-radius: 14px; font-size: 15px; background: #f9fafb; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); font-family: var(--font-display);", class: "form-input" %>
        </div>

        <div style="margin-bottom: 30px;">
          <%= f.label :current_password, "현재 비밀번호", style: "display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 8px;" %>
          <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "변경을 확인하려면 입력해주세요", style: "width: 100%; padding: 14px 16px; border: 1px solid #e5e7eb; border-radius: 14px; font-size: 15px; background: #f9fafb; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); font-family: var(--font-display);", class: "form-input" %>
        </div>

        <div style="margin-bottom: 16px;">
          <%= f.submit "변경사항 저장", style: "width: 100%; padding: 16px; background: var(--color-primary); color: white; font-weight: 700; border: none; border-radius: 9999px; cursor: pointer; font-size: 16px; font-family: var(--font-display); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);", class: "btn-login-submit" %>
        </div>
      <% end %>

      <!-- 계정 삭제 섹션 -->
      <div style="margin-top: 30px; padding-top: 24px; border-top: 1px solid #f3f4f6;">
        <p style="font-size: 14px; color: #9ca3af; text-align: center; margin-bottom: 12px;">계정을 삭제하면 모든 데이터가 영구 삭제됩니다.</p>
        <div style="text-align: center;">
          <%= button_to "계정 삭제", registration_path(resource_name), data: { confirm: "정말로 계정을 삭제하시겠습니까?", turbo_confirm: "정말로 계정을 삭제하시겠습니까?" }, method: :delete, style: "padding: 10px 24px; background: transparent; border: 1px solid #fca5a5; border-radius: 9999px; color: #ef4444; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); font-family: var(--font-display);", class: "btn-delete" %>
        </div>
      </div>

      <div style="text-align: center; margin-top: 20px;">
        <%= link_to "마이페이지로 돌아가기", mypage_path, style: "font-size: 14px; color: var(--color-primary); font-weight: 600; text-decoration: none;" %>
      </div>
    </div>
  </div>
</div>

<style>
  .form-input:focus {
    outline: none;
    border-color: var(--color-primary) !important;
    background: white !important;
    box-shadow: 0 0 0 4px rgba(0, 168, 89, 0.08);
  }
  .btn-login-submit:hover {
    background: var(--color-primary-dark) !important;
    transform: scale(1.02);
    box-shadow: 0 8px 24px -4px rgba(0, 168, 89, 0.3);
  }
  .btn-login-submit:active {
    transform: scale(0.98);
  }
  .btn-delete:hover {
    background: #fef2f2 !important;
    border-color: #ef4444 !important;
  }
</style>
