<!-- ───────── HOW IT WORKS ───────── -->
<section style="padding:80px 24px;max-width:1100px;margin:0 auto;">
  <div style="text-align:center;margin-bottom:56px;">
    <span style="font-size:12px;font-weight:800;color:#4ade80;letter-spacing:0.1em;text-transform:uppercase;">진행 방식</span>
    <h2 style="font-size:clamp(26px,3.5vw,42px);font-weight:900;letter-spacing:-0.04em;margin-top:12px;">
      상담부터 오픈까지<br>4단계로 끝납니다
    </h2>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px;position:relative;">
    <% [
      ["01", "무료 상담 신청", "아래 폼을 작성하면 24시간 내 메이저텍스 담당자가 연락드립니다.", "#4ade80"],
      ["02", "세무 + 홈페이지 플랜 확정", "업종·매출 규모에 맞는 세무 플랜과 홈페이지 구성을 함께 결정합니다.", "#60a5fa"],
      ["03", "계약 및 자료 제출", "계약 완료 후 사업자 서류와 홈페이지 콘텐츠(사진·텍스트)를 제출합니다.", "#a78bfa"],
      ["04", "세무 시작 + 홈페이지 오픈", "다음 달 기장 시작, 2~3주 내 홈페이지 오픈. 이후 꾸준히 관리해드립니다.", "#f472b6"]
    ].each_with_index do |(num, title, desc, color), i| %>
      <div class="mxt-card" style="padding:32px;position:relative;">
        <div style="font-size:48px;font-weight:900;color:<%= color %>;opacity:0.3;line-height:1;margin-bottom:16px;"><%= num %></div>
        <h3 style="font-size:18px;font-weight:800;margin-bottom:10px;letter-spacing:-0.02em;"><%= title %></h3>
        <p style="color:rgba(255,255,255,0.45);font-size:14px;line-height:1.7;word-break:keep-all;"><%= desc %></p>
      </div>
    <% end %>
  </div>
</section>

<!-- ───────── REVIEWS ───────── -->
<section style="padding:80px 24px;background:rgba(0,0,0,0.3);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:56px;">
      <span style="font-size:12px;font-weight:800;color:#4ade80;letter-spacing:0.1em;text-transform:uppercase;">고객 후기</span>
      <h2 style="font-size:clamp(26px,3.5vw,42px);font-weight:900;letter-spacing:-0.04em;margin-top:12px;">
        이미 함께하고 있는<br>사장님들의 이야기
      </h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;">
      <% [
        ["카페 사장님", "카페·디저트", "세무는 맡기고 싶었는데 홈페이지까지 같이 해준다고 해서 계약했어요. 홈페이지 덕분에 인스타에서 검색해서 오는 손님이 생겼습니다.", 5],
        ["피부관리샵 원장님", "뷰티·피부관리", "매년 세금 때문에 스트레스받던 게 사라졌어요. 홈페이지도 전문적으로 만들어줘서 신뢰도가 훨씬 높아진 것 같아요.", 5],
        ["온라인쇼핑몰 대표님", "이커머스", "기장이랑 홈페이지를 따로 관리하다 번거로웠는데 한 팀이 다 해주니까 소통이 훨씬 편하더라고요. 강력 추천합니다.", 5]
      ].each do |name, biz, text, rating| %>
        <div class="mxt-card" style="padding:32px;">
          <div style="display:flex;gap:4px;margin-bottom:20px;">
            <% rating.times do %>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#fbbf24" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <% end %>
          </div>
          <p style="color:rgba(255,255,255,0.75);font-size:15px;line-height:1.8;margin-bottom:24px;word-break:keep-all;">"<%= text %>"</p>
          <div>
            <div style="font-weight:800;font-size:15px;"><%= name %></div>
            <div style="font-size:13px;color:rgba(255,255,255,0.35);margin-top:2px;"><%= biz %></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ───────── CONTACT FORM ───────── -->
<section id="contact" style="padding:100px 24px;">
  <div style="max-width:680px;margin:0 auto;">
    <!-- 헤더 -->
    <div style="text-align:center;margin-bottom:56px;">
      <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 20px;background:rgba(0,168,89,0.1);border:1px solid rgba(0,168,89,0.3);border-radius:50px;margin-bottom:24px;">
        <span style="color:#4ade80;font-size:13px;font-weight:800;">무료 상담 · 24시간 응답 보장</span>
      </div>
      <h2 style="font-size:clamp(28px,4vw,48px);font-weight:900;letter-spacing:-0.04em;margin-bottom:12px;word-break:keep-all;">
        지금 바로 시작하세요
      </h2>
      <p style="color:rgba(255,255,255,0.45);font-size:16px;line-height:1.6;">
        아래 양식을 작성하시면 메이저텍스 담당자가<br>24시간 이내에 직접 연락드립니다.
      </p>
    </div>

    <!-- 성공 메시지 -->
    <% if flash[:notice] %>
      <div style="background:rgba(0,168,89,0.15);border:1px solid rgba(0,168,89,0.4);border-radius:14px;padding:24px 28px;margin-bottom:32px;display:flex;align-items:center;gap:16px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <div>
          <p style="color:#4ade80;font-weight:800;margin-bottom:2px;">신청 완료!</p>
          <p style="color:rgba(255,255,255,0.6);font-size:14px;"><%= flash[:notice] %></p>
        </div>
      </div>
    <% end %>

    <!-- 폼 -->
    <div class="mxt-card glow-green" style="padding:48px 40px;">
      <%= form_with url: majortax_quote_path, method: :post, local: true do |f| %>
        <%= f.hidden_field :nickname, value: "" %>
        <input type="text" name="quote[nickname]" value="" style="display:none;" autocomplete="off" tabindex="-1">

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:700;color:rgba(255,255,255,0.6);margin-bottom:8px;letter-spacing:0.02em;">이름 <span style="color:#ef4444;">*</span></label>
            <%= f.text_field :contact_name, placeholder: "홍길동", required: true, class: "mxt-input" %>
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:700;color:rgba(255,255,255,0.6);margin-bottom:8px;letter-spacing:0.02em;">연락처 <span style="color:#ef4444;">*</span></label>
            <%= f.text_field :phone, placeholder: "010-0000-0000", required: true, class: "mxt-input" %>
          </div>
        </div>

        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:13px;font-weight:700;color:rgba(255,255,255,0.6);margin-bottom:8px;letter-spacing:0.02em;">이메일 <span style="color:#ef4444;">*</span></label>
          <%= f.email_field :email, placeholder: "example@business.com", required: true, class: "mxt-input" %>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:700;color:rgba(255,255,255,0.6);margin-bottom:8px;letter-spacing:0.02em;">업종</label>
            <%= f.select :company_name,
                [["카페·베이커리", "카페·베이커리"], ["뷰티·헤어·네일", "뷰티·헤어·네일"], ["음식점·식당", "음식점·식당"], ["쇼핑몰·온라인", "쇼핑몰·온라인"], ["의원·병원", "의원·병원"], ["학원·교육", "학원·교육"], ["건설·인테리어", "건설·인테리어"], ["기타 소상공인", "기타 소상공인"]],
                { prompt: "업종을 선택하세요" },
                class: "mxt-input" %>
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:700;color:rgba(255,255,255,0.6);margin-bottom:8px;letter-spacing:0.02em;">사업자 구분</label>
            <%= f.select :budget,
                [["개인사업자", "개인사업자"], ["법인사업자", "법인사업자"], ["예비창업자", "예비창업자"], ["모름/미정", "모름/미정"]],
                { prompt: "선택하세요" },
                class: "mxt-input" %>
          </div>
        </div>

        <div style="margin-bottom:28px;">
          <label style="display:block;font-size:13px;font-weight:700;color:rgba(255,255,255,0.6);margin-bottom:8px;letter-spacing:0.02em;">문의 내용</label>
          <%= f.text_area :message, rows: 4, placeholder: "현재 상황이나 궁금한 점을 자유롭게 적어주세요.\n예) '기장 맡기고 싶고 홈페이지도 필요한데 어떻게 하면 될까요?'", class: "mxt-input", style: "resize:vertical;" %>
        </div>

        <button type="submit" class="mxt-btn">
          무료 상담 신청하기 →
        </button>

        <p style="text-align:center;font-size:12px;color:rgba(255,255,255,0.25);margin-top:16px;line-height:1.6;">
          제출하신 정보는 상담 목적으로만 사용되며 외부에 공유되지 않습니다.
        </p>
      <% end %>
    </div>

    <!-- 직접 연락 -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:24px;">
      <div class="mxt-card" style="padding:20px 24px;display:flex;align-items:center;gap:14px;">
        <div style="width:40px;height:40px;background:rgba(0,168,89,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 3.12h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.74a16 16 0 0 0 6.29 6.29l.95-1.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div>
          <div style="font-size:11px;color:rgba(255,255,255,0.35);margin-bottom:2px;">전화 문의</div>
          <div style="font-weight:800;font-size:15px;color:white;">메이저텍스 직통</div>
        </div>
      </div>
      <div class="mxt-card" style="padding:20px 24px;display:flex;align-items:center;gap:14px;">
        <div style="width:40px;height:40px;background:rgba(0,112,201,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <div style="font-size:11px;color:rgba(255,255,255,0.35);margin-bottom:2px;">이메일 문의</div>
          <div style="font-weight:800;font-size:15px;color:white;">majortax@designd.co.kr</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ───────── FOOTER ───────── -->
