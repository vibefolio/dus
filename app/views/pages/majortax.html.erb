              <%= f %>
            </li>
          <% end %>
        </ul>
        <a href="#contact" style="display:block;text-align:center;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);color:white;padding:14px;border-radius:10px;font-weight:800;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.12)'" onmouseout="this.style.background='rgba(255,255,255,0.06)'">
