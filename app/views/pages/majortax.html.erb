<script>
  function selectSegment(type) {
    const newContent = document.getElementById('content-new');
    const existingContent = document.getElementById('content-existing');
    const segNew = document.getElementById('seg-new');
    const segExisting = document.getElementById('seg-existing');

    // 리셋
    newContent.style.display = 'none';
    existingContent.style.display = 'none';
    segNew.classList.remove('active');
    segExisting.classList.remove('active');

    if (type === 'new') {
      newContent.style.display = 'block';
      segNew.classList.add('active');
      // 폼 라디오도 선택
      document.getElementById('new_customer').checked = true;
      highlightCustomerType('new');
    } else {
      existingContent.style.display = 'block';
      segExisting.classList.add('active');
      document.getElementById('existing_customer').checked = true;
      highlightCustomerType('existing');
    }

    // 부드럽게 스크롤
    setTimeout(() => {
      const el = type === 'new' ? newContent : existingContent;
      el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }

  function highlightCustomerType(type) {
    const labelNew = document.getElementById('label-new-customer');
    const labelExisting = document.getElementById('label-existing-customer');
    if (type === 'new') {
      labelNew.style.borderColor = '#3182f6';
      labelNew.style.background = '#f0f6ff';
      labelExisting.style.borderColor = '#eaecef';
      labelExisting.style.background = 'transparent';
    } else {
      labelExisting.style.borderColor = '#00a859';
      labelExisting.style.background = '#f0faf5';
      labelNew.style.borderColor = '#eaecef';
      labelNew.style.background = 'transparent';
    }
  }
</script>
