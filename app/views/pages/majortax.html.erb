<script>
  function switchBilling(type) {
    const monthly = document.getElementById('billing-monthly');
    const yearly  = document.getElementById('billing-yearly');
    const tabM    = document.getElementById('tab-monthly');
    const tabY    = document.getElementById('tab-yearly');

    if (type === 'monthly') {
      monthly.style.display = 'block';
      yearly.style.display  = 'none';
      tabM.classList.add('active');
      tabY.classList.remove('active');
    } else {
      monthly.style.display = 'none';
      yearly.style.display  = 'block';
      tabM.classList.remove('active');
      tabY.classList.add('active');
    }
  }
</script>

