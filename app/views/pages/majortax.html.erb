      <!-- 인기 패키지 (가운데 강조) -->
      <div style="background:linear-gradient(145deg,rgba(0,168,89,0.15),rgba(0,112,201,0.1));border:1px solid rgba(0,168,89,0.4);border-radius:20px;padding:36px;position:relative;" class="glow-green">
        <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#00a859,#00d670);color:white;padding:6px 20px;border-radius:50px;font-size:12px;font-weight:800;white-space:nowrap;letter-spacing:0.05em;">🔥 가장 인기</div>
        <div style="font-size:13px;font-weight:700;color:#4ade80;letter-spacing:0.05em;margin-bottom:12px;">STANDARD</div>
