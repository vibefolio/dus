<% content_for :title, "메이저텍스 × 디어스 — 세무기장 + 홈페이지 한 번에" %>
<% content_for :description, "세무기장을 맡기면 홈페이지 제작이 함께! 메이저텍스와 디어스가 함께하는 소상공인 올인원 패키지." %>

<% content_for :head do %>
<style>
  /* 토스 스타일 라이트 테마 */
  body { background: #f8f9fa !important; color: #191f28; font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif; }

  .mxt-chip { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; background: #e8f5ee; border-radius: 50px; font-size: 13px; font-weight: 700; color: #00a859; }
  .mxt-section-label { font-size: 13px; font-weight: 700; color: #00a859; letter-spacing: 0.06em; text-transform: uppercase; }

  /* 토스 카드 */
  .mxt-card { background: #fff; border-radius: 20px; border: 1px solid #eaecef; }
  .mxt-card-blue { background: #f0f6ff; border: 1px solid #d4e5ff; border-radius: 20px; }

  /* 탭 */
  .mxt-tab-wrap { background: #eef0f3; border-radius: 12px; padding: 4px; display: inline-flex; gap: 2px; }
  .mxt-tab { padding: 10px 28px; border-radius: 9px; font-size: 15px; font-weight: 700; cursor: pointer; border: none; background: transparent; color: #8b95a1; transition: all 0.2s; }
  .mxt-tab.active { background: #fff; color: #191f28; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }

  /* 인풋 */
  .mxt-input { background: #f8f9fa; border: 1.5px solid #eaecef; border-radius: 10px; color: #191f28; padding: 14px 16px; width: 100%; outline: none; transition: border-color 0.2s; font-size: 15px; }
  .mxt-input:focus { border-color: #00a859; background: #fff; }
  .mxt-input::placeholder { color: #b0b8c1; }
  select.mxt-input option { background: #fff; color: #191f28; }

  /* 버튼 */
  .mxt-btn-primary { background: #00a859; color: white; border: none; border-radius: 12px; padding: 18px 40px; font-size: 17px; font-weight: 800; cursor: pointer; width: 100%; transition: all 0.2s; letter-spacing: -0.02em; }
  .mxt-btn-primary:hover { background: #008f4a; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,168,89,0.25); }

  /* 패키지 카드 */
  .pkg-card { background: #fff; border: 1.5px solid #eaecef; border-radius: 20px; padding: 32px; transition: all 0.2s; }
  .pkg-card:hover { border-color: #00a859; box-shadow: 0 8px 32px rgba(0,168,89,0.1); transform: translateY(-4px); }
  .pkg-card.featured { border: 2px solid #00a859; position: relative; }
  .pkg-badge { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: #00a859; color: white; padding: 4px 18px; border-radius: 50px; font-size: 12px; font-weight: 800; white-space: nowrap; }

  /* 리뷰 카드 */
  .review-card { background: #fff; border: 1px solid #eaecef; border-radius: 16px; padding: 28px; }

  /* 스텝 */
  .step-number { width: 44px; height: 44px; border-radius: 50%; background: #e8f5ee; color: #00a859; font-size: 18px; font-weight: 900; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

  /* 구분 배너 */
  .segment-banner { border-radius: 16px; padding: 20px 28px; display: flex; align-items: center; gap: 16px; cursor: pointer; transition: all 0.2s; }
  .segment-new { background: #f0f8ff; border: 2px solid #d4e5ff; }
  .segment-new:hover, .segment-new.active { border-color: #3182f6; background: #e8f4ff; }
  .segment-existing { background: #f0faf5; border: 2px solid #c8ecd8; }
  .segment-existing:hover, .segment-existing.active { border-color: #00a859; background: #e2f5ea; }

  /* 토스 스텝 바 */
  .toss-step-bar { display: flex; align-items: center; gap: 0; }
  .toss-step-item { display: flex; align-items: center; gap: 8px; }
  .toss-step-dot { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; flex-shrink: 0; }
  .toss-step-dot.done { background: #00a859; color: white; }
  .toss-step-dot.current { background: #191f28; color: white; }
  .toss-step-dot.upcoming { background: #eaecef; color: #8b95a1; }
  .toss-step-line { width: 32px; height: 2px; background: #eaecef; margin: 0 4px; }
  .toss-step-line.done { background: #00a859; }

  @media (max-width: 768px) {
    .pkg-grid { grid-template-columns: 1fr !important; }
    .stats-grid { grid-template-columns: repeat(2,1fr) !important; }
    .hide-mobile { display: none !important; }
    .examples-grid { grid-template-columns: repeat(2,1fr) !important; }
  }
</style>
<% end %>

<!-- ───────── NAVBAR ───────── -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(255,255,255,0.92);backdrop-filter:blur(20px);border-bottom:1px solid #eaecef;">
  <div style="max-width:1080px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:68px;">
    <div style="display:flex;align-items:center;gap:12px;">
      <span style="font-size:16px;font-weight:900;color:#191f28;letter-spacing:-0.03em;">메이저텍스</span>
      <span style="color:#c4c9d0;font-weight:300;">×</span>
      <span style="font-size:16px;font-weight:900;color:#00a859;letter-spacing:-0.03em;">디어스</span>
      <div class="mxt-chip hide-mobile" style="margin-left:8px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="#00a859"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        공식 파트너십
      </div>
    </div>
    <a href="#contact" style="background:#00a859;color:white;padding:10px 22px;border-radius:50px;font-size:14px;font-weight:700;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background='#008f4a'" onmouseout="this.style.background='#00a859'">
      무료 상담 신청
    </a>
  </div>
</nav>

<!-- ───────── HERO ───────── -->
<section style="padding:120px 24px 80px;max-width:1080px;margin:0 auto;">
  <div style="text-align:center;">
    <div class="mxt-chip" style="margin-bottom:24px;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#00a859" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
      소상공인 맞춤 올인원 패키지
    </div>

    <h1 style="font-size:clamp(34px,5.5vw,68px);font-weight:900;line-height:1.1;letter-spacing:-0.04em;margin-bottom:24px;word-break:keep-all;color:#191f28;">
      세무기장 맡기고<br>
      <span style="color:#00a859;">홈페이지까지</span> 한 번에
    </h1>

    <p style="font-size:clamp(15px,2vw,19px);color:#6b7684;max-width:540px;margin:0 auto 48px;line-height:1.7;word-break:keep-all;">
      메이저텍스의 세무 전문성과 디어스의 웹 제작을 묶어<br>
      <strong style="color:#191f28;">월 정액 하나로 세무 + 홈페이지를 모두 해결</strong>합니다.
    </p>

    <!-- 신뢰 지표 -->
    <div class="stats-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#eaecef;border-radius:16px;overflow:hidden;max-width:640px;margin:0 auto 64px;">
      <% [["12년+","세무 경력"],["847+","누적 고객사"],["98.7%","신고 정확도"],["24h","응답 보장"]].each do |val, label| %>
        <div style="background:#fff;padding:24px 12px;text-align:center;">
          <div style="font-size:24px;font-weight:900;color:#191f28;letter-spacing:-0.03em;"><%= val %></div>
          <div style="font-size:12px;color:#8b95a1;margin-top:4px;"><%= label %></div>
        </div>
      <% end %>
    </div>

    <!-- CTA -->
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#segment" style="background:#00a859;color:white;padding:16px 40px;border-radius:12px;font-size:16px;font-weight:800;text-decoration:none;box-shadow:0 4px 20px rgba(0,168,89,0.2);transition:all 0.2s;" onmouseover="this.style.background='#008f4a';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#00a859';this.style.transform='translateY(0)'">
        나에게 맞는 플랜 보기
      </a>
      <a href="#packages" style="background:#fff;border:1.5px solid #eaecef;color:#191f28;padding:16px 32px;border-radius:12px;font-size:16px;font-weight:700;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.borderColor='#00a859'" onmouseout="this.style.borderColor='#eaecef'">
        요금제 보기
      </a>
    </div>
  </div>
</section>

<!-- ───────── 신규 / 기존 고객 구분 ───────── -->
<section id="segment" style="padding:0 24px 80px;">
  <div style="max-width:1080px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:40px;">
      <div class="mxt-section-label">어떤 상황이신가요?</div>
      <h2 style="font-size:clamp(24px,3.5vw,40px);font-weight:900;letter-spacing:-0.04em;margin-top:12px;color:#191f28;">
        지금 상황에 맞게 골라보세요
      </h2>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:760px;margin:0 auto;" id="segmentGrid">

      <!-- 신규 고객 -->
      <div class="segment-banner segment-new" onclick="selectSegment('new')" id="seg-new">
        <div style="width:48px;height:48px;border-radius:14px;background:#daeeff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3182f6" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
        </div>
        <div>
          <div style="font-size:16px;font-weight:800;color:#191f28;margin-bottom:4px;">세무사 처음 맡겨요</div>
          <div style="font-size:13px;color:#6b7684;line-height:1.5;">세무기장도, 홈페이지도<br>새로 시작하는 분</div>
        </div>
        <div style="margin-left:auto;font-size:20px;color:#3182f6;">→</div>
      </div>

      <!-- 기존 고객 -->
      <div class="segment-banner segment-existing" onclick="selectSegment('existing')" id="seg-existing">
        <div style="width:48px;height:48px;border-radius:14px;background:#d4ede0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00a859" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div>
          <div style="font-size:16px;font-weight:800;color:#191f28;margin-bottom:4px;">메이저텍스 기존 고객이에요</div>
          <div style="font-size:13px;color:#6b7684;line-height:1.5;">이미 세무기장 중인데<br>홈페이지만 추가하고 싶은 분</div>
        </div>
        <div style="margin-left:auto;font-size:20px;color:#00a859;">→</div>
      </div>
    </div>

    <!-- 신규 고객 콘텐츠 -->
    <div id="content-new" style="display:none;margin-top:32px;max-width:760px;margin-left:auto;margin-right:auto;">
      <div class="mxt-card-blue" style="padding:32px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
          <div style="background:#3182f6;color:white;padding:6px 16px;border-radius:50px;font-size:13px;font-weight:800;">신규 고객 혜택</div>
          <span style="font-size:14px;color:#6b7684;">세무기장 + 홈페이지 동시 시작</span>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;">
          <% [
            ["홈페이지 제작비 최대 30% 할인", "번들 계약 시 월정액 할인 적용"],
            ["세무기장 첫 달 무료 상담", "사업 초기 세무 방향 1:1 컨설팅"],
            ["사업자등록 + 세무 초기 설정 지원", "시작부터 끝까지 원스톱"],
            ["전담 담당자 배정", "세무사 + 웹에이전시 담당자 함께 배정"]
          ].each do |title, desc| %>
            <li style="display:flex;align-items:flex-start;gap:12px;padding:16px;background:white;border-radius:12px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3182f6" stroke-width="2.5" style="margin-top:1px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <div style="font-weight:700;color:#191f28;font-size:15px;"><%= title %></div>
                <div style="font-size:13px;color:#8b95a1;margin-top:2px;"><%= desc %></div>
              </div>
            </li>
          <% end %>
        </ul>
        <a href="#contact" style="display:block;background:#3182f6;color:white;text-align:center;padding:16px;border-radius:12px;font-size:16px;font-weight:800;text-decoration:none;margin-top:24px;transition:all 0.2s;" onmouseover="this.style.background='#1b6de3'" onmouseout="this.style.background='#3182f6'">
          신규 고객 혜택으로 상담 신청하기
        </a>
      </div>
    </div>

    <!-- 기존 고객 콘텐츠 -->
    <div id="content-existing" style="display:none;margin-top:32px;max-width:760px;margin-left:auto;margin-right:auto;">
      <div class="mxt-card" style="padding:32px;border-color:#c8ecd8;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
          <div style="background:#00a859;color:white;padding:6px 16px;border-radius:50px;font-size:13px;font-weight:800;">기존 고객 혜택</div>
          <span style="font-size:14px;color:#6b7684;">홈페이지 추가 시 추가 할인</span>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;">
          <% [
            ["홈페이지 제작비 추가 15% 할인", "기존 고객 전용 추가 할인"],
            ["브리핑 없이 바로 제작 시작", "이미 사업 파악 완료 — 빠른 착수"],
            ["기존 세무기장료 그대로 유지", "홈페이지 추가해도 세무 비용 불변"],
            ["연간 계약 시 월 1회 무료 콘텐츠 업데이트", "사업 변경사항 반영 무료"]
          ].each do |title, desc| %>
            <li style="display:flex;align-items:flex-start;gap:12px;padding:16px;background:#f8fcf9;border-radius:12px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00a859" stroke-width="2.5" style="margin-top:1px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <div style="font-weight:700;color:#191f28;font-size:15px;"><%= title %></div>
                <div style="font-size:13px;color:#8b95a1;margin-top:2px;"><%= desc %></div>
              </div>
            </li>
          <% end %>
        </ul>
        <a href="#contact" style="display:block;background:#00a859;color:white;text-align:center;padding:16px;border-radius:12px;font-size:16px;font-weight:800;text-decoration:none;margin-top:24px;transition:all 0.2s;" onmouseover="this.style.background='#008f4a'" onmouseout="this.style.background='#00a859'">
          기존 고객 혜택으로 상담 신청하기
        </a>
      </div>
    </div>

  </div>
</section>

<!-- ───────── PACKAGES ───────── -->
<section id="packages" style="padding:80px 24px;background:#f2f4f8;">
  <div style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:32px;">
      <div class="mxt-section-label">요금제</div>
      <h2 style="font-size:clamp(26px,3.5vw,42px);font-weight:900;letter-spacing:-0.04em;margin-top:12px;color:#191f28;">
        세무 + 홈페이지 번들 요금
      </h2>
      <p style="color:#6b7684;margin-top:12px;font-size:15px;">세무기장 계약 시 홈페이지 초기 세팅비 할인</p>
    </div>

    <!-- 월간 / 연간 탭 -->
    <div style="display:flex;justify-content:center;margin-bottom:40px;">
      <div class="mxt-tab-wrap">
        <button class="mxt-tab active" id="tab-monthly" onclick="switchBilling('monthly')">월간 결제</button>
        <button class="mxt-tab" id="tab-yearly" onclick="switchBilling('yearly')">
          연간 결제
          <span style="margin-left:6px;background:#00a859;color:white;font-size:11px;font-weight:800;padding:2px 8px;border-radius:50px;">세팅비 할인</span>
        </button>
      </div>
    </div>

    <!-- 월간 -->
    <div id="billing-monthly">
      <div class="pkg-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;align-items:start;">

        <!-- BASIC 월간 -->
        <div class="pkg-card">
          <div style="font-size:12px;font-weight:800;color:#8b95a1;letter-spacing:0.08em;margin-bottom:8px;">BASIC</div>
          <div style="font-size:13px;color:#6b7684;margin-bottom:20px;">1인 자영업자 · 프리랜서</div>
          <div style="padding:16px;background:#f8f9fa;border-radius:12px;margin-bottom:12px;">
            <div style="font-size:11px;font-weight:700;color:#8b95a1;margin-bottom:4px;">초기 세팅비 (1회)</div>
            <div style="font-size:28px;font-weight:900;color:#191f28;letter-spacing:-0.03em;">50만원</div>
          </div>
          <div style="padding:16px;background:#f0faf5;border-radius:12px;margin-bottom:20px;border:1px solid #c8ecd8;">
            <div style="font-size:11px;font-weight:700;color:#00a859;margin-bottom:8px;">월 정기 비용</div>
            <div style="display:flex;justify-content:space-between;margin-bottom:5px;font-size:13px;color:#4e5968;"><span>개인사업자 기장</span><span style="font-weight:700;">월 10만~</span></div>
            <div style="display:flex;justify-content:space-between;margin-bottom:10px;font-size:13px;color:#4e5968;"><span>홈페이지 유지비</span><span style="font-weight:700;">월 3만</span></div>
            <div style="display:flex;justify-content:space-between;padding-top:10px;border-top:1.5px solid #c8ecd8;">
              <span style="font-size:13px;font-weight:700;color:#191f28;">월 합계</span>
              <span style="font-size:18px;font-weight:900;color:#00a859;">월 13만~</span>
            </div>
          </div>
          <ul style="list-style:none;padding:0;margin:0 0 20px;display:flex;flex-direction:column;gap:8px;">
            <% ["기본 랜딩페이지 디자인", "반응형 웹 디자인", "기본 문의 폼", "SEO 기본 설정", "월 1회 콘텐츠 수정", "부가세·종소세 신고", "세무 상담 월 2회"].each do |item| %>
              <li style="display:flex;align-items:center;gap:8px;font-size:13px;color:#4e5968;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00a859" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><%= item %></li>
            <% end %>
          </ul>
          <a href="#contact" style="display:block;background:#f0faf5;color:#00a859;text-align:center;padding:14px;border-radius:10px;font-size:15px;font-weight:700;text-decoration:none;border:1.5px solid #c8ecd8;" onmouseover="this.style.background='#e2f5ea'" onmouseout="this.style.background='#f0faf5'">상담 신청</a>
        </div>

        <!-- PRO 월간 -->
        <div class="pkg-card featured" style="padding-top:44px;">
          <div class="pkg-badge">가장 많이 선택</div>
          <div style="font-size:12px;font-weight:800;color:#00a859;letter-spacing:0.08em;margin-bottom:8px;">PRO</div>
