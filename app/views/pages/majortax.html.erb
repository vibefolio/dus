    </div>
  </div>
</section>

<script>
  function switchPath(path) {
    const paths = ['dusCustomer', 'taxCustomer', 'bothNew'];
    paths.forEach(p => {
      const panel = document.getElementById('path-' + p);
      const tab = document.getElementById('path-tab-' + p);
      const circle = tab ? tab.querySelector('span') : null;
      if (p === path) {
        panel.style.display = 'block';
        tab.style.background = '#fff';
        tab.style.color = '#191f28';
        tab.style.boxShadow = '0 2px 8px rgba(0,0,0,0.08)';
        if (circle) circle.style.background = '#00a859';
      } else {
        panel.style.display = 'none';
        tab.style.background = 'transparent';
        tab.style.color = '#8b95a1';
        tab.style.boxShadow = 'none';
        if (circle) circle.style.background = '#8b95a1';
      }
    });
  }
</script>

<!-- ───────── HOW IT WORKS ───────── -->
<section style="padding:80px 24px;max-width:1080px;margin:0 auto;">
  <div style="text-align:center;margin-bottom:48px;">
    <div class="mxt-section-label">진행 과정</div>
    <h2 style="font-size:clamp(24px,3.5vw,40px);font-weight:900;letter-spacing:-0.04em;margin-top:12px;color:#191f28;">
      신청부터 오픈까지 4단계
    </h2>
  </div>

  <!-- 토스식 스텝 바 (데스크탑) -->
  <div class="toss-step-bar hide-mobile" style="justify-content:center;margin-bottom:48px;">
    <% [["01","상담 신청","오늘"],["02","계약 체결","D+2"],["03","제작 착수","D+3"],["04","사이트 오픈","D+14"]].each_with_index do |(num,label,day), idx| %>
      <div class="toss-step-item">
        <div style="text-align:center;">
          <div class="toss-step-dot <%= idx == 0 ? 'current' : 'upcoming' %>"><%= num %></div>
          <div style="font-size:13px;font-weight:700;color:#191f28;margin-top:6px;white-space:nowrap;"><%= label %></div>
          <div style="font-size:11px;color:#8b95a1;margin-top:2px;"><%= day %></div>
        </div>
      </div>
      <% if idx < 3 %>
        <div class="toss-step-line"></div>
      <% end %>
    <% end %>
  </div>

  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
    <% [
      ["01", "상담 신청", "아래 폼을 작성하거나 전화로 연락주세요. 현재 상황과 원하시는 것을 간단히 알려주시면 됩니다.", "#e8f5ee", "#00a859"],
      ["02", "계약 및 미팅", "담당 세무사와 웹 디렉터가 함께 미팅합니다. 세무 구조와 홈페이지 방향을 한 번에 결정합니다.", "#f0f6ff", "#3182f6"],
      ["03", "동시 착수", "세무기장 시작과 함께 홈페이지 제작이 병행됩니다. 서로 다른 팀이 한 방향으로 움직입니다.", "#fff8e8", "#f5a623"],
      ["04", "완료 & 운영", "홈페이지 오픈 후 세무 + 웹 모두 월정액으로 관리됩니다. 바뀌는 것도 빠르게 반영됩니다.", "#fef0f0", "#e04848"]
    ].each do |num, title, desc, bg, color| %>
      <div class="mxt-card" style="padding:28px;display:flex;gap:20px;">
        <div style="width:44px;height:44px;border-radius:50%;background:<%= bg %>;color:<%= color %>;font-size:16px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><%= num %></div>
        <div>
          <div style="font-size:17px;font-weight:800;color:#191f28;margin-bottom:8px;"><%= title %></div>
          <div style="font-size:14px;color:#6b7684;line-height:1.6;word-break:keep-all;"><%= desc %></div>
        </div>
      </div>
    <% end %>
  </div>
</section>

