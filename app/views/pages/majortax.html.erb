              <%= f %>
            </li>
          <% end %>
        </ul>
        <a href="#contact" style="display:block;text-align:center;background:linear-gradient(135deg,#00a859,#00d670);color:white;padding:16px;border-radius:10px;font-weight:800;text-decoration:none;font-size:16px;transition:all 0.2s;box-shadow:0 8px 32px rgba(0,168,89,0.3);" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
