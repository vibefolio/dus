<% content_for :title, "메이저텍스 × 디어스 — 세무기장 + 홈페이지 한 번에" %>
<% content_for :description, "세무기장을 맡기면 홈페이지 제작이 함께! 메이저텍스와 디어스가 함께하는 소상공인 올인원 패키지." %>

<% content_for :head do %>
<style>
  /* 이 페이지만의 다크 테마 */
  body { background: #080c10 !important; color: #f0f4f8; }
  .mxt-gradient { background: linear-gradient(135deg, #00a859 0%, #0070c9 100%); }
  .mxt-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; }
  .mxt-badge { background: rgba(0,168,89,0.15); border: 1px solid rgba(0,168,89,0.3); color: #4ade80; }
  .mxt-input { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; color: white; padding: 14px 18px; width: 100%; outline: none; transition: border-color 0.2s; }
  .mxt-input:focus { border-color: #00a859; }
  .mxt-input::placeholder { color: rgba(255,255,255,0.3); }
  .mxt-btn { background: linear-gradient(135deg, #00a859, #00d670); color: white; border: none; border-radius: 12px; padding: 18px 40px; font-size: 18px; font-weight: 800; cursor: pointer; width: 100%; transition: all 0.3s; letter-spacing: -0.02em; }
  .mxt-btn:hover { transform: translateY(-2px); box-shadow: 0 20px 60px rgba(0,168,89,0.4); }
  .glow-green { box-shadow: 0 0 60px rgba(0,168,89,0.2); }
  .glow-blue  { box-shadow: 0 0 60px rgba(0,112,201,0.2); }
  select.mxt-input option { background: #1a2030; color: white; }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  .float { animation: float 4s ease-in-out infinite; }
</style>
<% end %>

<!-- ───────── NAVBAR ───────── -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(8,12,16,0.85);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.06);">
  <div style="max-width:1100px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:72px;">
    <!-- 로고 영역 -->
    <div style="display:flex;align-items:center;gap:16px;">
      <div style="display:flex;align-items:center;gap:8px;padding:6px 14px;background:rgba(0,168,89,0.1);border:1px solid rgba(0,168,89,0.25);border-radius:50px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        <span style="font-size:13px;font-weight:800;color:#4ade80;letter-spacing:0.05em;">PARTNERSHIP</span>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-size:17px;font-weight:900;color:white;letter-spacing:-0.03em;">메이저텍스</span>
        <span style="color:rgba(255,255,255,0.25);font-size:18px;">×</span>
        <span style="font-size:17px;font-weight:900;color:#00d670;letter-spacing:-0.03em;">디어스</span>
      </div>
    </div>
    <a href="#contact" style="background:linear-gradient(135deg,#00a859,#00d670);color:white;padding:10px 24px;border-radius:50px;font-size:14px;font-weight:800;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
      무료 상담 신청 →
    </a>
  </div>
</nav>

<!-- ───────── HERO ───────── -->
<section style="padding:160px 24px 100px;position:relative;overflow:hidden;">
  <!-- 배경 광원 -->
  <div style="position:absolute;top:-15%;left:-10%;width:55%;height:70%;background:radial-gradient(circle,rgba(0,168,89,0.12) 0%,transparent 70%);pointer-events:none;"></div>
  <div style="position:absolute;top:10%;right:-10%;width:45%;height:60%;background:radial-gradient(circle,rgba(0,112,201,0.1) 0%,transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1100px;margin:0 auto;text-align:center;position:relative;">
    <!-- 배지 -->
    <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 20px;background:rgba(0,168,89,0.1);border:1px solid rgba(0,168,89,0.3);border-radius:50px;margin-bottom:40px;">
      <span style="width:8px;height:8px;background:#4ade80;border-radius:50%;display:inline-block;box-shadow:0 0 6px #4ade80;"></span>
      <span style="color:#4ade80;font-size:13px;font-weight:800;letter-spacing:0.08em;">소상공인 한정 올인원 패키지</span>
    </div>

    <!-- 메인 헤드라인 -->
    <h1 style="font-size:clamp(38px,6vw,76px);font-weight:900;line-height:1.08;letter-spacing:-0.04em;margin-bottom:28px;word-break:keep-all;">
      <span style="color:rgba(255,255,255,0.5);font-size:0.45em;font-weight:600;display:block;margin-bottom:12px;letter-spacing:-0.01em;">세무기장 맡기면</span>
      홈페이지 제작이<br>
      <span style="background:linear-gradient(135deg,#00a859,#00d670,#0070c9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">함께 따라옵니다</span>
    </h1>

    <p style="font-size:clamp(16px,2vw,21px);color:rgba(255,255,255,0.55);max-width:620px;margin:0 auto 56px;line-height:1.7;word-break:keep-all;">
      메이저텍스에 세무기장을 맡기시면<br>
      <strong style="color:rgba(255,255,255,0.85);">디어스의 소상공인 맞춤 홈페이지 제작·운영을 특별가로</strong> 함께 제공합니다.
    </p>

    <!-- CTA 버튼 -->
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:80px;">
      <a href="#contact" style="background:linear-gradient(135deg,#00a859,#00d670);color:white;padding:18px 48px;border-radius:14px;font-size:17px;font-weight:800;text-decoration:none;letter-spacing:-0.02em;transition:all 0.3s;box-shadow:0 20px 60px rgba(0,168,89,0.3);" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
        지금 바로 무료 상담 신청
      </a>
      <a href="#packages" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);color:white;padding:18px 40px;border-radius:14px;font-size:17px;font-weight:700;text-decoration:none;letter-spacing:-0.02em;transition:all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.background='rgba(255,255,255,0.06)'">
        패키지 보기 ↓
      </a>
    </div>

    <!-- 신뢰 지표 -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,0.06);border-radius:20px;overflow:hidden;max-width:700px;margin:0 auto;" class="glow-green">
      <% [["12년+", "세무 경력"], ["847+", "누적 고객사"], ["98.7%", "신고 정확도"], ["24h", "응답 보장"]].each do |val, label| %>
        <div style="background:#080c10;padding:28px 16px;text-align:center;">
          <div style="font-size:28px;font-weight:900;color:#4ade80;letter-spacing:-0.03em;"><%= val %></div>
          <div style="font-size:12px;color:rgba(255,255,255,0.4);margin-top:4px;"><%= label %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ───────── WHY BUNDLE ───────── -->
<section style="padding:80px 24px;max-width:1100px;margin:0 auto;">
  <div style="text-align:center;margin-bottom:56px;">
    <span style="font-size:12px;font-weight:800;color:#4ade80;letter-spacing:0.1em;text-transform:uppercase;">왜 함께 하나요?</span>
    <h2 style="font-size:clamp(28px,4vw,46px);font-weight:900;letter-spacing:-0.04em;margin-top:12px;word-break:keep-all;">
      세무사와 웹에이전시가<br>손잡은 이유
    </h2>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;">
    <% [
      ["💼", "세금 아끼고 매출 올리기", "절세로 아낀 돈을 홈페이지 마케팅에 쓰세요. 메이저텍스가 세무를 맡고, 디어스가 온라인 존재감을 만듭니다."],
      ["🚀", "사장님이 할 일이 줄어듭니다", "기장·신고·홈페이지 업데이트까지 전부 맡기세요. 사업에만 집중하면 됩니다."],
      ["💰", "따로 맡기는 것보다 훨씬 저렴", "세무기장 계약 시 홈페이지 제작비 최대 50% 할인. 유지비도 묶음 할인 적용됩니다."]
    ].each do |icon, title, desc| %>
      <div class="mxt-card" style="padding:32px;">
        <div style="font-size:36px;margin-bottom:16px;"><%= icon %></div>
        <h3 style="font-size:20px;font-weight:800;margin-bottom:10px;letter-spacing:-0.03em;"><%= title %></h3>
        <p style="color:rgba(255,255,255,0.5);line-height:1.7;font-size:15px;word-break:keep-all;"><%= desc %></p>
      </div>
    <% end %>
  </div>
</section>

<!-- ───────── PACKAGES ───────── -->
<section id="packages" style="padding:80px 24px;background:rgba(0,0,0,0.3);">
