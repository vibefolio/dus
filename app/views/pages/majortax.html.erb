<% content_for :title, "메이저텍스 × 디어스 — 세무기장 + 홈페이지 한 번에" %>
<% content_for :description, "세무기장을 맡기면 홈페이지 제작이 함께! 메이저텍스와 디어스가 함께하는 소상공인 올인원 패키지." %>

<% content_for :head do %>
<style>
  /* 토스 스타일 라이트 테마 */
  body { background: #f8f9fa !important; color: #191f28; font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif; }

  .mxt-chip { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; background: #e8f5ee; border-radius: 50px; font-size: 13px; font-weight: 700; color: #00a859; }
  .mxt-section-label { font-size: 13px; font-weight: 700; color: #00a859; letter-spacing: 0.06em; text-transform: uppercase; }

  /* 토스 카드 */
  .mxt-card { background: #fff; border-radius: 20px; border: 1px solid #eaecef; }
  .mxt-card-blue { background: #f0f6ff; border: 1px solid #d4e5ff; border-radius: 20px; }

  /* 탭 */
  .mxt-tab-wrap { background: #eef0f3; border-radius: 12px; padding: 4px; display: inline-flex; gap: 2px; }
  .mxt-tab { padding: 10px 28px; border-radius: 9px; font-size: 15px; font-weight: 700; cursor: pointer; border: none; background: transparent; color: #8b95a1; transition: all 0.2s; }
  .mxt-tab.active { background: #fff; color: #191f28; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }

  /* 인풋 */
  .mxt-input { background: #f8f9fa; border: 1.5px solid #eaecef; border-radius: 10px; color: #191f28; padding: 14px 16px; width: 100%; outline: none; transition: border-color 0.2s; font-size: 15px; }
  .mxt-input:focus { border-color: #00a859; background: #fff; }
  .mxt-input::placeholder { color: #b0b8c1; }
  select.mxt-input option { background: #fff; color: #191f28; }

  /* 버튼 */
  .mxt-btn-primary { background: #00a859; color: white; border: none; border-radius: 12px; padding: 18px 40px; font-size: 17px; font-weight: 800; cursor: pointer; width: 100%; transition: all 0.2s; letter-spacing: -0.02em; }
  .mxt-btn-primary:hover { background: #008f4a; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,168,89,0.25); }

  /* 패키지 카드 */
  .pkg-card { background: #fff; border: 1.5px solid #eaecef; border-radius: 20px; padding: 32px; transition: all 0.2s; }
  .pkg-card:hover { border-color: #00a859; box-shadow: 0 8px 32px rgba(0,168,89,0.1); transform: translateY(-4px); }
  .pkg-card.featured { border: 2px solid #00a859; position: relative; }
  .pkg-badge { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: #00a859; color: white; padding: 4px 18px; border-radius: 50px; font-size: 12px; font-weight: 800; white-space: nowrap; }

  /* 리뷰 카드 */
  .review-card { background: #fff; border: 1px solid #eaecef; border-radius: 16px; padding: 28px; }

  /* 스텝 */
  .step-number { width: 44px; height: 44px; border-radius: 50%; background: #e8f5ee; color: #00a859; font-size: 18px; font-weight: 900; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

  /* 구분 배너 */
  .segment-banner { border-radius: 16px; padding: 20px 28px; display: flex; align-items: center; gap: 16px; cursor: pointer; transition: all 0.2s; }
  .segment-new { background: #f0f8ff; border: 2px solid #d4e5ff; }
  .segment-new:hover, .segment-new.active { border-color: #3182f6; background: #e8f4ff; }
  .segment-existing { background: #f0faf5; border: 2px solid #c8ecd8; }
  .segment-existing:hover, .segment-existing.active { border-color: #00a859; background: #e2f5ea; }

  /* 토스 스텝 바 */
  .toss-step-bar { display: flex; align-items: center; gap: 0; }
  .toss-step-item { display: flex; align-items: center; gap: 8px; }
  .toss-step-dot { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; flex-shrink: 0; }
  .toss-step-dot.done { background: #00a859; color: white; }
  .toss-step-dot.current { background: #191f28; color: white; }
  .toss-step-dot.upcoming { background: #eaecef; color: #8b95a1; }
  .toss-step-line { width: 32px; height: 2px; background: #eaecef; margin: 0 4px; }
  .toss-step-line.done { background: #00a859; }

  @media (max-width: 768px) {
    .mxt-hero { padding: 80px 20px 48px !important; }
    .pkg-grid { grid-template-columns: 1fr !important; }
    .stats-grid { grid-template-columns: repeat(2,1fr) !important; }
    .hide-mobile { display: none !important; }
    .examples-grid { grid-template-columns: repeat(2,1fr) !important; }
    .pkg-card { padding: 24px !important; }
    .mxt-tab { padding: 10px 16px !important; font-size: 13px !important; }
  }
</style>
<% end %>

<!-- ───────── NAVBAR ───────── -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(255,255,255,0.92);backdrop-filter:blur(20px);border-bottom:1px solid #eaecef;">
  <div style="max-width:1080px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:68px;">
    <div style="display:flex;align-items:center;gap:12px;">
      <span style="font-size:16px;font-weight:900;color:#191f28;letter-spacing:-0.03em;">메이저텍스</span>
      <span style="color:#c4c9d0;font-weight:300;">×</span>
      <span style="font-size:16px;font-weight:900;color:#00a859;letter-spacing:-0.03em;">디어스</span>
      <div class="mxt-chip hide-mobile" style="margin-left:8px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="#00a859"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        공식 파트너십
      </div>
    </div>
    <a href="#contact" style="background:#00a859;color:white;padding:10px 22px;border-radius:50px;font-size:14px;font-weight:700;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background='#008f4a'" onmouseout="this.style.background='#00a859'">
      무료 상담 신청
    </a>
  </div>
</nav>

<!-- ───────── HERO ───────── -->
<section class="mxt-hero" style="padding:100px 24px 64px;max-width:1080px;margin:0 auto;">
  <div style="text-align:center;">
    <div class="mxt-chip" style="margin-bottom:24px;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#00a859" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
      메이저텍스 × 디어스
    </div>

    <h1 style="font-size:clamp(34px,5.5vw,68px);font-weight:900;line-height:1.1;letter-spacing:-0.04em;margin-bottom:24px;word-break:keep-all;color:#191f28;">
      창업하면<br>
      <span style="color:#00a859;">세무회계 + 홈페이지</span><br>한 번에 끝
    </h1>

    <p style="font-size:clamp(15px,2vw,19px);color:#6b7684;max-width:560px;margin:0 auto 48px;line-height:1.7;word-break:keep-all;">
      사업자등록부터 세무기장, 홈페이지 제작까지<br>
      <strong style="color:#191f28;">따로 알아볼 필요 없이 한 곳에서 해결</strong>됩니다.
    </p>

    <!-- 핵심 가치 3개 -->
    <div class="stats-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#eaecef;border-radius:16px;overflow:hidden;max-width:640px;margin:0 auto 64px;">
      <% [["D+14","사이트 오픈"],["저렴한","초기 개발비"],["올인원","세무+웹 통합"]].each do |val, label| %>
        <div style="background:#fff;padding:24px 12px;text-align:center;">
          <div style="font-size:24px;font-weight:900;color:#191f28;letter-spacing:-0.03em;"><%= val %></div>
          <div style="font-size:12px;color:#8b95a1;margin-top:4px;"><%= label %></div>
        </div>
      <% end %>
    </div>

    <!-- CTA -->
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#packages" style="background:#00a859;color:white;padding:16px 40px;border-radius:12px;font-size:16px;font-weight:800;text-decoration:none;box-shadow:0 4px 20px rgba(0,168,89,0.2);transition:all 0.2s;" onmouseover="this.style.background='#008f4a';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#00a859';this.style.transform='translateY(0)'">
        요금제 확인하기
      </a>
      <a href="#contact" style="background:#fff;border:1.5px solid #eaecef;color:#191f28;padding:16px 32px;border-radius:12px;font-size:16px;font-weight:700;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.borderColor='#00a859'" onmouseout="this.style.borderColor='#eaecef'">
        무료 상담 신청
      </a>
    </div>
  </div>
</section>

<!-- ───────── 공통 혜택 안내 ───────── -->
<section id="segment" style="padding:0 24px 80px;">
  <div style="max-width:760px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:40px;">
      <div class="mxt-section-label">파트너십 혜택</div>
      <h2 style="font-size:clamp(24px,3.5vw,40px);font-weight:900;letter-spacing:-0.04em;margin-top:12px;color:#191f28;">
        누구든 동일한 혜택을 드립니다
      </h2>
      <p style="color:#6b7684;margin-top:10px;font-size:15px;">신규든 기존이든, 파트너십으로 들어오시면 동일 할인</p>
    </div>

    <div class="mxt-card" style="padding:32px;">
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;">
        <% [
          ["초기 개발비 30% 할인", "파트너십 채널 공통 혜택"],
          ["유지관리비 최대 3만원 할인", "월 2~4만원으로 전문 홈페이지 관리"],
          ["브리핑 없이 빠른 착수", "세무사가 이미 사업을 파악 — 바로 제작 시작"],
          ["전담 담당자 배정", "세무사 + 웹 디렉터가 함께 움직입니다"],
          ["기존 세무기장료 그대로 유지", "홈페이지 추가해도 세무 비용 불변"]
        ].each do |title, desc| %>
          <li style="display:flex;align-items:flex-start;gap:12px;padding:16px;background:#f8fcf9;border-radius:12px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00a859" stroke-width="2.5" style="margin-top:1px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
            <div>
              <div style="font-weight:700;color:#191f28;font-size:15px;"><%= title %></div>
              <div style="font-size:13px;color:#8b95a1;margin-top:2px;"><%= desc %></div>
            </div>
          </li>
        <% end %>
      </ul>
      <a href="#packages" style="display:block;background:#00a859;color:white;text-align:center;padding:16px;border-radius:12px;font-size:16px;font-weight:800;text-decoration:none;margin-top:24px;transition:all 0.2s;" onmouseover="this.style.background='#008f4a'" onmouseout="this.style.background='#00a859'">
        요금제 확인하기 ↓
      </a>
    </div>

  </div>
</section>

<!-- ───────── PACKAGES (경로 기반) ───────── -->
<section id="packages" style="padding:80px 24px;background:#f2f4f8;">
  <div style="width:80%;max-width:1600px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:32px;">
      <div class="mxt-section-label">요금제</div>
      <h2 style="font-size:clamp(26px,3.5vw,42px);font-weight:900;letter-spacing:-0.04em;margin-top:12px;color:#191f28;">나에게 맞는 요금제를 확인하세요</h2>
      <p style="color:#6b7684;margin-top:12px;font-size:15px;">상황에 따라 파트너십 할인이 적용됩니다</p>
    </div>

    <!-- 경로 탭 -->
    <div style="display:flex;justify-content:center;margin-bottom:40px;">
      <div style="display:inline-flex;background:#e8eaed;border-radius:16px;padding:6px;gap:6px;flex-wrap:wrap;justify-content:center;">
        <button onclick="switchPath('dusCustomer')" id="path-tab-dusCustomer" style="padding:14px 28px;border-radius:12px;border:none;font-size:16px;font-weight:800;cursor:pointer;background:#fff;color:#191f28;box-shadow:0 2px 8px rgba(0,0,0,0.08);white-space:nowrap;display:flex;align-items:center;gap:10px;letter-spacing:-0.02em;">
          <span style="width:28px;height:28px;border-radius:50%;background:#00a859;color:white;font-size:13px;font-weight:900;display:inline-flex;align-items:center;justify-content:center;">1</span>
          디어스 고객 + 세무
        </button>
        <button onclick="switchPath('taxCustomer')" id="path-tab-taxCustomer" style="padding:14px 28px;border-radius:12px;border:none;font-size:16px;font-weight:800;cursor:pointer;background:transparent;color:#8b95a1;white-space:nowrap;display:flex;align-items:center;gap:10px;letter-spacing:-0.02em;">
          <span style="width:28px;height:28px;border-radius:50%;background:#8b95a1;color:white;font-size:13px;font-weight:900;display:inline-flex;align-items:center;justify-content:center;">2</span>
          메이저텍스 고객 + 홈페이지
        </button>
        <button onclick="switchPath('bothNew')" id="path-tab-bothNew" style="padding:14px 28px;border-radius:12px;border:none;font-size:16px;font-weight:800;cursor:pointer;background:transparent;color:#8b95a1;white-space:nowrap;display:flex;align-items:center;gap:10px;letter-spacing:-0.02em;">
          <span style="width:28px;height:28px;border-radius:50%;background:#8b95a1;color:white;font-size:13px;font-weight:900;display:inline-flex;align-items:center;justify-content:center;">3</span>
          둘 다 처음이에요
        </button>
      </div>
    </div>

    <!-- ── 경로 A: 디어스 기존 고객 → 세무기장 추가 ── -->
    <div id="path-dusCustomer">
      <div style="text-align:center;margin-bottom:24px;padding:12px 20px;background:#f0f6ff;border:1px solid #d4e5ff;border-radius:10px;font-size:13px;color:#1b4eb5;font-weight:600;">
        이미 디어스를 이용 중이시라면, 기존 요금제에 세무기장만 추가하세요
      </div>
      <div class="pkg-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;align-items:start;">

        <% [
          ["BASIC + 세무", "개인사업자", "100만원", "3만원", "8만원", "11만원", ["랜딩페이지 (기존 유지)", "월 1회 수정", "개인사업자 세무기장", "세무기장 기본 관리", "절세 포인트 안내"], false],
          ["PRO + 세무", "개인 · 법인", "200만원", "5만원", "8만원~", "13만원~", ["브랜드 홈페이지 (기존 유지)", "월 2회 수정", "개인/법인 세무기장", "부가세·종소세 신고", "절세 컨설팅"], true],
          ["MASTER + 세무", "성장 법인", "300만원~", "7만원", "15만원~", "22만원~", ["풀 커스텀 (기존 유지)", "무제한 수정", "법인 전체 세무관리", "법인세·부가세 신고", "전담 세무사 직통"], false]
        ].each do |name, target, init, web, tax, total, features, featured| %>
          <div class="pkg-card<%= ' featured' if featured %>" style="<%= 'padding-top:44px;' if featured %>">
            <% if featured %><div class="pkg-badge">가장 많이 선택</div><% end %>
            <div style="font-size:12px;font-weight:800;color:<%= featured ? '#00a859' : '#8b95a1' %>;letter-spacing:0.08em;margin-bottom:6px;"><%= name %></div>
            <div style="font-size:15px;font-weight:800;color:#191f28;margin-bottom:16px;"><%= target %></div>
            <div style="padding:10px 16px;background:#f8f9fa;border-radius:12px;margin-bottom:8px;">
              <div style="font-size:11px;font-weight:700;color:#8b95a1;margin-bottom:2px;">기존 홈페이지 관리</div>
              <div style="font-size:18px;font-weight:900;color:#191f28;">월 <%= web %></div>
            </div>
            <div style="padding:10px 16px;background:#f0faf5;border-radius:12px;margin-bottom:8px;border:<%= featured ? '1.5px solid #00a859' : '1px solid #c8ecd8' %>;">
              <div style="font-size:11px;font-weight:700;color:#00a859;margin-bottom:2px;">+ 세무기장 추가</div>
              <div style="font-size:18px;font-weight:900;color:#191f28;">월 <%= tax %></div>
            </div>
            <div style="padding:12px 16px;background:#191f28;border-radius:12px;margin-bottom:20px;text-align:center;">
              <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.6);margin-bottom:2px;">매월 유지관리비</div>
              <div style="font-size:22px;font-weight:900;color:white;"><%= total %></div>
            </div>
            <ul style="list-style:none;padding:0;margin:0 0 20px;display:flex;flex-direction:column;gap:7px;">
              <% features.each do |i| %><li style="display:flex;align-items:center;gap:7px;font-size:13px;color:#4e5968;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#00a859" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><%= i %></li><% end %>
            </ul>
            <a href="#contact" style="display:block;background:<%= featured ? '#00a859' : '#f0faf5' %>;color:<%= featured ? 'white' : '#00a859' %>;text-align:center;padding:13px;border-radius:10px;font-size:14px;font-weight:700;text-decoration:none;<%= 'border:1.5px solid #c8ecd8;' unless featured %>">상담 신청</a>
          </div>
        <% end %>

      </div>
    </div>

    <!-- ── 경로 B: 메이저텍스 기존 고객 → 홈페이지 추가 ── -->
    <div id="path-taxCustomer" style="display:none;">
      <div style="text-align:center;margin-bottom:24px;padding:12px 20px;background:#f0faf5;border:1px solid #c8ecd8;border-radius:10px;font-size:13px;color:#007a3d;font-weight:600;">
        기존 세무기장료에 월 2~4만원만 더하면, 전문 홈페이지까지 함께합니다
      </div>
      <div class="pkg-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;align-items:start;">

        <% [
          ["BASIC", "개인 / 포트폴리오", "100만원", "70만원", "3만원", "2만원", ["랜딩페이지 디자인", "반응형 웹", "기본 문의폼", "SEO 기본", "월 1회 수정"], false],
          ["PRO", "소상공인 · 일반 사업자", "200만원", "140만원", "5만원", "3만원", ["브랜드 홈페이지 디자인", "마케팅 최적화 레이아웃", "카카오채널 연동", "SEO 고급", "월 2회 수정"], true],
          ["MASTER", "성장 법인 · 프랜차이즈", "300만원~", "210만원~", "7만원", "4만원", ["풀 커스텀 디자인", "마케팅 자동화 연동", "무제한 수정", "전담 디렉터 배정", "월간 리포트"], false]
        ].each do |name, target, orig_init, disc_init, orig_monthly, disc_monthly, features, featured| %>
          <div class="pkg-card<%= ' featured' if featured %>" style="<%= 'padding-top:44px;' if featured %>">
            <% if featured %><div class="pkg-badge">가장 많이 선택</div><% end %>
            <div style="font-size:12px;font-weight:800;color:<%= featured ? '#00a859' : '#8b95a1' %>;letter-spacing:0.08em;margin-bottom:6px;"><%= name %></div>
            <div style="font-size:15px;font-weight:800;color:#191f28;margin-bottom:16px;"><%= target %></div>
            <div style="padding:12px 16px;background:#f8f9fa;border-radius:12px;margin-bottom:8px;">
