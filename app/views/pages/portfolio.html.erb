<% content_for :title, "포트폴리오 - 디어스" %>
<% content_for :description, "디어스가 완성한 다양한 프로젝트를 확인해보세요. 웹/앱/플랫폼 개발, UI/UX 디자인 등 성공적인 프로젝트 사례를 소개합니다." %>

<!-- Portfolio Hero -->
<section class="hero" style="min-height: 30vh; padding-top: 100px; padding-bottom: 48px;">
  <div class="hero-content">
    <span class="eyebrow-light" style="margin-bottom: 16px; display: inline-block;">Our Works</span>
    <h1 class="hero-title" style="font-size: var(--text-5xl); word-break: keep-all; line-height: 1.3;">포트폴리오</h1>
    <p class="hero-subtitle" style="word-break: keep-all;">
      디어스가 만들어온 성공적인 프로젝트들을 만나보세요
    </p>
  </div>
</section>

<!-- Portfolio Sections by Category -->
<section class="section-lg" style="padding: 80px 0 96px;">
  <div class="container">
    <% if @portfolio_groups.any? %>
      <% global_idx = 0 %>
      <% @portfolio_groups.each do |category, portfolios| %>
        <!-- Category Section -->
        <div style="margin-bottom: 80px;">
          <!-- Category Header -->
          <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 40px;">
            <% if category == "앱 및 플랫폼" %>
              <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="18" height="18" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
              </div>
            <% elsif category == "웹사이트" %>
              <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #00a859, #00d670); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="18" height="18" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
            <% else %>
              <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #f59e0b, #ef4444); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="18" height="18" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              </div>
            <% end %>
            <div>
              <h2 style="font-size: 22px; font-weight: 800; color: #111; line-height: 1.2;"><%= category %></h2>
              <p style="font-size: 13px; color: #9ca3af; margin-top: 2px;"><%= portfolios.length %>개 프로젝트</p>
            </div>
            <div style="flex: 1; height: 1px; background: #f3f4f6; margin-left: 8px;"></div>
          </div>

          <!-- Grid -->
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;" class="portfolio-grid">
            <% portfolios.each do |portfolio| %>
              <div class="card-premium" style="--index: <%= global_idx %>; opacity: 0; animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--index) * 60ms);">
                <div class="card-premium-inner" style="padding: 0; overflow: hidden;">
                  <div class="portfolio-image-wrapper" style="position: relative; width: 100%; aspect-ratio: 1200/630; overflow: hidden;">
                    <% if portfolio.image.attached? %>
                      <%= image_tag portfolio.image, alt: portfolio.title, class: "portfolio-img pc-ver", style: "width: 100%; height: 100%; object-fit: cover; transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); position: absolute; top: 0; left: 0; z-index: 10;" %>
                    <% elsif portfolio.image_url.present? %>
                      <%= image_tag portfolio.image_url, alt: portfolio.title, class: "portfolio-img pc-ver", style: "width: 100%; height: 100%; object-fit: cover; transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); position: absolute; top: 0; left: 0; z-index: 10;" %>
                    <% else %>
                      <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #00a859, #00d670); display: flex; align-items: center; justify-content: center; color: white; font-size: 40px; font-weight: 700; position: absolute; top: 0; left: 0; z-index: 10;">
                        <%= portfolio.title[0] %>
                      </div>
                    <% end %>

                    <% if portfolio.mobile_image.attached? %>
                      <%= image_tag portfolio.mobile_image, alt: "#{portfolio.title} Mobile", class: "portfolio-img mobile-ver", style: "width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 20; transform: translateY(100%); opacity: 0; transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);" %>
                    <% end %>
                  </div>

                  <div style="padding: 24px;">
                    <% if portfolio.category.present? %>
                      <span class="eyebrow" style="margin-bottom: 12px; display: inline-block;">
                        <%= portfolio.category %>
                      </span>
                    <% end %>

                    <h3 style="font-size: 20px; font-weight: 700; color: #111; margin-bottom: 8px; line-height: 1.4; word-break: keep-all;">
                      <% if portfolio.preview_url.present? %>
                        <%= link_to portfolio.title, portfolio.preview_url, target: "_blank", style: "color: #111; text-decoration: none; transition: color 0.3s;", class: "portfolio-title-link" %>
                      <% else %>
                        <%= portfolio.title %>
                      <% end %>
                    </h3>

                    <% if portfolio.description.present? %>
                      <p style="color: #9ca3af; font-size: 14px; line-height: 1.6; word-break: keep-all;"><%= truncate(portfolio.description.to_plain_text, length: 120) %></p>
                    <% end %>

                    <div style="margin-top: 20px; display: flex; justify-content: space-between; align-items: center;">
                      <% if portfolio.project_date.present? %>
                        <p style="color: #9ca3af; font-size: 13px;">
                          <%= portfolio.project_date.strftime("%Y년 %m월") %>
                        </p>
                      <% end %>

                      <% if portfolio.preview_url.present? %>
                        <%= link_to portfolio.preview_url, target: "_blank", style: "display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border: 1px solid #e5e7eb; border-radius: 9999px; font-size: 13px; font-weight: 600; color: #374151; text-decoration: none; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);", class: "portfolio-visit-btn" do %>
                          사이트 방문 <svg style="display:inline; width:12px; height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
              <% global_idx += 1 %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div style="text-align: center; padding: 120px 0;">
        <div style="width: 100px; height: 100px; background: #f3f4f6; border-radius: 9999px; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
          <svg width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="M21 15l-5-5L5 21"/>
          </svg>
        </div>
        <h3 style="font-size: 28px; font-weight: 700; color: #374151; margin-bottom: 16px; word-break: keep-all;">
          아직 등록된 포트폴리오가 없습니다
        </h3>
        <p style="color: #9ca3af; font-size: 18px; word-break: keep-all;">
          곧 멋진 프로젝트들을 선보일 예정입니다
        </p>
      </div>
    <% end %>
  </div>
</section>

<!-- Collaboration Portfolio Section -->
<% if @collab_groups.present? %>
<section class="section-lg" style="padding: 0 0 96px;">
  <div class="container">
    <!-- Section Header -->
    <div style="margin-bottom: 48px;">
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 20px;">
        <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #f59e0b, #f97316); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="18" height="18" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div>
          <h2 style="font-size: 22px; font-weight: 800; color: #111; line-height: 1.2;">협업 프로젝트</h2>
          <p style="font-size: 13px; color: #9ca3af; margin-top: 2px;">브랜드 간 협업으로 완성한 작업물</p>
        </div>
        <div style="flex: 1; height: 1px; background: #f3f4f6; margin-left: 8px;"></div>
      </div>

      <!-- Sub-category Filter -->
      <div id="collab-filter" style="display: flex; gap: 8px; flex-wrap: wrap;">
        <button onclick="filterCollab('all')" class="collab-filter-btn active" data-filter="all" style="padding: 8px 18px; border-radius: 9999px; font-size: 13px; font-weight: 600; border: 1px solid #00a859; background: #00a859; color: white; cursor: pointer; transition: all 0.3s;">전체</button>
        <% all_sub_categories = @collab_groups.values.flatten.map(&:sub_category).compact.uniq %>
        <% all_sub_categories.each do |sub| %>
          <button onclick="filterCollab('<%= sub %>')" class="collab-filter-btn" data-filter="<%= sub %>" style="padding: 8px 18px; border-radius: 9999px; font-size: 13px; font-weight: 600; border: 1px solid #e5e7eb; background: white; color: #374151; cursor: pointer; transition: all 0.3s;"><%= sub %></button>
        <% end %>
      </div>
    </div>

    <!-- Partner Groups -->
    <% @collab_groups.each do |partner, portfolios| %>
      <div class="collab-partner-group" style="margin-bottom: 64px;">
        <!-- Partner Header Badge -->
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 28px;">
          <div style="display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: #fff7ed; border: 1px solid #fed7aa; border-radius: 9999px;">
            <span style="font-size: 13px; color: #9a3412; font-weight: 400;">디어스</span>
            <span style="color: #f97316; font-weight: 700;">×</span>
            <span style="font-size: 13px; color: #9a3412; font-weight: 700;"><%= partner %></span>
          </div>
          <span style="font-size: 13px; color: #9ca3af;"><%= portfolios.length %>개 프로젝트</span>
        </div>

        <!-- Cards Grid -->
        <div class="collab-grid portfolio-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;">
          <% portfolios.each_with_index do |portfolio, idx| %>
            <div class="collab-card card-premium" data-sub="<%= portfolio.sub_category %>" style="opacity: 0; animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: <%= idx * 60 %>ms;">
              <div class="card-premium-inner" style="padding: 0; overflow: hidden;">
                <div class="portfolio-image-wrapper" style="position: relative; width: 100%; aspect-ratio: 1200/630; overflow: hidden;">
                  <% if portfolio.image.attached? %>
                    <%= image_tag portfolio.image, alt: portfolio.title, class: "portfolio-img pc-ver", style: "width: 100%; height: 100%; object-fit: cover; transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); position: absolute; top: 0; left: 0; z-index: 10;" %>
                  <% elsif portfolio.image_url.present? %>
                    <%= image_tag portfolio.image_url, alt: portfolio.title, class: "portfolio-img pc-ver", style: "width: 100%; height: 100%; object-fit: cover; transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); position: absolute; top: 0; left: 0; z-index: 10;" %>
                  <% else %>
                    <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #f59e0b, #f97316); display: flex; align-items: center; justify-content: center; color: white; font-size: 40px; font-weight: 700; position: absolute; top: 0; left: 0; z-index: 10;">
                      <%= portfolio.title[0] %>
                    </div>
                  <% end %>
                </div>

                <div style="padding: 24px;">
                  <div style="display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                    <% if portfolio.sub_category.present? %>
                      <span style="display: inline-block; padding: 4px 10px; background: #fff7ed; color: #f97316; border-radius: 6px; font-size: 12px; font-weight: 600;"><%= portfolio.sub_category %></span>
                    <% end %>
                    <% if portfolio.collab_partner.present? %>
                      <span style="display: inline-block; padding: 4px 10px; background: #f9fafb; color: #9ca3af; border-radius: 6px; font-size: 12px; font-weight: 500;">via <%= portfolio.collab_partner %></span>
                    <% end %>
                  </div>

                  <h3 style="font-size: 18px; font-weight: 700; color: #111; margin-bottom: 8px; line-height: 1.4; word-break: keep-all;">
                    <% if portfolio.preview_url.present? %>
                      <%= link_to portfolio.title, portfolio.preview_url, target: "_blank", style: "color: #111; text-decoration: none; transition: color 0.3s;", class: "portfolio-title-link" %>
                    <% else %>
                      <%= portfolio.title %>
                    <% end %>
                  </h3>

                  <% if portfolio.description.present? %>
                    <p style="color: #9ca3af; font-size: 14px; line-height: 1.6; word-break: keep-all;"><%= truncate(portfolio.description.to_plain_text, length: 100) %></p>
                  <% end %>

                  <div style="margin-top: 20px; display: flex; justify-content: space-between; align-items: center;">
                    <% if portfolio.project_date.present? %>
                      <p style="color: #9ca3af; font-size: 13px;"><%= portfolio.project_date.strftime("%Y년 %m월") %></p>
                    <% end %>
                    <% if portfolio.preview_url.present? %>
                      <%= link_to portfolio.preview_url, target: "_blank", style: "display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border: 1px solid #e5e7eb; border-radius: 9999px; font-size: 13px; font-weight: 600; color: #374151; text-decoration: none; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);", class: "portfolio-visit-btn" do %>
                        사이트 방문 <svg style="display:inline; width:12px; height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<script>
  function filterCollab(sub) {
    document.querySelectorAll('.collab-filter-btn').forEach(function(btn) {
      var isActive = btn.dataset.filter === sub;
      btn.style.background = isActive ? '#00a859' : 'white';
      btn.style.color = isActive ? 'white' : '#374151';
      btn.style.borderColor = isActive ? '#00a859' : '#e5e7eb';
    });

    document.querySelectorAll('.collab-card').forEach(function(card) {
      if (sub === 'all' || card.dataset.sub === sub) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });

    // Hide partner group header if all cards hidden
    document.querySelectorAll('.collab-partner-group').forEach(function(group) {
      var visible = group.querySelectorAll('.collab-card:not([style*="display: none"])').length;
      group.style.display = visible === 0 ? 'none' : '';
    });
  }
</script>
<% end %>

<!-- CTA Section -->
<section class="section-lg" style="padding: 96px 0; background: #f9fafb;">
  <div class="container" style="text-align: center;">
    <span class="eyebrow" style="margin-bottom: 16px; display: inline-block;">Next Project</span>
    <h2 class="cta-title" style="font-size: 40px; font-weight: 800; margin-bottom: 16px; color: #111; word-break: keep-all; line-height: 1.3;">
      다음 성공 사례의 주인공이 되어보세요
    </h2>
    <p style="color: #6b7280; font-size: 18px; margin-bottom: 40px; word-break: keep-all;">
      지금 바로 프로젝트를 시작하세요
    </p>
    <%= link_to contact_path, style: "display: inline-flex; align-items: center; gap: 8px; padding: 16px 32px; background: var(--color-primary); color: white; font-weight: 700; border-radius: 9999px; text-decoration: none; font-size: 16px; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);", class: "btn-cta-primary" do %>
      프로젝트 문의하기
      <span style="width: 32px; height: 32px; border-radius: 9999px; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center;">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
      </span>
    <% end %>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .card-premium:hover .portfolio-img.pc-ver {
    transform: translateY(-20px) scale(0.95);
    filter: brightness(0.9);
  }
  .card-premium:hover .portfolio-img.mobile-ver {
    transform: translateY(0) !important;
    opacity: 1 !important;
  }
  .portfolio-title-link:hover { color: var(--color-primary) !important; }
  .portfolio-visit-btn:hover {
    border-color: var(--color-primary) !important;
    color: var(--color-primary) !important;
    transform: scale(1.02);
  }
  .btn-cta-primary:hover {
    transform: scale(1.02);
    box-shadow: 0 8px 24px -4px rgba(0, 168, 89, 0.3);
  }
  .btn-cta-primary:active { transform: scale(0.98); }
  .btn-cta-primary:hover span {
    transform: translateX(4px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (max-width: 1024px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 20px !important; }
  }
  @media (max-width: 640px) {
    .portfolio-grid { grid-template-columns: 1fr !important; gap: 16px !important; }
    .card-premium { animation-delay: 0ms !important; }
  }
</style>
