<% content_for :title, "돈 벌어주는 홈페이지!" %>
<% content_for :description, "디어스는 AI 기술과 창의적인 디자인으로 비즈니스의 성공을 이끄는 프리미엄 개발 에이전시입니다. 혁신적인 디지털 솔루션으로 비즈니스 성장을 가속화합니다." %>

<!-- Hero Section -->
<section class="hero" style="padding: 6rem 0 4rem;">
  <div class="hero-content">
<!-- Hero Layout with Side Money Images -->
    <style>
      @keyframes float-vertical {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
      }

      @keyframes heroFadeUp {
        from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
        to { opacity: 1; transform: translateY(0); filter: blur(0); }
      }

      .hero-animate {
        animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
      }
      .hero-animate-delay-1 { animation-delay: 0.1s; }
      .hero-animate-delay-2 { animation-delay: 0.25s; }
      .hero-animate-delay-3 { animation-delay: 0.4s; }
      .hero-animate-delay-4 { animation-delay: 0.6s; }

      .hero-wide-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .hero-flex-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2rem;
        position: relative;
        text-align: center;
      }

      .hero-text-box {
        z-index: 10;
        width: 100%;
      }

      .money-side-img {
        width: clamp(132px, 33vw, 176px);
        height: auto;
        animation: float-vertical 3s ease-in-out infinite;
        filter: drop-shadow(0 15px 30px rgba(0,0,0,0.1));
        flex-shrink: 0;
      }

      @media (min-width: 900px) {
        .hero-flex-wrapper {
          flex-direction: row;
          justify-content: space-between;
          text-align: left;
          gap: 3rem;
        }
        .hero-text-box {
          flex: 0 0 60%;
        }
        .money-side-img.money-right {
          width: 320px;
        }
        .money-wrapper-right {
          flex: 1;
          display: flex;
          justify-content: flex-end;
        }
        .hero-cta {
          justify-content: flex-start !important;
        }
      }

      /* Stats Grid Responsive Styles */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
        margin-top: 2.5rem;
        width: 100%;
      }

      @media (min-width: 1024px) {
        .stats-grid {
          grid-template-columns: repeat(4, 1fr);
          gap: 1.5rem;
          margin-top: 4rem;
        }
      }

      /* Stat Card Styles — Double-Bezel on glass */
      .stat-card {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        padding: 1.5rem 0.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1);
      }

      .stat-card:hover {
        background: rgba(255, 255, 255, 0.16);
        transform: translateY(-4px);
        box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1), 0 12px 24px -8px rgba(0, 100, 50, 0.2);
      }

      .stat-number {
        font-size: clamp(1.25rem, 5vw, 1.75rem);
        font-weight: 850;
        color: white;
        margin-bottom: 0.25rem;
        white-space: nowrap;
        word-break: keep-all;
        line-height: 1.1;
        letter-spacing: -0.03em;
        font-variant-numeric: tabular-nums;
      }

      .stat-label {
        font-size: clamp(0.75rem, 3.5vw, 0.875rem);
        font-weight: 500;
        color: rgba(255,255,255,0.85);
        letter-spacing: -0.01em;
      }

      @media (min-width: 1024px) {
        .stat-card {
          padding: 2.5rem 1.5rem;
          min-height: 160px;
          border-radius: 24px;
        }
        .stat-number {
          font-size: 2.75rem;
          margin-bottom: 0.75rem;
        }
        .stat-label {
          font-size: 1.125rem;
        }
      }

      .hero-cta {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
        margin-top: 2.5rem;
      }

      @media (max-width: 480px) {
        .hero-cta .btn-supanova {
          width: 100%;
          justify-content: center;
        }
      }

      /* Grid Global Helper Responsive */
      @media (max-width: 768px) {
        .grid-3 {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <div class="hero-wide-container">
      <div class="hero-flex-wrapper">
        <!-- Left Spacer for PC Balance -->
        <div class="pc-spacer hidden lg:block" style="display: none;"></div>

        <!-- Center Text -->
        <div class="hero-text-box">
          <!-- Eyebrow Tag removed -->
          <h1 class="hero-title hero-animate hero-animate-delay-2" style="margin-bottom: 1.5rem; line-height: 1.15; font-weight: 850; letter-spacing: -0.03em; font-size: clamp(2rem, 10vw, 4.5rem); word-break: keep-all; text-wrap: balance;">
            비싼 홈페이지? NO!<br>
            돈 벌어주는 홈페이지!
          </h1>
          <p class="hero-subtitle hero-animate hero-animate-delay-3" style="margin-bottom: 0.5rem; word-break: keep-all; font-size: clamp(1rem, 4.5vw, 1.5rem); opacity: 0.9; line-height: 1.6; max-width: 520px;">
            요금제로 초기 개발비 부담은 낮추고,<br>주력 사업에 집중하세요!
          </p>
        </div>

        <!-- Right Money (Wrapper for PC alignment) -->
        <div class="money-wrapper-right hero-animate hero-animate-delay-4">
          <img src="/images/money_final.png" class="money-side-img money-right" style="animation-delay: 1.5s;" alt="Money Icon" loading="lazy" decoding="async">
        </div>
      </div>
    </div>

    <!-- Premium CTA Buttons -->
    <div class="hero-cta hero-animate hero-animate-delay-3">
      <%= link_to pricing_path, class: "inline-flex items-center gap-2 px-10 py-5 rounded-2xl text-lg font-bold text-white transition-all duration-300", style: "background: linear-gradient(135deg, #00a859, #00d670); box-shadow: 0 8px 32px -8px rgba(0, 168, 89, 0.4); letter-spacing: -0.01em;" do %>
        요금제 보기
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      <% end %>
      <%= link_to design_templates_path, class: "inline-flex items-center gap-2 px-10 py-5 rounded-2xl text-lg font-bold text-white/90 border-2 border-white/25 backdrop-blur-sm transition-all duration-300 hover:bg-white/10 hover:border-white/40", style: "letter-spacing: -0.01em;" do %>
        디자인 템플릿 보기
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      <% end %>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid hero-animate hero-animate-delay-4">
      <div class="stat-card">
        <div class="stat-number">30+</div>
        <div class="stat-label">템플릿 선택</div>
      </div>

      <div class="stat-card">
        <div class="stat-number">3+</div>
        <div class="stat-label">플랜 선택</div>
      </div>

      <div class="stat-card">
        <div class="stat-number">맞춤형</div>
        <div class="stat-label">개발 서비스</div>
      </div>

      <div class="stat-card">
        <div class="stat-number">안정적인</div>
        <div class="stat-label">유지보수</div>
      </div>
    </div>
  </div>
</section>

<!-- Portfolio Showcase Section -->
<section class="section" style="background: white;">
  <div class="container">
    <div class="text-center" style="margin-bottom: 4rem;">
      <h2 style="font-size: clamp(1.75rem, 5vw, 3rem); margin-top: var(--space-2); margin-bottom: var(--space-4); font-weight: 800; word-break: keep-all; line-height: 1.3;">디어스의 고객은 곧<br>함께 성장하는 파트너입니다</h2>
      <p class="text-gray" style="font-size: clamp(1rem, 4vw, 1.25rem); max-width: 700px; margin: 0 auto; word-break: keep-all; line-height: 1.6;">
        실제 운영 중인 파트너사 사이트입니다.
      </p>
    </div>

    <div class="grid grid-3" style="gap: var(--space-8);">
      <% Portfolio.order(project_date: :desc).limit(6).each do |portfolio| %>
        <div class="card" style="padding: 0; overflow: hidden; border: none; box-shadow: var(--shadow-xl); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);" onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 25px 50px -12px rgba(0,0,0,0.25)'" onmouseout="this.style.transform=''; this.style.boxShadow='var(--shadow-xl)'">
          <% if portfolio.preview_url.present? %>
            <a href="<%= portfolio.preview_url %>" target="_blank" style="display: block; aspect-ratio: 1200/630; overflow: hidden; position: relative;">
          <% else %>
            <div style="aspect-ratio: 1200/630; overflow: hidden; position: relative;">
          <% end %>
            <% if portfolio.image.attached? %>
              <%= image_tag portfolio.image, alt: portfolio.title, style: "width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s;", loading: "lazy" %>
            <% elsif portfolio.image_url.present? %>
              <img src="<%= portfolio.image_url %>" alt="<%= portfolio.title %>" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s;" loading="lazy" />
            <% end %>
            <div style="position: absolute; top: 12px; left: 12px; background: rgba(0, 168, 89, 0.9); padding: 4px 12px; border-radius: 99px; font-size: 11px; font-weight: bold; color: white;">
              운영 중
            </div>
          <% if portfolio.preview_url.present? %>
            </a>
          <% else %>
            </div>
          <% end %>
          <div style="padding: var(--space-6);">
            <h3 style="font-size: 1.25rem; font-weight: 800; margin-bottom: var(--space-2); color: #111;"><%= portfolio.title %></h3>
            <% if portfolio.description.present? %>
              <p style="color: var(--color-gray-500); font-size: 14px; margin-bottom: var(--space-4); line-height: 1.6; min-height: 44px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; word-break: keep-all;">
                <%= truncate(portfolio.description.to_plain_text, length: 80) %>
              </p>
            <% end %>
            <% if portfolio.preview_url.present? %>
              <a href="<%= portfolio.preview_url %>" target="_blank" style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 20px; border: 1px solid #e5e7eb; border-radius: 9999px; font-size: 13px; font-weight: 600; color: #374151; text-decoration: none; transition: all 0.3s;" onmouseover="this.style.borderColor='#00a859'; this.style.color='#00a859'" onmouseout="this.style.borderColor='#e5e7eb'; this.style.color='#374151'">
                사이트 방문
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div style="text-align: center; margin-top: var(--space-12);">
      <%= link_to "포트폴리오 더 보기 →", portfolio_path, class: "btn btn-link", style: "font-size: var(--text-lg); font-weight: 600; color: var(--color-primary);" %>
    </div>
  </div>
</section>

<!-- Services Section -->
<section class="section bg-gray-50">
  <div class="container">
    <div class="text-center" style="margin-bottom: 4rem;">
      <h2 style="font-size: var(--text-5xl); margin-bottom: var(--space-4);">우리의 서비스</h2>
