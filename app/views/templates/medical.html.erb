<%# Medical Template - 미래 의원 (MIRAE CLINIC) %>

<style>
  /* Supanova Design — Clean Medical Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 32px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .dept-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .dept-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(14,165,233,0.12); }
</style>

<div class="bg-[#FFFFFF] text-[#1E293B] font-sans selection:bg-[#0EA5E9] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-4 bg-white/80 backdrop-blur-xl border-b border-slate-100">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-9 h-9 bg-[#0EA5E9] rounded-lg flex items-center justify-center">
          <i class="fas fa-plus text-white text-sm"></i>
        </div>
        <span class="font-bold text-xl text-[#0EA5E9]">미래 의원</span>
      </a>

      <div class="hidden md:flex gap-10 text-sm font-medium text-slate-400">
        <a href="#departments" class="hover:text-[#0EA5E9] transition">진료과목</a>
        <a href="#doctors" class="hover:text-[#0EA5E9] transition">의료진</a>
        <a href="#facility" class="hover:text-[#0EA5E9] transition">시설안내</a>
        <a href="#reservation" class="hover:text-[#0EA5E9] transition">예약</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="tel:02-1234-5678" class="text-sm font-medium text-slate-500 hover:text-[#0EA5E9]"><i class="fas fa-phone mr-1"></i> 02-1234-5678</a>
        <a href="#reservation" class="bg-[#0EA5E9] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#0284C7] shadow-lg shadow-[#0EA5E9]/20" data-mobile-menu-copy="true">온라인 예약</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#F0F9FF] via-white to-[#E0F2FE]"></div>
    <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-[#0EA5E9]/5 rounded-full blur-[120px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 items-center w-full">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-[#F0F9FF] px-4 py-2 rounded-full border border-[#0EA5E9]/20 reveal" style="--delay: 0;">
          <span class="w-2 h-2 bg-[#0EA5E9] rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-[#0EA5E9]">진료 접수 중</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mobile-title reveal" style="--delay: 1;">
          건강한 미래를<br>
          <span class="text-[#0EA5E9]">함께 만듭니다</span>
        </h1>

        <p class="text-slate-400 text-base md:text-lg leading-relaxed max-w-md mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          미래 의원은 최신 의료 장비와 전문 의료진이 함께하는 신뢰할 수 있는 의원입니다. 환자 중심의 정확한 진단과 치료를 약속드립니다.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#reservation" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#0EA5E9] text-white rounded-full font-semibold shadow-lg shadow-[#0EA5E9]/25 hover:bg-[#0284C7]">
            <i class="fas fa-calendar-check text-sm"></i> 진료 예약하기
          </a>
          <a href="#departments" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-slate-200 rounded-full font-semibold text-slate-600 hover:border-[#0EA5E9] hover:text-[#0EA5E9]">
            진료과목 보기
          </a>
        </div>

        <div class="flex items-center gap-8 justify-center lg:justify-start pt-4 reveal" style="--delay: 4;">
          <div class="text-center">
            <p class="text-2xl font-bold text-[#0EA5E9]">15+</p>
            <p class="text-xs text-slate-400 mt-1">전문 의료진</p>
          </div>
          <div class="w-px h-8 bg-slate-200"></div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[#0EA5E9]">50,000+</p>
            <p class="text-xs text-slate-400 mt-1">누적 진료</p>
          </div>
          <div class="w-px h-8 bg-slate-200"></div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[#0EA5E9]">98%</p>
            <p class="text-xs text-slate-400 mt-1">환자 만족도</p>
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block reveal" style="--delay: 2;">
        <img src="https://images.unsplash.com/photo-1631217868264-e5b90bb7e133?q=80&w=800" alt="의료진" class="w-full h-[550px] object-cover rounded-3xl shadow-2xl">
        <div class="absolute -bottom-6 -left-6 bg-white p-5 rounded-2xl shadow-xl border border-slate-100">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-[#0EA5E9]/10 rounded-full flex items-center justify-center">
              <i class="fas fa-shield-alt text-[#0EA5E9]"></i>
            </div>
            <div>
              <p class="font-bold text-sm">건강보험 적용</p>
              <p class="text-xs text-slate-400">모든 진료과목</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 진료과목 ========== -->
  <section id="departments" class="py-24 md:py-32 bg-[#F8FAFC]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#0EA5E9] tracking-wider uppercase reveal" style="--delay: 0;">Departments</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">전문 진료과목</h2>
        <p class="text-slate-400 text-base mt-4 max-w-lg mx-auto reveal" style="--delay: 2;">각 분야 전문의가 정확한 진단과 맞춤 치료를 제공합니다</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="dept-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#0EA5E9]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-heartbeat text-[#0EA5E9] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">내과</h3>
          <p class="text-sm text-slate-400 leading-relaxed">감기, 소화기 질환, 만성질환 관리 등 내과 전반의 진료를 제공합니다.</p>
          <a href="#" class="inline-flex items-center gap-1 text-[#0EA5E9] text-sm font-semibold mt-4 hover:gap-2 transition-all">자세히 <i class="fas fa-arrow-right text-xs"></i></a>
        </div>

        <div class="dept-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#0EA5E9]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-brain text-[#0EA5E9] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">신경과</h3>
          <p class="text-sm text-slate-400 leading-relaxed">두통, 어지러움, 손발 저림 등 신경계 질환을 전문적으로 치료합니다.</p>
          <a href="#" class="inline-flex items-center gap-1 text-[#0EA5E9] text-sm font-semibold mt-4 hover:gap-2 transition-all">자세히 <i class="fas fa-arrow-right text-xs"></i></a>
        </div>

        <div class="dept-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 2;">
          <div class="w-14 h-14 bg-[#0EA5E9]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-x-ray text-[#0EA5E9] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">영상의학과</h3>
          <p class="text-sm text-slate-400 leading-relaxed">최신 CT, MRI, 초음파 장비로 정확한 영상 진단을 시행합니다.</p>
          <a href="#" class="inline-flex items-center gap-1 text-[#0EA5E9] text-sm font-semibold mt-4 hover:gap-2 transition-all">자세히 <i class="fas fa-arrow-right text-xs"></i></a>
        </div>

        <div class="dept-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#0EA5E9]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-lungs text-[#0EA5E9] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">건강검진센터</h3>
          <p class="text-sm text-slate-400 leading-relaxed">국가검진부터 프리미엄 종합검진까지 체계적인 건강관리를 돕습니다.</p>
          <a href="#" class="inline-flex items-center gap-1 text-[#0EA5E9] text-sm font-semibold mt-4 hover:gap-2 transition-all">자세히 <i class="fas fa-arrow-right text-xs"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 의료진 ========== -->
  <section id="doctors" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
        <div>
          <span class="text-sm font-semibold text-[#0EA5E9] tracking-wider uppercase reveal" style="--delay: 0;">Medical Team</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">전문 의료진</h2>
        </div>
        <p class="text-slate-400 text-base max-w-sm reveal" style="--delay: 2;">대학병원 출신 전문의가 최선의 진료를 약속합니다.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group reveal" style="--delay: 0;">
          <div class="overflow-hidden rounded-2xl mb-5">
            <img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=600" alt="김미래 원장" class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <span class="text-xs font-semibold text-[#0EA5E9] tracking-wider">원장</span>
          <h3 class="text-xl font-bold mt-1">김미래</h3>
          <p class="text-sm text-slate-400 mt-2">서울대학교 의과대학 졸업<br>서울대학교병원 내과 전문의<br>대한내과학회 정회원</p>
        </div>

        <div class="group reveal" style="--delay: 1;">
          <div class="overflow-hidden rounded-2xl mb-5">
            <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?q=80&w=600" alt="이진수 전문의" class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <span class="text-xs font-semibold text-[#0EA5E9] tracking-wider">전문의</span>
          <h3 class="text-xl font-bold mt-1">이진수</h3>
          <p class="text-sm text-slate-400 mt-2">연세대학교 의과대학 졸업<br>세브란스병원 신경과 전문의<br>대한신경과학회 정회원</p>
        </div>

        <div class="group reveal" style="--delay: 2;">
          <div class="overflow-hidden rounded-2xl mb-5">
            <img src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?q=80&w=600" alt="박서연 전문의" class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <span class="text-xs font-semibold text-[#0EA5E9] tracking-wider">전문의</span>
          <h3 class="text-xl font-bold mt-1">박서연</h3>
          <p class="text-sm text-slate-400 mt-2">고려대학교 의과대학 졸업<br>고려대학교병원 영상의학과<br>대한영상의학회 정회원</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 시설안내 ========== -->
  <section id="facility" class="py-24 md:py-32 bg-[#F8FAFC]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#0EA5E9] tracking-wider uppercase reveal" style="--delay: 0;">Facility</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">최신 시설과 장비</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?q=80&w=800" alt="로비" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl md:row-span-2 group reveal" style="--delay: 1;">
          <img src="https://images.unsplash.com/photo-1586773860418-d37222d8fce3?q=80&w=800" alt="진료실" class="w-full h-full object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1538108149393-fbbd81895907?q=80&w=800" alt="검진센터" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 3;">
          <img src="https://images.unsplash.com/photo-1516549655169-df83a0774514?q=80&w=800" alt="수술실" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl col-span-2 md:col-span-1 group reveal" style="--delay: 4;">
          <img src="https://images.unsplash.com/photo-1581595220892-b0739db3ba8c?q=80&w=800" alt="대기실" class="w-full aspect-[2/1] md:aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 진료안내 ========== -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#0EA5E9] tracking-wider uppercase reveal" style="--delay: 0;">Information</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">진료 안내</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="bg-[#F0F9FF] p-8 rounded-2xl text-center reveal" style="--delay: 0;">
          <div class="w-16 h-16 bg-[#0EA5E9] rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-clock text-white text-2xl"></i>
          </div>
          <h3 class="font-bold text-lg mb-4">진료시간</h3>
          <div class="space-y-2 text-sm text-slate-500">
            <div class="flex justify-between"><span>평일</span><span class="font-semibold text-slate-700">09:00 - 18:00</span></div>
            <div class="flex justify-between"><span>토요일</span><span class="font-semibold text-slate-700">09:00 - 13:00</span></div>
            <div class="flex justify-between"><span>점심시간</span><span class="font-semibold text-slate-700">13:00 - 14:00</span></div>
            <div class="flex justify-between text-[#0EA5E9]"><span>일/공휴일</span><span class="font-semibold">휴진</span></div>
          </div>
        </div>

        <div class="bg-[#F0F9FF] p-8 rounded-2xl text-center reveal" style="--delay: 1;">
          <div class="w-16 h-16 bg-[#0EA5E9] rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-map-marker-alt text-white text-2xl"></i>
          </div>
          <h3 class="font-bold text-lg mb-4">오시는 길</h3>
          <div class="space-y-2 text-sm text-slate-500">
            <p>서울특별시 강남구<br>테헤란로 123</p>
            <p>미래빌딩 3-5층</p>
            <p class="text-[#0EA5E9] font-semibold">강남역 3번 출구 도보 5분</p>
            <p>주차 2시간 무료</p>
          </div>
        </div>

        <div class="bg-[#F0F9FF] p-8 rounded-2xl text-center reveal" style="--delay: 2;">
          <div class="w-16 h-16 bg-[#0EA5E9] rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-phone-alt text-white text-2xl"></i>
          </div>
          <h3 class="font-bold text-lg mb-4">연락처</h3>
          <div class="space-y-2 text-sm text-slate-500">
            <p class="text-xl font-bold text-[#0EA5E9]">02-1234-5678</p>
            <p>팩스: 02-1234-5679</p>
            <p>이메일: info@miraeclinic.kr</p>
            <a href="#" class="inline-flex items-center gap-1 text-[#0EA5E9] font-semibold mt-2">카카오톡 상담 <i class="fas fa-arrow-right text-xs"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 예약 ========== -->
  <section id="reservation" class="py-24 md:py-32 bg-gradient-to-br from-[#0EA5E9] to-[#0284C7] text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-[100px]"></div>

    <div class="max-w-4xl mx-auto px-4 md:px-8 relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold reveal" style="--delay: 0;">온라인 진료 예약</h2>
        <p class="text-white/70 text-base mt-4 reveal" style="--delay: 1;">간편하게 예약하시면 대기 없이 진료받으실 수 있습니다</p>
      </div>

      <div class="bg-white/10 backdrop-blur-xl rounded-3xl p-8 md:p-12 reveal" style="--delay: 2;">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">이름</label>
            <input type="text" placeholder="홍길동" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">연락처</label>
