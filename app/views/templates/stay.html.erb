<%# Stay Template — 머무름 (게스트하우스/에어비앤비) %>

<style>
  /* Supanova Design — Natural Warmth Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-serif { font-family: 'Nanum Myeongjo', serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 34px !important; }
  }

  /* Scroll reveal */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  /* Card hover */
  .stay-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .stay-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(91, 140, 90, 0.12); }
  .stay-card:hover img { transform: scale(1.05); }

  /* Soft texture */
  .linen-texture {
    background-image: url("https://www.transparenttextures.com/patterns/cream-paper.png");
    opacity: 0.3;
  }

  /* Review card */
  .review-card { transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .review-card:hover { transform: translateY(-4px); }
</style>

<div class="bg-[#F7F5F0] text-[#2D2D2D] font-sans selection:bg-[#5B8C5A] selection:text-white min-h-screen overflow-x-hidden relative">
  <div class="fixed inset-0 linen-texture pointer-events-none z-[60]"></div>

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#F7F5F0]/85 backdrop-blur-xl border-b border-[#5B8C5A]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <span class="font-serif text-2xl font-bold text-[#2D2D2D]">머무름</span>
        <span class="text-[9px] text-[#5B8C5A] font-semibold tracking-[0.3em] uppercase mt-1">Guesthouse</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#2D2D2D]/30">
        <a href="#rooms" class="hover:text-[#5B8C5A] transition">객실</a>
        <a href="#host" class="hover:text-[#5B8C5A] transition">호스트</a>
        <a href="#around" class="hover:text-[#5B8C5A] transition">주변</a>
        <a href="#reviews" class="hover:text-[#5B8C5A] transition">후기</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none text-[#2D2D2D]">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleStayModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#2D2D2D]/30 hover:text-[#5B8C5A]" data-mobile-menu-copy="true">로그인</button>
        <a href="#booking" class="bg-[#5B8C5A] text-white px-8 py-3.5 rounded-full font-semibold text-[10px] tracking-[0.3em] uppercase hover:bg-[#2D2D2D] transition shadow-lg shadow-[#5B8C5A]/20" data-mobile-menu-copy="true">
          예약하기
        </a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== 1. Hero ========== -->
  <header class="min-h-screen relative flex items-center pt-20">
    <div class="max-w-7xl mx-auto px-6 md:px-10 w-full grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-8 reveal">
        <div class="inline-flex items-center gap-4">
          <span class="w-8 h-8 rounded-full bg-[#5B8C5A]/10 flex items-center justify-center">
            <span class="text-[#5B8C5A] text-sm">&#x1F33F;</span>
          </span>
          <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#5B8C5A]">Stay with warmth</span>
        </div>

        <h1 class="text-4xl md:text-6xl font-serif font-bold leading-[1.2] mobile-title" style="--delay:1">
          여행의 쉼표,<br>
          <span class="text-[#5B8C5A]">머무름에서.</span>
        </h1>

        <p class="reveal text-[#2D2D2D]/50 text-sm md:text-base leading-[2] max-w-md mobile-desc" style="--delay:2">
          북촌 한옥마을 골목 안, 조용한 게스트하우스에서<br class="hidden md:block">
          느린 아침과 따뜻한 대화가 있는 하루를 시작하세요.
        </p>

        <div class="reveal flex flex-wrap gap-4 pt-4" style="--delay:3">
          <a href="#rooms" class="bg-[#5B8C5A] text-white px-8 py-4 rounded-full font-semibold text-[11px] tracking-[0.2em] hover:bg-[#2D2D2D] transition shadow-lg shadow-[#5B8C5A]/20">
            객실 둘러보기
          </a>
          <a href="#booking" class="border border-[#5B8C5A]/30 text-[#5B8C5A] px-8 py-4 rounded-full font-semibold text-[11px] tracking-[0.2em] hover:bg-[#5B8C5A]/5 transition">
            날짜 확인
          </a>
        </div>

        <!-- Mini stats -->
        <div class="reveal flex gap-8 pt-6" style="--delay:4">
          <div>
            <span class="font-serif text-2xl font-bold text-[#5B8C5A]">4.9</span>
            <span class="block text-[10px] text-[#2D2D2D]/30 mt-1">게스트 평점</span>
          </div>
          <div class="border-l border-[#2D2D2D]/10 pl-8">
            <span class="font-serif text-2xl font-bold text-[#5B8C5A]">320+</span>
            <span class="block text-[10px] text-[#2D2D2D]/30 mt-1">누적 후기</span>
          </div>
          <div class="border-l border-[#2D2D2D]/10 pl-8">
            <span class="font-serif text-2xl font-bold text-[#5B8C5A]">5년</span>
            <span class="block text-[10px] text-[#2D2D2D]/30 mt-1">운영 경력</span>
          </div>
        </div>
      </div>

      <div class="reveal relative" style="--delay:2">
        <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl shadow-[#5B8C5A]/10">
          <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=1200&auto=format" alt="머무름 외관" class="w-full h-full object-cover">
        </div>
        <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-6 shadow-xl max-w-[200px]">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-[#5B8C5A]">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="text-sm font-serif leading-relaxed">"마치 친구 집에 온 것 같은 편안함"</p>
          <p class="text-[10px] text-[#2D2D2D]/40 mt-2">— 김서연님</p>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 2. 객실 소개 (3종) ========== -->
  <section id="rooms" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#5B8C5A]">Our Rooms</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold mt-4">각자의 방식으로 머무르다</h2>
        <p class="text-[#2D2D2D]/40 text-sm mt-4 max-w-md mx-auto">모든 객실은 따뜻한 우드 톤과 린넨 소재로 꾸며져 있습니다.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- 싱글룸 -->
        <div class="stay-card bg-white rounded-3xl overflow-hidden shadow-sm reveal" style="--delay:0">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?q=80&w=800&auto=format" alt="싱글룸" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-8">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2 h-2 rounded-full bg-[#5B8C5A]"></span>
              <span class="text-[10px] text-[#5B8C5A] font-semibold tracking-[0.3em] uppercase">Single</span>
            </div>
            <h3 class="font-serif text-xl font-bold">혼자만의 시간</h3>
            <p class="text-[#2D2D2D]/40 text-sm mt-3 leading-relaxed">
              12m² · 싱글베드 · 개인 욕실 · 와이파이<br>
              조용히 쉬고 싶은 솔로 여행자를 위한 아늑한 공간.
            </p>
            <div class="flex justify-between items-end mt-6 pt-6 border-t border-[#2D2D2D]/5">
              <div>
                <span class="font-serif text-2xl font-bold text-[#5B8C5A]">₩45,000</span>
                <span class="text-[10px] text-[#2D2D2D]/30 ml-1">/ 1박</span>
              </div>
              <a href="#booking" class="text-[10px] text-[#5B8C5A] font-semibold tracking-[0.2em] uppercase hover:underline">예약 →</a>
            </div>
          </div>
        </div>

        <!-- 더블룸 -->
        <div class="stay-card bg-white rounded-3xl overflow-hidden shadow-sm reveal" style="--delay:1">
          <div class="aspect-[4/3] overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1586105251261-72a756497a11?q=80&w=800&auto=format" alt="더블룸" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute top-4 right-4 bg-[#5B8C5A] text-white px-3 py-1 rounded-full text-[10px] font-semibold">인기</div>
          </div>
          <div class="p-8">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2 h-2 rounded-full bg-[#5B8C5A]"></span>
              <span class="text-[10px] text-[#5B8C5A] font-semibold tracking-[0.3em] uppercase">Double</span>
            </div>
            <h3 class="font-serif text-xl font-bold">둘만의 여유</h3>
            <p class="text-[#2D2D2D]/40 text-sm mt-3 leading-relaxed">
              18m² · 더블베드 · 전용 욕실 · 미니 테라스<br>
              커플과 친구를 위한 넉넉한 공간과 작은 테라스.
            </p>
            <div class="flex justify-between items-end mt-6 pt-6 border-t border-[#2D2D2D]/5">
              <div>
                <span class="font-serif text-2xl font-bold text-[#5B8C5A]">₩65,000</span>
                <span class="text-[10px] text-[#2D2D2D]/30 ml-1">/ 1박</span>
              </div>
              <a href="#booking" class="text-[10px] text-[#5B8C5A] font-semibold tracking-[0.2em] uppercase hover:underline">예약 →</a>
            </div>
          </div>
        </div>

        <!-- 온돌룸 -->
        <div class="stay-card bg-white rounded-3xl overflow-hidden shadow-sm reveal" style="--delay:2">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?q=80&w=800&auto=format" alt="온돌룸" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-8">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2 h-2 rounded-full bg-[#5B8C5A]"></span>
              <span class="text-[10px] text-[#5B8C5A] font-semibold tracking-[0.3em] uppercase">Ondol Family</span>
            </div>
            <h3 class="font-serif text-xl font-bold">가족의 온기</h3>
            <p class="text-[#2D2D2D]/40 text-sm mt-3 leading-relaxed">
              26m² · 온돌 난방 · 이불 세트 · 최대 4인<br>
              한옥의 온기를 담은 전통 온돌 패밀리룸.
            </p>
            <div class="flex justify-between items-end mt-6 pt-6 border-t border-[#2D2D2D]/5">
              <div>
                <span class="font-serif text-2xl font-bold text-[#5B8C5A]">₩95,000</span>
                <span class="text-[10px] text-[#2D2D2D]/30 ml-1">/ 1박</span>
              </div>
              <a href="#booking" class="text-[10px] text-[#5B8C5A] font-semibold tracking-[0.2em] uppercase hover:underline">예약 →</a>
            </div>
          </div>
        </div>
      </div>

      <!-- 공통 편의시설 -->
      <div class="mt-16 bg-white rounded-3xl p-8 md:p-12 reveal" style="--delay:1">
        <h3 class="text-center font-serif text-lg font-bold mb-8">모든 객실 공통 제공</h3>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-6 text-center">
          <div>
            <span class="text-2xl text-[#5B8C5A]"><i class="fas fa-wifi"></i></span>
            <p class="text-xs text-[#2D2D2D]/50 mt-2">고속 와이파이</p>
          </div>
          <div>
            <span class="text-2xl text-[#5B8C5A]"><i class="fas fa-coffee"></i></span>
            <p class="text-xs text-[#2D2D2D]/50 mt-2">무료 조식</p>
          </div>
          <div>
            <span class="text-2xl text-[#5B8C5A]"><i class="fas fa-tshirt"></i></span>
            <p class="text-xs text-[#2D2D2D]/50 mt-2">세탁 시설</p>
          </div>
          <div>
            <span class="text-2xl text-[#5B8C5A]"><i class="fas fa-book"></i></span>
            <p class="text-xs text-[#2D2D2D]/50 mt-2">공용 라운지</p>
          </div>
          <div>
            <span class="text-2xl text-[#5B8C5A]"><i class="fas fa-bicycle"></i></span>
            <p class="text-xs text-[#2D2D2D]/50 mt-2">자전거 대여</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 3. 호스트 소개 ========== -->
  <section id="host" class="py-24 md:py-40 px-6 md:px-10 bg-[#EDE9E0]">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="reveal">
          <div class="aspect-[4/5] rounded-3xl overflow-hidden">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1000&auto=format" alt="호스트" class="w-full h-full object-cover grayscale hover:grayscale-0 transition duration-1000">
          </div>
        </div>

        <div class="space-y-8 reveal" style="--delay:1">
          <div class="inline-flex items-center gap-4">
            <span class="w-10 h-[1px] bg-[#5B8C5A]"></span>
            <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#5B8C5A]">Your Host</span>
          </div>

          <h2 class="font-serif text-3xl md:text-4xl font-bold leading-tight">
            안녕하세요,<br>호스트 <span class="text-[#5B8C5A]">민준</span>입니다.
          </h2>

          <p class="text-[#2D2D2D]/50 text-sm md:text-base leading-[2] mobile-desc">
            서울 토박이이자 여행 애호가입니다. 2019년부터 이 작은 공간을 운영하며
            전 세계에서 오시는 게스트분들과 이야기를 나누고 있어요.
          </p>
          <p class="text-[#2D2D2D]/50 text-sm md:text-base leading-[2] mobile-desc">
            매일 아침 직접 내린 커피와 간단한 한식 조식을 준비합니다.
            북촌의 숨은 맛집이나 산책 코스가 궁금하시면 편하게 물어보세요.
          </p>

          <div class="flex flex-wrap gap-3 pt-4">
            <span class="px-4 py-2 bg-[#5B8C5A]/10 text-[#5B8C5A] rounded-full text-xs font-semibold">슈퍼호스트</span>
            <span class="px-4 py-2 bg-[#5B8C5A]/10 text-[#5B8C5A] rounded-full text-xs font-semibold">응답률 98%</span>
            <span class="px-4 py-2 bg-[#5B8C5A]/10 text-[#5B8C5A] rounded-full text-xs font-semibold">한/영/일</span>
          </div>

          <blockquote class="border-l-4 border-[#5B8C5A] pl-6 py-4 mt-6 bg-white/50 rounded-r-2xl">
            <p class="font-serif text-lg italic leading-relaxed text-[#2D2D2D]/70">
              "여행은 새로운 곳이 아니라, 새로운 시선으로 보는 것입니다."
            </p>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 4. 주변 관광 ========== -->
  <section id="around" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#5B8C5A]">Neighborhood</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold mt-4">머무름 주변, 걸어서 만나는 북촌</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="stay-card bg-white rounded-2xl overflow-hidden shadow-sm reveal" style="--delay:0">
          <div class="aspect-square overflow-hidden">
            <img src="https://images.unsplash.com/photo-1578469550956-0e16b69c6a3d?q=80&w=600&auto=format" alt="북촌 한옥마을" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-6">
            <span class="text-[10px] text-[#5B8C5A] font-semibold">도보 3분</span>
            <h4 class="font-serif text-base font-bold mt-1">북촌 한옥마을</h4>
            <p class="text-[#2D2D2D]/40 text-xs mt-2 leading-relaxed">전통 한옥이 모여있는 서울의 대표 관광지</p>
          </div>
        </div>

        <div class="stay-card bg-white rounded-2xl overflow-hidden shadow-sm reveal" style="--delay:1">
          <div class="aspect-square overflow-hidden">
            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=600&auto=format" alt="경복궁" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-6">
            <span class="text-[10px] text-[#5B8C5A] font-semibold">도보 10분</span>
            <h4 class="font-serif text-base font-bold mt-1">경복궁</h4>
            <p class="text-[#2D2D2D]/40 text-xs mt-2 leading-relaxed">조선의 정궁, 한복 체험과 야간 개장</p>
          </div>
        </div>

        <div class="stay-card bg-white rounded-2xl overflow-hidden shadow-sm reveal" style="--delay:2">
          <div class="aspect-square overflow-hidden">
            <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=600&auto=format" alt="삼청동 카페거리" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-6">
            <span class="text-[10px] text-[#5B8C5A] font-semibold">도보 5분</span>
            <h4 class="font-serif text-base font-bold mt-1">삼청동 카페거리</h4>
            <p class="text-[#2D2D2D]/40 text-xs mt-2 leading-relaxed">감각적인 카페와 갤러리가 줄지어 있는 거리</p>
          </div>
        </div>

        <div class="stay-card bg-white rounded-2xl overflow-hidden shadow-sm reveal" style="--delay:3">
          <div class="aspect-square overflow-hidden">
            <img src="https://images.unsplash.com/photo-1572375992501-4b0892d50c69?q=80&w=600&auto=format" alt="인사동" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-6">
