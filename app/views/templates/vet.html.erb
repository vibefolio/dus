<%# Vet Template - 해피펫 동물병원 (HAPPYPET) %>

<style>
  /* Supanova Design — Warm Pet Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }
  .font-display { font-family: 'Nunito', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 32px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .vet-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .vet-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(245,158,11,0.12); }
</style>

<div class="bg-[#FFF8F0] text-[#3D2E1C] font-sans selection:bg-[#F59E0B] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-4 bg-[#FFF8F0]/80 backdrop-blur-xl border-b border-[#F59E0B]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-9 h-9 bg-[#F59E0B] rounded-xl flex items-center justify-center">
          <i class="fas fa-paw text-white text-sm"></i>
        </div>
        <span class="font-bold text-xl">해피펫 <span class="text-[#F59E0B]">동물병원</span></span>
      </a>

      <div class="hidden md:flex gap-10 text-sm font-medium text-[#3D2E1C]/40">
        <a href="#treatments" class="hover:text-[#F59E0B] transition">진료과목</a>
        <a href="#doctors" class="hover:text-[#F59E0B] transition">수의사</a>
        <a href="#facility" class="hover:text-[#F59E0B] transition">시설</a>
        <a href="#reservation" class="hover:text-[#F59E0B] transition">예약</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="tel:02-333-7979" class="text-sm font-medium text-[#3D2E1C]/50 hover:text-[#F59E0B]"><i class="fas fa-phone mr-1"></i> 02-333-7979</a>
        <a href="#reservation" class="bg-[#F59E0B] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#D97706] shadow-lg shadow-[#F59E0B]/20" data-mobile-menu-copy="true">예약하기</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#FFFBEB] via-[#FFF8F0] to-[#FEF3C7]"></div>
    <div class="absolute top-40 left-0 w-[400px] h-[400px] bg-[#F59E0B]/8 rounded-full blur-[120px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 items-center w-full">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-white px-4 py-2 rounded-full border border-[#F59E0B]/20 shadow-sm reveal" style="--delay: 0;">
          <i class="fas fa-heart text-[#F59E0B] text-sm"></i>
          <span class="text-sm font-medium text-[#F59E0B]">24시간 응급진료 가능</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mobile-title reveal" style="--delay: 1;">
          소중한 가족의<br>
          <span class="text-[#F59E0B]">건강을 지킵니다</span>
        </h1>

        <p class="text-[#3D2E1C]/50 text-base md:text-lg leading-relaxed max-w-md mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          해피펫 동물병원은 반려동물 전문 의료기관입니다. 내과, 외과, 피부과, 치과 등 각 분야 전문 수의사가 최선의 진료를 제공합니다.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#reservation" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#F59E0B] text-white rounded-full font-semibold shadow-lg shadow-[#F59E0B]/25 hover:bg-[#D97706]">
            <i class="fas fa-calendar-check text-sm"></i> 진료 예약
          </a>
          <a href="tel:02-333-7979" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-[#F59E0B]/30 rounded-full font-semibold text-[#3D2E1C]/70 hover:border-[#F59E0B] hover:text-[#F59E0B]">
            <i class="fas fa-phone text-sm"></i> 응급 전화
          </a>
        </div>

        <div class="flex items-center gap-8 justify-center lg:justify-start pt-4 reveal" style="--delay: 4;">
          <div class="text-center">
            <p class="text-2xl font-bold text-[#F59E0B]">24H</p>
            <p class="text-xs text-[#3D2E1C]/40 mt-1">응급진료</p>
          </div>
          <div class="w-px h-8 bg-[#3D2E1C]/10"></div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[#F59E0B]">8명</p>
            <p class="text-xs text-[#3D2E1C]/40 mt-1">전문 수의사</p>
          </div>
          <div class="w-px h-8 bg-[#3D2E1C]/10"></div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[#F59E0B]">20,000+</p>
            <p class="text-xs text-[#3D2E1C]/40 mt-1">진료 케이스</p>
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block reveal" style="--delay: 2;">
        <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?q=80&w=800" alt="반려견" class="w-full h-[550px] object-cover rounded-3xl shadow-2xl">
        <div class="absolute -bottom-6 -left-6 bg-white p-5 rounded-2xl shadow-xl border border-[#F59E0B]/10">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-[#F59E0B]/10 rounded-full flex items-center justify-center">
              <i class="fas fa-stethoscope text-[#F59E0B]"></i>
            </div>
            <div>
              <p class="font-bold text-sm">건강검진 패키지</p>
              <p class="text-xs text-[#3D2E1C]/40">연 2회 정기검진</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 진료과목 ========== -->
  <section id="treatments" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#F59E0B] tracking-wider uppercase reveal" style="--delay: 0;">Departments</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">전문 진료과목</h2>
        <p class="text-[#3D2E1C]/40 text-base mt-4 max-w-lg mx-auto reveal" style="--delay: 2;">각 분야 전문 수의사가 반려동물의 건강을 책임집니다</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="vet-card bg-[#FFF8F0] p-8 rounded-2xl border border-[#F59E0B]/10 reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-heartbeat text-[#F59E0B] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">내과</h3>
          <p class="text-sm text-[#3D2E1C]/40 leading-relaxed">소화기, 호흡기, 내분비 질환 등 내과 전반의 정밀 진료를 제공합니다.</p>
        </div>

        <div class="vet-card bg-[#FFF8F0] p-8 rounded-2xl border border-[#F59E0B]/10 reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-bone text-[#F59E0B] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">외과/정형외과</h3>
          <p class="text-sm text-[#3D2E1C]/40 leading-relaxed">골절, 관절 질환, 슬개골 탈구 등 정형외과 수술 전문입니다.</p>
        </div>

        <div class="vet-card bg-[#FFF8F0] p-8 rounded-2xl border border-[#F59E0B]/10 reveal" style="--delay: 2;">
          <div class="w-14 h-14 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-allergies text-[#F59E0B] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">피부과</h3>
          <p class="text-sm text-[#3D2E1C]/40 leading-relaxed">알러지, 아토피, 피부감염 등 반려동물 피부 질환을 전문 치료합니다.</p>
        </div>

        <div class="vet-card bg-[#FFF8F0] p-8 rounded-2xl border border-[#F59E0B]/10 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-tooth text-[#F59E0B] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">치과</h3>
          <p class="text-sm text-[#3D2E1C]/40 leading-relaxed">스케일링, 발치, 구강질환 치료 등 반려동물 치과 진료를 시행합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 수의사 ========== -->
  <section id="doctors" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
        <div>
          <span class="text-sm font-semibold text-[#F59E0B] tracking-wider uppercase reveal" style="--delay: 0;">Veterinarians</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">전문 수의사</h2>
        </div>
        <p class="text-[#3D2E1C]/40 text-base max-w-sm reveal" style="--delay: 2;">각 분야 전문 수의사가 반려동물의 건강을 지킵니다.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group reveal" style="--delay: 0;">
          <div class="overflow-hidden rounded-2xl mb-5">
            <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?q=80&w=600" alt="박해피 원장" class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <span class="text-xs font-semibold text-[#F59E0B] tracking-wider">원장</span>
          <h3 class="text-xl font-bold mt-1">박해피</h3>
          <p class="text-sm text-[#3D2E1C]/40 mt-2">서울대학교 수의과대학 졸업<br>내과/외과 전문<br>대한수의사회 정회원</p>
        </div>

        <div class="group reveal" style="--delay: 1;">
          <div class="overflow-hidden rounded-2xl mb-5">
            <img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=600" alt="김우리 수의사" class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <span class="text-xs font-semibold text-[#F59E0B] tracking-wider">수의사</span>
          <h3 class="text-xl font-bold mt-1">김우리</h3>
          <p class="text-sm text-[#3D2E1C]/40 mt-2">건국대학교 수의과대학 졸업<br>피부과/알러지 전문<br>한국수의피부학회 정회원</p>
        </div>

        <div class="group reveal" style="--delay: 2;">
          <div class="overflow-hidden rounded-2xl mb-5">
            <img src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?q=80&w=600" alt="이든든 수의사" class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <span class="text-xs font-semibold text-[#F59E0B] tracking-wider">수의사</span>
          <h3 class="text-xl font-bold mt-1">이든든</h3>
          <p class="text-sm text-[#3D2E1C]/40 mt-2">충남대학교 수의과대학 졸업<br>정형외과/재활의학 전문<br>한국수의외과학회 정회원</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 시설 ========== -->
  <section id="facility" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#F59E0B] tracking-wider uppercase reveal" style="--delay: 0;">Facility</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">최신 진료 시설</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1628009368231-7bb7cfcb0def?q=80&w=800" alt="진료실" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl md:row-span-2 group reveal" style="--delay: 1;">
          <img src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?q=80&w=800" alt="수술실" class="w-full h-full object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1601758228041-f3b2795255f1?q=80&w=800" alt="검사실" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 3;">
          <img src="https://images.unsplash.com/photo-1583337130417-13571e35e2da?q=80&w=800" alt="입원실" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl col-span-2 md:col-span-1 group reveal" style="--delay: 4;">
          <img src="https://images.unsplash.com/photo-1450778869180-e11c4f1a3d44?q=80&w=800" alt="대기실" class="w-full aspect-[2/1] md:aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 진료안내 ========== -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#F59E0B] tracking-wider uppercase reveal" style="--delay: 0;">Information</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">병원 안내</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#F59E0B]/10 text-center reveal" style="--delay: 0;">
          <div class="w-16 h-16 bg-[#F59E0B] rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-clock text-white text-2xl"></i>
          </div>
          <h3 class="font-bold text-lg mb-4">진료시간</h3>
          <div class="space-y-2 text-sm text-[#3D2E1C]/50">
            <div class="flex justify-between"><span>평일</span><span class="font-semibold text-[#3D2E1C]/70">10:00 - 20:00</span></div>
            <div class="flex justify-between"><span>토요일</span><span class="font-semibold text-[#3D2E1C]/70">10:00 - 17:00</span></div>
            <div class="flex justify-between"><span>일/공휴일</span><span class="font-semibold text-[#3D2E1C]/70">10:00 - 14:00</span></div>
            <div class="flex justify-between text-[#F59E0B]"><span>응급진료</span><span class="font-semibold">24시간</span></div>
          </div>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#F59E0B]/10 text-center reveal" style="--delay: 1;">
          <div class="w-16 h-16 bg-[#F59E0B] rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-map-marker-alt text-white text-2xl"></i>
          </div>
          <h3 class="font-bold text-lg mb-4">오시는 길</h3>
          <div class="space-y-2 text-sm text-[#3D2E1C]/50">
            <p>서울특별시 마포구<br>와우산로 94</p>
            <p>해피펫 빌딩 1-3층</p>
            <p class="text-[#F59E0B] font-semibold">홍대입구역 9번 출구 도보 3분</p>
            <p>주차장 완비</p>
          </div>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#F59E0B]/10 text-center reveal" style="--delay: 2;">
          <div class="w-16 h-16 bg-[#F59E0B] rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-phone-alt text-white text-2xl"></i>
          </div>
          <h3 class="font-bold text-lg mb-4">연락처</h3>
          <div class="space-y-2 text-sm text-[#3D2E1C]/50">
            <p class="text-xl font-bold text-[#F59E0B]">02-333-7979</p>
            <p>응급: 010-9999-7979</p>
            <p>이메일: hello@happypet.kr</p>
            <a href="#" class="inline-flex items-center gap-1 text-[#F59E0B] font-semibold mt-2">카카오톡 상담 <i class="fas fa-arrow-right text-xs"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 예약 ========== -->
  <section id="reservation" class="py-24 md:py-32 bg-gradient-to-br from-[#F59E0B] to-[#D97706] text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-[100px]"></div>

    <div class="max-w-4xl mx-auto px-4 md:px-8 relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold reveal" style="--delay: 0;">진료 예약</h2>
        <p class="text-white/70 text-base mt-4 reveal" style="--delay: 1;">사랑하는 반려동물의 건강을 위해 미리 예약해주세요</p>
      </div>

      <div class="bg-white/10 backdrop-blur-xl rounded-3xl p-8 md:p-12 reveal" style="--delay: 2;">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">보호자 이름</label>
            <input type="text" placeholder="홍길동" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">연락처</label>
            <input type="tel" placeholder="010-0000-0000" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
