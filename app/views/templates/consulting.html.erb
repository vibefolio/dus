<%# Consulting Template - 인사이트 파트너스 (INSIGHT PARTNERS) — 컨설팅 회사 %>

<style>
  /* Supanova Design Upgrade */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

  .font-display { font-family: 'Inter', sans-serif; }
  .font-body { font-family: 'Noto Sans KR', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 32px !important; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="bg-[#FAFAFA] text-[#1F2937] font-body selection:bg-[#2563EB] selection:text-white min-h-screen overflow-x-hidden relative">

  <!-- Nav -->
  <nav class="fixed w-full z-50 px-6 py-5 bg-white/95 backdrop-blur-xl border-b border-gray-100 shadow-sm">
    <div class="container mx-auto px-4 md:px-6 flex justify-between items-center flex-nowrap">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-[#2563EB] rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <span class="font-display text-xl font-bold tracking-tight text-[#1F2937]">INSIGHT<span class="text-[#2563EB]">.</span></span>
      </div>

      <div class="hidden md:flex gap-10 text-[13px] font-medium text-[#1F2937]/60">
        <a href="#about" class="hover:text-[#2563EB] transition">소개</a>
        <a href="#services" class="hover:text-[#2563EB] transition">서비스</a>
        <a href="#process" class="hover:text-[#2563EB] transition">프로세스</a>
        <a href="#clients" class="hover:text-[#2563EB] transition">고객사</a>
        <a href="#booking" class="hover:text-[#2563EB] transition">상담 예약</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: #2563EB;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="flex-nowrap shrink-0 flex gap-4 items-center">
        <button onclick="toggleConsultingModal()" class="hidden md:block text-[13px] font-medium text-[#1F2937]/60 hover:text-[#2563EB]" data-mobile-menu-copy="true">로그인</button>
        <button class="hidden md:inline-flex bg-[#2563EB] text-white px-5 py-2.5 rounded-lg font-semibold text-[13px] hover:bg-[#1D4ED8] transition shadow-lg shadow-[#2563EB]/20" data-mobile-menu-copy="true">
          무료 상담 예약
        </button>
      </div>
    </div>
    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- Hero -->
  <header class="min-h-screen relative flex items-center pt-24 overflow-hidden">
    <div class="absolute right-0 top-0 w-1/2 h-full bg-gradient-to-l from-[#2563EB]/5 to-transparent pointer-events-none"></div>
    <div class="container mx-auto px-6 md:px-12 grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-[#2563EB]/5 border border-[#2563EB]/15 rounded-full px-4 py-1.5">
          <span class="w-2 h-2 bg-[#2563EB] rounded-full"></span>
          <span class="text-[12px] font-medium text-[#2563EB]">Top 10 컨설팅 펌 선정</span>
        </div>

        <h1 class="text-4xl md:text-6xl font-display font-extrabold leading-[1.1] tracking-tight text-[#1F2937] mobile-title">
          비즈니스 성장의<br>
          <span class="text-[#2563EB]">인사이트</span>를 제공합니다
        </h1>

        <p class="text-lg md:text-xl text-[#1F2937]/60 leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc">
          데이터 기반 전략 수립부터 실행까지, 인사이트 파트너스가 귀사의 지속가능한 성장을 이끌어 드립니다.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#booking" class="px-8 py-4 bg-[#2563EB] text-white font-semibold text-[15px] rounded-lg hover:bg-[#1D4ED8] transition shadow-lg shadow-[#2563EB]/25">
            무료 상담 신청
          </a>
          <a href="#services" class="px-8 py-4 border border-[#2563EB]/20 text-[#2563EB] font-semibold text-[15px] rounded-lg hover:bg-[#2563EB]/5 transition">
            서비스 살펴보기
          </a>
        </div>

        <div class="flex items-center gap-8 pt-4 justify-center lg:justify-start">
          <div>
            <div class="text-2xl font-display font-bold text-[#1F2937]">350+</div>
            <div class="text-[12px] text-[#1F2937]/40">프로젝트 수행</div>
          </div>
          <div class="w-px h-10 bg-gray-200"></div>
          <div>
            <div class="text-2xl font-display font-bold text-[#1F2937]">97%</div>
            <div class="text-[12px] text-[#1F2937]/40">재계약률</div>
          </div>
          <div class="w-px h-10 bg-gray-200"></div>
          <div>
            <div class="text-2xl font-display font-bold text-[#1F2937]">15년</div>
            <div class="text-[12px] text-[#1F2937]/40">업력</div>
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <img src="https://images.unsplash.com/photo-1557804506-669a67965ba0?q=80&w=800&auto=format&fit=crop" alt="컨설팅 미팅" class="rounded-2xl shadow-2xl shadow-[#2563EB]/10 w-full object-cover aspect-[4/3]" loading="lazy" decoding="async">
        <div class="absolute -bottom-4 -right-4 bg-white rounded-xl shadow-xl p-5 border border-gray-100">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-green-50 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
              <div class="text-[11px] text-[#1F2937]/40">평균 ROI 개선</div>
              <div class="text-lg font-display font-bold text-[#1F2937]">+230%</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- About -->
  <section id="about" class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6 reveal">
          <span class="text-[12px] font-semibold text-[#2563EB] uppercase tracking-widest">About Us</span>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-[#1F2937]">
            전략과 실행의<br>차이를 만드는 파트너
          </h2>
          <p class="text-[#1F2937]/60 leading-relaxed">
            인사이트 파트너스는 2009년 설립 이래 국내 주요 기업의 전략 수립과 실행을 지원해온 전문 컨설팅 펌입니다.
            맥킨지, BCG 출신의 파트너들이 이끄는 전문 팀이 데이터에 기반한 실질적인 인사이트를 제공합니다.
          </p>
          <p class="text-[#1F2937]/60 leading-relaxed">
            단순한 보고서가 아닌, 고객사와 함께 전략을 실행하고 결과를 만들어내는 것이 우리의 철학입니다.
          </p>
          <div class="grid grid-cols-2 gap-6 pt-4">
            <div class="bg-[#FAFAFA] rounded-xl p-5 border border-gray-100">
              <div class="text-3xl font-display font-bold text-[#2563EB]">42명</div>
              <div class="text-sm text-[#1F2937]/50 mt-1">전문 컨설턴트</div>
            </div>
            <div class="bg-[#FAFAFA] rounded-xl p-5 border border-gray-100">
              <div class="text-3xl font-display font-bold text-[#2563EB]">12개</div>
              <div class="text-sm text-[#1F2937]/50 mt-1">산업 전문 영역</div>
            </div>
          </div>
        </div>
        <div class="reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=800&auto=format&fit=crop" alt="전문 팀 전략 회의" class="rounded-2xl shadow-lg w-full object-cover aspect-[4/3]" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-24 md:py-32">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 reveal">
        <span class="text-[12px] font-semibold text-[#2563EB] uppercase tracking-widest">Services</span>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-[#1F2937] mt-3">전문 컨설팅 서비스</h2>
        <p class="text-[#1F2937]/50 mt-4 max-w-xl mx-auto">각 산업과 비즈니스 환경에 최적화된 맞춤형 솔루션을 제공합니다</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-gray-100 hover:shadow-xl hover:shadow-[#2563EB]/5 transition-all duration-500 group" style="--delay: 1;">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 bg-[#2563EB]/5 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#2563EB] transition-colors duration-500">
              <svg class="w-7 h-7 text-[#2563EB] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-[#1F2937] text-lg mb-2">경영 전략 컨설팅</h3>
              <p class="text-[#1F2937]/55 text-sm leading-relaxed">시장 분석, 경쟁 전략, 사업 포트폴리오 최적화 등 기업의 핵심 의사결정을 지원합니다.</p>
            </div>
          </div>
        </div>

        <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-gray-100 hover:shadow-xl hover:shadow-[#2563EB]/5 transition-all duration-500 group" style="--delay: 2;">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 bg-[#2563EB]/5 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#2563EB] transition-colors duration-500">
              <svg class="w-7 h-7 text-[#2563EB] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-[#1F2937] text-lg mb-2">디지털 트랜스포메이션</h3>
              <p class="text-[#1F2937]/55 text-sm leading-relaxed">AI, 클라우드, 데이터 분석 등 디지털 기술을 활용한 비즈니스 혁신 전략을 수립합니다.</p>
            </div>
          </div>
        </div>

        <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-gray-100 hover:shadow-xl hover:shadow-[#2563EB]/5 transition-all duration-500 group" style="--delay: 3;">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 bg-[#2563EB]/5 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#2563EB] transition-colors duration-500">
              <svg class="w-7 h-7 text-[#2563EB] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-[#1F2937] text-lg mb-2">조직 혁신 컨설팅</h3>
              <p class="text-[#1F2937]/55 text-sm leading-relaxed">조직 구조 개편, 성과 관리 체계, 기업 문화 혁신 등 인적 자원의 효율성을 극대화합니다.</p>
            </div>
          </div>
        </div>

        <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-gray-100 hover:shadow-xl hover:shadow-[#2563EB]/5 transition-all duration-500 group" style="--delay: 4;">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 bg-[#2563EB]/5 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#2563EB] transition-colors duration-500">
              <svg class="w-7 h-7 text-[#2563EB] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-[#1F2937] text-lg mb-2">M&A / 재무 자문</h3>
              <p class="text-[#1F2937]/55 text-sm leading-relaxed">기업 가치 평가, M&A 전략, 구조조정 자문 등 재무 전문 서비스를 제공합니다.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Strategy Visual -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=800&auto=format&fit=crop" alt="전략 화이트보드 세션" class="rounded-2xl shadow-lg w-full object-cover aspect-[4/3]" loading="lazy" decoding="async">
        </div>
        <div class="space-y-6 reveal" style="--delay: 2;">
          <span class="text-[12px] font-semibold text-[#2563EB] uppercase tracking-widest">Strategy</span>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-[#1F2937]">데이터와 경험이<br>만나는 <span class="text-[#2563EB]">전략 수립</span></h2>
          <p class="text-[#1F2937]/60 leading-relaxed">산업별 전문 컨설턴트가 정량적 데이터 분석과 정성적 인사이트를 결합하여 실행 가능한 전략을 설계합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Workshop & Office Gallery -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-3 gap-6 reveal" style="--delay: 1;">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=800&auto=format&fit=crop" alt="모던 오피스" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async">
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="https://images.unsplash.com/photo-1515187029135-18ee286d815b?q=80&w=800&auto=format&fit=crop" alt="워크숍 진행" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async">
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?q=80&w=800&auto=format&fit=crop" alt="프레젠테이션" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section id="process" class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 reveal">
        <span class="text-[12px] font-semibold text-[#2563EB] uppercase tracking-widest">Process</span>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-[#1F2937] mt-3">컨설팅 프로세스</h2>
        <p class="text-[#1F2937]/50 mt-4 max-w-xl mx-auto">체계적인 4단계 프로세스로 최적의 결과를 도출합니다</p>
      </div>

      <div class="grid md:grid-cols-4 gap-8 relative">
        <div class="hidden md:block absolute top-16 left-[12.5%] right-[12.5%] h-0.5 bg-[#2563EB]/10"></div>

        <div class="reveal text-center relative" style="--delay: 1;">
          <div class="w-12 h-12 bg-[#2563EB] rounded-full flex items-center justify-center text-white font-display font-bold text-lg mx-auto mb-6 relative z-10 shadow-lg shadow-[#2563EB]/30">1</div>
          <h3 class="font-display font-bold text-[#1F2937] text-lg mb-3">진단 & 분석</h3>
          <p class="text-[#1F2937]/55 text-sm leading-relaxed">현재 비즈니스 환경과 내부 역량을 심층 분석하고, 핵심 과제를 도출합니다.</p>
        </div>

        <div class="reveal text-center relative" style="--delay: 2;">
          <div class="w-12 h-12 bg-[#2563EB] rounded-full flex items-center justify-center text-white font-display font-bold text-lg mx-auto mb-6 relative z-10 shadow-lg shadow-[#2563EB]/30">2</div>
          <h3 class="font-display font-bold text-[#1F2937] text-lg mb-3">전략 수립</h3>
          <p class="text-[#1F2937]/55 text-sm leading-relaxed">데이터와 인사이트를 기반으로 실행 가능한 맞춤형 전략을 설계합니다.</p>
        </div>

        <div class="reveal text-center relative" style="--delay: 3;">
          <div class="w-12 h-12 bg-[#2563EB] rounded-full flex items-center justify-center text-white font-display font-bold text-lg mx-auto mb-6 relative z-10 shadow-lg shadow-[#2563EB]/30">3</div>
