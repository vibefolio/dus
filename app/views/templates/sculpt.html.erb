<%# Sculpt Template - 에테르노 (ETERNO) %>

<style>
  /* Supanova Design Upgrade */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');
  
  .font-serif { font-family: 'Nanum Myeongjo', serif; }
  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 40px !important; }
  }
</style>

<div class="bg-[#F9F8F6] text-[#1A1A1A] font-sans selection:bg-[#D4A373] selection:text-white min-h-screen overflow-x-hidden">

  <!-- Nav -->
  <nav class="fixed w-full z-50 px-8 py-12 md:px-12 bg-[#F9F8F6]/80 backdrop-blur-xl border-b border-[#D4A373]/10">
    <div class="container mx-auto px-4 md:px-6 flex justify-between items-center flex-nowrap">
      <div class="flex items-center gap-6">
         <div class="w-[1px] h-6 bg-[#D4A373]"></div>
         <span class="font-serif text-2xl tracking-[0.5em] font-semibold uppercase">ETERNO</span>
      </div>
      
      <div class="hidden md:flex gap-14 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1A1A1A]/40">
        <a href="#about" class="hover:text-[#D4A373] transition">Studio</a>
        <a href="#program" class="hover:text-[#D4A373] transition">Sequence</a>
        <a href="#membership" class="hover:text-[#D4A373] transition">Retreat</a>
      </div>
           <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
             <i class="fas fa-bars"></i>
           </button>

      
      <div class="flex-nowrap shrink-0 flex gap-12 items-center">
         <button onclick="toggleSculptModal()" class="hidden md:block text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1A1A1A]/40 hover:text-[#D4A373]" data-mobile-menu-copy="true">Member ID</button>
         <button class="hidden md:inline-flex bg-[#1A1A1A] text-white px-4 py-2 text-xs md:text-base md:px-8 md:py-3 whitespace-nowrap rounded-lg font-semibold text-[10px] tracking-[0.3em] uppercase hover:bg-[#D4A373] transition shadow-2xl" data-mobile-menu-copy="true">
           Reserve
         </button>
      </div>
    </div>

      <%= render partial: 'templates/shared/mobile_menu_overlay' %></nav>

  <!-- Hero -->
  <header class="min-h-screen relative flex items-center justify-center pt-20">
    <div class="container mx-auto px-3 md:px-6 relative z-10 grid lg:grid-cols-2 gap-10 md:p-16 items-center">
      <div class="order-2 lg:order-1 relative">
         <div class="absolute -top-8 md:p-20 -left-20 w-64 h-64 bg-[#D4A373]/5 rounded-full blur-[100px]"></div>
         <div class="relative group">
            <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800&auto=format&fit=crop" alt="필라테스" class="w-full aspect-[3/4] object-cover rounded-[5rem_2rem_5rem_2rem] shadow-2xl grayscale brightness-90 group-hover:grayscale-0 transition duration-1000" loading="lazy" decoding="async">
            <div class="absolute -bottom-8 -right-8 bg-white p-10 rounded-2xl shadow-2xl border border-[#D4A373]/10">
               <p class="text-[10px] font-semibold text-[#D4A373] uppercase tracking-[0.4em] mb-4 text-center">Architectural Flow</p>
               <div class="flex gap-6 items-center">
                  <div class="w-12 h-[1px] bg-[#D4A373]"></div>
                  <span class="font-serif text-2xl italic">Sculpting Balance</span>
               </div>
            </div>
         </div>
      </div>

      <div class="order-1 lg:order-2 space-y-12 text-center lg:text-left">
        <div class="inline-flex items-center gap-3">
           <span class="w-8 h-[1px] bg-[#D4A373]"></span>
           <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#D4A373]">The Art of Pilates</span>
        </div>
        
        <h1 class="text-3xl md:text-5xl md:text-[7rem] font-serif font-semibold leading-none tracking-tight mobile-title">
           가장 우아한<br><span class="italic text-[#D4A373]">무브먼트.</span>
        </h1>
        
        <p class="text-[#1A1A1A]/50 text-sm md:text-xl leading-[1.8] max-w-lg mx-auto lg:mx-0 mobile-desc">
           몸과 마음의 불균형을 해결하는 정교한 시퀀스. 에테르노는 단순한 운동을 넘어 당신의 실루엣을 새롭게 정의하는 건축적 움직임을 제안합니다.
        </p>
        
        <div class="pt-6 flex flex-col sm:flex-row gap-12 justify-center lg:justify-start">
           <button class="px-14 py-6 bg-[#1A1A1A] text-white font-semibold text-[11px] tracking-[0.4em] uppercase hover:bg-[#D4A373] transition-all shadow-2xl">
              Discover Studio
           </button>
           <button class="px-14 py-6 border border-[#1A1A1A]/10 text-[#1A1A1A] font-semibold text-[11px] tracking-[0.4em] uppercase hover:bg-white transition-all">
              Private Lesson
           </button>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About Studio ========== -->
  <section id="about" class="py-24 md:py-40 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center gap-3">
            <span class="w-8 h-[1px] bg-[#D4A373]"></span>
            <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#D4A373]">The Studio</span>
          </div>
          <h2 class="text-3xl md:text-5xl font-serif font-semibold leading-tight">공간이 만드는<br><span class="italic text-[#D4A373]">균형의 미학</span></h2>
          <p class="text-[#1A1A1A]/50 text-sm md:text-lg leading-[1.8]">에테르노 스튜디오는 몸과 마음의 조화를 추구하는 프리미엄 필라테스 공간입니다. 자연광이 드리우는 넓은 스튜디오에서 당신만의 무브먼트를 발견하세요.</p>
          <div class="grid grid-cols-2 gap-6 pt-4">
            <div class="bg-[#F9F8F6] p-5 rounded-xl border border-[#D4A373]/10">
              <p class="text-2xl font-serif font-semibold text-[#D4A373]">200평</p>
              <p class="text-xs text-[#1A1A1A]/40 mt-1">스튜디오 면적</p>
            </div>
            <div class="bg-[#F9F8F6] p-5 rounded-xl border border-[#D4A373]/10">
              <p class="text-2xl font-serif font-semibold text-[#D4A373]">1:4</p>
              <p class="text-xs text-[#1A1A1A]/40 mt-1">소그룹 수업</p>
            </div>
          </div>
        </div>
        <div class="relative group">
          <img src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?q=80&w=800&auto=format&fit=crop" alt="에테르노 스튜디오" class="w-full aspect-[3/4] object-cover rounded-[2rem_5rem_2rem_5rem] shadow-2xl grayscale brightness-90 group-hover:grayscale-0 transition duration-1000" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Programs ========== -->
  <section id="program" class="py-24 md:py-40">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-3 justify-center mb-6">
          <span class="w-8 h-[1px] bg-[#D4A373]"></span>
          <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#D4A373]">Sequence</span>
          <span class="w-8 h-[1px] bg-[#D4A373]"></span>
        </div>
        <h2 class="text-3xl md:text-5xl font-serif font-semibold">프로그램</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="group">
          <div class="rounded-[2rem] overflow-hidden mb-6">
            <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?q=80&w=800&auto=format&fit=crop" alt="프라이빗 레슨" class="w-full h-72 object-cover grayscale group-hover:grayscale-0 transition duration-700" loading="lazy" decoding="async">
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2">Private Lesson</h3>
          <p class="text-[#1A1A1A]/40 text-sm leading-relaxed">1:1 맞춤 시퀀스로 체형 분석부터 교정까지. 전담 인스트럭터가 당신만의 움직임을 설계합니다.</p>
        </div>
        <div class="group">
          <div class="rounded-[2rem] overflow-hidden mb-6">
            <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800&auto=format&fit=crop" alt="그룹 클래스" class="w-full h-72 object-cover grayscale group-hover:grayscale-0 transition duration-700" loading="lazy" decoding="async">
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2">Group Flow</h3>
          <p class="text-[#1A1A1A]/40 text-sm leading-relaxed">4명 이하 소그룹 세션. 함께하는 에너지 속에서 각자의 리듬을 찾아가는 시간.</p>
        </div>
        <div class="group">
          <div class="rounded-[2rem] overflow-hidden mb-6">
            <img src="https://images.unsplash.com/photo-1575052814086-f385e2e2ad1b?q=80&w=800&auto=format&fit=crop" alt="스트레칭" class="w-full h-72 object-cover grayscale group-hover:grayscale-0 transition duration-700" loading="lazy" decoding="async">
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2">Stretch & Release</h3>
          <p class="text-[#1A1A1A]/40 text-sm leading-relaxed">근막 이완과 유연성 향상에 집중하는 릴리즈 프로그램. 몸의 긴장을 풀어드립니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Facility ========== -->
  <section class="py-24 md:py-40 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative group">
          <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=800&auto=format&fit=crop" alt="필라테스 장비" class="w-full aspect-[4/3] object-cover rounded-[2rem] shadow-2xl" loading="lazy" decoding="async">
        </div>
        <div class="space-y-8">
          <div class="inline-flex items-center gap-3">
            <span class="w-8 h-[1px] bg-[#D4A373]"></span>
            <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#D4A373]">Equipment</span>
          </div>
          <h2 class="text-3xl md:text-5xl font-serif font-semibold leading-tight">최상의 장비로<br><span class="italic text-[#D4A373]">완벽한 동작을.</span></h2>
          <p class="text-[#1A1A1A]/50 text-sm md:text-lg leading-[1.8]">Balanced Body 리포머, 캐딜락, 체어 등 프리미엄 장비를 갖추고 있습니다. 최적의 환경에서 효과적인 움직임을 경험하세요.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Results Gallery ========== -->
  <section id="membership" class="py-24 md:py-40">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-3 justify-center mb-6">
          <span class="w-8 h-[1px] bg-[#D4A373]"></span>
          <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#D4A373]">Retreat</span>
          <span class="w-8 h-[1px] bg-[#D4A373]"></span>
        </div>
        <h2 class="text-3xl md:text-5xl font-serif font-semibold">공간의 이야기</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-[2rem] overflow-hidden">
          <img src="https://images.unsplash.com/photo-1550345332-09e3ac987658?q=80&w=800&auto=format&fit=crop" alt="피트니스 결과" class="w-full h-80 object-cover hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="rounded-[2rem] overflow-hidden">
          <img src="https://images.unsplash.com/photo-1540497077202-7c8a3999166f?q=80&w=800&auto=format&fit=crop" alt="모던 스튜디오" class="w-full h-80 object-cover hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- Login Modal -->
  <div id="sculpt-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-[#1A1A1A]/ worse backdrop-blur-2xl">
    <div class="bg-white w-full max-w-sm p-14 shadow-2xl relative rounded-[4rem] border border-[#D4A373]/10">
      <button onclick="toggleSculptModal()" class="absolute top-12 right-12 text-[#1A1A1A]/20 hover:text-[#D4A373] transition text-2xl font-light">&times;</button>
      
      <div class="text-center mb-12">
        <h2 class="text-xl font-serif tracking-[0.5em] text-[#1A1A1A] mb-3 font-semibold uppercase">BALANCED_ID</h2>
        <p class="text-[9px] text-[#D4A373] font-semibold tracking-[0.3em] uppercase">Eterno Private Membership Access</p>
      </div>
      
      <div class="space-y-8">
        <div class="space-y-2">
           <p class="text-[9px] font-semibold text-[#1A1A1A]/30 uppercase tracking-[0.2em] ml-2">Authorized Account</p>
           <input type="text" placeholder="MEMBER SESSION KEY" class="w-full bg-[#F9F8F6] border-none rounded-2xl py-6 px-8 outline-none focus:ring-1 focus:ring-[#D4A373] transition text-[11px] font-semibold tracking-wide uppercase">
        </div>
        <button class="w-full bg-[#1A1A1A] text-white py-6 rounded-2xl text-[10px] tracking-[0.5em] font-semibold uppercase hover:bg-[#D4A373] transition shadow-xl shadow-[#D4A373]/20">
           Synchronize Flow
        </button>
        <div class="flex justify-center gap-16 pt-4">
           <a href="#" class="text-[9px] text-[#1A1A1A]/40 tracking-[0.3em] font-semibold uppercase hover:text-[#D4A373] transition italic">New Journey</a>
           <a href="#" class="text-[9px] text-[#1A1A1A]/40 tracking-[0.3em] font-semibold uppercase hover:text-[#D4A373] transition italic">Concierge</a>
        </div>
      </div>
    </div>
  </div>

  <footer class="py-24 md:py-40 bg-white text-center px-6 border-t border-[#D4A373]/10">
     <div class="inline-flex items-center gap-12 mb-10">
        <span class="font-serif text-2xl tracking-[0.5em] font-semibold uppercase">ETERNO</span>
        <span class="w-16 h-[1px] bg-[#D4A373]/20"></span>
        <span class="text-[10px] font-semibold text-[#1A1A1A]/30 tracking-[0.5em] uppercase">Architecture of Movement</span>
     </div>
     <p class="text-[10px] text-[#1A1A1A]/20 tracking-[0.8em] uppercase px-6">© 2024 ETERNO PILATES. ALL RIGHTS RESERVED BY DLAB.</p>
  </footer>

  <script>
    function toggleSculptModal() {
      const modal = document.getElementById('sculpt-modal');
      modal.classList.toggle('hidden');
      modal.classList.toggle('flex');
    }
  </script>

</div>
