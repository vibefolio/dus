  </section>

  <!-- ========== Reviews ========== -->
  <section id="reviews" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-14">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#7C3AED]/5 text-[#7C3AED] reveal" style="--delay: 0;">Reviews</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-snug mt-6 font-dm reveal" style="--delay: 1;">고객 리뷰</h2>
