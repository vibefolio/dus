<%# Ecommerce Template - MARKET (이커머스 종합) %>

<style>
  /* Supanova Design — Ecommerce Platform Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-dm { font-family: 'DM Sans', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 36px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .product-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .product-card:hover { transform: translateY(-8px); box-shadow: 0 25px 60px -15px rgba(124, 58, 237, 0.12); }
  .product-card:hover img { transform: scale(1.05); }

  .category-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .category-card:hover { transform: translateY(-4px); box-shadow: 0 15px 40px -10px rgba(124, 58, 237, 0.1); }
</style>

<div class="bg-white text-[#111827] font-sans selection:bg-[#7C3AED] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-4 bg-white/80 backdrop-blur-xl border-b border-[#7C3AED]/5">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-[#7C3AED] rounded-xl flex items-center justify-center">
          <i class="fas fa-shopping-basket text-white text-sm"></i>
        </div>
        <span class="font-dm text-xl font-extrabold tracking-tight">MARKET</span>
      </a>

      <div class="hidden md:flex gap-10 text-[11px] font-semibold uppercase tracking-[0.3em] text-[#111827]/30">
        <a href="#products" class="hover:text-[#7C3AED] transition">추천</a>
        <a href="#categories" class="hover:text-[#7C3AED] transition">카테고리</a>
        <a href="#reviews" class="hover:text-[#7C3AED] transition">리뷰</a>
        <a href="#shipping" class="hover:text-[#7C3AED] transition">배송</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-5 items-center shrink-0">
        <div class="relative hidden lg:block">
          <input type="text" placeholder="검색어를 입력하세요" class="bg-[#F3F4F6] rounded-full py-2.5 pl-10 pr-4 text-[12px] w-56 outline-none focus:ring-2 focus:ring-[#7C3AED]/20 transition">
          <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-[#111827]/20 text-xs"></i>
        </div>
        <button onclick="toggleEcommerceModal()" class="text-[#111827]/30 hover:text-[#7C3AED] transition" data-mobile-menu-copy="true"><i class="far fa-user text-lg"></i></button>
        <a href="#" class="relative text-[#111827]/30 hover:text-[#7C3AED] transition">
          <i class="fas fa-shopping-cart text-lg"></i>
          <span class="absolute -top-1 -right-2 w-4 h-4 bg-[#7C3AED] rounded-full text-white text-[9px] flex items-center justify-center font-bold">3</span>
        </a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-[#7C3AED]/5 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#A78BFA]/5 rounded-full blur-[100px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-3 bg-[#7C3AED]/5 rounded-full px-5 py-2 reveal" style="--delay: 0;">
          <i class="fas fa-fire text-[#7C3AED] text-sm"></i>
          <span class="text-[11px] font-bold tracking-[0.15em] uppercase text-[#7C3AED]">Spring Sale 최대 50% OFF</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-[4.5rem] font-extrabold leading-tight tracking-tight font-dm mobile-title reveal" style="--delay: 1;">
          당신이 찾는<br><span class="text-[#7C3AED]">모든 것.</span>
        </h1>

        <p class="text-[#111827]/40 text-base md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          패션, 뷰티, 전자기기, 리빙까지. MARKET에서 트렌디한 제품을 합리적인 가격에 만나보세요. 무료 배송은 기본입니다.
        </p>

        <div class="pt-2 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#products" class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-[#7C3AED] text-white font-bold text-[12px] tracking-[0.15em] uppercase hover:bg-[#6D28D9] rounded-2xl shadow-xl shadow-[#7C3AED]/20">
            쇼핑 시작 <i class="fas fa-arrow-right text-[10px]"></i>
          </a>
          <a href="#categories" class="inline-flex items-center justify-center px-10 py-4 border border-[#7C3AED]/15 text-[#7C3AED] font-semibold text-[12px] tracking-[0.15em] uppercase hover:bg-[#7C3AED]/5 rounded-2xl">
            카테고리
          </a>
        </div>

        <div class="flex items-center gap-6 pt-4 justify-center lg:justify-start reveal" style="--delay: 4;">
          <div class="flex items-center gap-2"><i class="fas fa-truck text-[#7C3AED]"></i><span class="text-[12px] text-[#111827]/40">무료 배송</span></div>
          <div class="flex items-center gap-2"><i class="fas fa-undo text-[#7C3AED]"></i><span class="text-[12px] text-[#111827]/40">무료 반품</span></div>
          <div class="flex items-center gap-2"><i class="fas fa-shield-alt text-[#7C3AED]"></i><span class="text-[12px] text-[#111827]/40">안전 결제</span></div>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <div class="bg-[#F3F4F6] rounded-2xl overflow-hidden"><img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=600" alt="상품 1" class="w-full aspect-square object-cover" loading="eager"></div>
            <div class="bg-[#F3F4F6] rounded-2xl overflow-hidden"><img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?q=80&w=600" alt="상품 2" class="w-full aspect-[4/3] object-cover" loading="eager"></div>
          </div>
          <div class="pt-8 space-y-4">
            <div class="bg-[#F3F4F6] rounded-2xl overflow-hidden"><img src="https://images.unsplash.com/photo-1526170375885-4d8ecf77b99f?q=80&w=600" alt="상품 3" class="w-full aspect-[4/3] object-cover" loading="eager"></div>
            <div class="bg-[#F3F4F6] rounded-2xl overflow-hidden"><img src="https://images.unsplash.com/photo-1572635196237-14b3f281503f?q=80&w=600" alt="상품 4" class="w-full aspect-square object-cover" loading="eager"></div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About ========== -->
  <section id="about" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8 text-center">
      <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#7C3AED]/5 text-[#7C3AED] reveal" style="--delay: 0;">Why MARKET</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-snug mt-6 font-dm reveal" style="--delay: 1;">
