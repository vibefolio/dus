        <a href="#" class="category-card bg-white rounded-2xl p-6 text-center border border-[#7C3AED]/5 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#7C3AED]/10 rounded-2xl flex items-center justify-center mx-auto mb-3"><i class="fas fa-couch text-[#7C3AED] text-xl"></i></div>
