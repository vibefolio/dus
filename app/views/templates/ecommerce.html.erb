            <div class="flex items-center gap-2 mt-2">
              <span class="text-[#7C3AED] font-bold text-sm font-dm">139,000원</span>
              <span class="text-[#111827]/20 text-[12px] line-through">199,000원</span>
            </div>
            <div class="flex items-center gap-1 mt-2"><div class="flex gap-0.5 text-yellow-400"><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i></div><span class="text-[10px] text-[#111827]/30">(324)</span></div>
          </div>
        </div>

        <div class="product-card bg-white rounded-2xl overflow-hidden border border-[#7C3AED]/5 reveal" style="--delay: 1;">
          <div class="overflow-hidden bg-[#F3F4F6] relative">
            <img src="https://images.unsplash.com/photo-1585386959984-a4155224a1ad?q=80&w=600" alt="향수" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
            <span class="absolute top-3 left-3 bg-[#EF4444] text-white text-[10px] font-bold px-2.5 py-1 rounded-full">HOT</span>
          </div>
          <div class="p-4">
            <p class="text-[10px] text-[#7C3AED] font-bold uppercase tracking-wider">뷰티</p>
            <h3 class="font-semibold text-sm mt-1">시그니처 향수 50ml</h3>
            <div class="flex items-center gap-2 mt-2"><span class="text-[#7C3AED] font-bold text-sm font-dm">89,000원</span></div>
            <div class="flex items-center gap-1 mt-2"><div class="flex gap-0.5 text-yellow-400"><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star-half-alt text-[9px]"></i></div><span class="text-[10px] text-[#111827]/30">(189)</span></div>
          </div>
        </div>

        <div class="product-card bg-white rounded-2xl overflow-hidden border border-[#7C3AED]/5 reveal" style="--delay: 2;">
          <div class="overflow-hidden bg-[#F3F4F6] relative">
            <img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?q=80&w=600" alt="운동화" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
            <span class="absolute top-3 left-3 bg-[#7C3AED] text-white text-[10px] font-bold px-2.5 py-1 rounded-full">-20%</span>
          </div>
          <div class="p-4">
            <p class="text-[10px] text-[#7C3AED] font-bold uppercase tracking-wider">패션</p>
            <h3 class="font-semibold text-sm mt-1">클래식 러닝 스니커즈</h3>
            <div class="flex items-center gap-2 mt-2"><span class="text-[#7C3AED] font-bold text-sm font-dm">119,000원</span><span class="text-[#111827]/20 text-[12px] line-through">149,000원</span></div>
            <div class="flex items-center gap-1 mt-2"><div class="flex gap-0.5 text-yellow-400"><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i></div><span class="text-[10px] text-[#111827]/30">(567)</span></div>
          </div>
        </div>

        <div class="product-card bg-white rounded-2xl overflow-hidden border border-[#7C3AED]/5 reveal" style="--delay: 3;">
          <div class="overflow-hidden bg-[#F3F4F6] relative">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=600" alt="무선 이어폰" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-4">
            <p class="text-[10px] text-[#7C3AED] font-bold uppercase tracking-wider">전자기기</p>
            <h3 class="font-semibold text-sm mt-1">프리미엄 무선 이어폰</h3>
            <div class="flex items-center gap-2 mt-2"><span class="text-[#7C3AED] font-bold text-sm font-dm">249,000원</span></div>
            <div class="flex items-center gap-1 mt-2"><div class="flex gap-0.5 text-yellow-400"><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i><i class="fas fa-star text-[9px]"></i></div><span class="text-[10px] text-[#111827]/30">(891)</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Categories ========== -->
  <section id="categories" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-14">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#7C3AED]/5 text-[#7C3AED] reveal" style="--delay: 0;">Categories</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-snug mt-6 font-dm reveal" style="--delay: 1;">카테고리</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        <a href="#" class="category-card bg-white rounded-2xl p-6 text-center border border-[#7C3AED]/5 reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#7C3AED]/10 rounded-2xl flex items-center justify-center mx-auto mb-3"><i class="fas fa-tshirt text-[#7C3AED] text-xl"></i></div>
          <p class="font-semibold text-sm">패션</p>
          <p class="text-[11px] text-[#111827]/30 mt-1">2,400+ 상품</p>
        </a>
        <a href="#" class="category-card bg-white rounded-2xl p-6 text-center border border-[#7C3AED]/5 reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#7C3AED]/10 rounded-2xl flex items-center justify-center mx-auto mb-3"><i class="fas fa-spa text-[#7C3AED] text-xl"></i></div>
          <p class="font-semibold text-sm">뷰티</p>
          <p class="text-[11px] text-[#111827]/30 mt-1">1,800+ 상품</p>
        </a>
        <a href="#" class="category-card bg-white rounded-2xl p-6 text-center border border-[#7C3AED]/5 reveal" style="--delay: 2;">
          <div class="w-14 h-14 bg-[#7C3AED]/10 rounded-2xl flex items-center justify-center mx-auto mb-3"><i class="fas fa-laptop text-[#7C3AED] text-xl"></i></div>
          <p class="font-semibold text-sm">전자기기</p>
          <p class="text-[11px] text-[#111827]/30 mt-1">950+ 상품</p>
