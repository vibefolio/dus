<%# Wedding Template - ETERNAL %>

<style>
  /* Supanova Design — Elegant Wedding Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }
  .font-serif { font-family: 'Cormorant Garamond', serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 36px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .pkg-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .pkg-card:hover { transform: translateY(-8px); }
  .pkg-card:hover img { transform: scale(1.05); }

  .gallery-item { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .gallery-item:hover img { transform: scale(1.08); }
</style>

<div class="bg-[#FDF8F4] text-[#3D2E1C] font-sans selection:bg-[#B08968] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#FDF8F4]/80 backdrop-blur-xl border-b border-[#B08968]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="font-serif text-3xl tracking-tight font-semibold italic text-[#B08968]">Eternal</a>

      <div class="hidden md:flex gap-10 text-sm font-medium text-[#3D2E1C]/40 tracking-wide">
        <a href="#packages" class="hover:text-[#B08968] transition">패키지</a>
        <a href="#gallery" class="hover:text-[#B08968] transition">갤러리</a>
        <a href="#process" class="hover:text-[#B08968] transition">진행과정</a>
        <a href="#consultation" class="hover:text-[#B08968] transition">상담예약</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="#consultation" class="bg-[#B08968] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#96724E] shadow-lg shadow-[#B08968]/20" data-mobile-menu-copy="true">상담 예약</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=1600" alt="웨딩" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-[#FDF8F4]/70"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 md:px-8 relative z-10 text-center py-20">
      <p class="font-serif italic text-[#B08968] text-lg md:text-xl tracking-wide reveal" style="--delay: 0;">Your Forever Begins Here</p>

      <h1 class="text-5xl md:text-6xl lg:text-8xl font-serif font-semibold leading-tight mt-6 mobile-title reveal" style="--delay: 1;">
        영원한 순간을<br>
        <span class="italic text-[#B08968]">함께 만듭니다</span>
      </h1>

      <p class="text-[#3D2E1C]/50 text-base md:text-lg leading-relaxed max-w-lg mx-auto mt-8 mobile-desc reveal" style="--delay: 2;">
        두 사람의 특별한 이야기를 담아 세상에 하나뿐인 웨딩을 완성합니다. ETERNAL이 당신의 가장 아름다운 날을 디자인합니다.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 reveal" style="--delay: 3;">
        <a href="#consultation" class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-[#B08968] text-white rounded-full font-semibold shadow-lg shadow-[#B08968]/20 hover:bg-[#96724E]">
          무료 상담 예약
        </a>
        <a href="#gallery" class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-[#B08968]/30 rounded-full font-semibold text-[#B08968] hover:bg-[#B08968] hover:text-white">
          갤러리 보기
        </a>
      </div>
    </div>
  </header>

  <!-- ========== 패키지 ========== -->
  <section id="packages" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="font-serif italic text-[#B08968] text-lg reveal" style="--delay: 0;">Packages</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">웨딩 패키지</h2>
        <p class="text-[#3D2E1C]/40 text-base mt-4 max-w-lg mx-auto reveal" style="--delay: 2;">두 분의 스타일과 예산에 맞는 맞춤 패키지를 준비했습니다</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="pkg-card group reveal" style="--delay: 0;">
          <div class="overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?q=80&w=600" alt="클래식 패키지" class="w-full aspect-[3/4] object-cover transition duration-700" loading="lazy">
          </div>
          <div class="mt-5">
            <span class="font-serif italic text-[#B08968] text-sm">Classic</span>
            <h3 class="text-lg font-bold mt-1">클래식 웨딩</h3>
            <p class="text-sm text-[#3D2E1C]/40 mt-2 leading-relaxed">전통적인 아름다움을 담은 클래식한 웨딩 패키지.</p>
            <p class="text-[#B08968] font-bold mt-3">350만원~</p>
          </div>
        </div>

        <div class="pkg-card group reveal" style="--delay: 1;">
          <div class="overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=600" alt="모던 패키지" class="w-full aspect-[3/4] object-cover transition duration-700" loading="lazy">
          </div>
          <div class="mt-5">
            <span class="font-serif italic text-[#B08968] text-sm">Modern</span>
            <h3 class="text-lg font-bold mt-1">모던 웨딩</h3>
            <p class="text-sm text-[#3D2E1C]/40 mt-2 leading-relaxed">세련되고 현대적인 감각의 모던 웨딩 패키지.</p>
            <p class="text-[#B08968] font-bold mt-3">500만원~</p>
          </div>
        </div>

        <div class="pkg-card group reveal" style="--delay: 2;">
          <div class="overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf?q=80&w=600" alt="가든 패키지" class="w-full aspect-[3/4] object-cover transition duration-700" loading="lazy">
          </div>
          <div class="mt-5">
            <span class="font-serif italic text-[#B08968] text-sm">Garden</span>
            <h3 class="text-lg font-bold mt-1">가든 웨딩</h3>
            <p class="text-sm text-[#3D2E1C]/40 mt-2 leading-relaxed">자연 속에서 펼쳐지는 로맨틱한 야외 웨딩.</p>
            <p class="text-[#B08968] font-bold mt-3">700만원~</p>
          </div>
        </div>

        <div class="pkg-card group reveal" style="--delay: 3;">
          <div class="overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1546032996-6dfacbacbf3f?q=80&w=600" alt="프리미엄 패키지" class="w-full aspect-[3/4] object-cover transition duration-700" loading="lazy">
          </div>
          <div class="mt-5">
            <span class="font-serif italic text-[#B08968] text-sm">Premium</span>
            <h3 class="text-lg font-bold mt-1">프리미엄 웨딩</h3>
            <p class="text-sm text-[#3D2E1C]/40 mt-2 leading-relaxed">모든 것을 맞춤 제작하는 올인원 프리미엄 웨딩.</p>
            <p class="text-[#B08968] font-bold mt-3">1,200만원~</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 갤러리 ========== -->
  <section id="gallery" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="font-serif italic text-[#B08968] text-lg reveal" style="--delay: 0;">Gallery</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">웨딩 갤러리</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div class="gallery-item overflow-hidden rounded-2xl reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=800" alt="웨딩 1" class="w-full aspect-square object-cover transition duration-700" loading="lazy">
        </div>
        <div class="gallery-item overflow-hidden rounded-2xl md:row-span-2 reveal" style="--delay: 1;">
          <img src="https://images.unsplash.com/photo-1591604466107-ec97de577aff?q=80&w=800" alt="웨딩 2" class="w-full h-full object-cover transition duration-700" loading="lazy">
        </div>
        <div class="gallery-item overflow-hidden rounded-2xl reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?q=80&w=800" alt="웨딩 3" class="w-full aspect-square object-cover transition duration-700" loading="lazy">
        </div>
        <div class="gallery-item overflow-hidden rounded-2xl reveal" style="--delay: 3;">
          <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=800" alt="웨딩 4" class="w-full aspect-square object-cover transition duration-700" loading="lazy">
        </div>
        <div class="gallery-item overflow-hidden rounded-2xl col-span-2 md:col-span-1 reveal" style="--delay: 4;">
          <img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf?q=80&w=800" alt="웨딩 5" class="w-full aspect-[2/1] md:aspect-square object-cover transition duration-700" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 진행과정 ========== -->
  <section id="process" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="font-serif italic text-[#B08968] text-lg reveal" style="--delay: 0;">Process</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">웨딩 진행 과정</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-8 max-w-5xl mx-auto">
        <div class="text-center reveal" style="--delay: 0;">
          <div class="w-16 h-16 bg-[#B08968] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="font-serif text-white text-2xl font-semibold italic">01</span>
          </div>
          <h3 class="font-bold mb-2">상담</h3>
          <p class="text-sm text-[#3D2E1C]/40">1:1 맞춤 상담으로 두 분의 이야기를 듣습니다.</p>
        </div>
        <div class="text-center reveal" style="--delay: 1;">
          <div class="w-16 h-16 bg-[#B08968] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="font-serif text-white text-2xl font-semibold italic">02</span>
          </div>
          <h3 class="font-bold mb-2">기획</h3>
          <p class="text-sm text-[#3D2E1C]/40">컨셉, 플라워, 공간 디자인을 기획합니다.</p>
        </div>
        <div class="text-center reveal" style="--delay: 2;">
          <div class="w-16 h-16 bg-[#B08968] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="font-serif text-white text-2xl font-semibold italic">03</span>
          </div>
          <h3 class="font-bold mb-2">준비</h3>
          <p class="text-sm text-[#3D2E1C]/40">드레스, 메이크업, 촬영 등 세부 준비를 진행합니다.</p>
        </div>
        <div class="text-center reveal" style="--delay: 3;">
          <div class="w-16 h-16 bg-[#B08968] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="font-serif text-white text-2xl font-semibold italic">04</span>
          </div>
          <h3 class="font-bold mb-2">당일</h3>
          <p class="text-sm text-[#3D2E1C]/40">전담 코디네이터가 당일 모든 진행을 담당합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 후기 ========== -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="font-serif italic text-[#B08968] text-lg reveal" style="--delay: 0;">Reviews</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">신랑신부 후기</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="bg-[#FDF8F4] p-8 rounded-2xl reveal" style="--delay: 0;">
          <div class="flex items-center gap-1 text-[#B08968] mb-4">
            <i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i>
          </div>
          <p class="text-sm text-[#3D2E1C]/60 leading-relaxed italic">"상상 이상의 웨딩이었어요. 모든 디테일이 완벽했고, 코디네이터분이 너무 잘 챙겨주셨어요."</p>
          <p class="text-sm font-bold mt-4">김OO & 이OO 부부</p>
          <p class="text-xs text-[#3D2E1C]/30">2024년 5월 가든 웨딩</p>
        </div>

        <div class="bg-[#FDF8F4] p-8 rounded-2xl reveal" style="--delay: 1;">
          <div class="flex items-center gap-1 text-[#B08968] mb-4">
            <i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i>
          </div>
          <p class="text-sm text-[#3D2E1C]/60 leading-relaxed italic">"플라워 데코레이션이 정말 아름다웠어요. 하객분들 모두 감탄하셨습니다."</p>
          <p class="text-sm font-bold mt-4">박OO & 최OO 부부</p>
          <p class="text-xs text-[#3D2E1C]/30">2024년 3월 클래식 웨딩</p>
        </div>

        <div class="bg-[#FDF8F4] p-8 rounded-2xl reveal" style="--delay: 2;">
          <div class="flex items-center gap-1 text-[#B08968] mb-4">
            <i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i>
          </div>
          <p class="text-sm text-[#3D2E1C]/60 leading-relaxed italic">"준비부터 당일까지 정말 편안하게 진행할 수 있었어요. 강력 추천합니다!"</p>
          <p class="text-sm font-bold mt-4">정OO & 한OO 부부</p>
          <p class="text-xs text-[#3D2E1C]/30">2024년 10월 프리미엄 웨딩</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 숫자로 보는 ETERNAL ========== -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="font-serif italic text-[#B08968] text-lg reveal" style="--delay: 0;">Numbers</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">숫자로 보는 ETERNAL</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto">
        <div class="text-center reveal" style="--delay: 0;">
          <p class="text-4xl md:text-5xl font-bold text-[#B08968]">1,200+</p>
          <p class="text-sm text-[#3D2E1C]/40 mt-2">웨딩 진행</p>
        </div>
        <div class="text-center reveal" style="--delay: 1;">
          <p class="text-4xl md:text-5xl font-bold text-[#B08968]">8년</p>
          <p class="text-sm text-[#3D2E1C]/40 mt-2">업계 경험</p>
        </div>
        <div class="text-center reveal" style="--delay: 2;">
          <p class="text-4xl md:text-5xl font-bold text-[#B08968]">4.9</p>
          <p class="text-sm text-[#3D2E1C]/40 mt-2">평균 평점</p>
        </div>
        <div class="text-center reveal" style="--delay: 3;">
          <p class="text-4xl md:text-5xl font-bold text-[#B08968]">15명</p>
          <p class="text-sm text-[#3D2E1C]/40 mt-2">전문 스태프</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 상담예약 ========== -->
  <section id="consultation" class="py-24 md:py-32 bg-gradient-to-br from-[#B08968] to-[#96724E] text-white relative overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full blur-[100px]"></div>

    <div class="max-w-4xl mx-auto px-4 md:px-8 relative z-10">
      <div class="text-center mb-12">
        <p class="font-serif italic text-white/70 text-lg reveal" style="--delay: 0;">Consultation</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">무료 상담 예약</h2>
        <p class="text-white/60 text-base mt-4 reveal" style="--delay: 2;">두 분의 특별한 날을 함께 준비하겠습니다</p>
      </div>

      <div class="bg-white/10 backdrop-blur-xl rounded-3xl p-8 md:p-12 reveal" style="--delay: 3;">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">신랑 이름</label>
            <input type="text" placeholder="홍길동" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">신부 이름</label>
            <input type="text" placeholder="김영희" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">연락처</label>
            <input type="tel" placeholder="010-0000-0000" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">예식 예정일</label>
            <input type="date" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white outline-none focus:border-white/60 transition">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-white/80 mb-2">원하시는 웨딩 스타일</label>
            <textarea rows="3" placeholder="원하시는 컨셉이나 분위기를 알려주세요" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition resize-none"></textarea>
          </div>
        </div>
        <button class="w-full mt-8 bg-white text-[#B08968] py-4 rounded-full font-bold text-lg hover:bg-[#FDF8F4] shadow-lg">상담 신청하기</button>
      </div>
    </div>
  </section>

