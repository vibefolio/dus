<%# Pension Template — 솔바람 펜션 %>

<style>
  /* Supanova Design — Forest Fresh Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-serif { font-family: 'Nanum Myeongjo', serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 34px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  .pension-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .pension-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(46, 125, 91, 0.1); }
  .pension-card:hover img { transform: scale(1.05); }

  .facility-card { transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .facility-card:hover { transform: translateY(-4px); background-color: #2E7D5B; color: white; }
  .facility-card:hover .fc-icon { color: white; }
  .facility-card:hover .fc-desc { color: rgba(255,255,255,0.7); }
</style>

<div class="bg-[#F0F7F4] text-[#1A1A1A] font-sans selection:bg-[#2E7D5B] selection:text-white min-h-screen overflow-x-hidden relative">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#F0F7F4]/85 backdrop-blur-xl border-b border-[#2E7D5B]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="text-[#2E7D5B] text-2xl"><i class="fas fa-tree"></i></span>
        <span class="font-serif text-xl md:text-2xl font-bold text-[#1A1A1A]">솔바람 펜션</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1A1A1A]/30">
        <a href="#rooms" class="hover:text-[#2E7D5B] transition">객실</a>
        <a href="#facilities" class="hover:text-[#2E7D5B] transition">시설</a>
        <a href="#around" class="hover:text-[#2E7D5B] transition">주변</a>
        <a href="#directions" class="hover:text-[#2E7D5B] transition">오시는 길</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none text-[#1A1A1A]">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="togglePensionModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1A1A1A]/30 hover:text-[#2E7D5B]" data-mobile-menu-copy="true">문의</button>
        <a href="#booking" class="bg-[#2E7D5B] text-white px-8 py-3.5 rounded-full font-semibold text-[10px] tracking-[0.3em] uppercase hover:bg-[#1A1A1A] transition shadow-lg shadow-[#2E7D5B]/20" data-mobile-menu-copy="true">
          예약하기
        </a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== 1. Hero ========== -->
  <header class="min-h-screen relative flex items-end pb-20 md:pb-32">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?q=80&w=2000&auto=format" alt="솔바람 펜션" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A] via-[#1A1A1A]/40 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 w-full">
      <div class="max-w-2xl space-y-8">
        <div class="reveal inline-flex items-center gap-4">
          <span class="w-8 h-8 rounded-full bg-[#2E7D5B] flex items-center justify-center text-white text-xs"><i class="fas fa-leaf"></i></span>
          <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-white/60">Healing Pension in Gangwon</span>
        </div>

        <h1 class="reveal text-4xl md:text-7xl font-serif font-bold leading-[1.1] text-white mobile-title" style="--delay:1">
          솔향 가득한<br>
          <span class="text-[#7BC9A3]">자연 속 쉼터.</span>
        </h1>

        <p class="reveal text-white/50 text-sm md:text-lg leading-[2] max-w-lg mobile-desc" style="--delay:2">
          강원도 홍천의 깊은 숲속, 솔바람 펜션에서<br class="hidden md:block">
          사계절의 아름다움과 함께 특별한 힐링을 경험하세요.
        </p>

        <div class="reveal flex flex-wrap gap-4 pt-4" style="--delay:3">
          <a href="#rooms" class="bg-[#2E7D5B] text-white px-8 py-4 rounded-full font-semibold text-[11px] tracking-[0.2em] hover:bg-white hover:text-[#1A1A1A] transition">
            객실 둘러보기
          </a>
          <a href="#booking" class="border border-white/30 text-white px-8 py-4 rounded-full font-semibold text-[11px] tracking-[0.2em] hover:bg-white/10 transition">
            빈 객실 확인
          </a>
        </div>
      </div>

      <!-- Quick info -->
      <div class="reveal mt-16 grid grid-cols-2 md:grid-cols-4 gap-4" style="--delay:4">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 text-center">
          <span class="text-[#7BC9A3] text-xl"><i class="fas fa-home"></i></span>
          <p class="text-white text-sm font-semibold mt-2">독채 펜션</p>
          <p class="text-white/40 text-[10px] mt-1">프라이빗 공간</p>
        </div>
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 text-center">
          <span class="text-[#7BC9A3] text-xl"><i class="fas fa-fire"></i></span>
          <p class="text-white text-sm font-semibold mt-2">바베큐장</p>
          <p class="text-white/40 text-[10px] mt-1">각 동 전용</p>
        </div>
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 text-center">
          <span class="text-[#7BC9A3] text-xl"><i class="fas fa-water"></i></span>
          <p class="text-white text-sm font-semibold mt-2">계곡 인접</p>
          <p class="text-white/40 text-[10px] mt-1">도보 3분</p>
        </div>
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 text-center">
          <span class="text-[#7BC9A3] text-xl"><i class="fas fa-parking"></i></span>
          <p class="text-white text-sm font-semibold mt-2">무료 주차</p>
          <p class="text-white/40 text-[10px] mt-1">동별 1대</p>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 2. 객실 소개 (4종) ========== -->
  <section id="rooms" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#2E7D5B]">Rooms</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold mt-4">자연을 닮은 네 개의 공간</h2>
        <p class="text-[#1A1A1A]/40 text-sm mt-4 max-w-lg mx-auto">모든 객실은 독립된 독채형 펜션으로, 전용 바베큐장과 주차장을 제공합니다.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- 소나무 (2인) -->
        <div class="pension-card bg-white rounded-3xl overflow-hidden shadow-sm reveal" style="--delay:0">
          <div class="aspect-[16/10] overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1595576508898-0ad5c879a061?q=80&w=1000&auto=format" alt="소나무 객실" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute top-4 left-4 bg-[#2E7D5B] text-white px-4 py-1.5 rounded-full text-[10px] font-semibold">커플 추천</div>
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-serif text-xl font-bold">소나무</h3>
                <p class="text-[#1A1A1A]/40 text-sm mt-2 leading-relaxed">
                  20m² · 원룸형 · 킹베드 · 최대 2인<br>
                  아늑한 커플 전용 공간. 테라스에서 숲을 바라보며.
                </p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="font-serif text-xl font-bold text-[#2E7D5B]">₩80,000</span>
                <span class="block text-[10px] text-[#1A1A1A]/30">비수기 기준</span>
              </div>
            </div>
            <div class="flex gap-3 mt-6 flex-wrap">
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">바베큐</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">에어컨</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">취사 가능</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">와이파이</span>
            </div>
          </div>
        </div>

        <!-- 자작나무 (4인) -->
        <div class="pension-card bg-white rounded-3xl overflow-hidden shadow-sm reveal" style="--delay:1">
          <div class="aspect-[16/10] overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?q=80&w=1000&auto=format" alt="자작나무 객실" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute top-4 left-4 bg-[#E8A317] text-white px-4 py-1.5 rounded-full text-[10px] font-semibold">인기 객실</div>
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-serif text-xl font-bold">자작나무</h3>
                <p class="text-[#1A1A1A]/40 text-sm mt-2 leading-relaxed">
                  36m² · 투룸형 · 퀸+싱글2 · 최대 4인<br>
                  가족 여행에 딱 맞는 넉넉한 공간과 넓은 거실.
                </p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="font-serif text-xl font-bold text-[#2E7D5B]">₩150,000</span>
                <span class="block text-[10px] text-[#1A1A1A]/30">비수기 기준</span>
              </div>
            </div>
            <div class="flex gap-3 mt-6 flex-wrap">
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">바베큐</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">복층</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">취사 가능</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">TV</span>
            </div>
          </div>
        </div>

        <!-- 참나무 (6인) -->
        <div class="pension-card bg-white rounded-3xl overflow-hidden shadow-sm reveal" style="--delay:2">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?q=80&w=1000&auto=format" alt="참나무 객실" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-serif text-xl font-bold">참나무</h3>
                <p class="text-[#1A1A1A]/40 text-sm mt-2 leading-relaxed">
                  48m² · 투룸형 · 퀸2+싱글2 · 최대 6인<br>
                  단체 모임과 소규모 워크숍에 적합한 넓은 펜션.
                </p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="font-serif text-xl font-bold text-[#2E7D5B]">₩220,000</span>
                <span class="block text-[10px] text-[#1A1A1A]/30">비수기 기준</span>
              </div>
            </div>
            <div class="flex gap-3 mt-6 flex-wrap">
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">바베큐</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">노래방</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">프로젝터</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">대형 주방</span>
            </div>
          </div>
        </div>

        <!-- 전나무 특실 (8인) -->
        <div class="pension-card bg-white rounded-3xl overflow-hidden shadow-sm reveal" style="--delay:3">
          <div class="aspect-[16/10] overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?q=80&w=1000&auto=format" alt="전나무 특실" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute top-4 left-4 bg-[#1A1A1A] text-white px-4 py-1.5 rounded-full text-[10px] font-semibold">프리미엄</div>
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-serif text-xl font-bold">전나무 특실</h3>
                <p class="text-[#1A1A1A]/40 text-sm mt-2 leading-relaxed">
                  66m² · 쓰리룸형 · 퀸3+싱글2 · 최대 8인<br>
                  프라이빗 스파와 넓은 데크가 있는 프리미엄 독채.
                </p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="font-serif text-xl font-bold text-[#2E7D5B]">₩350,000</span>
                <span class="block text-[10px] text-[#1A1A1A]/30">비수기 기준</span>
              </div>
            </div>
            <div class="flex gap-3 mt-6 flex-wrap">
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">스파</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">대형 데크</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">노래방</span>
              <span class="px-3 py-1 bg-[#F0F7F4] text-[#2E7D5B] rounded-full text-[10px]">2면 창</span>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-12 bg-white rounded-2xl p-6 md:p-8 text-center reveal">
        <p class="text-sm text-[#1A1A1A]/50">
          <i class="fas fa-info-circle text-[#2E7D5B] mr-2"></i>
          성수기(7~8월, 연말) 요금은 비수기 대비 30~50% 할증됩니다. 정확한 요금은 예약 시 확인해주세요.
        </p>
      </div>
    </div>
  </section>

  <!-- ========== 3. 바베큐/시설 안내 ========== -->
  <section id="facilities" class="py-24 md:py-40 px-6 md:px-10 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#2E7D5B]">Facilities</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold mt-4">펜션 시설 안내</h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center mb-20">
        <div class="reveal">
          <div class="aspect-[4/3] rounded-3xl overflow-hidden">
            <img src="https://images.unsplash.com/photo-1529926078117-673cb35a1300?q=80&w=1200&auto=format" alt="바베큐장" class="w-full h-full object-cover">
          </div>
        </div>
        <div class="space-y-8 reveal" style="--delay:1">
          <div class="inline-flex items-center gap-4">
            <span class="w-10 h-[1px] bg-[#2E7D5B]"></span>
            <span class="text-[10px] font-semibold tracking-[0.5em] uppercase text-[#2E7D5B]">BBQ Zone</span>
          </div>
          <h3 class="font-serif text-2xl md:text-3xl font-bold">별빛 아래 바베큐</h3>
          <p class="text-[#1A1A1A]/50 text-sm leading-[2] mobile-desc">
            각 객실 전용 바베큐장에서 신선한 숯불 바베큐를 즐기세요.
            그릴, 숯, 집게 등 기본 장비를 무료로 제공하며,
            식재료 세트도 사전 주문이 가능합니다.
          </p>
          <div class="space-y-3">
            <div class="flex items-center gap-3 text-sm text-[#1A1A1A]/60">
              <i class="fas fa-check text-[#2E7D5B]"></i>
              <span>숯불 그릴 + 기본 도구 무료 제공</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-[#1A1A1A]/60">
              <i class="fas fa-check text-[#2E7D5B]"></i>
              <span>한우 세트 / 삼겹살 세트 사전 주문 가능</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-[#1A1A1A]/60">
              <i class="fas fa-check text-[#2E7D5B]"></i>
              <span>조명이 설치된 야외 테이블 + 의자</span>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <div class="facility-card bg-[#F0F7F4] rounded-2xl p-6 md:p-8 text-center reveal" style="--delay:0">
          <span class="fc-icon text-3xl text-[#2E7D5B] transition"><i class="fas fa-hot-tub"></i></span>
          <h4 class="font-semibold mt-4 text-sm">스파/족욕</h4>
          <p class="fc-desc text-[#1A1A1A]/40 text-xs mt-2 transition">전나무 특실 전용</p>
        </div>
        <div class="facility-card bg-[#F0F7F4] rounded-2xl p-6 md:p-8 text-center reveal" style="--delay:1">
          <span class="fc-icon text-3xl text-[#2E7D5B] transition"><i class="fas fa-child"></i></span>
          <h4 class="font-semibold mt-4 text-sm">놀이터</h4>
          <p class="fc-desc text-[#1A1A1A]/40 text-xs mt-2 transition">어린이 놀이시설</p>
        </div>
        <div class="facility-card bg-[#F0F7F4] rounded-2xl p-6 md:p-8 text-center reveal" style="--delay:2">
          <span class="fc-icon text-3xl text-[#2E7D5B] transition"><i class="fas fa-swimmer"></i></span>
          <h4 class="font-semibold mt-4 text-sm">계곡 물놀이</h4>
          <p class="fc-desc text-[#1A1A1A]/40 text-xs mt-2 transition">도보 3분 거리</p>
        </div>
        <div class="facility-card bg-[#F0F7F4] rounded-2xl p-6 md:p-8 text-center reveal" style="--delay:3">
          <span class="fc-icon text-3xl text-[#2E7D5B] transition"><i class="fas fa-campground"></i></span>
          <h4 class="font-semibold mt-4 text-sm">캠프파이어</h4>
