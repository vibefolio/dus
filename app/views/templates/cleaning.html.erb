    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-9 h-9 bg-[#0284C7] rounded-lg flex items-center justify-center">
          <i class="fas fa-sparkles text-white text-sm"></i>
        </div>
        <span class="font-bold text-xl">클린<span class="text-[#0284C7]">홈</span></span>
      </a>

      <div class="hidden md:flex gap-10 text-sm font-medium text-slate-400">
        <a href="#services" class="hover:text-[#0284C7] transition">서비스</a>
        <a href="#pricing" class="hover:text-[#0284C7] transition">가격표</a>
        <a href="#process" class="hover:text-[#0284C7] transition">진행과정</a>
        <a href="#reservation" class="hover:text-[#0284C7] transition">예약</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="tel:1588-1234" class="text-sm font-medium text-slate-500 hover:text-[#0284C7]"><i class="fas fa-phone mr-1"></i> 1588-1234</a>
        <a href="#reservation" class="bg-[#0284C7] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#0369A1] shadow-lg shadow-[#0284C7]/20" data-mobile-menu-copy="true">견적 요청</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-white via-[#F0F9FF] to-[#E0F2FE]"></div>
    <div class="absolute top-40 left-0 w-[500px] h-[500px] bg-[#0284C7]/5 rounded-full blur-[120px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 items-center w-full">
