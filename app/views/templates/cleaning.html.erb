          <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?q=80&w=800&auto=format&fit=crop" alt="청소 디테일" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async">
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=800&auto=format&fit=crop" alt="깨끗한 공간" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

