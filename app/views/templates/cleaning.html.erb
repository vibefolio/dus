        <div class="flex items-center gap-8 justify-center lg:justify-start pt-4 reveal" style="--delay: 4;">
          <div class="text-center">
            <p class="text-2xl font-bold text-[#0284C7]">10,000+</p>
            <p class="text-xs text-slate-400 mt-1">서비스 완료</p>
