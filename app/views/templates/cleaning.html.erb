          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white p-5 rounded-xl border border-[#0284C7]/10">
              <p class="text-2xl font-bold text-[#0284C7]">100+</p>
              <p class="text-xs text-slate-400 mt-1">전문 매니저</p>
            </div>
            <div class="bg-white p-5 rounded-xl border border-[#0284C7]/10">
              <p class="text-2xl font-bold text-[#0284C7]">100시간</p>
              <p class="text-xs text-slate-400 mt-1">교육 이수</p>
            </div>
          </div>
        </div>
      </div>
    </div>
