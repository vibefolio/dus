<%# OluOlu Franchise Template - 올루올루 프랜차이즈 (OLU OLU) %>

<style>
  /* Supanova Design — Franchise HQ Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 42px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  .benefit-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .benefit-card:hover { transform: translateY(-8px); }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .warm-pattern {
    background-image: url("https://www.transparenttextures.com/patterns/cream-paper.png");
    opacity: 0.3;
  }
</style>

<div class="bg-[#FFFBEB] text-[#1F2937] font-sans selection:bg-[#D97706] selection:text-white min-h-screen overflow-x-hidden relative">
  <div class="fixed inset-0 warm-pattern pointer-events-none z-[60]"></div>

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#FFFBEB]/80 backdrop-blur-xl border-b border-[#D97706]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="font-jakarta text-2xl tracking-tight font-extrabold text-[#D97706]">OLU OLU</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1F2937]/40">
        <a href="#about" class="hover:text-[#D97706] transition">브랜드</a>
        <a href="#benefits" class="hover:text-[#D97706] transition">혜택</a>
        <a href="#revenue" class="hover:text-[#D97706] transition">매출</a>
        <a href="#process" class="hover:text-[#D97706] transition">프로세스</a>
        <a href="#consult" class="hover:text-[#D97706] transition">상담</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleFranchiseModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1F2937]/40 hover:text-[#D97706]" data-mobile-menu-copy="true">Login</button>
        <button class="bg-[#D97706] text-white px-8 py-3.5 rounded-full font-bold text-[10px] tracking-[0.3em] uppercase hover:bg-[#B45309] transition shadow-lg shadow-[#D97706]/20" data-mobile-menu-copy="true">
          가맹 상담
        </button>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center justify-center pt-20">
    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-10 text-center lg:text-left">
        <div class="inline-flex items-center gap-5 reveal" style="--delay: 0;">
          <span class="w-10 h-[1px] bg-[#D97706]"></span>
          <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#D97706]">Franchise HQ</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-[5.5rem] font-jakarta font-extrabold leading-tight tracking-tight text-[#1F2937] mobile-title reveal" style="--delay: 1;">
          함께 성장하는<br><span class="text-[#D97706]">올루올루.</span>
        </h1>

        <p class="text-[#1F2937]/50 text-sm md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          검증된 비즈니스 모델과 체계적인 본사 지원. 올루올루와 함께라면 성공적인 창업이 가능합니다. 전국 150개 매장의 노하우를 공유합니다.
        </p>

        <div class="pt-4 flex flex-col sm:flex-row gap-5 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#consult" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#D97706] text-white font-bold text-[11px] tracking-[0.3em] uppercase hover:bg-[#B45309] rounded-full shadow-xl shadow-[#D97706]/20">
            가맹 상담 신청
            <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center"><i class="fas fa-arrow-right text-[10px]"></i></span>
          </a>
          <a href="#benefits" class="inline-flex items-center justify-center px-10 py-5 border border-[#D97706]/30 text-[#D97706] font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-white rounded-full">
            가맹 혜택
          </a>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <div class="absolute -top-12 -right-12 w-72 h-72 bg-[#D97706]/10 rounded-full blur-[100px]"></div>
        <div class="relative group">
          <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?q=80&w=800&auto=format&fit=crop" alt="올루올루 매장" class="w-full aspect-[4/5] object-cover rounded-[3rem] shadow-2xl group-hover:shadow-[0_30px_80px_-20px_rgba(217,119,6,0.3)] transition-all duration-700" loading="eager" decoding="async">
          <div class="absolute -bottom-6 -left-6 md:-bottom-8 md:-left-8 bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-[#D97706]/10 max-w-[260px]" style="animation: float 6s ease-in-out infinite;">
            <p class="text-[10px] font-semibold text-[#D97706] uppercase tracking-[0.4em] mb-3">Nationwide</p>
            <p class="text-xl font-jakarta font-extrabold text-[#1F2937]">전국 150+ 매장</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About 브랜드 소개 ========== -->
  <section id="about" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative reveal" style="--delay: 0;">
        <div class="grid grid-cols-5 gap-4">
          <div class="col-span-3 overflow-hidden rounded-[2rem]">
            <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=800&auto=format&fit=crop" alt="매장 인테리어" class="w-full h-full object-cover aspect-[3/4]" loading="lazy" decoding="async">
          </div>
          <div class="col-span-2 flex flex-col gap-4">
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=800&auto=format&fit=crop" alt="음식 준비" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=800&auto=format&fit=crop" alt="프랜차이즈 교육" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-8 reveal" style="--delay: 1;">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#D97706]/10 text-[#D97706]">Brand Story</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-jakarta font-extrabold leading-snug text-[#1F2937]">
          10년의 노하우,<br>150개 매장의 성공
        </h2>
        <p class="text-[#1F2937]/50 text-base md:text-lg leading-relaxed">
          2016년 서울 강남 1호점을 시작으로 10년간 꾸준히 성장해온 올루올루. 독자적인 레시피와 체계적인 운영 시스템으로 전국 150개 매장 모두 안정적인 수익을 달성하고 있습니다.
        </p>

        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-[#D97706]/10">
          <div>
            <p class="text-2xl md:text-3xl font-jakarta font-extrabold text-[#D97706]">150+</p>
            <p class="text-[11px] text-[#1F2937]/40 uppercase tracking-[0.1em] mt-1 font-medium">전국 매장</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-jakarta font-extrabold text-[#D97706]">10yr</p>
            <p class="text-[11px] text-[#1F2937]/40 uppercase tracking-[0.1em] mt-1 font-medium">브랜드 역사</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-jakarta font-extrabold text-[#D97706]">92%</p>
            <p class="text-[11px] text-[#1F2937]/40 uppercase tracking-[0.1em] mt-1 font-medium">가맹 만족도</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Benefits 가맹 혜택 (4개) ========== -->
  <section id="benefits" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#D97706]/10 text-[#D97706] reveal" style="--delay: 0;">Benefits</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-jakarta font-extrabold leading-snug text-[#1F2937] mt-6 reveal" style="--delay: 1;">가맹점주를 위한 혜택</h2>
        <p class="text-[#1F2937]/40 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">올루올루 본사가 성공을 위해 준비한 4가지 핵심 지원.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="benefit-card bg-[#FFFBEB] rounded-[2rem] p-8 border border-[#D97706]/10 reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#D97706]/10 rounded-2xl flex items-center justify-center mb-6"><i class="fas fa-graduation-cap text-[#D97706] text-xl"></i></div>
          <h3 class="text-lg font-bold text-[#1F2937] mb-3">교육 시스템</h3>
          <p class="text-[#1F2937]/40 text-sm leading-relaxed">4주 집중 교육 + 개점 후 2주 현장 지원. 경험 없어도 전문가로 만들어드립니다.</p>
        </div>

        <div class="benefit-card bg-[#FFFBEB] rounded-[2rem] p-8 border border-[#D97706]/10 reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#D97706]/10 rounded-2xl flex items-center justify-center mb-6"><i class="fas fa-truck text-[#D97706] text-xl"></i></div>
          <h3 class="text-lg font-bold text-[#1F2937] mb-3">물류 지원</h3>
          <p class="text-[#1F2937]/40 text-sm leading-relaxed">전국 3곳의 물류센터에서 주 3회 신선 식자재를 직배송합니다.</p>
        </div>

        <div class="benefit-card bg-[#FFFBEB] rounded-[2rem] p-8 border border-[#D97706]/10 reveal" style="--delay: 2;">
          <div class="w-14 h-14 bg-[#D97706]/10 rounded-2xl flex items-center justify-center mb-6"><i class="fas fa-bullhorn text-[#D97706] text-xl"></i></div>
          <h3 class="text-lg font-bold text-[#1F2937] mb-3">마케팅 지원</h3>
          <p class="text-[#1F2937]/40 text-sm leading-relaxed">본사 주도 전국 광고 + 지역 맞춤 마케팅. SNS, 배달앱 운영까지 지원합니다.</p>
        </div>

        <div class="benefit-card bg-[#FFFBEB] rounded-[2rem] p-8 border border-[#D97706]/10 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#D97706]/10 rounded-2xl flex items-center justify-center mb-6"><i class="fas fa-tools text-[#D97706] text-xl"></i></div>
          <h3 class="text-lg font-bold text-[#1F2937] mb-3">인테리어 지원</h3>
          <p class="text-[#1F2937]/40 text-sm leading-relaxed">전문 시공팀이 입지 분석부터 인테리어까지 원스톱으로 진행합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Success Stories ========== -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#D97706]/10 text-[#D97706] reveal" style="--delay: 0;">Success</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-jakarta font-extrabold leading-snug text-[#1F2937] mt-6 reveal" style="--delay: 1;">가맹점주 성공 스토리</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="rounded-[2rem] overflow-hidden reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1556742111-a301076d9d18?q=80&w=800&auto=format&fit=crop" alt="성공적인 점주" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async">
        </div>
        <div class="space-y-6 reveal" style="--delay: 1;">
          <blockquote class="text-lg text-[#1F2937]/70 leading-relaxed italic">"올루올루와 함께한 2년, 월 매출 5천만 원을 넘겼습니다. 체계적인 본사 지원 덕분에 처음 창업하는 저도 안정적으로 운영하고 있습니다."</blockquote>
          <p class="font-bold text-[#1F2937]">강남점 김OO 점주</p>
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-8 mt-16">
        <div class="rounded-[2rem] overflow-hidden reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=800&auto=format&fit=crop" alt="매출 차트" class="w-full aspect-video object-cover" loading="lazy" decoding="async">
        </div>
        <div class="rounded-[2rem] overflow-hidden reveal" style="--delay: 3;">
          <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?q=80&w=800&auto=format&fit=crop" alt="본사 지원팀" class="w-full aspect-video object-cover" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Revenue 매출 현황 ========== -->
  <section id="revenue" class="py-24 md:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#D97706] to-[#B45309]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-white/15 text-white reveal" style="--delay: 0;">Revenue</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-jakarta font-extrabold leading-snug text-white mt-6 reveal" style="--delay: 1;">매출이 증명합니다</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center reveal" style="--delay: 0;">
          <p class="text-5xl md:text-6xl font-jakarta font-extrabold text-white mb-3">4,200만</p>
          <p class="text-white/60 text-sm font-medium">월평균 매출</p>
        </div>
        <div class="text-center reveal" style="--delay: 1;">
          <p class="text-5xl md:text-6xl font-jakarta font-extrabold text-white mb-3">35%</p>
          <p class="text-white/60 text-sm font-medium">평균 영업이익률</p>
        </div>
        <div class="text-center reveal" style="--delay: 2;">
          <p class="text-5xl md:text-6xl font-jakarta font-extrabold text-white mb-3">8개월</p>
          <p class="text-white/60 text-sm font-medium">평균 투자금 회수</p>
        </div>
        <div class="text-center reveal" style="--delay: 3;">
          <p class="text-5xl md:text-6xl font-jakarta font-extrabold text-white mb-3">0건</p>
          <p class="text-white/60 text-sm font-medium">폐점 (최근 3년)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Process 창업 프로세스 ========== -->
  <section id="process" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#D97706]/10 text-[#D97706] reveal" style="--delay: 0;">Process</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-jakarta font-extrabold leading-snug text-[#1F2937] mt-6 reveal" style="--delay: 1;">창업 프로세스</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center reveal" style="--delay: 0;">
          <div class="w-16 h-16 bg-[#D97706] rounded-full flex items-center justify-center mx-auto mb-6 text-white font-jakarta font-extrabold text-xl">01</div>
          <h3 class="font-bold text-[#1F2937] mb-2">상담 및 신청</h3>
          <p class="text-[#1F2937]/40 text-sm leading-relaxed">온라인 상담 신청 후 본사 방문 상담. 사업 설명회 참석.</p>
        </div>
        <div class="text-center reveal" style="--delay: 1;">
          <div class="w-16 h-16 bg-[#D97706] rounded-full flex items-center justify-center mx-auto mb-6 text-white font-jakarta font-extrabold text-xl">02</div>
          <h3 class="font-bold text-[#1F2937] mb-2">입지 선정</h3>
          <p class="text-[#1F2937]/40 text-sm leading-relaxed">전문 상권 분석팀이 최적의 입지를 선정하고 계약을 지원합니다.</p>
        </div>
        <div class="text-center reveal" style="--delay: 2;">
          <div class="w-16 h-16 bg-[#D97706] rounded-full flex items-center justify-center mx-auto mb-6 text-white font-jakarta font-extrabold text-xl">03</div>
          <h3 class="font-bold text-[#1F2937] mb-2">인테리어 & 교육</h3>
          <p class="text-[#1F2937]/40 text-sm leading-relaxed">시공과 동시에 4주 집중 교육을 진행합니다.</p>
        </div>
        <div class="text-center reveal" style="--delay: 3;">
          <div class="w-16 h-16 bg-[#D97706] rounded-full flex items-center justify-center mx-auto mb-6 text-white font-jakarta font-extrabold text-xl">04</div>
          <h3 class="font-bold text-[#1F2937] mb-2">오픈 & 지원</h3>
          <p class="text-[#1F2937]/40 text-sm leading-relaxed">그랜드 오픈과 함께 2주간 본사 직원이 현장을 지원합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Multiple Locations ========== -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6 reveal" style="--delay: 0;">
