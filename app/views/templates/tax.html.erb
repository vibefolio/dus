<%# Tax Template - 그린 세무회계 (GREEN TAX) — 세무/회계 사무소 %>

<style>
  /* Supanova Design Upgrade */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

  .font-display { font-family: 'Plus Jakarta Sans', sans-serif; }
  .font-body { font-family: 'Noto Sans KR', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 32px !important; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Tax calendar styling */
  .calendar-item {
    position: relative;
  }
  .calendar-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: #059669;
    border-radius: 2px;
  }
</style>

<div class="bg-[#F9FAFB] text-[#374151] font-body selection:bg-[#059669] selection:text-white min-h-screen overflow-x-hidden relative">

  <!-- Nav -->
  <nav class="fixed w-full z-50 px-6 py-5 bg-white/95 backdrop-blur-xl border-b border-gray-100 shadow-sm">
    <div class="container mx-auto px-4 md:px-6 flex justify-between items-center flex-nowrap">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-[#059669] rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </div>
        <div>
          <span class="font-display text-xl font-bold tracking-tight text-[#374151]">GREEN<span class="text-[#059669]">TAX</span></span>
        </div>
      </div>

      <div class="hidden md:flex gap-10 text-[13px] font-medium text-[#374151]/60">
        <a href="#about" class="hover:text-[#059669] transition">소개</a>
        <a href="#services" class="hover:text-[#059669] transition">서비스</a>
        <a href="#calendar" class="hover:text-[#059669] transition">세무 달력</a>
        <a href="#consult" class="hover:text-[#059669] transition">상담 예약</a>
        <a href="#location" class="hover:text-[#059669] transition">오시는 길</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: #059669;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="flex-nowrap shrink-0 flex gap-4 items-center">
        <button onclick="toggleTaxModal()" class="hidden md:block text-[13px] font-medium text-[#374151]/60 hover:text-[#059669]" data-mobile-menu-copy="true">로그인</button>
        <button class="hidden md:inline-flex bg-[#059669] text-white px-5 py-2.5 rounded-lg font-semibold text-[13px] hover:bg-[#047857] transition shadow-lg shadow-[#059669]/20" data-mobile-menu-copy="true">
          무료 상담
        </button>
      </div>
    </div>
    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- Hero -->
  <header class="min-h-screen relative flex items-center pt-24 overflow-hidden">
    <div class="absolute right-0 top-1/4 w-[500px] h-[500px] bg-[#059669]/5 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="container mx-auto px-6 md:px-12 grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-[#059669]/5 border border-[#059669]/15 rounded-full px-4 py-1.5">
          <svg class="w-4 h-4 text-[#059669]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-[12px] font-medium text-[#059669]">국세청 등록 세무사 사무소</span>
        </div>

        <h1 class="text-4xl md:text-6xl font-display font-extrabold leading-[1.1] tracking-tight text-[#374151] mobile-title">
          세금 걱정 없는<br>
          <span class="text-[#059669]">든든한 파트너</span>
        </h1>

        <p class="text-lg md:text-xl text-[#374151]/60 leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc">
          개인 사업자부터 법인까지, 그린 세무회계가 정확하고 절세 효과 높은 세무 서비스를 제공합니다.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#consult" class="px-8 py-4 bg-[#059669] text-white font-semibold text-[15px] rounded-lg hover:bg-[#047857] transition shadow-lg shadow-[#059669]/20">
            무료 세무 상담
          </a>
          <a href="#services" class="px-8 py-4 border border-[#059669]/20 text-[#059669] font-semibold text-[15px] rounded-lg hover:bg-[#059669]/5 transition">
            서비스 안내
          </a>
        </div>

        <div class="flex items-center gap-8 pt-4 justify-center lg:justify-start">
          <div>
            <div class="text-2xl font-display font-bold text-[#374151]">15년</div>
            <div class="text-[12px] text-[#374151]/40">세무 경력</div>
          </div>
          <div class="w-px h-10 bg-gray-200"></div>
          <div>
            <div class="text-2xl font-display font-bold text-[#374151]">3,200+</div>
            <div class="text-[12px] text-[#374151]/40">누적 고객</div>
          </div>
          <div class="w-px h-10 bg-gray-200"></div>
          <div>
            <div class="text-2xl font-display font-bold text-[#374151]">100%</div>
            <div class="text-[12px] text-[#374151]/40">기한 내 신고</div>
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?q=80&w=800&auto=format&fit=crop" alt="세무 상담" class="rounded-2xl shadow-2xl shadow-[#059669]/10 w-full object-cover aspect-[4/3]" loading="lazy" decoding="async">
        <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-xl p-5 border border-gray-100">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#059669]/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-[#059669]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <div class="text-[11px] text-[#374151]/40">평균 절세 효과</div>
              <div class="text-lg font-display font-bold text-[#059669]">연 320만원</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- About -->
  <section id="about" class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6 reveal">
          <span class="text-[12px] font-semibold text-[#059669] uppercase tracking-widest">About Us</span>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-[#374151]">
            정확한 세무,<br>따뜻한 상담
          </h2>
          <p class="text-[#374151]/60 leading-relaxed">
            그린 세무회계는 2009년 개업 이래 개인 사업자, 프리랜서, 중소기업의 세무 업무를 전담해왔습니다.
            국세청 출신 세무사가 직접 상담하며, 고객 한 분 한 분에게 맞춤형 절세 전략을 제안합니다.
          </p>
          <p class="text-[#374151]/60 leading-relaxed">
            복잡한 세법을 쉽게 설명하고, 기한을 놓치지 않는 꼼꼼한 관리로
            고객의 소중한 자산을 지켜드립니다.
          </p>
          <div class="flex flex-wrap gap-3 pt-2">
            <span class="px-4 py-2 bg-[#059669]/5 rounded-full text-[#059669] text-sm font-medium">국세청 경력 세무사</span>
            <span class="px-4 py-2 bg-[#059669]/5 rounded-full text-[#059669] text-sm font-medium">무료 초기 상담</span>
            <span class="px-4 py-2 bg-[#059669]/5 rounded-full text-[#059669] text-sm font-medium">카카오톡 실시간 상담</span>
          </div>
        </div>
        <div class="reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?q=80&w=800&auto=format&fit=crop" alt="사무실" class="rounded-2xl shadow-lg w-full object-cover aspect-[4/3]" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-24 md:py-32">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 reveal">
        <span class="text-[12px] font-semibold text-[#059669] uppercase tracking-widest">Services</span>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-[#374151] mt-3">세무/회계 서비스</h2>
        <p class="text-[#374151]/50 mt-4 max-w-xl mx-auto">사업 규모와 업종에 맞는 맞춤형 세무 서비스를 제공합니다</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-gray-100 hover:shadow-xl hover:shadow-[#059669]/5 transition-all duration-500 group" style="--delay: 1;">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 bg-[#059669]/5 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#059669] transition-colors duration-500">
              <svg class="w-7 h-7 text-[#059669] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM10 8.5a.5.5 0 11-1 0 .5.5 0 011 0zm5 5a.5.5 0 11-1 0 .5.5 0 011 0z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-[#374151] text-lg mb-2">기장 대리</h3>
              <p class="text-[#374151]/55 text-sm leading-relaxed">월별 장부 기장, 매입/매출 관리, 부가세 신고 등 사업 운영에 필요한 기본 세무를 대행합니다.</p>
              <div class="mt-3 text-[#059669] text-xs font-semibold">월 11만원부터</div>
            </div>
          </div>
        </div>

        <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-gray-100 hover:shadow-xl hover:shadow-[#059669]/5 transition-all duration-500 group" style="--delay: 2;">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 bg-[#059669]/5 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#059669] transition-colors duration-500">
              <svg class="w-7 h-7 text-[#059669] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-[#374151] text-lg mb-2">종합소득세 신고</h3>
              <p class="text-[#374151]/55 text-sm leading-relaxed">프리랜서, 개인사업자, 부동산 임대 소득자의 종합소득세 신고와 절세 전략을 수립합니다.</p>
              <div class="mt-3 text-[#059669] text-xs font-semibold">건당 22만원부터</div>
            </div>
          </div>
        </div>

        <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-gray-100 hover:shadow-xl hover:shadow-[#059669]/5 transition-all duration-500 group" style="--delay: 3;">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 bg-[#059669]/5 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#059669] transition-colors duration-500">
              <svg class="w-7 h-7 text-[#059669] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-[#374151] text-lg mb-2">법인 세무</h3>
              <p class="text-[#374151]/55 text-sm leading-relaxed">법인세 신고, 결산, 이전가격, 법인 설립 및 전환 등 법인 운영 전반의 세무를 지원합니다.</p>
              <div class="mt-3 text-[#059669] text-xs font-semibold">맞춤 견적</div>
            </div>
          </div>
        </div>

        <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-gray-100 hover:shadow-xl hover:shadow-[#059669]/5 transition-all duration-500 group" style="--delay: 4;">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 bg-[#059669]/5 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#059669] transition-colors duration-500">
              <svg class="w-7 h-7 text-[#059669] group-hover:text-white transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-[#374151] text-lg mb-2">양도/상속/증여세</h3>
              <p class="text-[#374151]/55 text-sm leading-relaxed">부동산 양도, 상속, 증여 시 세금 계산과 신고를 대행하며, 합법적 절세 방안을 제시합니다.</p>
              <div class="mt-3 text-[#059669] text-xs font-semibold">건당 33만원부터</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tax Calendar -->
  <section id="calendar" class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 reveal">
        <span class="text-[12px] font-semibold text-[#059669] uppercase tracking-widest">Tax Calendar</span>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-[#374151] mt-3">2024 세무 달력</h2>
        <p class="text-[#374151]/50 mt-4 max-w-xl mx-auto">중요한 세금 신고 기한을 놓치지 마세요</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="reveal calendar-item bg-[#F9FAFB] rounded-xl p-6 pl-8 border border-gray-100" style="--delay: 1;">
          <div class="text-xs font-display font-bold text-[#059669] mb-1">1월 25일</div>
          <h4 class="font-display font-bold text-[#374151] text-sm mb-1">부가가치세 확정신고</h4>
          <p class="text-[#374151]/50 text-xs">2기 확정 (7-12월분)</p>
        </div>

        <div class="reveal calendar-item bg-[#F9FAFB] rounded-xl p-6 pl-8 border border-gray-100" style="--delay: 2;">
          <div class="text-xs font-display font-bold text-[#059669] mb-1">3월 31일</div>
          <h4 class="font-display font-bold text-[#374151] text-sm mb-1">법인세 신고</h4>
          <p class="text-[#374151]/50 text-xs">12월 결산법인 대상</p>
        </div>

        <div class="reveal calendar-item bg-[#F9FAFB] rounded-xl p-6 pl-8 border border-gray-100" style="--delay: 3;">
          <div class="text-xs font-display font-bold text-[#059669] mb-1">5월 31일</div>
          <h4 class="font-display font-bold text-[#374151] text-sm mb-1">종합소득세 신고</h4>
          <p class="text-[#374151]/50 text-xs">개인사업자, 프리랜서 대상</p>
        </div>

        <div class="reveal calendar-item bg-[#F9FAFB] rounded-xl p-6 pl-8 border border-gray-100" style="--delay: 4;">
          <div class="text-xs font-display font-bold text-[#059669] mb-1">7월 25일</div>
          <h4 class="font-display font-bold text-[#374151] text-sm mb-1">부가가치세 확정신고</h4>
          <p class="text-[#374151]/50 text-xs">1기 확정 (1-6월분)</p>
        </div>

        <div class="reveal calendar-item bg-[#F9FAFB] rounded-xl p-6 pl-8 border border-gray-100" style="--delay: 5;">
          <div class="text-xs font-display font-bold text-[#059669] mb-1">9월 30일</div>
          <h4 class="font-display font-bold text-[#374151] text-sm mb-1">재산세 납부</h4>
          <p class="text-[#374151]/50 text-xs">토지분 (2기분)</p>
        </div>

        <div class="reveal calendar-item bg-[#F9FAFB] rounded-xl p-6 pl-8 border border-gray-100" style="--delay: 6;">
          <div class="text-xs font-display font-bold text-[#059669] mb-1">12월 31일</div>
          <h4 class="font-display font-bold text-[#374151] text-sm mb-1">종합부동산세 납부</h4>
          <p class="text-[#374151]/50 text-xs">주택, 토지 합산</p>
        </div>
      </div>

      <div class="text-center mt-10 reveal" style="--delay: 3;">
        <p class="text-sm text-[#374151]/50">신고 기한을 놓치면 가산세가 부과됩니다. 그린 세무회계가 기한 내 정확하게 처리해 드립니다.</p>
      </div>
    </div>
  </section>

  <!-- Expert Team & Documents -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?q=80&w=800&auto=format&fit=crop" alt="상담 미팅" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async">
        </div>
        <div class="space-y-6 reveal">
