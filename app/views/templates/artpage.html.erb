<%# Artpage Template - 캔버스 (CANVAS) %>

<style>
  /* Supanova Design — Minimal Gallery Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-garamond { font-family: 'EB Garamond', serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 42px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  .exhibit-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .exhibit-card:hover { transform: translateY(-8px); }
  .exhibit-card:hover img { transform: scale(1.05); }

  .gallery-item { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .gallery-item:hover { transform: scale(1.02); }
  .gallery-item:hover img { transform: scale(1.08); }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
</style>

<div class="bg-white text-[#000000] font-sans selection:bg-black selection:text-white min-h-screen overflow-x-hidden relative">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-white/80 backdrop-blur-xl border-b border-black/5">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="font-garamond text-2xl tracking-tight font-medium text-black">CANVAS</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-black/40">
        <a href="#exhibitions" class="hover:text-black transition">Exhibition</a>
        <a href="#artist" class="hover:text-black transition">Artist</a>
        <a href="#tour" class="hover:text-black transition">Tour</a>
        <a href="#visit" class="hover:text-black transition">Visit</a>
        <a href="#contact" class="hover:text-black transition">Contact</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleArtpageModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-black/40 hover:text-black" data-mobile-menu-copy="true">Members</button>
        <button class="bg-black text-white px-8 py-3.5 rounded-full font-medium text-[10px] tracking-[0.3em] uppercase hover:bg-black/80 transition" data-mobile-menu-copy="true">
          Tickets
        </button>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center justify-center pt-20">
    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-10 text-center lg:text-left">
        <div class="inline-flex items-center gap-5 reveal" style="--delay: 0;">
          <span class="w-10 h-[1px] bg-black"></span>
          <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-black/40">Art Gallery</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-[5.5rem] font-garamond font-medium leading-tight tracking-tight text-black mobile-title reveal" style="--delay: 1;">
          예술이 숨 쉬는<br><span class="italic">공간.</span>
        </h1>

        <p class="text-black/50 text-sm md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          현대미술과 전통의 경계를 허무는 갤러리. CANVAS는 국내외 아티스트의 작품을 큐레이션하여 새로운 시각적 경험을 제안합니다.
        </p>

        <div class="pt-4 flex flex-col sm:flex-row gap-5 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#exhibitions" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-black text-white font-medium text-[11px] tracking-[0.3em] uppercase hover:bg-black/80 rounded-full">
            현재 전시
            <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center">
              <i class="fas fa-arrow-right text-[10px]"></i>
            </span>
          </a>
          <a href="#visit" class="inline-flex items-center justify-center px-10 py-5 border border-black/10 text-black/60 font-medium text-[11px] tracking-[0.3em] uppercase hover:bg-black/5 rounded-full">
            관람 안내
          </a>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <div class="relative group">
          <img src="https://images.unsplash.com/photo-1531243269054-5ebf6f34081e?q=80&w=1200" alt="갤러리 전시" class="w-full aspect-[4/5] object-cover rounded-[3rem] shadow-2xl group-hover:shadow-[0_30px_80px_-20px_rgba(0,0,0,0.2)] transition-all duration-700" loading="eager">
          <div class="absolute -bottom-6 -left-6 md:-bottom-8 md:-left-8 bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-black/5 max-w-[260px]" style="animation: float 6s ease-in-out infinite;">
            <p class="text-[10px] font-semibold text-black/40 uppercase tracking-[0.4em] mb-3">Now Showing</p>
            <p class="text-xl font-garamond italic font-medium text-black">Infinite Horizons</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== Exhibitions (4개) ========== -->
  <section id="exhibitions" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-black/5 text-black/60 reveal" style="--delay: 0;">Exhibition</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-garamond font-medium leading-snug text-black mt-6 reveal" style="--delay: 1;">현재 전시</h2>
        <p class="text-black/40 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">CANVAS에서 만나는 동시대 예술.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="exhibit-card bg-white rounded-[2rem] overflow-hidden border border-black/5 reveal" style="--delay: 0;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1541961017774-22349e4a1262?q=80&w=600" alt="추상화 전시" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <p class="text-[10px] font-semibold text-black/30 uppercase tracking-[0.2em] mb-2">2026.03.15 – 05.30</p>
            <h3 class="text-lg font-garamond font-medium text-black mb-2">무한의 지평선</h3>
            <p class="text-black/40 text-sm leading-relaxed">김지원 작가의 대형 추상화 시리즈. 자연과 인간의 경계를 탐구합니다.</p>
          </div>
        </div>

        <div class="exhibit-card bg-white rounded-[2rem] overflow-hidden border border-black/5 reveal" style="--delay: 1;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1578301978693-85fa9c0320b9?q=80&w=600" alt="설치미술" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <p class="text-[10px] font-semibold text-black/30 uppercase tracking-[0.2em] mb-2">2026.04.01 – 06.15</p>
            <h3 class="text-lg font-garamond font-medium text-black mb-2">빛의 건축</h3>
            <p class="text-black/40 text-sm leading-relaxed">이하늘의 빛과 공간을 소재로 한 대규모 설치 작품전.</p>
          </div>
        </div>

        <div class="exhibit-card bg-white rounded-[2rem] overflow-hidden border border-black/5 reveal" style="--delay: 2;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?q=80&w=600" alt="사진전" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <p class="text-[10px] font-semibold text-black/30 uppercase tracking-[0.2em] mb-2">2026.04.20 – 05.20</p>
            <h3 class="text-lg font-garamond font-medium text-black mb-2">도시의 초상</h3>
            <p class="text-black/40 text-sm leading-relaxed">서울의 일상을 담은 다큐멘터리 사진전. 박성호 작가.</p>
          </div>
        </div>

        <div class="exhibit-card bg-white rounded-[2rem] overflow-hidden border border-black/5 reveal" style="--delay: 3;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1513364776144-60967b0f800f?q=80&w=600" alt="미디어아트" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <p class="text-[10px] font-semibold text-black/30 uppercase tracking-[0.2em] mb-2">Coming Soon</p>
            <h3 class="text-lg font-garamond font-medium text-black mb-2">디지털 자연</h3>
            <p class="text-black/40 text-sm leading-relaxed">AI와 인간 감성의 교차점을 탐구하는 미디어아트 전시.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Artist ========== -->
  <section id="artist" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative reveal" style="--delay: 0;">
        <div class="grid grid-cols-5 gap-4">
          <div class="col-span-3 overflow-hidden rounded-[2rem]">
            <img src="https://images.unsplash.com/photo-1513364776144-60967b0f800f?q=80&w=800" alt="아티스트 작업" class="w-full h-full object-cover aspect-[3/4]" loading="lazy" decoding="async">
          </div>
          <div class="col-span-2 flex flex-col gap-4">
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1513364776144-60967b0f800f?q=80&w=600" alt="작품 디테일" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1547891654-e66ed7ebb968?q=80&w=600" alt="전시 공간" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-8 reveal" style="--delay: 1;">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-black/5 text-black/60">Featured Artist</span>

        <h2 class="text-3xl md:text-4xl lg:text-5xl font-garamond font-medium leading-snug text-black">
          김지원<br><span class="italic text-black/40">Jiwon Kim</span>
        </h2>

        <p class="text-black/50 text-base md:text-lg leading-relaxed">
          서울대학교 미술대학을 졸업하고 런던 슬레이드 스쿨에서 석사 학위를 취득했습니다. 자연의 순환과 인간 감성의 관계를 대형 캔버스에 추상적으로 표현하는 작업으로 국제적 주목을 받고 있습니다.
        </p>
        <p class="text-black/50 text-base md:text-lg leading-relaxed">
          2020년 베니스 비엔날레 참여를 비롯해 뉴욕, 파리, 도쿄에서 개인전을 개최했으며, 국립현대미술관에 작품이 소장되어 있습니다.
        </p>

        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-black/5">
          <div>
            <p class="text-2xl md:text-3xl font-garamond font-medium text-black">15yr</p>
            <p class="text-[11px] text-black/30 uppercase tracking-[0.1em] mt-1 font-medium">작가 경력</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-garamond font-medium text-black">40+</p>
            <p class="text-[11px] text-black/30 uppercase tracking-[0.1em] mt-1 font-medium">전시 참여</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-garamond font-medium text-black">8개국</p>
            <p class="text-[11px] text-black/30 uppercase tracking-[0.1em] mt-1 font-medium">글로벌 전시</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Gallery Tour ========== -->
  <section id="tour" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-black/5 text-black/60 reveal" style="--delay: 0;">Gallery Tour</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-garamond font-medium leading-snug text-black mt-6 reveal" style="--delay: 1;">갤러리 투어</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 0;"><img src="https://images.unsplash.com/photo-1531243269054-5ebf6f34081e?q=80&w=600" alt="전시실 1" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 1;"><img src="https://images.unsplash.com/photo-1544967082-d9d25d867d66?q=80&w=600" alt="전시실 2" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 2;"><img src="https://images.unsplash.com/photo-1578301978693-85fa9c0320b9?q=80&w=600" alt="로비" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 3;"><img src="https://images.unsplash.com/photo-1541961017774-22349e4a1262?q=80&w=600" alt="전시 작품" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] col-span-2 reveal" style="--delay: 4;"><img src="https://images.unsplash.com/photo-1518998053901-5348d3961a04?q=80&w=900" alt="갤러리 전경" class="w-full aspect-[2/1] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
      </div>
    </div>
  </section>

  <!-- ========== 관람 안내 ========== -->
  <section id="visit" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="overflow-hidden rounded-[2rem] reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1518998053901-5348d3961a04?q=80&w=800" alt="갤러리 입구" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async">
        </div>

        <div class="space-y-8 reveal" style="--delay: 1;">
          <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-black/5 text-black/60">Visit</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-garamond font-medium leading-snug text-black">관람 안내</h2>

          <div class="space-y-6">
            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-black/5 flex items-center justify-center shrink-0 mt-0.5"><i class="fas fa-clock text-black/40 text-sm"></i></div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-black/30 mb-2">Hours</p>
                <p class="text-black/70 text-base leading-relaxed">화–일 10:00 – 19:00 (수요일 21:00까지)<br>매주 월요일 휴관</p>
              </div>
            </div>
            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-black/5 flex items-center justify-center shrink-0 mt-0.5"><i class="fas fa-ticket-alt text-black/40 text-sm"></i></div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-black/30 mb-2">Admission</p>
                <p class="text-black/70 text-base leading-relaxed">성인 ₩15,000 / 학생 ₩10,000<br>수요일 야간(18:00–) 무료 입장</p>
              </div>
            </div>
            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-black/5 flex items-center justify-center shrink-0 mt-0.5"><i class="fas fa-map-marker-alt text-black/40 text-sm"></i></div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-black/30 mb-2">Address</p>
                <p class="text-black/70 text-base leading-relaxed">서울시 용산구 이태원로 55길 12<br>CANVAS Gallery</p>
              </div>
            </div>
            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-black/5 flex items-center justify-center shrink-0 mt-0.5"><i class="fas fa-subway text-black/40 text-sm"></i></div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-black/30 mb-2">Transport</p>
                <p class="text-black/70 text-base leading-relaxed">이태원역 3번 출구에서 도보 7분<br>주차장 없음, 대중교통 이용 권장</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Contact / CTA ========== -->
  <section id="contact" class="py-24 md:py-32 bg-black text-white">
    <div class="max-w-3xl mx-auto px-4 md:px-8 text-center">
      <div class="reveal" style="--delay: 0;">
        <span class="font-garamond text-6xl md:text-8xl italic text-white/10 block mb-6">C</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-garamond font-medium leading-snug text-white reveal" style="--delay: 1;">
        예술과 만나는<br>가장 가까운 순간
      </h2>
      <p class="text-white/40 text-base md:text-lg mt-6 max-w-lg mx-auto reveal" style="--delay: 2;">
        전시 문의, 작품 구매, 대관 상담 등 궁금한 점이 있으시면 언제든 연락해주세요.
      </p>
      <div class="flex flex-col sm:flex-row gap-5 justify-center mt-10 reveal" style="--delay: 3;">
        <a href="#" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-white text-black font-medium text-[11px] tracking-[0.3em] uppercase rounded-full hover:bg-white/90">
          문의하기
          <span class="w-7 h-7 rounded-full bg-black/5 flex items-center justify-center"><i class="fas fa-arrow-right text-[10px]"></i></span>
        </a>
        <a href="https://www.instagram.com/" target="_blank" class="inline-flex items-center justify-center gap-3 px-10 py-5 border border-white/10 text-white/70 font-medium text-[11px] tracking-[0.3em] uppercase rounded-full hover:bg-white/5">
          <i class="fab fa-instagram text-sm"></i> Instagram
        </a>
      </div>

      <div class="mt-16 pt-10 border-t border-white/5 reveal" style="--delay: 4;">
        <p class="text-white/30 text-sm">전화: 02-987-6543 / 이메일: hello@canvas-gallery.kr</p>
      </div>
    </div>
  </section>

  <!-- ========== Footer ========== -->
  <footer class="py-16 md:py-24 bg-black border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="grid md:grid-cols-3 gap-12 items-start mb-16">
        <div>
          <span class="font-garamond text-2xl text-white tracking-tight font-medium block mb-4">CANVAS</span>
