<%# Hotel Template — VELLA RESORT (벨라 리조트) %>

<style>
  /* Supanova Design — Dark Luxury Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-serif { font-family: 'Cormorant Garamond', serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 36px !important; }
  }

  /* Scroll reveal */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2.5rem); filter: blur(6px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(2.5rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 120ms);
  }

  /* Room card hover */
  .room-card { transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
  .room-card:hover { transform: translateY(-10px); }
  .room-card:hover img { transform: scale(1.08); }

  /* Gallery hover */
  .gallery-item { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .gallery-item:hover { transform: scale(1.02); }
  .gallery-item:hover img { transform: scale(1.06); }

  /* Parallax shimmer */
  @keyframes shimmer {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.6; }
  }

  /* Gold line animation */
  @keyframes expandLine {
    from { width: 0; }
    to { width: 80px; }
  }
  .gold-line.is-visible { animation: expandLine 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
</style>

<div class="bg-[#0C1015] text-[#F5F0E8] font-sans selection:bg-[#C9A96E] selection:text-[#0C1015] min-h-screen overflow-x-hidden relative">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-10 py-5 bg-[#0C1015]/70 backdrop-blur-2xl border-b border-[#C9A96E]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="font-serif text-2xl md:text-3xl tracking-wide font-semibold italic text-[#C9A96E]">Vella Resort</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#F5F0E8]/30">
        <a href="#rooms" class="hover:text-[#C9A96E] transition">Rooms</a>
        <a href="#dining" class="hover:text-[#C9A96E] transition">Dining</a>
        <a href="#facilities" class="hover:text-[#C9A96E] transition">Facilities</a>
        <a href="#location" class="hover:text-[#C9A96E] transition">Location</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none text-[#C9A96E]">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleHotelModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#F5F0E8]/30 hover:text-[#C9A96E]" data-mobile-menu-copy="true">Concierge</button>
        <a href="#booking" class="bg-[#C9A96E] text-[#0C1015] px-8 py-3.5 rounded-none font-bold text-[10px] tracking-[0.3em] uppercase hover:bg-[#F5F0E8] transition shadow-lg shadow-[#C9A96E]/20" data-mobile-menu-copy="true">
          예약하기
        </a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== 1. Hero ========== -->
  <header class="min-h-screen relative flex items-end pb-20 md:pb-32">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=2000&auto=format" alt="Vella Resort 전경" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015] via-[#0C1015]/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0C1015]/80 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 w-full">
      <div class="max-w-2xl space-y-8">
        <div class="reveal inline-flex items-center gap-6">
          <span class="w-12 h-[1px] bg-[#C9A96E]"></span>
          <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#C9A96E]">Premium Resort & Spa</span>
        </div>

        <h1 class="reveal text-4xl md:text-7xl font-serif font-semibold leading-[1.1] tracking-tight mobile-title" style="--delay:1">
          자연이 빚은<br>
          <span class="italic text-[#C9A96E]">완벽한 휴식.</span>
        </h1>

        <p class="reveal text-[#F5F0E8]/50 text-sm md:text-lg leading-[2] max-w-lg mobile-desc" style="--delay:2">
          제주의 바다와 하늘이 만나는 곳, 벨라 리조트에서<br class="hidden md:block">
          일상의 무게를 내려놓고 진정한 쉼을 발견하세요.
        </p>

        <div class="reveal flex flex-wrap gap-4 pt-4" style="--delay:3">
          <a href="#rooms" class="bg-[#C9A96E] text-[#0C1015] px-10 py-4 font-bold text-[11px] tracking-[0.3em] uppercase hover:bg-[#F5F0E8] transition">
            객실 보기
          </a>
          <a href="#booking" class="border border-[#C9A96E]/40 text-[#C9A96E] px-10 py-4 font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-[#C9A96E]/10 transition">
            예약하기
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="reveal mt-16 grid grid-cols-3 gap-8 max-w-lg" style="--delay:4">
        <div class="border-l border-[#C9A96E]/30 pl-6">
          <span class="font-serif text-3xl md:text-4xl italic text-[#C9A96E]">5</span>
          <span class="block text-[9px] text-[#F5F0E8]/30 tracking-[0.3em] uppercase mt-1">Star Resort</span>
        </div>
        <div class="border-l border-[#C9A96E]/30 pl-6">
          <span class="font-serif text-3xl md:text-4xl italic text-[#C9A96E]">142</span>
          <span class="block text-[9px] text-[#F5F0E8]/30 tracking-[0.3em] uppercase mt-1">Luxury Rooms</span>
        </div>
        <div class="border-l border-[#C9A96E]/30 pl-6">
          <span class="font-serif text-3xl md:text-4xl italic text-[#C9A96E]">9.4</span>
          <span class="block text-[9px] text-[#F5F0E8]/30 tracking-[0.3em] uppercase mt-1">Guest Rating</span>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 2. 객실 소개 (4종) ========== -->
  <section id="rooms" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#C9A96E]">Rooms & Suites</span>
        <h2 class="font-serif text-3xl md:text-5xl italic mt-4 text-[#F5F0E8]">특별한 공간, 완벽한 하루</h2>
        <div class="w-16 h-[1px] bg-[#C9A96E]/40 mx-auto mt-8"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8">
        <!-- 디럭스 트윈 -->
        <div class="room-card group relative overflow-hidden reveal" style="--delay:0">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1618773928121-c32242e63f39?q=80&w=1200&auto=format" alt="디럭스 트윈" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015] via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="p-8 bg-[#0C1015] border border-[#C9A96E]/10 border-t-0">
            <div class="flex justify-between items-start">
              <div>
                <span class="text-[9px] text-[#C9A96E] tracking-[0.4em] uppercase font-semibold">Deluxe Twin</span>
                <h3 class="font-serif text-2xl italic mt-2">디럭스 트윈</h3>
                <p class="text-[#F5F0E8]/40 text-sm mt-3 leading-relaxed">36m² · 오션뷰 · 트윈베드 · 최대 2인</p>
              </div>
              <div class="text-right">
                <span class="font-serif text-2xl italic text-[#C9A96E]">₩280,000</span>
                <span class="block text-[10px] text-[#F5F0E8]/30 mt-1">1박 기준</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 슈페리어 더블 -->
        <div class="room-card group relative overflow-hidden reveal" style="--delay:1">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1582719508461-905c673771fd?q=80&w=1200&auto=format" alt="슈페리어 더블" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015] via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="p-8 bg-[#0C1015] border border-[#C9A96E]/10 border-t-0">
            <div class="flex justify-between items-start">
              <div>
                <span class="text-[9px] text-[#C9A96E] tracking-[0.4em] uppercase font-semibold">Superior Double</span>
                <h3 class="font-serif text-2xl italic mt-2">슈페리어 더블</h3>
                <p class="text-[#F5F0E8]/40 text-sm mt-3 leading-relaxed">42m² · 오션뷰 · 킹베드 · 최대 2인</p>
              </div>
              <div class="text-right">
                <span class="font-serif text-2xl italic text-[#C9A96E]">₩380,000</span>
                <span class="block text-[10px] text-[#F5F0E8]/30 mt-1">1박 기준</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 프리미엄 스위트 -->
        <div class="room-card group relative overflow-hidden reveal" style="--delay:2">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?q=80&w=1200&auto=format" alt="프리미엄 스위트" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015] via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="p-8 bg-[#0C1015] border border-[#C9A96E]/10 border-t-0">
            <div class="flex justify-between items-start">
              <div>
                <span class="text-[9px] text-[#C9A96E] tracking-[0.4em] uppercase font-semibold">Premium Suite</span>
                <h3 class="font-serif text-2xl italic mt-2">프리미엄 스위트</h3>
                <p class="text-[#F5F0E8]/40 text-sm mt-3 leading-relaxed">68m² · 파노라마뷰 · 거실+침실 · 최대 3인</p>
              </div>
              <div class="text-right">
                <span class="font-serif text-2xl italic text-[#C9A96E]">₩580,000</span>
                <span class="block text-[10px] text-[#F5F0E8]/30 mt-1">1박 기준</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 로얄 펜트하우스 -->
        <div class="room-card group relative overflow-hidden reveal" style="--delay:3">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?q=80&w=1200&auto=format" alt="로얄 펜트하우스" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015] via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="p-8 bg-[#0C1015] border border-[#C9A96E]/10 border-t-0">
            <div class="flex justify-between items-start">
              <div>
                <span class="text-[9px] text-[#C9A96E] tracking-[0.4em] uppercase font-semibold">Royal Penthouse</span>
                <h3 class="font-serif text-2xl italic mt-2">로얄 펜트하우스</h3>
                <p class="text-[#F5F0E8]/40 text-sm mt-3 leading-relaxed">120m² · 루프탑 테라스 · 프라이빗 풀 · 최대 4인</p>
              </div>
              <div class="text-right">
                <span class="font-serif text-2xl italic text-[#C9A96E]">₩1,200,000</span>
                <span class="block text-[10px] text-[#F5F0E8]/30 mt-1">1박 기준</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 3. 다이닝 ========== -->
  <section id="dining" class="py-24 md:py-40 px-6 md:px-10 bg-[#0F151A]">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="space-y-10 reveal">
          <div class="inline-flex items-center gap-6">
            <span class="w-12 h-[1px] bg-[#C9A96E]"></span>
            <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#C9A96E]">Gastronomy</span>
          </div>

          <h2 class="font-serif text-3xl md:text-5xl italic leading-tight">
            미식의 정수,<br><span class="text-[#C9A96E]">바다를 담다.</span>
          </h2>

          <p class="text-[#F5F0E8]/40 text-sm md:text-base leading-[2] mobile-desc">
            벨라 리조트의 셰프 테이블에서는 제주 청정 식재료로<br class="hidden md:block">
            완성한 모던 한식 코스를 선보입니다. 일몰과 함께하는<br class="hidden md:block">
            다이닝은 잊을 수 없는 특별한 경험이 됩니다.
          </p>

          <div class="space-y-6 pt-4">
            <div class="flex items-center gap-6 group">
              <span class="w-10 h-10 flex items-center justify-center border border-[#C9A96E]/20 text-[#C9A96E] text-sm group-hover:bg-[#C9A96E] group-hover:text-[#0C1015] transition">01</span>
              <div>
                <h4 class="font-serif text-lg italic">오션 뷰 레스토랑</h4>
                <p class="text-[#F5F0E8]/30 text-xs mt-1">조식 뷔페 · 런치 코스 · 디너 코스</p>
              </div>
            </div>
            <div class="flex items-center gap-6 group">
              <span class="w-10 h-10 flex items-center justify-center border border-[#C9A96E]/20 text-[#C9A96E] text-sm group-hover:bg-[#C9A96E] group-hover:text-[#0C1015] transition">02</span>
              <div>
                <h4 class="font-serif text-lg italic">스카이 바 & 라운지</h4>
                <p class="text-[#F5F0E8]/30 text-xs mt-1">시그니처 칵테일 · 와인 셀렉션 · 타파스</p>
              </div>
            </div>
            <div class="flex items-center gap-6 group">
              <span class="w-10 h-10 flex items-center justify-center border border-[#C9A96E]/20 text-[#C9A96E] text-sm group-hover:bg-[#C9A96E] group-hover:text-[#0C1015] transition">03</span>
              <div>
                <h4 class="font-serif text-lg italic">프라이빗 다이닝</h4>
                <p class="text-[#F5F0E8]/30 text-xs mt-1">2~10인 전용 룸 · 맞춤 코스 · 소믈리에 서비스</p>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal" style="--delay:2">
          <div class="relative">
            <div class="aspect-[3/4] overflow-hidden">
              <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?q=80&w=1200&auto=format" alt="다이닝" class="w-full h-full object-cover grayscale hover:grayscale-0 transition duration-1000">
            </div>
            <div class="absolute -bottom-8 -left-8 bg-[#C9A96E] text-[#0C1015] p-8 md:p-10 max-w-[220px]">
              <p class="font-serif text-3xl italic font-semibold">Chef's<br>Table</p>
              <p class="text-[9px] font-bold tracking-[0.3em] uppercase mt-2 opacity-60">Reservation Only</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 4. 시설 갤러리 ========== -->
  <section id="facilities" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#C9A96E]">Facilities</span>
        <h2 class="font-serif text-3xl md:text-5xl italic mt-4">리조트의 모든 순간</h2>
        <div class="w-16 h-[1px] bg-[#C9A96E]/40 mx-auto mt-8"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-5">
        <div class="gallery-item overflow-hidden col-span-2 row-span-2 reveal" style="--delay:0">
          <div class="aspect-square md:aspect-auto md:h-full overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?q=80&w=1200&auto=format" alt="인피니티 풀" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-8">
              <div>
                <h4 class="font-serif text-xl italic text-[#C9A96E]">인피니티 풀</h4>
                <p class="text-[#F5F0E8]/50 text-xs mt-1">바다와 하나되는 수영장</p>
              </div>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden reveal" style="--delay:1">
          <div class="aspect-square overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?q=80&w=800&auto=format" alt="스파" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
              <h4 class="font-serif text-lg italic text-[#C9A96E]">아로마 스파</h4>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden reveal" style="--delay:2">
          <div class="aspect-square overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=800&auto=format" alt="피트니스" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
              <h4 class="font-serif text-lg italic text-[#C9A96E]">피트니스 센터</h4>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden reveal" style="--delay:3">
          <div class="aspect-square overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1507652313519-d4e9174996dd?q=80&w=800&auto=format" alt="프라이빗 비치" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
              <h4 class="font-serif text-lg italic text-[#C9A96E]">프라이빗 비치</h4>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden col-span-2 reveal" style="--delay:4">
          <div class="aspect-[2/1] overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?q=80&w=1200&auto=format" alt="키즈 라운지" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0C1015]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-8">
              <div>
                <h4 class="font-serif text-xl italic text-[#C9A96E]">키즈 라운지 & 놀이시설</h4>
                <p class="text-[#F5F0E8]/50 text-xs mt-1">가족 여행객을 위한 특별한 공간</p>
              </div>
            </div>
          </div>
        </div>
      </div>
