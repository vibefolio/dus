      <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mt-10 reveal" style="--delay: 2;">
        <input type="email" placeholder="이메일 주소" class="flex-1 bg-[#F5F5F5] border-none py-4 px-6 outline-none focus:ring-2 focus:ring-black/10 text-[13px]">
        <button class="bg-black text-white px-8 py-4 font-bold text-[12px] uppercase tracking-[0.2em] hover:bg-[#FF4B4B]">구독</button>
      </div>
    </div>
  </section>

  <!-- ========== Footer ========== -->
  <footer class="py-16 md:py-24 bg-black text-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="grid md:grid-cols-4 gap-12 items-start mb-16">
        <div>
          <span class="font-outfit text-2xl font-black tracking-tighter block mb-4">MODO</span>
          <p class="text-white/30 text-sm leading-relaxed">Less is More. 본질에 집중하는 라이프스타일 쇼핑몰.</p>
        </div>
        <div>
          <p class="text-[10px] font-semibold text-white/20 uppercase tracking-[0.3em] mb-4">Shop</p>
          <ul class="space-y-2.5"><li><a href="#" class="text-white/50 text-sm hover:text-[#FF4B4B] transition">신상품</a></li><li><a href="#" class="text-white/50 text-sm hover:text-[#FF4B4B] transition">베스트셀러</a></li><li><a href="#" class="text-white/50 text-sm hover:text-[#FF4B4B] transition">세일</a></li></ul>
        </div>
