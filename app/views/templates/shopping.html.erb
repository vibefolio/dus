<%# Shopping Template - MODO (쇼핑몰) %>

<style>
  /* Supanova Design — Minimal Shopping Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-outfit { font-family: 'Outfit', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 38px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .product-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .product-card:hover { transform: translateY(-8px); }
  .product-card:hover img { transform: scale(1.05); }
  .product-card .cart-btn { opacity: 0; transform: translateY(10px); }
  .product-card:hover .cart-btn { opacity: 1; transform: translateY(0); }
</style>

<div class="bg-white text-[#000000] font-sans selection:bg-[#FF4B4B] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-white/80 backdrop-blur-xl border-b border-black/5">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="font-outfit text-2xl font-black tracking-tighter">MODO</a>

      <div class="hidden md:flex gap-10 text-[11px] font-semibold uppercase tracking-[0.3em] text-black/30">
        <a href="#new" class="hover:text-[#FF4B4B] transition">신상품</a>
        <a href="#category" class="hover:text-[#FF4B4B] transition">카테고리</a>
        <a href="#best" class="hover:text-[#FF4B4B] transition">베스트</a>
        <a href="#story" class="hover:text-[#FF4B4B] transition">브랜드</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-5 items-center shrink-0">
        <button onclick="toggleShoppingModal()" class="text-black/30 hover:text-black transition" data-mobile-menu-copy="true"><i class="far fa-user text-lg"></i></button>
        <a href="#" class="text-black/30 hover:text-black transition"><i class="far fa-heart text-lg"></i></a>
        <a href="#" class="relative text-black/30 hover:text-black transition">
          <i class="fas fa-shopping-bag text-lg"></i>
          <span class="absolute -top-1 -right-1 w-4 h-4 bg-[#FF4B4B] rounded-full text-white text-[9px] flex items-center justify-center font-bold">2</span>
        </a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20">
    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 reveal" style="--delay: 0;">
          <span class="w-2 h-2 bg-[#FF4B4B] rounded-full"></span>
          <span class="text-[11px] font-bold tracking-[0.3em] uppercase text-[#FF4B4B]">New Season 2026</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-[5rem] font-black leading-none tracking-tighter font-outfit mobile-title reveal" style="--delay: 1;">
          Less is<br><span class="text-[#FF4B4B]">More.</span>
        </h1>

        <p class="text-black/40 text-base md:text-lg leading-relaxed max-w-md mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          미니멀한 디자인, 최고의 품질. MODO는 당신의 일상에 세련된 스타일을 더합니다.
        </p>

        <div class="pt-2 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#new" class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-black text-white font-bold text-[12px] tracking-[0.2em] uppercase hover:bg-[#FF4B4B] rounded-none">
            Shop Now <i class="fas fa-arrow-right text-[10px]"></i>
          </a>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 1;">
        <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=1200" alt="쇼핑" class="w-full aspect-[3/4] object-cover" loading="eager">
      </div>
    </div>
  </header>

  <!-- ========== About ========== -->
  <section id="about" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8 text-center">
      <span class="text-[11px] font-bold tracking-[0.4em] uppercase text-[#FF4B4B] reveal" style="--delay: 0;">About MODO</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tighter font-outfit mt-6 reveal" style="--delay: 1;">
        단순함 속에 담긴<br>완벽한 스타일
      </h2>
      <p class="text-black/40 text-base md:text-lg mt-6 max-w-2xl mx-auto reveal" style="--delay: 2;">
        MODO는 불필요한 것을 덜어내고 본질에 집중하는 라이프스타일 쇼핑몰입니다. 엄격한 기준으로 선별된 제품만을 소개합니다.
      </p>
      <div class="grid grid-cols-4 gap-8 max-w-2xl mx-auto mt-16">
        <div class="reveal" style="--delay: 0;"><p class="text-3xl font-black font-outfit">500+</p><p class="text-[11px] text-black/30 mt-1">큐레이션 아이템</p></div>
        <div class="reveal" style="--delay: 1;"><p class="text-3xl font-black font-outfit">50K+</p><p class="text-[11px] text-black/30 mt-1">고객 수</p></div>
        <div class="reveal" style="--delay: 2;"><p class="text-3xl font-black font-outfit">98%</p><p class="text-[11px] text-black/30 mt-1">재구매율</p></div>
        <div class="reveal" style="--delay: 3;"><p class="text-3xl font-black font-outfit">무료</p><p class="text-[11px] text-black/30 mt-1">배송 · 반품</p></div>
      </div>
    </div>
  </section>

  <!-- ========== New Arrivals ========== -->
  <section id="new" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="flex items-end justify-between mb-14">
