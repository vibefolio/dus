            <div class="absolute top-3 left-3"><span class="bg-[#FF4B4B] text-white text-[10px] font-bold px-2.5 py-1 uppercase tracking-wider">New</span></div>
            <button class="cart-btn absolute bottom-3 left-3 right-3 bg-black text-white py-3 text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-[#FF4B4B] transition-all duration-500">Add to Cart</button>
          </div>
          <h3 class="font-semibold text-sm">미니멀 손목시계</h3>
          <p class="text-black/40 text-[12px] mt-1">MODO Essential</p>
          <p class="font-bold text-sm mt-2 font-outfit">189,000원</p>
        </div>

        <div class="product-card group reveal" style="--delay: 1;">
          <div class="relative overflow-hidden bg-[#F5F5F5] mb-4">
            <img src="https://images.unsplash.com/photo-1491637639811-60e2756cc1c7?q=80&w=600" alt="선글라스" class="w-full aspect-[3/4] object-cover transition-transform duration-700" loading="lazy" decoding="async">
            <div class="absolute top-3 left-3"><span class="bg-[#FF4B4B] text-white text-[10px] font-bold px-2.5 py-1 uppercase tracking-wider">New</span></div>
            <button class="cart-btn absolute bottom-3 left-3 right-3 bg-black text-white py-3 text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-[#FF4B4B] transition-all duration-500">Add to Cart</button>
          </div>
          <h3 class="font-semibold text-sm">클래식 선글라스</h3>
          <p class="text-black/40 text-[12px] mt-1">MODO Eyewear</p>
          <p class="font-bold text-sm mt-2 font-outfit">129,000원</p>
        </div>

        <div class="product-card group reveal" style="--delay: 2;">
          <div class="relative overflow-hidden bg-[#F5F5F5] mb-4">
            <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=600" alt="가방" class="w-full aspect-[3/4] object-cover transition-transform duration-700" loading="lazy" decoding="async">
            <button class="cart-btn absolute bottom-3 left-3 right-3 bg-black text-white py-3 text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-[#FF4B4B] transition-all duration-500">Add to Cart</button>
          </div>
          <h3 class="font-semibold text-sm">레더 토트백</h3>
          <p class="text-black/40 text-[12px] mt-1">MODO Bag</p>
          <p class="font-bold text-sm mt-2 font-outfit">249,000원</p>
        </div>

        <div class="product-card group reveal" style="--delay: 3;">
          <div class="relative overflow-hidden bg-[#F5F5F5] mb-4">
            <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=600" alt="스니커즈" class="w-full aspect-[3/4] object-cover transition-transform duration-700" loading="lazy" decoding="async">
            <button class="cart-btn absolute bottom-3 left-3 right-3 bg-black text-white py-3 text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-[#FF4B4B] transition-all duration-500">Add to Cart</button>
          </div>
          <h3 class="font-semibold text-sm">화이트 스니커즈</h3>
          <p class="text-black/40 text-[12px] mt-1">MODO Shoes</p>
          <p class="font-bold text-sm mt-2 font-outfit">159,000원</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Category ========== -->
  <section id="category" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-14">
        <span class="text-[11px] font-bold tracking-[0.4em] uppercase text-[#FF4B4B] reveal" style="--delay: 0;">Categories</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tighter font-outfit mt-4 reveal" style="--delay: 1;">카테고리</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="#" class="group relative overflow-hidden aspect-[3/4] reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=600" alt="의류" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async">
          <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors duration-500"></div>
          <div class="absolute bottom-6 left-6"><p class="text-white font-bold text-lg font-outfit">의류</p><p class="text-white/60 text-[11px] uppercase tracking-wider mt-1">Clothing</p></div>
        </a>
        <a href="#" class="group relative overflow-hidden aspect-[3/4] reveal" style="--delay: 1;">
          <img src="https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?q=80&w=600" alt="신발" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async">
          <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors duration-500"></div>
          <div class="absolute bottom-6 left-6"><p class="text-white font-bold text-lg font-outfit">신발</p><p class="text-white/60 text-[11px] uppercase tracking-wider mt-1">Shoes</p></div>
        </a>
        <a href="#" class="group relative overflow-hidden aspect-[3/4] reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1611923134239-b9be5816e23c?q=80&w=600" alt="가방" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async">
          <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors duration-500"></div>
          <div class="absolute bottom-6 left-6"><p class="text-white font-bold text-lg font-outfit">가방</p><p class="text-white/60 text-[11px] uppercase tracking-wider mt-1">Bags</p></div>
        </a>
        <a href="#" class="group relative overflow-hidden aspect-[3/4] reveal" style="--delay: 3;">
          <img src="https://images.unsplash.com/photo-1612817159949-195b6eb9e31a?q=80&w=600" alt="액세서리" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async">
          <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors duration-500"></div>
          <div class="absolute bottom-6 left-6"><p class="text-white font-bold text-lg font-outfit">액세서리</p><p class="text-white/60 text-[11px] uppercase tracking-wider mt-1">Accessories</p></div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== Best Sellers ========== -->
  <section id="best" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-14">
        <span class="text-[11px] font-bold tracking-[0.4em] uppercase text-[#FF4B4B] reveal" style="--delay: 0;">Best Sellers</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tighter font-outfit mt-4 reveal" style="--delay: 1;">베스트셀러</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="group relative overflow-hidden reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1516762689617-e1cffcef479d?q=80&w=800" alt="베스트 1" class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async">
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
          <div class="absolute bottom-6 left-6 right-6">
            <span class="text-[#FF4B4B] text-[10px] font-bold uppercase tracking-wider">#1 Best Seller</span>
            <h3 class="text-white font-bold text-lg mt-1">오버사이즈 코트</h3>
            <p class="text-white/60 text-sm font-outfit mt-1">329,000원</p>
