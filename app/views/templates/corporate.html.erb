<%# Corporate Template - 넥서스 그룹 (NEXUS GROUP) — 기업 홈페이지 %>

<style>
  /* Supanova Design Upgrade */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

  .font-display { font-family: 'Manrope', sans-serif; }
  .font-body { font-family: 'Noto Sans KR', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 32px !important; }
  }

  /* Scroll Reveal */
  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Counter Animation */
  .counter-box {
    background: linear-gradient(135deg, #1E3A5F 0%, #2D4A6F 100%);
  }

  /* Subtle grid pattern */
  .grid-bg {
    background-size: 60px 60px;
    background-image:
      linear-gradient(to right, rgba(30, 58, 95, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(30, 58, 95, 0.04) 1px, transparent 1px);
  }
</style>

<div class="bg-white text-[#2D3748] font-body selection:bg-[#1E3A5F] selection:text-white min-h-screen overflow-x-hidden relative grid-bg">

  <!-- Nav -->
  <nav class="fixed w-full z-50 px-6 py-5 bg-white/95 backdrop-blur-xl border-b border-gray-100 shadow-sm">
    <div class="container mx-auto px-4 md:px-6 flex justify-between items-center flex-nowrap">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-[#1E3A5F] rounded-md flex items-center justify-center text-white font-display font-bold text-sm">N</div>
        <span class="font-display text-xl font-bold tracking-tight text-[#1E3A5F]">NEXUS<span class="text-[#1E3A5F]/40">GROUP</span></span>
      </div>

      <div class="hidden md:flex gap-10 text-[13px] font-medium text-[#2D3748]/70">
        <a href="#about" class="hover:text-[#1E3A5F] transition">회사소개</a>
        <a href="#services" class="hover:text-[#1E3A5F] transition">서비스</a>
        <a href="#performance" class="hover:text-[#1E3A5F] transition">실적</a>
        <a href="#partners" class="hover:text-[#1E3A5F] transition">파트너</a>
        <a href="#contact" class="hover:text-[#1E3A5F] transition">문의</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: #1E3A5F;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="flex-nowrap shrink-0 flex gap-4 items-center">
        <button onclick="toggleCorporateModal()" class="hidden md:block text-[13px] font-medium text-[#2D3748]/60 hover:text-[#1E3A5F]" data-mobile-menu-copy="true">로그인</button>
        <button class="hidden md:inline-flex bg-[#1E3A5F] text-white px-5 py-2.5 rounded-md font-semibold text-[13px] hover:bg-[#2D4A6F] transition shadow-lg shadow-[#1E3A5F]/20" data-mobile-menu-copy="true">
          무료 상담 신청
        </button>
      </div>
    </div>
    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- Hero -->
  <header class="min-h-screen relative flex items-center pt-24 overflow-hidden">
    <div class="absolute right-0 top-1/4 w-[600px] h-[600px] bg-gradient-to-bl from-[#1E3A5F]/5 to-transparent rounded-full blur-3xl pointer-events-none"></div>
    <div class="container mx-auto px-6 md:px-12 grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-[#1E3A5F]/5 border border-[#1E3A5F]/10 rounded-full px-4 py-1.5">
          <span class="w-2 h-2 bg-[#1E3A5F] rounded-full animate-pulse"></span>
          <span class="text-[12px] font-medium text-[#1E3A5F]">2024 대한민국 혁신기업 선정</span>
        </div>

        <h1 class="text-4xl md:text-6xl font-display font-bold leading-[1.15] tracking-tight text-[#1E3A5F] mobile-title">
          비즈니스의 미래를<br>
          <span class="text-[#2D3748]/40">함께 설계합니다</span>
        </h1>

        <p class="text-lg md:text-xl text-[#2D3748]/70 leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc">
          넥서스 그룹은 디지털 혁신과 전략 컨설팅으로 기업의 지속가능한 성장을 이끕니다.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#contact" class="px-8 py-4 bg-[#1E3A5F] text-white font-semibold text-[15px] rounded-md hover:bg-[#2D4A6F] transition shadow-lg shadow-[#1E3A5F]/20">
            기업 상담 신청
          </a>
          <a href="#about" class="px-8 py-4 border border-[#1E3A5F]/20 text-[#1E3A5F] font-semibold text-[15px] rounded-md hover:bg-[#1E3A5F]/5 transition">
