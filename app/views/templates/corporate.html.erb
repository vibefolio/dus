          </a>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=700&h=500&fit=crop" alt="기업 오피스" class="rounded-2xl shadow-2xl shadow-[#1E3A5F]/10 w-full object-cover aspect-[4/3]">
