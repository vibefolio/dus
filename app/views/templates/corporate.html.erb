  <!-- Scripts -->
  <script>
    function toggleCorporateModal() {
      const modal = document.getElementById('corporate-modal');
      modal.classList.toggle('hidden');
      modal.classList.toggle('flex');
    }
    document.getElementById('corporate-modal').addEventListener('click', function(e) {
      if (e.target === this) toggleCorporateModal();
    });

    // Counter Animation
    function animateCount(el, target, suffix) {
      let start = 0;
      const duration = 2000;
      const startTime = performance.now();
      function update(now) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target) + (suffix || '');
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    // IntersectionObserver for scroll reveal
    (function() {
      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            // Trigger counters
            entry.target.querySelectorAll('[data-count]').forEach(function(el) {
              animateCount(el, parseInt(el.dataset.count), el.dataset.suffix || '');
            });
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      document.querySelectorAll('.reveal').forEach(function(el) {
        observer.observe(el);
      });
    })();
  </script>

