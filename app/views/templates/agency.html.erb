<%# Agency Template - WAVE %>

<style>
  /* Supanova Design — Bold Agency Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }
  .font-display { font-family: 'Space Grotesk', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 36px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .service-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .service-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(255,107,107,0.12); }
</style>

<div class="bg-[#FFFFFF] text-[#1E293B] font-sans selection:bg-[#FF6B6B] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-4 bg-white/80 backdrop-blur-xl border-b border-slate-100">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="font-display font-bold text-2xl tracking-tight">W<span class="text-[#FF6B6B]">AVE</span></a>

      <div class="hidden md:flex gap-10 text-sm font-medium text-slate-400">
        <a href="#services" class="hover:text-[#FF6B6B] transition">서비스</a>
        <a href="#portfolio" class="hover:text-[#FF6B6B] transition">포트폴리오</a>
        <a href="#about" class="hover:text-[#FF6B6B] transition">소개</a>
        <a href="#contact" class="hover:text-[#FF6B6B] transition">문의</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="#contact" class="bg-[#FF6B6B] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#EF4444] shadow-lg shadow-[#FF6B6B]/20" data-mobile-menu-copy="true">프로젝트 의뢰</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#FFF1F1] via-white to-[#FFE4E4]"></div>
    <div class="absolute top-20 right-20 w-[500px] h-[500px] bg-[#FF6B6B]/5 rounded-full blur-[150px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 w-full py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 text-center lg:text-left">
          <div class="inline-flex items-center gap-2 bg-white px-4 py-2 rounded-full border border-[#FF6B6B]/20 shadow-sm reveal" style="--delay: 0;">
            <span class="w-2 h-2 bg-[#FF6B6B] rounded-full animate-pulse"></span>
            <span class="text-sm font-semibold text-[#FF6B6B]">디지털 마케팅 전문</span>
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mobile-title reveal" style="--delay: 1;">
            브랜드에<br>
            <span class="text-[#FF6B6B]">파도를 일으킵니다</span>
          </h1>

          <p class="text-slate-400 text-base md:text-lg leading-relaxed max-w-md mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
            WAVE는 데이터 기반 디지털 마케팅 에이전시입니다. 브랜딩, 퍼포먼스 마케팅, 콘텐츠 제작까지 원스톱으로 제공합니다.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
            <a href="#contact" class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-[#FF6B6B] text-white rounded-full font-semibold shadow-lg shadow-[#FF6B6B]/25 hover:bg-[#EF4444]">
              무료 컨설팅 받기
            </a>
            <a href="#portfolio" class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-slate-200 rounded-full font-semibold text-slate-600 hover:border-[#FF6B6B] hover:text-[#FF6B6B]">
              포트폴리오 보기
            </a>
          </div>

          <div class="flex items-center gap-8 justify-center lg:justify-start pt-4 reveal" style="--delay: 4;">
            <div class="text-center">
              <p class="text-2xl font-bold text-[#FF6B6B]">300+</p>
              <p class="text-xs text-slate-400 mt-1">프로젝트</p>
            </div>
            <div class="w-px h-8 bg-slate-200"></div>
            <div class="text-center">
              <p class="text-2xl font-bold text-[#FF6B6B]">150+</p>
              <p class="text-xs text-slate-400 mt-1">파트너</p>
            </div>
            <div class="w-px h-8 bg-slate-200"></div>
            <div class="text-center">
              <p class="text-2xl font-bold text-[#FF6B6B]">ROAS 5x</p>
              <p class="text-xs text-slate-400 mt-1">평균 성과</p>
            </div>
          </div>
        </div>

        <div class="relative hidden lg:block reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=800" alt="팀 미팅" class="w-full h-[550px] object-cover rounded-3xl shadow-2xl">
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 서비스 ========== -->
  <section id="services" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#FF6B6B] tracking-wider uppercase reveal" style="--delay: 0;">Services</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">마케팅 서비스</h2>
        <p class="text-slate-400 text-base mt-4 max-w-lg mx-auto reveal" style="--delay: 2;">데이터와 크리에이티브의 완벽한 조합</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="service-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#FF6B6B]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-bullseye text-[#FF6B6B] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">퍼포먼스 마케팅</h3>
          <p class="text-sm text-slate-400 leading-relaxed">Google, Meta, 네이버 등 광고 플랫폼 최적화로 ROAS를 극대화합니다.</p>
        </div>

        <div class="service-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#FF6B6B]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-pen-nib text-[#FF6B6B] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">브랜드 전략</h3>
          <p class="text-sm text-slate-400 leading-relaxed">브랜드 아이덴티티, 네이밍, 포지셔닝 등 전략적 브랜딩 서비스.</p>
        </div>

        <div class="service-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 2;">
          <div class="w-14 h-14 bg-[#FF6B6B]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-video text-[#FF6B6B] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">콘텐츠 제작</h3>
          <p class="text-sm text-slate-400 leading-relaxed">SNS 콘텐츠, 영상, 카피라이팅 등 크리에이티브 콘텐츠 제작.</p>
        </div>

        <div class="service-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#FF6B6B]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-chart-bar text-[#FF6B6B] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">데이터 분석</h3>
          <p class="text-sm text-slate-400 leading-relaxed">GA4, 전환 추적, A/B 테스트 등 데이터 기반 의사결정 지원.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 포트폴리오 ========== -->
  <section id="portfolio" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#FF6B6B] tracking-wider uppercase reveal" style="--delay: 0;">Portfolio</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">최근 프로젝트</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="group reveal" style="--delay: 0;">
          <div class="overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=800" alt="포트폴리오 1" class="w-full aspect-video object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <div class="mt-4">
            <span class="text-xs font-semibold text-[#FF6B6B]">Performance</span>
            <h3 class="font-bold text-lg mt-1">F&B 브랜드 런칭</h3>
            <p class="text-sm text-slate-400 mt-1">3개월 만에 MAU 50만 달성. ROAS 720% 기록.</p>
          </div>
        </div>

        <div class="group reveal" style="--delay: 1;">
          <div class="overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1553895501-af9e282e7fc1?q=80&w=800" alt="포트폴리오 2" class="w-full aspect-video object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <div class="mt-4">
            <span class="text-xs font-semibold text-[#FF6B6B]">Branding</span>
            <h3 class="font-bold text-lg mt-1">패션 브랜드 리브랜딩</h3>
            <p class="text-sm text-slate-400 mt-1">브랜드 인지도 300% 향상. SNS 팔로워 10만 돌파.</p>
          </div>
        </div>

        <div class="group reveal" style="--delay: 2;">
          <div class="overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=800" alt="포트폴리오 3" class="w-full aspect-video object-cover group-hover:scale-105 transition duration-700" loading="lazy">
          </div>
          <div class="mt-4">
            <span class="text-xs font-semibold text-[#FF6B6B]">Content</span>
            <h3 class="font-bold text-lg mt-1">테크 스타트업 마케팅</h3>
            <p class="text-sm text-slate-400 mt-1">콘텐츠 마케팅으로 리드 생성 500% 증가.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 소개 ========== -->
  <section id="about" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
          <div>
            <span class="text-sm font-semibold text-[#FF6B6B] tracking-wider uppercase reveal" style="--delay: 0;">About</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">파도를 만드는 사람들</h2>
          </div>

          <p class="text-slate-400 text-base md:text-lg leading-relaxed reveal" style="--delay: 2;">
            WAVE는 2018년 설립된 풀서비스 디지털 마케팅 에이전시입니다. 브랜드 전략, 퍼포먼스 마케팅, 크리에이티브 콘텐츠를 통합적으로 제공하여 클라이언트의 비즈니스 성장을 돕습니다.
          </p>

          <div class="grid grid-cols-2 gap-6 reveal" style="--delay: 3;">
            <div class="bg-white p-6 rounded-xl border border-slate-100">
              <p class="text-3xl font-bold text-[#FF6B6B]">25명</p>
              <p class="text-sm text-slate-400 mt-1">전문 팀원</p>
            </div>
            <div class="bg-white p-6 rounded-xl border border-slate-100">
              <p class="text-3xl font-bold text-[#FF6B6B]">6년</p>
              <p class="text-sm text-slate-400 mt-1">업계 경험</p>
            </div>
          </div>
        </div>

        <div class="relative reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=700" alt="팀" class="w-full aspect-[4/3] object-cover rounded-3xl shadow-xl" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 고객 후기 ========== -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#FF6B6B] tracking-wider uppercase reveal" style="--delay: 0;">Testimonials</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">클라이언트 후기</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="bg-[#FFF1F1] p-8 rounded-2xl reveal" style="--delay: 0;">
          <div class="flex items-center gap-1 text-[#FF6B6B] mb-4">
            <i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i>
          </div>
          <p class="text-sm text-slate-500 leading-relaxed italic">"ROAS가 3배나 올랐습니다. 데이터 기반 접근이 확실히 다르다는 것을 체감했어요."</p>
          <p class="text-sm font-bold mt-4">김OO 대표</p>
          <p class="text-xs text-slate-400">뷰티 브랜드</p>
        </div>

        <div class="bg-[#FFF1F1] p-8 rounded-2xl reveal" style="--delay: 1;">
          <div class="flex items-center gap-1 text-[#FF6B6B] mb-4">
            <i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i>
          </div>
          <p class="text-sm text-slate-500 leading-relaxed italic">"브랜딩 리뉴얼 후 고객 반응이 확 달라졌어요. 전략적인 접근이 인상적이었습니다."</p>
          <p class="text-sm font-bold mt-4">박OO 이사</p>
          <p class="text-xs text-slate-400">F&B 프랜차이즈</p>
        </div>

        <div class="bg-[#FFF1F1] p-8 rounded-2xl reveal" style="--delay: 2;">
          <div class="flex items-center gap-1 text-[#FF6B6B] mb-4">
            <i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i><i class="fas fa-star text-xs"></i>
          </div>
          <p class="text-sm text-slate-500 leading-relaxed italic">"콘텐츠 제작부터 광고 운영까지 원스톱으로 해결되니 정말 편했습니다."</p>
          <p class="text-sm font-bold mt-4">이OO 팀장</p>
          <p class="text-xs text-slate-400">테크 스타트업</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 문의 ========== -->
  <section id="contact" class="py-24 md:py-32 bg-gradient-to-br from-[#FF6B6B] to-[#EF4444] text-white relative overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full blur-[100px]"></div>

    <div class="max-w-4xl mx-auto px-4 md:px-8 relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold reveal" style="--delay: 0;">프로젝트 문의</h2>
        <p class="text-white/70 text-base mt-4 reveal" style="--delay: 1;">무료 컨설팅을 통해 최적의 마케팅 전략을 제안드립니다</p>
      </div>

      <div class="bg-white/10 backdrop-blur-xl rounded-3xl p-8 md:p-12 reveal" style="--delay: 2;">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">회사명</label>
            <input type="text" placeholder="회사명" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">담당자</label>
            <input type="text" placeholder="이름" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">이메일</label>
            <input type="email" placeholder="email@company.com" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">관심 서비스</label>
            <select class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white outline-none focus:border-white/60 transition">
              <option value="">선택해주세요</option>
              <option>퍼포먼스 마케팅</option>
              <option>브랜드 전략</option>
              <option>콘텐츠 제작</option>
              <option>데이터 분석</option>
              <option>통합 마케팅</option>
            </select>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-white/80 mb-2">프로젝트 설명</label>
            <textarea rows="3" placeholder="마케팅 목표와 현재 상황을 알려주세요" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition resize-none"></textarea>
          </div>
        </div>
        <button class="w-full mt-8 bg-white text-[#FF6B6B] py-4 rounded-full font-bold text-lg hover:bg-[#FFF1F1] shadow-lg">문의 보내기</button>
      </div>
    </div>
  </section>

  <!-- ========== Footer ========== -->
  <footer class="py-16 md:py-24 bg-[#0F172A] text-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="grid md:grid-cols-3 gap-12 mb-16">
        <div>
          <p class="font-display font-bold text-xl mb-4">W<span class="text-[#FF6B6B]">AVE</span></p>
          <p class="text-white/30 text-sm leading-relaxed">서울특별시 마포구 양화로 186<br>웨이브 빌딩 5층</p>
          <p class="text-white/30 text-sm mt-2">대표: 이웨이브 | 사업자등록번호: 012-34-56789</p>
        </div>

        <div class="grid grid-cols-2 gap-8">
          <div>
