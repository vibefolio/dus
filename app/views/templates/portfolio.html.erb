      <a href="#" class="font-mono font-bold text-xl tracking-tight">STUDIO<span class="text-white/30">KIM</span></a>

      <div class="hidden md:flex gap-10 text-sm font-mono text-white/30">
        <a href="#work" class="hover:text-white transition">Work</a>
        <a href="#about" class="hover:text-white transition">About</a>
        <a href="#contact" class="hover:text-white transition">Contact</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="#contact" class="border border-white/20 text-white px-6 py-2.5 rounded-full text-sm font-mono font-medium hover:bg-white hover:text-black" data-mobile-menu-copy="true">프로젝트 문의</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

