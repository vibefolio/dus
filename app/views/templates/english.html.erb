<%# English Template - SPEAK UP (영어 학원) %>

<style>
  /* Supanova Design — English Academy Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-poppins { font-family: 'Poppins', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 38px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .program-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .program-card:hover { transform: translateY(-8px); }
  .program-card:hover .program-icon { transform: scale(1.1) rotate(-5deg); }
</style>

<div class="bg-white text-[#1F2937] font-sans selection:bg-[#F97316] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-white/80 backdrop-blur-xl border-b border-[#F97316]/5">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <span class="font-poppins text-2xl font-black tracking-tight text-[#F97316]">SPEAK</span>
        <span class="font-poppins text-2xl font-black tracking-tight text-[#1F2937]">UP</span>
      </a>

      <div class="hidden md:flex gap-10 text-[11px] font-semibold uppercase tracking-[0.3em] text-[#1F2937]/40">
        <a href="#programs" class="hover:text-[#F97316] transition">프로그램</a>
        <a href="#level-test" class="hover:text-[#F97316] transition">레벨테스트</a>
        <a href="#reviews" class="hover:text-[#F97316] transition">후기</a>
        <a href="#contact" class="hover:text-[#F97316] transition">상담</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center shrink-0">
        <button onclick="toggleEnglishModal()" class="text-[11px] font-semibold text-[#1F2937]/40 hover:text-[#F97316] tracking-[0.2em] uppercase" data-mobile-menu-copy="true">로그인</button>
        <a href="#contact" class="bg-[#F97316] text-white px-7 py-3 rounded-full font-semibold text-[11px] tracking-[0.2em] uppercase hover:bg-[#EA580C] shadow-lg shadow-[#F97316]/20" data-mobile-menu-copy="true">무료 레벨테스트</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute top-0 right-0 w-[50%] h-full bg-[#FFF7ED] rounded-bl-[4rem] hidden lg:block"></div>
    <div class="absolute top-40 left-10 w-20 h-20 bg-[#F97316]/10 rounded-full blur-[40px]"></div>
    <div class="absolute bottom-20 right-20 w-32 h-32 bg-[#FDBA74]/20 rounded-full blur-[60px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-3 bg-[#F97316]/5 rounded-full px-5 py-2 reveal" style="--delay: 0;">
          <span class="text-[11px] font-bold tracking-[0.2em] uppercase text-[#F97316]">English Made Fun</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-[4.5rem] font-bold leading-tight tracking-tight mobile-title reveal" style="--delay: 1;">
          말하는 영어,<br><span class="text-[#F97316] font-poppins">Speak Up!</span>
        </h1>

        <p class="text-[#1F2937]/50 text-base md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          원어민 강사와 함께하는 실전 회화 중심의 영어 교육. 듣기만 하는 영어는 그만, 직접 말하고 소통하는 진짜 영어를 경험하세요.
        </p>

        <div class="pt-2 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#level-test" class="inline-flex items-center justify-center gap-3 px-9 py-4 bg-[#F97316] text-white font-bold text-[12px] tracking-[0.15em] uppercase hover:bg-[#EA580C] rounded-full shadow-xl shadow-[#F97316]/20">
            무료 레벨테스트 <i class="fas fa-arrow-right text-[10px]"></i>
          </a>
          <a href="#programs" class="inline-flex items-center justify-center px-9 py-4 border-2 border-[#1F2937]/10 text-[#1F2937] font-semibold text-[12px] tracking-[0.15em] uppercase hover:border-[#F97316]/30 rounded-full">
            프로그램 보기
          </a>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <div class="bg-[#FFF7ED] rounded-[2.5rem] p-4 lg:p-0 lg:bg-transparent">
          <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=800&auto=format&fit=crop" alt="교실" class="w-full aspect-[4/5] object-cover rounded-[2rem] shadow-2xl" loading="eager" decoding="async">
        </div>
        <div class="absolute -bottom-4 -left-4 md:-bottom-6 md:-left-6 bg-white p-5 rounded-2xl shadow-xl border border-[#F97316]/10">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#F97316] rounded-full flex items-center justify-center text-white text-lg">
              <i class="fas fa-comments"></i>
            </div>
            <div>
              <p class="text-sm font-bold">회화 중심 수업</p>
              <p class="text-[11px] text-[#1F2937]/40">Speaking 70%</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About ========== -->
  <section id="about" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="space-y-8 reveal" style="--delay: 0;">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#F97316]/5 text-[#F97316]">About Us</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug">
          영어, 이제<br>자신있게 말하세요
        </h2>
        <p class="text-[#1F2937]/50 text-base md:text-lg leading-relaxed">
          SPEAK UP은 10년간 오직 '말하는 영어'에 집중해온 영어 전문 학원입니다. 원어민 강사와 한국인 강사의 팀티칭 시스템으로 정확한 발음과 자연스러운 표현을 동시에 잡아줍니다.
        </p>
        <div class="grid grid-cols-2 gap-6">
          <div class="text-center p-6 bg-[#FFF7ED] rounded-2xl">
            <p class="text-3xl font-bold text-[#F97316] font-poppins">5,000+</p>
            <p class="text-[12px] text-[#1F2937]/50 mt-2 font-medium">누적 수강생</p>
          </div>
          <div class="text-center p-6 bg-[#FFF7ED] rounded-2xl">
            <p class="text-3xl font-bold text-[#F97316] font-poppins">96%</p>
            <p class="text-[12px] text-[#1F2937]/50 mt-2 font-medium">만족도</p>
          </div>
          <div class="text-center p-6 bg-[#FFF7ED] rounded-2xl">
            <p class="text-3xl font-bold text-[#F97316] font-poppins">12</p>
            <p class="text-[12px] text-[#1F2937]/50 mt-2 font-medium">원어민 강사</p>
          </div>
          <div class="text-center p-6 bg-[#FFF7ED] rounded-2xl">
            <p class="text-3xl font-bold text-[#F97316] font-poppins">10yr</p>
            <p class="text-[12px] text-[#1F2937]/50 mt-2 font-medium">교육 경력</p>
          </div>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 1;">
        <div class="grid grid-cols-5 gap-3">
          <div class="col-span-3 overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?q=80&w=800&auto=format&fit=crop" alt="영어 수업" class="w-full h-full object-cover aspect-[3/4]" loading="lazy" decoding="async">
          </div>
          <div class="col-span-2 flex flex-col gap-3">
            <div class="overflow-hidden rounded-2xl flex-1">
              <img src="https://images.unsplash.com/photo-1544717305-2782549b5136?q=80&w=800&auto=format&fit=crop" alt="회화 수업" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
            <div class="overflow-hidden rounded-2xl flex-1">
              <img src="https://images.unsplash.com/photo-1434030216411-0b793f4b4173?q=80&w=800&auto=format&fit=crop" alt="시험/자격증" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Programs ========== -->
  <section id="programs" class="py-24 md:py-32 bg-[#FFF7ED]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#F97316]/10 text-[#F97316] reveal" style="--delay: 0;">Programs</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6 reveal" style="--delay: 1;">
          레벨에 맞는<br>최적의 프로그램
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="program-card bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl reveal" style="--delay: 0;">
          <div class="program-icon w-16 h-16 bg-[#F97316] rounded-2xl flex items-center justify-center mb-6 transition-transform duration-500">
            <i class="fas fa-baby text-white text-2xl"></i>
          </div>
          <span class="text-[10px] font-bold text-[#F97316] uppercase tracking-[0.2em]">Beginner</span>
          <h3 class="text-lg font-bold mt-2 mb-3">기초 영어 회화</h3>
          <p class="text-[13px] text-[#1F2937]/50 leading-relaxed mb-4">알파벳부터 기본 문장 구조까지, 영어의 첫걸음을 탄탄하게 시작하는 과정</p>
          <p class="text-[#F97316] font-bold text-lg font-poppins">월 180,000원</p>
        </div>

        <div class="program-card bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl reveal" style="--delay: 1;">
          <div class="program-icon w-16 h-16 bg-[#F97316] rounded-2xl flex items-center justify-center mb-6 transition-transform duration-500">
            <i class="fas fa-comments text-white text-2xl"></i>
          </div>
          <span class="text-[10px] font-bold text-[#F97316] uppercase tracking-[0.2em]">Intermediate</span>
          <h3 class="text-lg font-bold mt-2 mb-3">실전 스피킹</h3>
          <p class="text-[13px] text-[#1F2937]/50 leading-relaxed mb-4">일상 회화부터 비즈니스 상황까지, 실전에서 바로 쓸 수 있는 표현 학습</p>
          <p class="text-[#F97316] font-bold text-lg font-poppins">월 220,000원</p>
        </div>

        <div class="program-card bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl ring-2 ring-[#F97316] reveal" style="--delay: 2;">
          <div class="absolute -top-3 right-6"><span class="bg-[#F97316] text-white text-[10px] font-bold uppercase tracking-[0.15em] px-3 py-1 rounded-full">인기</span></div>
          <div class="program-icon w-16 h-16 bg-[#F97316] rounded-2xl flex items-center justify-center mb-6 transition-transform duration-500">
            <i class="fas fa-microphone text-white text-2xl"></i>
          </div>
          <span class="text-[10px] font-bold text-[#F97316] uppercase tracking-[0.2em]">Advanced</span>
          <h3 class="text-lg font-bold mt-2 mb-3">프리토킹 마스터</h3>
          <p class="text-[13px] text-[#1F2937]/50 leading-relaxed mb-4">원어민과 자유롭게 토론하며 네이티브에 가까운 영어 실력을 완성하는 과정</p>
          <p class="text-[#F97316] font-bold text-lg font-poppins">월 280,000원</p>
        </div>

        <div class="program-card bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl reveal" style="--delay: 3;">
          <div class="program-icon w-16 h-16 bg-[#F97316] rounded-2xl flex items-center justify-center mb-6 transition-transform duration-500">
            <i class="fas fa-briefcase text-white text-2xl"></i>
          </div>
          <span class="text-[10px] font-bold text-[#F97316] uppercase tracking-[0.2em]">Business</span>
          <h3 class="text-lg font-bold mt-2 mb-3">비즈니스 영어</h3>
          <p class="text-[13px] text-[#1F2937]/50 leading-relaxed mb-4">프레젠테이션, 이메일, 미팅 영어까지 직장인을 위한 맞춤 비즈니스 과정</p>
          <p class="text-[#F97316] font-bold text-lg font-poppins">월 300,000원</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Level Test ========== -->
  <section id="level-test" class="py-24 md:py-32 bg-[#1F2937] text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#F97316]/10 rounded-full blur-[120px]"></div>
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div class="reveal" style="--delay: 0;">
          <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#F97316]/20 text-[#F97316]">Level Test</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6">
            나의 영어 레벨은?
          </h2>
          <p class="text-white/50 text-base md:text-lg mt-4 leading-relaxed">
            무료 레벨테스트로 현재 실력을 정확하게 진단받으세요. AI 기반 분석과 원어민 강사의 1:1 피드백을 함께 제공합니다.
          </p>
        </div>
        <div class="space-y-4 reveal" style="--delay: 1;">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-[#F97316] rounded-full flex items-center justify-center text-white font-bold font-poppins">1</div>
            <div><p class="font-semibold">온라인 테스트 (15분)</p><p class="text-white/40 text-[13px]">문법, 어휘, 독해 능력 측정</p></div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-[#F97316] rounded-full flex items-center justify-center text-white font-bold font-poppins">2</div>
            <div><p class="font-semibold">1:1 스피킹 인터뷰 (10분)</p><p class="text-white/40 text-[13px]">원어민 강사와 실시간 회화 테스트</p></div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-[#F97316] rounded-full flex items-center justify-center text-white font-bold font-poppins">3</div>
            <div><p class="font-semibold">맞춤 학습 플랜 제공</p><p class="text-white/40 text-[13px]">레벨에 맞는 최적의 프로그램 추천</p></div>
          </div>
        </div>
      </div>

      <div class="bg-white/5 backdrop-blur-sm rounded-3xl p-8 md:p-10 border border-white/10 reveal" style="--delay: 2;">
        <h3 class="text-xl font-bold mb-6 text-white">무료 레벨테스트 신청</h3>
        <div class="space-y-4">
          <input type="text" placeholder="이름" class="w-full bg-white/5 border border-white/10 rounded-xl py-4 px-5 outline-none focus:ring-2 focus:ring-[#F97316]/30 transition text-[13px] text-white placeholder-white/30">
          <input type="tel" placeholder="연락처" class="w-full bg-white/5 border border-white/10 rounded-xl py-4 px-5 outline-none focus:ring-2 focus:ring-[#F97316]/30 transition text-[13px] text-white placeholder-white/30">
          <select class="w-full bg-white/5 border border-white/10 rounded-xl py-4 px-5 outline-none focus:ring-2 focus:ring-[#F97316]/30 transition text-[13px] text-white/50">
            <option>현재 영어 수준을 선택하세요</option><option>완전 초보</option><option>기초 (간단한 인사 가능)</option><option>중급 (일상 대화 가능)</option><option>고급 (자유로운 토론 가능)</option>
          </select>
          <button class="w-full bg-[#F97316] text-white py-4 rounded-xl font-bold text-[12px] tracking-[0.2em] uppercase hover:bg-[#EA580C] shadow-lg shadow-[#F97316]/20 mt-2">레벨테스트 신청하기</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Reviews ========== -->
  <section id="reviews" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#F97316]/5 text-[#F97316] reveal" style="--delay: 0;">Reviews</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6 reveal" style="--delay: 1;">수강생 후기</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-[#FFF7ED] rounded-3xl p-8 reveal" style="--delay: 0;">
          <div class="flex gap-1 text-[#F97316] mb-4"><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i></div>
          <p class="text-[14px] text-[#1F2937]/70 leading-relaxed mb-6">6개월 다니고 해외 출장에서 통역 없이 미팅을 진행했어요! 비즈니스 영어 과정 정말 추천합니다. 실무에서 바로 쓸 수 있는 표현들을 배웠어요.</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#F97316] rounded-full flex items-center justify-center text-white text-sm font-bold">P</div>
            <div><p class="font-semibold text-sm">박성진</p><p class="text-[#1F2937]/40 text-[11px]">비즈니스 영어 6개월 수강</p></div>
          </div>
        </div>
        <div class="bg-[#FFF7ED] rounded-3xl p-8 reveal" style="--delay: 1;">
          <div class="flex gap-1 text-[#F97316] mb-4"><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i><i class="fas fa-star text-sm"></i></div>
          <p class="text-[14px] text-[#1F2937]/70 leading-relaxed mb-6">완전 왕초보였는데 3개월 만에 원어민 선생님과 대화가 가능해졌어요. 소그룹이라 말할 기회가 정말 많아서 빠르게 늘었습니다.</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#F97316] rounded-full flex items-center justify-center text-white text-sm font-bold">L</div>
            <div><p class="font-semibold text-sm">이수아</p><p class="text-[#1F2937]/40 text-[11px]">기초 영어 회화 3개월 수강</p></div>
          </div>
