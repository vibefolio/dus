<%# Dining Template - 누아르 다이닝 (NOIR DINING) %>

<style>
  /* Supanova Design — Luxurious Cinematic Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-serif { font-family: 'Cormorant Garamond', serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 42px !important; }
  }

  .linen-overlay {
    background-image: url("https://www.transparenttextures.com/patterns/black-linen.png");
    opacity: 0.2;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }

  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  .menu-card {
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .menu-card:hover {
    transform: translateY(-8px);
  }
  .menu-card:hover img {
    transform: scale(1.05);
  }

  .gallery-item {
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-item:hover {
    transform: scale(1.02);
  }
  .gallery-item:hover img {
    transform: scale(1.08);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
</style>

<div class="bg-[#0A0A0A] text-[#E8E0D4] font-sans selection:bg-[#C9A96E] selection:text-[#0A0A0A] min-h-screen overflow-x-hidden relative">
  <div class="fixed inset-0 linen-overlay pointer-events-none z-[60]"></div>

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#0A0A0A]/80 backdrop-blur-xl border-b border-[#C9A96E]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="font-serif text-2xl tracking-[0.1em] font-semibold italic text-[#C9A96E]">Noir</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#E8E0D4]/40">
        <a href="#about" class="hover:text-[#C9A96E] transition">About</a>
        <a href="#menu" class="hover:text-[#C9A96E] transition">Course</a>
        <a href="#gallery" class="hover:text-[#C9A96E] transition">Gallery</a>
        <a href="#location" class="hover:text-[#C9A96E] transition">Reserve</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleDiningModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#E8E0D4]/40 hover:text-[#C9A96E]" data-mobile-menu-copy="true">Members</button>
        <button class="bg-[#C9A96E] text-[#0A0A0A] px-8 py-3.5 rounded-full font-semibold text-[10px] tracking-[0.3em] uppercase hover:bg-[#E8D5A3] transition shadow-lg shadow-[#C9A96E]/20" data-mobile-menu-copy="true">
          Reserve
        </button>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center justify-center pt-20">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0A0A] via-transparent to-[#0A0A0A] z-[1]"></div>
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?q=80&w=1800" alt="파인다이닝" class="w-full h-full object-cover opacity-40" loading="eager">
    </div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 text-center">
      <div class="space-y-10">
        <div class="inline-flex items-center gap-5 reveal" style="--delay: 0;">
          <span class="w-16 h-[1px] bg-[#C9A96E]/50"></span>
          <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#C9A96E]">Fine Dining &middot; Hannam</span>
          <span class="w-16 h-[1px] bg-[#C9A96E]/50"></span>
        </div>

        <h1 class="text-5xl md:text-7xl lg:text-[7rem] font-serif font-semibold leading-none tracking-tight text-[#E8E0D4] mobile-title reveal" style="--delay: 1;">
          하나의 접시에<br><span class="italic text-[#C9A96E]">계절을 담다.</span>
        </h1>

        <p class="text-[#E8E0D4]/50 text-sm md:text-lg leading-relaxed max-w-lg mx-auto mobile-desc reveal" style="--delay: 2;">
          한남동의 고요한 골목, 누아르 다이닝은 제철 식재료와 프렌치 테크닉이 만나는 곳입니다. 코스 하나하나에 셰프의 철학이 담겨 있습니다.
        </p>

        <div class="pt-4 flex flex-col sm:flex-row gap-5 justify-center reveal" style="--delay: 3;">
          <a href="#menu" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#C9A96E] text-[#0A0A0A] font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-[#E8D5A3] rounded-full shadow-xl shadow-[#C9A96E]/20">
            Today's Course
            <span class="w-7 h-7 rounded-full bg-[#0A0A0A]/10 flex items-center justify-center">
              <i class="fas fa-arrow-right text-[10px]"></i>
            </span>
          </a>
          <a href="#about" class="inline-flex items-center justify-center px-10 py-5 border border-[#C9A96E]/30 text-[#C9A96E] font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-white/5 rounded-full">
            Chef's Story
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About Section ========== -->
  <section id="about" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative reveal" style="--delay: 0;">
        <div class="absolute -top-8 -left-8 w-60 h-60 bg-[#C9A96E]/8 rounded-full blur-[80px]"></div>
        <div class="grid grid-cols-5 gap-4">
          <div class="col-span-3 overflow-hidden rounded-[2rem]">
            <img src="https://images.unsplash.com/photo-1600565193348-f74bd3c7ccdf?q=80&w=800" alt="셰프 플레이팅" class="w-full h-full object-cover aspect-[3/4]" loading="lazy" decoding="async">
          </div>
          <div class="col-span-2 flex flex-col gap-4">
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?q=80&w=600" alt="주방 풍경" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1470337458703-46ad1756a187?q=80&w=600" alt="와인 페어링" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-8 reveal" style="--delay: 1;">
        <div class="inline-flex items-center gap-4">
          <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#C9A96E]/10 text-[#C9A96E]">Philosophy</span>
        </div>

        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif font-semibold leading-snug text-[#E8E0D4]">
          식재료가<br>이야기를 시작합니다
        </h2>

        <p class="text-[#E8E0D4]/50 text-base md:text-lg leading-relaxed">
          누아르 다이닝의 박준호 셰프는 파리 Le Cinq에서 5년간 수련한 후, 한국의 제철 식재료에 프렌치 테크닉을 입히는 자신만의 요리 세계를 한남동에 펼쳤습니다.
        </p>
        <p class="text-[#E8E0D4]/50 text-base md:text-lg leading-relaxed">
          강원도 산나물, 제주 갈치, 여수 전복. 산지에서 직접 공수한 식재료로 매주 코스를 새로 구성합니다. 같은 요리는 두 번 나오지 않습니다.
        </p>

        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-[#C9A96E]/10">
          <div>
            <p class="text-2xl md:text-3xl font-serif font-semibold text-[#C9A96E] italic">7</p>
            <p class="text-[11px] text-[#E8E0D4]/40 uppercase tracking-[0.1em] mt-1 font-medium">코스 구성</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-serif font-semibold text-[#C9A96E] italic">12</p>
            <p class="text-[11px] text-[#E8E0D4]/40 uppercase tracking-[0.1em] mt-1 font-medium">좌석 한정</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-serif font-semibold text-[#C9A96E] italic">5yr</p>
            <p class="text-[11px] text-[#E8E0D4]/40 uppercase tracking-[0.1em] mt-1 font-medium">파리 수련</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Course Menu ========== -->
  <section id="menu" class="py-24 md:py-32 bg-[#111111] relative">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#C9A96E]/10 text-[#C9A96E] reveal" style="--delay: 0;">This Week</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif font-semibold leading-snug text-[#E8E0D4] mt-6 reveal" style="--delay: 1;">
          이번 주의 코스
        </h2>
        <p class="text-[#E8E0D4]/50 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">
          제철 식재료에 따라 매주 새롭게 구성됩니다. 디너 코스 150,000원.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Course 1 -->
        <div class="menu-card group reveal" style="--delay: 0;">
          <div class="bg-[#1A1A1A] rounded-[2rem] p-1.5 ring-1 ring-[#C9A96E]/10">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden">
              <div class="overflow-hidden">
                <img src="https://images.unsplash.com/photo-1544025162-d76694265947?q=80&w=600" alt="아뮤즈 부쉬" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
              </div>
              <div class="p-6 bg-[#1A1A1A]">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-lg font-semibold text-[#E8E0D4]">아뮤즈 부쉬</h3>
                  <span class="text-[#C9A96E] font-serif font-semibold italic text-sm">1st</span>
                </div>
                <p class="text-[13px] text-[#E8E0D4]/50 leading-relaxed">제주 성게, 감태 에스푸마, 유자 젤리</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Course 2 -->
        <div class="menu-card group reveal" style="--delay: 1;">
          <div class="bg-[#1A1A1A] rounded-[2rem] p-1.5 ring-1 ring-[#C9A96E]/10">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden">
              <div class="overflow-hidden">
                <img src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?q=80&w=600" alt="전채" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
              </div>
              <div class="p-6 bg-[#1A1A1A]">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-lg font-semibold text-[#E8E0D4]">뽀아송</h3>
                  <span class="text-[#C9A96E] font-serif font-semibold italic text-sm">3rd</span>
                </div>
                <p class="text-[13px] text-[#E8E0D4]/50 leading-relaxed">여수 광어, 브뢰 블랑, 봄나물 가니쉬</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Course 3 -->
        <div class="menu-card group reveal" style="--delay: 2;">
          <div class="bg-[#1A1A1A] rounded-[2rem] p-1.5 ring-1 ring-[#C9A96E]/10">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden">
              <div class="overflow-hidden">
                <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=600" alt="메인" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
              </div>
              <div class="p-6 bg-[#1A1A1A]">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-lg font-semibold text-[#E8E0D4]">비앙드</h3>
                  <span class="text-[#C9A96E] font-serif font-semibold italic text-sm">5th</span>
                </div>
                <p class="text-[13px] text-[#E8E0D4]/50 leading-relaxed">횡성 한우 등심, 트러플 주, 계절 채소 로스트</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Course 4 -->
        <div class="menu-card group reveal" style="--delay: 3;">
          <div class="bg-[#1A1A1A] rounded-[2rem] p-1.5 ring-1 ring-[#C9A96E]/10">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden">
              <div class="overflow-hidden">
                <img src="https://images.unsplash.com/photo-1551024506-0bccd828d307?q=80&w=600" alt="디저트" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
              </div>
              <div class="p-6 bg-[#1A1A1A]">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-lg font-semibold text-[#E8E0D4]">데세르</h3>
                  <span class="text-[#C9A96E] font-serif font-semibold italic text-sm">7th</span>
                </div>
                <p class="text-[13px] text-[#E8E0D4]/50 leading-relaxed">발로나 쇼콜라, 제주 감귤 소르베, 프랄린</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-12 reveal" style="--delay: 4;">
        <a href="#" class="inline-flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.3em] text-[#C9A96E] hover:text-[#E8E0D4]">
          와인 페어링 보기
          <span class="w-6 h-6 rounded-full bg-[#C9A96E]/10 flex items-center justify-center">
            <i class="fas fa-arrow-right text-[9px]"></i>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== Gallery ========== -->
  <section id="gallery" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-14 gap-6">
        <div>
          <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#C9A96E]/10 text-[#C9A96E] reveal" style="--delay: 0;">Gallery</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif font-semibold leading-snug text-[#E8E0D4] mt-6 reveal" style="--delay: 1;">
            한 접시의 미학
          </h2>
        </div>
        <p class="text-[#E8E0D4]/50 text-base max-w-sm reveal" style="--delay: 2;">
          한남동 골목, 12석의 고요한 공간에서.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
        <div class="gallery-item overflow-hidden rounded-2xl md:rounded-[2rem] reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?q=80&w=800" alt="오픈 키친" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-2xl md:rounded-[2rem] md:row-span-2 reveal" style="--delay: 1;">
          <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?q=80&w=800" alt="다이닝 홀" class="w-full h-full object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-2xl md:rounded-[2rem] reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1551218808-94e220e084d2?q=80&w=800" alt="플레이팅" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-2xl md:rounded-[2rem] reveal" style="--delay: 3;">
          <img src="https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?q=80&w=800" alt="와인 셀렉션" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-2xl md:rounded-[2rem] col-span-2 md:col-span-1 reveal" style="--delay: 4;">
          <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=800" alt="테이블 세팅" class="w-full aspect-[2/1] md:aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Location & Reservation ========== -->
  <section id="location" class="py-24 md:py-32 bg-[#111111] text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#C9A96E]/8 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-[#C9A96E]/5 rounded-full blur-[100px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        <div class="reveal" style="--delay: 0;">
          <div class="rounded-[2rem] overflow-hidden aspect-[4/3] bg-[#1A1A1A] relative group">
            <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=800" alt="레스토랑 내부" class="w-full h-full object-cover opacity-50 group-hover:opacity-70 transition-opacity duration-700" loading="lazy" decoding="async">
            <div class="absolute inset-0 flex items-center justify-center">
              <a href="#" class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-xl border border-white/20 text-white px-8 py-4 rounded-full text-[11px] font-semibold uppercase tracking-[0.3em] hover:bg-white/20 transition">
                <i class="fas fa-map-marker-alt text-[#C9A96E]"></i>
                지도에서 보기
              </a>
            </div>
          </div>
        </div>

        <div class="space-y-10">
          <div class="reveal" style="--delay: 1;">
            <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-white/10 text-[#C9A96E]">Reservation</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif font-semibold leading-snug mt-6 italic">
              예약 안내
            </h2>
          </div>

          <div class="space-y-8 reveal" style="--delay: 2;">
            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                <i class="fas fa-map-pin text-[#C9A96E] text-sm"></i>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-white/40 mb-2">Address</p>
                <p class="text-white/80 text-base leading-relaxed">서울특별시 용산구 한남대로 42길 18<br>2층 누아르 다이닝</p>
              </div>
            </div>

            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                <i class="fas fa-clock text-[#C9A96E] text-sm"></i>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-white/40 mb-2">Service</p>
                <div class="space-y-1.5 text-white/80 text-base">
