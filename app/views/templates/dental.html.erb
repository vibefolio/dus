<%# Dental Template - 스마일 치과 (SMILE DENTAL) %>

<style>
  /* Supanova Design — Fresh Dental Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 32px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .treat-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .treat-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(6,182,212,0.12); }
</style>

<div class="bg-[#FAFAFA] text-[#1E293B] font-sans selection:bg-[#06B6D4] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-4 bg-[#FAFAFA]/80 backdrop-blur-xl border-b border-slate-100">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-9 h-9 bg-gradient-to-br from-[#06B6D4] to-[#0891B2] rounded-full flex items-center justify-center">
          <i class="fas fa-tooth text-white text-sm"></i>
        </div>
        <span class="font-bold text-xl">스마일 <span class="text-[#06B6D4]">치과</span></span>
      </a>

      <div class="hidden md:flex gap-10 text-sm font-medium text-slate-400">
        <a href="#treatments" class="hover:text-[#06B6D4] transition">진료분야</a>
        <a href="#director" class="hover:text-[#06B6D4] transition">원장소개</a>
        <a href="#facility" class="hover:text-[#06B6D4] transition">시설안내</a>
        <a href="#reservation" class="hover:text-[#06B6D4] transition">예약</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="tel:02-555-2828" class="text-sm font-medium text-slate-500 hover:text-[#06B6D4]"><i class="fas fa-phone mr-1"></i> 02-555-2828</a>
        <a href="#reservation" class="bg-[#06B6D4] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#0891B2] shadow-lg shadow-[#06B6D4]/20" data-mobile-menu-copy="true">예약하기</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#ECFEFF] via-[#FAFAFA] to-white"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-[#06B6D4]/5 rounded-full blur-[150px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 items-center w-full">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-white px-4 py-2 rounded-full border border-[#06B6D4]/20 shadow-sm reveal" style="--delay: 0;">
          <i class="fas fa-smile text-[#06B6D4] text-sm"></i>
          <span class="text-sm font-medium text-[#06B6D4]">당신의 미소를 디자인합니다</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mobile-title reveal" style="--delay: 1;">
          자신있는 미소,<br>
          <span class="text-[#06B6D4]">스마일 치과</span>
        </h1>

        <p class="text-slate-400 text-base md:text-lg leading-relaxed max-w-md mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          1:1 맞춤 진료로 환자 한 분 한 분에게 최적의 치료를 제공합니다. 편안하고 안전한 치과 진료를 경험하세요.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#reservation" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#06B6D4] text-white rounded-full font-semibold shadow-lg shadow-[#06B6D4]/25 hover:bg-[#0891B2]">
            <i class="fas fa-calendar-alt text-sm"></i> 진료 예약
          </a>
          <a href="#treatments" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-slate-200 rounded-full font-semibold text-slate-600 hover:border-[#06B6D4] hover:text-[#06B6D4]">
            진료분야 보기
          </a>
        </div>

        <div class="flex items-center gap-8 justify-center lg:justify-start pt-4 reveal" style="--delay: 4;">
          <div class="text-center">
            <p class="text-2xl font-bold text-[#06B6D4]">20년+</p>
            <p class="text-xs text-slate-400 mt-1">진료 경력</p>
          </div>
          <div class="w-px h-8 bg-slate-200"></div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[#06B6D4]">30,000+</p>
            <p class="text-xs text-slate-400 mt-1">임플란트 시술</p>
          </div>
          <div class="w-px h-8 bg-slate-200"></div>
          <div class="text-center">
            <p class="text-2xl font-bold text-[#06B6D4]">99%</p>
            <p class="text-xs text-slate-400 mt-1">재방문율</p>
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block reveal" style="--delay: 2;">
        <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?q=80&w=800" alt="치과 시설" class="w-full h-[550px] object-cover rounded-3xl shadow-2xl">
        <div class="absolute -bottom-6 -right-6 bg-white p-5 rounded-2xl shadow-xl border border-slate-100">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-[#06B6D4]/10 rounded-full flex items-center justify-center">
              <i class="fas fa-certificate text-[#06B6D4]"></i>
            </div>
            <div>
              <p class="font-bold text-sm">무통 마취 시스템</p>
              <p class="text-xs text-slate-400">편안한 진료</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 진료분야 ========== -->
  <section id="treatments" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#06B6D4] tracking-wider uppercase reveal" style="--delay: 0;">Treatments</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">전문 진료분야</h2>
        <p class="text-slate-400 text-base mt-4 max-w-lg mx-auto reveal" style="--delay: 2;">최신 장비와 숙련된 기술로 최상의 결과를 보장합니다</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="treat-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#06B6D4]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-teeth text-[#06B6D4] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">임플란트</h3>
          <p class="text-sm text-slate-400 leading-relaxed">네비게이션 임플란트로 정확하고 안전한 식립. 당일 임플란트 가능.</p>
          <p class="text-[#06B6D4] font-bold text-sm mt-4">1회 식립 70만원~</p>
        </div>

        <div class="treat-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#06B6D4]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-smile-beam text-[#06B6D4] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">치아교정</h3>
          <p class="text-sm text-slate-400 leading-relaxed">투명교정, 설측교정, 세라믹교정 등 다양한 교정 옵션을 제공합니다.</p>
          <p class="text-[#06B6D4] font-bold text-sm mt-4">교정 상담 무료</p>
        </div>

        <div class="treat-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 2;">
          <div class="w-14 h-14 bg-[#06B6D4]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-star text-[#06B6D4] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">심미보철</h3>
          <p class="text-sm text-slate-400 leading-relaxed">라미네이트, 올세라믹으로 자연스럽고 아름다운 치아를 만듭니다.</p>
          <p class="text-[#06B6D4] font-bold text-sm mt-4">1일 완성 가능</p>
        </div>

        <div class="treat-card bg-white p-8 rounded-2xl border border-slate-100 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#06B6D4]/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fas fa-magic text-[#06B6D4] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">치아미백</h3>
          <p class="text-sm text-slate-400 leading-relaxed">전문 미백 시스템으로 환하고 밝은 치아를 되찾아드립니다.</p>
          <p class="text-[#06B6D4] font-bold text-sm mt-4">1회 15만원~</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 원장소개 ========== -->
  <section id="director" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1537368910025-700350fe46c7?q=80&w=700" alt="이스마일 원장" class="w-full aspect-[3/4] object-cover rounded-3xl shadow-xl" loading="lazy">
          <div class="absolute -bottom-6 left-6 bg-[#06B6D4] text-white p-5 rounded-2xl shadow-lg">
            <p class="font-bold text-lg">20년+ 경력</p>
            <p class="text-white/70 text-sm">임플란트 전문의</p>
          </div>
        </div>

        <div class="space-y-8">
          <div>
            <span class="text-sm font-semibold text-[#06B6D4] tracking-wider uppercase reveal" style="--delay: 0;">Director</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">이스마일 원장</h2>
          </div>

          <p class="text-slate-400 text-base md:text-lg leading-relaxed reveal" style="--delay: 2;">
            "환자분의 치아를 내 치아처럼 소중히 생각합니다. 최소한의 삭제, 최대한의 보존을 원칙으로 정직한 진료를 약속드립니다."
          </p>

          <div class="space-y-4 reveal" style="--delay: 3;">
            <div class="flex items-center gap-3">
              <i class="fas fa-check-circle text-[#06B6D4]"></i>
              <span class="text-slate-600">서울대학교 치과대학 졸업</span>
            </div>
            <div class="flex items-center gap-3">
              <i class="fas fa-check-circle text-[#06B6D4]"></i>
              <span class="text-slate-600">서울대학교치과병원 보철과 수련</span>
            </div>
            <div class="flex items-center gap-3">
              <i class="fas fa-check-circle text-[#06B6D4]"></i>
              <span class="text-slate-600">대한임플란트학회 인정의</span>
            </div>
            <div class="flex items-center gap-3">
              <i class="fas fa-check-circle text-[#06B6D4]"></i>
              <span class="text-slate-600">대한구강악안면임플란트학회 정회원</span>
            </div>
            <div class="flex items-center gap-3">
              <i class="fas fa-check-circle text-[#06B6D4]"></i>
              <span class="text-slate-600">전 삼성서울병원 치과 진료의</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 시설 ========== -->
  <section id="facility" class="py-24 md:py-32 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#06B6D4] tracking-wider uppercase reveal" style="--delay: 0;">Facility</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">편안한 진료 환경</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?q=80&w=800" alt="대기실" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl md:row-span-2 group reveal" style="--delay: 1;">
          <img src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?q=80&w=800" alt="진료실" class="w-full h-full object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?q=80&w=800" alt="상담실" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl group reveal" style="--delay: 3;">
          <img src="https://images.unsplash.com/photo-1598256989800-fe5f95da9787?q=80&w=800" alt="CT실" class="w-full aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
        <div class="overflow-hidden rounded-2xl col-span-2 md:col-span-1 group reveal" style="--delay: 4;">
          <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?q=80&w=800" alt="수술실" class="w-full aspect-[2/1] md:aspect-square object-cover group-hover:scale-105 transition duration-700" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 진료안내 ========== -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#06B6D4] tracking-wider uppercase reveal" style="--delay: 0;">Guide</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">진료 안내</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="text-center reveal" style="--delay: 0;">
          <div class="w-16 h-16 bg-[#06B6D4] rounded-full flex items-center justify-center mx-auto mb-4 text-white text-xl font-bold">1</div>
          <h3 class="font-bold mb-2">예약</h3>
          <p class="text-sm text-slate-400">온라인 또는 전화로 편리하게 예약</p>
        </div>
        <div class="text-center reveal" style="--delay: 1;">
          <div class="w-16 h-16 bg-[#06B6D4] rounded-full flex items-center justify-center mx-auto mb-4 text-white text-xl font-bold">2</div>
          <h3 class="font-bold mb-2">상담 및 검진</h3>
          <p class="text-sm text-slate-400">3D CT 촬영 후 맞춤 치료 계획 수립</p>
        </div>
        <div class="text-center reveal" style="--delay: 2;">
          <div class="w-16 h-16 bg-[#06B6D4] rounded-full flex items-center justify-center mx-auto mb-4 text-white text-xl font-bold">3</div>
          <h3 class="font-bold mb-2">치료</h3>
          <p class="text-sm text-slate-400">무통마취 시스템으로 편안한 진료</p>
        </div>
        <div class="text-center reveal" style="--delay: 3;">
          <div class="w-16 h-16 bg-[#06B6D4] rounded-full flex items-center justify-center mx-auto mb-4 text-white text-xl font-bold">4</div>
          <h3 class="font-bold mb-2">사후관리</h3>
          <p class="text-sm text-slate-400">정기 검진과 체계적인 사후 관리</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 예약 ========== -->
  <section id="reservation" class="py-24 md:py-32 bg-gradient-to-br from-[#06B6D4] to-[#0891B2] text-white relative overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full blur-[100px]"></div>

    <div class="max-w-4xl mx-auto px-4 md:px-8 relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold reveal" style="--delay: 0;">온라인 예약</h2>
        <p class="text-white/70 text-base mt-4 reveal" style="--delay: 1;">예약 후 방문하시면 대기 시간 없이 바로 진료받으실 수 있습니다</p>
      </div>

      <div class="bg-white/10 backdrop-blur-xl rounded-3xl p-8 md:p-12 reveal" style="--delay: 2;">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">이름</label>
            <input type="text" placeholder="홍길동" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">연락처</label>
            <input type="tel" placeholder="010-0000-0000" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">진료 항목</label>
            <select class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white outline-none focus:border-white/60 transition">
              <option value="">선택해주세요</option>
              <option>임플란트</option>
              <option>치아교정</option>
              <option>심미보철</option>
              <option>치아미백</option>
              <option>일반진료</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-white/80 mb-2">희망 날짜</label>
            <input type="date" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white outline-none focus:border-white/60 transition">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-white/80 mb-2">추가 메모</label>
            <textarea rows="3" placeholder="궁금한 점이나 증상을 적어주세요" class="w-full bg-white/10 border border-white/20 rounded-xl px-5 py-3.5 text-white placeholder-white/40 outline-none focus:border-white/60 transition resize-none"></textarea>
          </div>
        </div>
        <button class="w-full mt-8 bg-white text-[#06B6D4] py-4 rounded-full font-bold text-lg hover:bg-[#ECFEFF] shadow-lg">예약 신청하기</button>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="py-24 md:py-32">
