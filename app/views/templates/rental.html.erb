<%# Rental Template — SPACE ON (렌탈/공간대여) %>

<style>
  /* Supanova Design — Clean Modern Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

  .font-sans { font-family: 'Inter', 'Pretendard Variable', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 32px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  .space-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .space-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(59, 130, 246, 0.1); }
  .space-card:hover img { transform: scale(1.05); }

  .review-card { transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .review-card:hover { transform: translateY(-4px); }

  .option-card { transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .option-card:hover { transform: translateY(-4px); border-color: #3B82F6; }
</style>

<div class="bg-[#FAFAFA] text-[#1F2937] font-sans selection:bg-[#3B82F6] selection:text-white min-h-screen overflow-x-hidden relative">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#FAFAFA]/90 backdrop-blur-xl border-b border-[#1F2937]/5">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <span class="w-8 h-8 bg-[#3B82F6] rounded-lg flex items-center justify-center text-white font-black text-sm">S</span>
        <span class="text-xl font-extrabold tracking-tight text-[#1F2937]">SPACE ON</span>
      </a>

      <div class="hidden md:flex gap-10 text-[11px] font-semibold text-[#1F2937]/40">
        <a href="#spaces" class="hover:text-[#3B82F6] transition">공간</a>
        <a href="#equipment" class="hover:text-[#3B82F6] transition">장비/옵션</a>
        <a href="#reviews" class="hover:text-[#3B82F6] transition">후기</a>
        <a href="#location" class="hover:text-[#3B82F6] transition">위치</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none text-[#1F2937]">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center shrink-0">
        <button onclick="toggleRentalModal()" class="text-[11px] font-semibold text-[#1F2937]/40 hover:text-[#3B82F6]" data-mobile-menu-copy="true">로그인</button>
        <a href="#booking" class="bg-[#3B82F6] text-white px-6 py-3 rounded-xl font-semibold text-[11px] hover:bg-[#1F2937] transition shadow-lg shadow-[#3B82F6]/20" data-mobile-menu-copy="true">
          예약하기
        </a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== 1. Hero ========== -->
  <header class="min-h-screen relative flex items-center pt-20">
    <div class="max-w-7xl mx-auto px-6 md:px-10 w-full grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-8">
        <div class="reveal inline-flex items-center gap-3 bg-[#3B82F6]/5 rounded-full px-4 py-2">
          <span class="w-2 h-2 rounded-full bg-[#3B82F6] animate-pulse"></span>
          <span class="text-[11px] font-semibold text-[#3B82F6]">공간대여 전문 플랫폼</span>
        </div>

        <h1 class="reveal text-4xl md:text-6xl font-black leading-[1.1] tracking-tight mobile-title" style="--delay:1">
          당신의 아이디어에<br>
          <span class="text-[#3B82F6]">공간을 더하다.</span>
        </h1>

        <p class="reveal text-[#1F2937]/50 text-sm md:text-base leading-[2] max-w-md mobile-desc" style="--delay:2">
          촬영, 세미나, 파티, 워크숍 등 다양한 목적에 맞는<br class="hidden md:block">
          프리미엄 공간을 시간 단위로 합리적으로 이용하세요.
        </p>

        <div class="reveal flex flex-wrap gap-3 pt-4" style="--delay:3">
          <a href="#spaces" class="bg-[#3B82F6] text-white px-8 py-4 rounded-xl font-semibold text-[11px] hover:bg-[#1F2937] transition shadow-lg shadow-[#3B82F6]/20">
            공간 둘러보기
          </a>
          <a href="#booking" class="border border-[#3B82F6]/20 text-[#3B82F6] px-8 py-4 rounded-xl font-semibold text-[11px] hover:bg-[#3B82F6]/5 transition">
            견적 문의
          </a>
        </div>

        <!-- Trust badges -->
        <div class="reveal flex flex-wrap gap-6 pt-8" style="--delay:4">
          <div class="flex items-center gap-2">
            <span class="text-[#3B82F6]"><i class="fas fa-check-circle"></i></span>
            <span class="text-xs text-[#1F2937]/40">당일 예약 가능</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[#3B82F6]"><i class="fas fa-check-circle"></i></span>
            <span class="text-xs text-[#1F2937]/40">시간 단위 결제</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[#3B82F6]"><i class="fas fa-check-circle"></i></span>
            <span class="text-xs text-[#1F2937]/40">무료 주차 50대</span>
          </div>
        </div>
      </div>

      <div class="reveal relative" style="--delay:2">
        <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl shadow-[#3B82F6]/10">
          <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1200&auto=format" alt="SPACE ON" class="w-full h-full object-cover">
        </div>
        <div class="absolute -bottom-5 -right-5 bg-white rounded-2xl p-5 shadow-xl border border-[#1F2937]/5">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#3B82F6]/10 rounded-xl flex items-center justify-center text-[#3B82F6]">
              <i class="fas fa-star"></i>
            </div>
            <div>
              <p class="font-bold text-sm">4.8 / 5.0</p>
              <p class="text-[10px] text-[#1F2937]/40">1,200+ 이용 후기</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 2. 공간 소개 (4종) ========== -->
  <section id="spaces" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[11px] font-semibold text-[#3B82F6]">Our Spaces</span>
        <h2 class="text-3xl md:text-4xl font-black mt-3 tracking-tight">목적에 맞는 최적의 공간</h2>
        <p class="text-[#1F2937]/40 text-sm mt-4 max-w-lg mx-auto">모든 공간은 고속 와이파이, 에어컨, 음향 시스템이 기본 제공됩니다.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- 스튜디오 A -->
        <div class="space-card bg-white rounded-2xl overflow-hidden shadow-sm border border-[#1F2937]/5 reveal" style="--delay:0">
          <div class="aspect-[16/10] overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1000&auto=format" alt="스튜디오 A" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute top-4 left-4 bg-[#3B82F6] text-white px-3 py-1.5 rounded-lg text-[10px] font-bold">인기</div>
          </div>
          <div class="p-7">
            <div class="flex justify-between items-start">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-[#3B82F6]"></span>
                  <span class="text-[10px] font-semibold text-[#3B82F6]">STUDIO A</span>
                </div>
                <h3 class="text-lg font-bold">촬영 스튜디오</h3>
                <p class="text-[#1F2937]/40 text-sm mt-2 leading-relaxed">
                  80m² · 자연광 대형 창 · 화이트/그레이 월 · 최대 20인
                </p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="text-xl font-black text-[#3B82F6]">₩50,000</span>
                <span class="block text-[10px] text-[#1F2937]/30">/ 시간</span>
              </div>
            </div>
            <div class="flex gap-2 mt-5 flex-wrap">
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">자연광</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">조명</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">탈의실</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">메이크업존</span>
            </div>
          </div>
        </div>

        <!-- 세미나룸 -->
        <div class="space-card bg-white rounded-2xl overflow-hidden shadow-sm border border-[#1F2937]/5 reveal" style="--delay:1">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1517502884422-41eaead166d4?q=80&w=1000&auto=format" alt="세미나룸" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-7">
            <div class="flex justify-between items-start">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-[#3B82F6]"></span>
                  <span class="text-[10px] font-semibold text-[#3B82F6]">SEMINAR</span>
                </div>
                <h3 class="text-lg font-bold">세미나 & 컨퍼런스</h3>
                <p class="text-[#1F2937]/40 text-sm mt-2 leading-relaxed">
                  120m² · 대형 스크린 · 마이크 시스템 · 최대 60인
                </p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="text-xl font-black text-[#3B82F6]">₩80,000</span>
                <span class="block text-[10px] text-[#1F2937]/30">/ 시간</span>
              </div>
            </div>
            <div class="flex gap-2 mt-5 flex-wrap">
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">프로젝터</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">마이크</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">화이트보드</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">케이터링</span>
            </div>
          </div>
        </div>

        <!-- 파티룸 -->
        <div class="space-card bg-white rounded-2xl overflow-hidden shadow-sm border border-[#1F2937]/5 reveal" style="--delay:2">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=1000&auto=format" alt="파티룸" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-7">
            <div class="flex justify-between items-start">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-[#3B82F6]"></span>
                  <span class="text-[10px] font-semibold text-[#3B82F6]">PARTY</span>
                </div>
                <h3 class="text-lg font-bold">파티 & 이벤트</h3>
                <p class="text-[#1F2937]/40 text-sm mt-2 leading-relaxed">
                  100m² · DJ 부스 · 미러볼 · 주방 · 최대 40인
                </p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="text-xl font-black text-[#3B82F6]">₩70,000</span>
                <span class="block text-[10px] text-[#1F2937]/30">/ 시간</span>
              </div>
            </div>
            <div class="flex gap-2 mt-5 flex-wrap">
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">음향</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">주방</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">루프탑</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">포토존</span>
            </div>
          </div>
        </div>

        <!-- 코워킹 -->
        <div class="space-card bg-white rounded-2xl overflow-hidden shadow-sm border border-[#1F2937]/5 reveal" style="--delay:3">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1527192491265-7e15c55b1ed2?q=80&w=1000&auto=format" alt="코워킹" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-7">
            <div class="flex justify-between items-start">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-[#3B82F6]"></span>
                  <span class="text-[10px] font-semibold text-[#3B82F6]">CO-WORK</span>
                </div>
                <h3 class="text-lg font-bold">코워킹 스페이스</h3>
                <p class="text-[#1F2937]/40 text-sm mt-2 leading-relaxed">
                  60m² · 개별 데스크 · 회의실 · 프린터 · 최대 15인
                </p>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="text-xl font-black text-[#3B82F6]">₩15,000</span>
                <span class="block text-[10px] text-[#1F2937]/30">/ 시간</span>
              </div>
            </div>
            <div class="flex gap-2 mt-5 flex-wrap">
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">모니터</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">프린터</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">커피</span>
              <span class="px-3 py-1 bg-[#3B82F6]/5 text-[#3B82F6] rounded-lg text-[10px] font-medium">락커</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 3. 장비/옵션 ========== -->
  <section id="equipment" class="py-24 md:py-40 px-6 md:px-10 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[11px] font-semibold text-[#3B82F6]">Equipment & Options</span>
        <h2 class="text-3xl md:text-4xl font-black mt-3 tracking-tight">추가 장비 & 옵션</h2>
        <p class="text-[#1F2937]/40 text-sm mt-4">필요에 따라 추가 장비를 대여하실 수 있습니다.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <div class="option-card bg-[#FAFAFA] rounded-2xl p-6 text-center border border-transparent reveal" style="--delay:0">
          <span class="text-3xl text-[#3B82F6]"><i class="fas fa-video"></i></span>
          <h4 class="font-bold text-sm mt-4">카메라 장비</h4>
          <p class="text-[#1F2937]/40 text-xs mt-2">삼각대, 조명, 배경지</p>
          <p class="text-[#3B82F6] font-bold text-sm mt-3">₩30,000~</p>
        </div>
        <div class="option-card bg-[#FAFAFA] rounded-2xl p-6 text-center border border-transparent reveal" style="--delay:1">
          <span class="text-3xl text-[#3B82F6]"><i class="fas fa-desktop"></i></span>
          <h4 class="font-bold text-sm mt-4">프레젠테이션</h4>
          <p class="text-[#1F2937]/40 text-xs mt-2">빔프로젝터, 스크린, 포인터</p>
          <p class="text-[#3B82F6] font-bold text-sm mt-3">₩20,000~</p>
        </div>
        <div class="option-card bg-[#FAFAFA] rounded-2xl p-6 text-center border border-transparent reveal" style="--delay:2">
          <span class="text-3xl text-[#3B82F6]"><i class="fas fa-music"></i></span>
          <h4 class="font-bold text-sm mt-4">음향 시스템</h4>
          <p class="text-[#1F2937]/40 text-xs mt-2">스피커, 마이크, 앰프</p>
          <p class="text-[#3B82F6] font-bold text-sm mt-3">₩40,000~</p>
        </div>
        <div class="option-card bg-[#FAFAFA] rounded-2xl p-6 text-center border border-transparent reveal" style="--delay:3">
          <span class="text-3xl text-[#3B82F6]"><i class="fas fa-utensils"></i></span>
          <h4 class="font-bold text-sm mt-4">케이터링</h4>
          <p class="text-[#1F2937]/40 text-xs mt-2">커피, 다과, 도시락</p>
          <p class="text-[#3B82F6] font-bold text-sm mt-3">₩10,000~/인</p>
        </div>
        <div class="option-card bg-[#FAFAFA] rounded-2xl p-6 text-center border border-transparent reveal" style="--delay:4">
          <span class="text-3xl text-[#3B82F6]"><i class="fas fa-chair"></i></span>
          <h4 class="font-bold text-sm mt-4">가구 세팅</h4>
          <p class="text-[#1F2937]/40 text-xs mt-2">테이블, 의자, 소파</p>
          <p class="text-[#3B82F6] font-bold text-sm mt-3">₩20,000~</p>
        </div>
        <div class="option-card bg-[#FAFAFA] rounded-2xl p-6 text-center border border-transparent reveal" style="--delay:5">
          <span class="text-3xl text-[#3B82F6]"><i class="fas fa-camera-retro"></i></span>
          <h4 class="font-bold text-sm mt-4">포토 프롭</h4>
          <p class="text-[#1F2937]/40 text-xs mt-2">소품, 배경, 조화</p>
          <p class="text-[#3B82F6] font-bold text-sm mt-3">₩15,000~</p>
        </div>
        <div class="option-card bg-[#FAFAFA] rounded-2xl p-6 text-center border border-transparent reveal" style="--delay:6">
          <span class="text-3xl text-[#3B82F6]"><i class="fas fa-broom"></i></span>
          <h4 class="font-bold text-sm mt-4">정리 서비스</h4>
          <p class="text-[#1F2937]/40 text-xs mt-2">이용 후 전문 청소</p>
          <p class="text-[#3B82F6] font-bold text-sm mt-3">₩50,000</p>
        </div>
        <div class="option-card bg-[#FAFAFA] rounded-2xl p-6 text-center border border-transparent reveal" style="--delay:7">
          <span class="text-3xl text-[#3B82F6]"><i class="fas fa-user-tie"></i></span>
          <h4 class="font-bold text-sm mt-4">매니저 배치</h4>
          <p class="text-[#1F2937]/40 text-xs mt-2">현장 운영 매니저</p>
          <p class="text-[#3B82F6] font-bold text-sm mt-3">₩30,000/h</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 4. 이용 후기 ========== -->
  <section id="reviews" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[11px] font-semibold text-[#3B82F6]">Reviews</span>
        <h2 class="text-3xl md:text-4xl font-black mt-3 tracking-tight">이용하신 분들의 후기</h2>
