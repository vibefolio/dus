<%# Yoga Template - 숨 요가 스튜디오 (SUM YOGA) %>

<style>
  /* Supanova Design — Calm Natural Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap');

  .font-serif-flow { font-family: 'Cormorant Garamond', serif; }
  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 40px !important; }
  }

  .paper-texture {
    background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
    opacity: 0.5;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .program-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .program-card:hover { transform: translateY(-8px); }
  .program-card:hover img { transform: scale(1.05); }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes morph-slow {
    0%, 100% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
    50% { border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%; }
  }
  .animate-morph { animation: morph-slow 10s ease-in-out infinite; }
</style>

<div class="bg-[#F7F5F0] text-[#2D2D2D] font-sans selection:bg-[#7B8F6B] selection:text-white min-h-screen overflow-x-hidden relative">
  <div class="fixed inset-0 paper-texture pointer-events-none z-[1]"></div>

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#F7F5F0]/80 backdrop-blur-xl border-b border-[#7B8F6B]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="font-serif-flow text-3xl tracking-wide font-medium italic text-[#2D2D2D]">Sum<span class="text-[#7B8F6B]">Yoga</span></span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#2D2D2D]/40">
        <a href="#about" class="hover:text-[#7B8F6B] transition">About</a>
        <a href="#programs" class="hover:text-[#7B8F6B] transition">Programs</a>
        <a href="#schedule" class="hover:text-[#7B8F6B] transition">Schedule</a>
        <a href="#location" class="hover:text-[#7B8F6B] transition">Location</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleYogaModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#2D2D2D]/40 hover:text-[#7B8F6B]" data-mobile-menu-copy="true">Member</button>
        <button class="bg-[#7B8F6B] text-white px-8 py-3.5 rounded-full font-semibold text-[10px] tracking-[0.3em] uppercase hover:bg-[#2D2D2D] transition shadow-lg shadow-[#7B8F6B]/20" data-mobile-menu-copy="true">
          체험 신청
        </button>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center justify-center pt-20">
    <div class="absolute top-[20%] left-[10%] w-[400px] h-[400px] bg-[#7B8F6B]/8 animate-morph mix-blend-multiply filter blur-2xl"></div>
    <div class="absolute bottom-[15%] right-[10%] w-[350px] h-[350px] bg-[#D4CFC4]/20 animate-morph mix-blend-multiply filter blur-2xl" style="animation-delay: -5s;"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-10 text-center lg:text-left">
        <div class="inline-flex items-center gap-5 reveal" style="--delay: 0;">
          <span class="w-10 h-[1px] bg-[#7B8F6B]"></span>
          <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#7B8F6B]">Yoga &amp; Meditation</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-[5.5rem] font-serif-flow font-light leading-tight tracking-tight text-[#2D2D2D] mobile-title reveal" style="--delay: 1;">
          호흡으로 만나는<br><span class="italic text-[#7B8F6B]">온전한 나.</span>
        </h1>

        <p class="text-[#2D2D2D]/60 text-sm md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          매트 위에서 시작되는 내면으로의 여정. 숨 요가는 호흡과 동작이 하나가 되는 순간, 진정한 균형을 찾도록 안내합니다.
        </p>

        <div class="pt-4 flex flex-col sm:flex-row gap-5 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#programs" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#2D2D2D] text-white font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-[#7B8F6B] rounded-full shadow-xl">
            프로그램 보기
            <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center">
              <i class="fas fa-arrow-right text-[10px]"></i>
            </span>
          </a>
          <a href="#schedule" class="inline-flex items-center justify-center px-10 py-5 border border-[#7B8F6B]/30 text-[#7B8F6B] font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-white rounded-full">
            시간표 확인
          </a>
        </div>
      </div>

      <div class="relative hidden lg:block reveal" style="--delay: 2;">
        <div class="aspect-[4/5] rounded-[8rem_8rem_2rem_2rem] overflow-hidden relative group">
          <img src="https://images.unsplash.com/photo-1599447332191-aaa5d52540c4?q=80&w=1200" alt="요가 수련" class="w-full h-full object-cover transition duration-[2s] group-hover:scale-105" loading="eager">
          <div class="absolute inset-0 bg-gradient-to-t from-[#7B8F6B]/20 to-transparent pointer-events-none"></div>
        </div>
        <div class="absolute -bottom-6 -left-6 md:-bottom-8 md:-left-8 bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-[#7B8F6B]/10 max-w-[240px]" style="animation: float 6s ease-in-out infinite;">
          <p class="text-[10px] font-semibold text-[#7B8F6B] uppercase tracking-[0.4em] mb-3">Daily Flow</p>
          <p class="text-base font-serif-flow italic text-[#2D2D2D]">오늘도 한 호흡, 나를 위한 시간.</p>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About ========== -->
  <section id="about" class="py-24 md:py-32 relative z-10">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative reveal" style="--delay: 0;">
        <div class="grid grid-cols-2 gap-4">
          <div class="overflow-hidden rounded-[2rem]">
            <img src="https://images.unsplash.com/photo-1545389336-cf090694435e?q=80&w=600" alt="요가 스튜디오" class="w-full aspect-[3/4] object-cover" loading="lazy">
          </div>
          <div class="overflow-hidden rounded-[2rem] mt-8">
            <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=600" alt="명상" class="w-full aspect-[3/4] object-cover" loading="lazy">
          </div>
        </div>
      </div>

      <div class="space-y-8 reveal" style="--delay: 1;">
        <div class="inline-flex items-center gap-4">
          <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#7B8F6B]/10 text-[#7B8F6B]">Our Philosophy</span>
        </div>

        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif-flow font-medium leading-snug text-[#2D2D2D]">
          몸과 마음의<br>자연스러운 균형
        </h2>

        <p class="text-[#2D2D2D]/60 text-base md:text-lg leading-relaxed">
          숨 요가는 2019년 연남동의 오래된 한옥을 개조하여 시작되었습니다. 자연광이 들어오는 따뜻한 공간에서, 숙련된 강사와 함께 몸과 마음의 조화를 경험합니다.
        </p>
        <p class="text-[#2D2D2D]/60 text-base md:text-lg leading-relaxed">
          빠르게 흘러가는 일상에서 잠시 멈추는 연습. 숨 요가는 당신이 다시 자신과 연결되는 공간이 되고 싶습니다.
        </p>

        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-[#7B8F6B]/10">
          <div>
            <p class="text-2xl md:text-3xl font-serif-flow font-medium text-[#7B8F6B]">6yr</p>
            <p class="text-[11px] text-[#2D2D2D]/40 uppercase tracking-[0.1em] mt-1 font-medium">연남동 한옥</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-serif-flow font-medium text-[#7B8F6B]">12명</p>
            <p class="text-[11px] text-[#2D2D2D]/40 uppercase tracking-[0.1em] mt-1 font-medium">소수 정원</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-serif-flow font-medium text-[#7B8F6B]">4+</p>
            <p class="text-[11px] text-[#2D2D2D]/40 uppercase tracking-[0.1em] mt-1 font-medium">전문 강사</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 프로그램 ========== -->
  <section id="programs" class="py-24 md:py-32 bg-white relative z-10">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#7B8F6B]/10 text-[#7B8F6B] reveal" style="--delay: 0;">Programs</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif-flow font-medium leading-snug text-[#2D2D2D] mt-6 reveal" style="--delay: 1;">
          당신에게 맞는<br>요가 여정
        </h2>
        <p class="text-[#2D2D2D]/50 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">
          초보자부터 숙련자까지, 단계별 맞춤 프로그램을 제공합니다
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- 프로그램 1 -->
        <div class="program-card group reveal" style="--delay: 0;">
          <div class="bg-[#F7F5F0] rounded-[2rem] p-1.5 ring-1 ring-[#2D2D2D]/5">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden">
              <div class="overflow-hidden">
                <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=600" alt="하타 요가" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy">
              </div>
              <div class="p-6 bg-[#F7F5F0]">
                <span class="text-[10px] text-[#7B8F6B] font-semibold uppercase tracking-[0.2em]">Beginner</span>
                <h3 class="text-lg font-semibold text-[#2D2D2D] mt-2">하타 요가</h3>
                <p class="text-[13px] text-[#2D2D2D]/50 leading-relaxed mt-2">기본 아사나와 호흡법을 배우는 입문 클래스. 유연성과 균형감 향상.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- 프로그램 2 -->
        <div class="program-card group reveal" style="--delay: 1;">
          <div class="bg-[#F7F5F0] rounded-[2rem] p-1.5 ring-1 ring-[#2D2D2D]/5">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden">
              <div class="overflow-hidden">
                <img src="https://images.unsplash.com/photo-1599447332191-aaa5d52540c4?q=80&w=600" alt="빈야사 플로우" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy">
              </div>
              <div class="p-6 bg-[#F7F5F0]">
                <span class="text-[10px] text-[#7B8F6B] font-semibold uppercase tracking-[0.2em]">Intermediate</span>
                <h3 class="text-lg font-semibold text-[#2D2D2D] mt-2">빈야사 플로우</h3>
                <p class="text-[13px] text-[#2D2D2D]/50 leading-relaxed mt-2">호흡과 동작을 연결하는 다이나믹한 시퀀스. 체력과 집중력 강화.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- 프로그램 3 -->
        <div class="program-card group reveal" style="--delay: 2;">
          <div class="bg-[#F7F5F0] rounded-[2rem] p-1.5 ring-1 ring-[#2D2D2D]/5">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden">
              <div class="overflow-hidden">
                <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=600" alt="음양 요가" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy">
              </div>
              <div class="p-6 bg-[#F7F5F0]">
                <span class="text-[10px] text-[#7B8F6B] font-semibold uppercase tracking-[0.2em]">Restorative</span>
                <h3 class="text-lg font-semibold text-[#2D2D2D] mt-2">음양 요가</h3>
                <p class="text-[13px] text-[#2D2D2D]/50 leading-relaxed mt-2">깊은 이완과 근막 이완에 집중. 스트레스 해소와 회복에 최적.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- 프로그램 4 -->
        <div class="program-card group reveal" style="--delay: 3;">
          <div class="bg-[#F7F5F0] rounded-[2rem] p-1.5 ring-1 ring-[#2D2D2D]/5">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden">
              <div class="overflow-hidden">
                <img src="https://images.unsplash.com/photo-1545389336-cf090694435e?q=80&w=600" alt="명상 클래스" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy">
              </div>
              <div class="p-6 bg-[#F7F5F0]">
                <span class="text-[10px] text-[#7B8F6B] font-semibold uppercase tracking-[0.2em]">Mindfulness</span>
                <h3 class="text-lg font-semibold text-[#2D2D2D] mt-2">마음챙김 명상</h3>
                <p class="text-[13px] text-[#2D2D2D]/50 leading-relaxed mt-2">호흡 명상과 바디스캔으로 내면의 고요함을 찾는 시간.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 강사 소개 ========== -->
  <section class="py-24 md:py-32 relative z-10">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#7B8F6B]/10 text-[#7B8F6B] reveal" style="--delay: 0;">Instructors</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif-flow font-medium leading-snug text-[#2D2D2D] mt-6 reveal" style="--delay: 1;">
          함께하는 안내자
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row gap-6 items-center md:items-start text-center md:text-left reveal" style="--delay: 0;">
          <div class="w-32 h-32 rounded-full overflow-hidden shrink-0">
            <img src="https://images.unsplash.com/photo-1594381898411-846e7d193883?q=80&w=400" alt="강사 1" class="w-full h-full object-cover" loading="lazy">
          </div>
          <div>
            <h3 class="text-xl font-serif-flow font-medium text-[#2D2D2D] mb-1">윤 서영</h3>
            <p class="text-[11px] text-[#7B8F6B] uppercase tracking-[0.3em] font-semibold mb-3">Lead Instructor</p>
            <p class="text-sm text-[#2D2D2D]/50 leading-relaxed">인도 리시케시 200h RYT 자격. 10년 수련 경력. 빈야사와 하타 요가 전문. 부드럽지만 깊이 있는 수업을 지향합니다.</p>
          </div>
        </div>

        <div class="flex flex-col md:flex-row gap-6 items-center md:items-start text-center md:text-left reveal" style="--delay: 1;">
          <div class="w-32 h-32 rounded-full overflow-hidden shrink-0">
            <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?q=80&w=400" alt="강사 2" class="w-full h-full object-cover" loading="lazy">
          </div>
          <div>
            <h3 class="text-xl font-serif-flow font-medium text-[#2D2D2D] mb-1">김 하늘</h3>
            <p class="text-[11px] text-[#7B8F6B] uppercase tracking-[0.3em] font-semibold mb-3">Meditation Guide</p>
            <p class="text-sm text-[#2D2D2D]/50 leading-relaxed">MBSR 마음챙김 인증 강사. 음양 요가와 명상 전문. 일상에서 실천할 수 있는 마음챙김을 가르칩니다.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 시간표 ========== -->
  <section id="schedule" class="py-24 md:py-32 bg-white relative z-10">
    <div class="max-w-5xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#7B8F6B]/10 text-[#7B8F6B] reveal" style="--delay: 0;">Weekly Schedule</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif-flow font-medium leading-snug text-[#2D2D2D] mt-6 reveal" style="--delay: 1;">
          주간 시간표
        </h2>
      </div>

      <div class="overflow-x-auto reveal" style="--delay: 2;">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-[#7B8F6B]/20">
              <th class="py-4 px-3 text-left text-[10px] font-semibold uppercase tracking-[0.3em] text-[#7B8F6B]">시간</th>
              <th class="py-4 px-3 text-center text-[10px] font-semibold uppercase tracking-[0.3em] text-[#2D2D2D]/40">월</th>
              <th class="py-4 px-3 text-center text-[10px] font-semibold uppercase tracking-[0.3em] text-[#2D2D2D]/40">화</th>
              <th class="py-4 px-3 text-center text-[10px] font-semibold uppercase tracking-[0.3em] text-[#2D2D2D]/40">수</th>
              <th class="py-4 px-3 text-center text-[10px] font-semibold uppercase tracking-[0.3em] text-[#2D2D2D]/40">목</th>
              <th class="py-4 px-3 text-center text-[10px] font-semibold uppercase tracking-[0.3em] text-[#2D2D2D]/40">금</th>
              <th class="py-4 px-3 text-center text-[10px] font-semibold uppercase tracking-[0.3em] text-[#2D2D2D]/40">토</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[#2D2D2D]/5">
              <td class="py-5 px-3 font-serif-flow font-medium text-[#2D2D2D]">07:00</td>
              <td class="py-5 px-3 text-center"><span class="inline-block bg-[#7B8F6B]/10 text-[#7B8F6B] text-[12px] font-medium px-3 py-1.5 rounded-full">하타</span></td>
              <td class="py-5 px-3 text-center text-[#2D2D2D]/20">-</td>
