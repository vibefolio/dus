<%# Academy Template - 에듀플러스 아카데미 (학원/교육센터) %>

<style>
  /* Supanova Design — Education Center Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-inter { font-family: 'Inter', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 36px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .curriculum-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .curriculum-card:hover { transform: translateY(-8px); box-shadow: 0 25px 60px -15px rgba(99, 102, 241, 0.15); }
  .instructor-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .instructor-card:hover { transform: translateY(-4px); }
  .instructor-card:hover img { transform: scale(1.05); }
</style>

<div class="bg-[#F8FAFC] text-[#1E293B] font-sans selection:bg-[#6366F1] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#F8FAFC]/80 backdrop-blur-xl border-b border-[#6366F1]/5">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-[#6366F1] rounded-lg flex items-center justify-center">
          <i class="fas fa-graduation-cap text-white text-sm"></i>
        </div>
        <span class="font-inter text-xl font-bold tracking-tight text-[#1E293B]">에듀플러스</span>
      </a>

      <div class="hidden md:flex gap-10 text-[11px] font-semibold uppercase tracking-[0.3em] text-[#1E293B]/40">
        <a href="#curriculum" class="hover:text-[#6366F1] transition">커리큘럼</a>
        <a href="#instructors" class="hover:text-[#6366F1] transition">강사진</a>
        <a href="#reviews" class="hover:text-[#6366F1] transition">후기</a>
        <a href="#contact" class="hover:text-[#6366F1] transition">상담</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center shrink-0">
        <button onclick="toggleAcademyModal()" class="text-[11px] font-semibold text-[#1E293B]/40 hover:text-[#6366F1] tracking-[0.2em] uppercase" data-mobile-menu-copy="true">로그인</button>
        <a href="#contact" class="bg-[#6366F1] text-white px-7 py-3 rounded-full font-semibold text-[11px] tracking-[0.2em] uppercase hover:bg-[#4F46E5] shadow-lg shadow-[#6366F1]/20" data-mobile-menu-copy="true">무료 상담</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 right-0 w-[600px] h-[600px] bg-[#6366F1]/5 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#818CF8]/5 rounded-full blur-[100px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-3 bg-[#6366F1]/5 rounded-full px-5 py-2 reveal" style="--delay: 0;">
          <span class="w-2 h-2 bg-[#6366F1] rounded-full animate-pulse"></span>
          <span class="text-[11px] font-semibold tracking-[0.2em] uppercase text-[#6366F1]">2026 신규 등록 오픈</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-[4.5rem] font-bold leading-tight tracking-tight mobile-title reveal" style="--delay: 1;">
          배움의 시작,<br><span class="text-[#6366F1]">성장의 완성.</span>
        </h1>

        <p class="text-[#1E293B]/50 text-base md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          에듀플러스 아카데미는 학생 개개인의 잠재력을 끌어내는 맞춤형 교육을 제공합니다. 체계적인 커리큘럼과 검증된 강사진이 여러분의 목표 달성을 함께합니다.
        </p>

        <div class="pt-2 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#contact" class="inline-flex items-center justify-center gap-3 px-9 py-4 bg-[#6366F1] text-white font-semibold text-[12px] tracking-[0.15em] uppercase hover:bg-[#4F46E5] rounded-2xl shadow-xl shadow-[#6366F1]/20">
            무료 상담 예약 <i class="fas fa-arrow-right text-[10px]"></i>
          </a>
          <a href="#curriculum" class="inline-flex items-center justify-center px-9 py-4 border border-[#6366F1]/20 text-[#6366F1] font-semibold text-[12px] tracking-[0.15em] uppercase hover:bg-[#6366F1]/5 rounded-2xl">
            커리큘럼 보기
          </a>
        </div>

        <div class="grid grid-cols-3 gap-6 pt-6 reveal" style="--delay: 4;">
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-bold text-[#6366F1]">98%</p>
            <p class="text-[11px] text-[#1E293B]/40 mt-1 font-medium">목표 달성률</p>
          </div>
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-bold text-[#6366F1]">1,200+</p>
            <p class="text-[11px] text-[#1E293B]/40 mt-1 font-medium">수강생 배출</p>
          </div>
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-bold text-[#6366F1]">15년</p>
            <p class="text-[11px] text-[#1E293B]/40 mt-1 font-medium">교육 노하우</p>
          </div>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200" alt="교육 현장" class="w-full aspect-[4/5] object-cover rounded-[2.5rem] shadow-2xl" loading="eager">
        <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl border border-[#6366F1]/5">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-[#6366F1]/10 rounded-xl flex items-center justify-center">
              <i class="fas fa-trophy text-[#6366F1]"></i>
            </div>
            <div>
              <p class="text-sm font-bold text-[#1E293B]">2026 교육 대상</p>
              <p class="text-[11px] text-[#1E293B]/40">올해의 학원 선정</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About ========== -->
  <section id="about" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative reveal" style="--delay: 0;">
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <div class="overflow-hidden rounded-2xl">
              <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?q=80&w=600" alt="수업 장면" class="w-full aspect-[3/4] object-cover" loading="lazy" decoding="async">
            </div>
            <div class="bg-[#6366F1] rounded-2xl p-6 text-white text-center">
              <p class="text-3xl font-bold">15</p>
              <p class="text-[11px] font-medium text-white/70 mt-1">Years of Excellence</p>
            </div>
          </div>
          <div class="pt-8">
            <div class="overflow-hidden rounded-2xl">
              <img src="https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?q=80&w=600" alt="학생들" class="w-full aspect-[3/5] object-cover" loading="lazy" decoding="async">
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-8 reveal" style="--delay: 1;">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-semibold bg-[#6366F1]/5 text-[#6366F1]">About Us</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug">
          학생의 미래를<br>설계하는 교육
        </h2>
        <p class="text-[#1E293B]/50 text-base md:text-lg leading-relaxed">
          에듀플러스 아카데미는 단순한 점수 향상이 아닌, 학생 스스로 문제를 해결하는 힘을 길러주는 교육 철학을 가지고 있습니다. 소수 정예 수업과 1:1 맞춤 관리로 모든 학생이 자신의 목표에 도달할 수 있도록 돕습니다.
        </p>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white rounded-2xl p-5 border border-[#6366F1]/5">
            <i class="fas fa-user-friends text-[#6366F1] text-lg mb-3"></i>
            <p class="font-semibold text-sm">소수 정예 클래스</p>
            <p class="text-[12px] text-[#1E293B]/40 mt-1">반당 최대 8명</p>
          </div>
          <div class="bg-white rounded-2xl p-5 border border-[#6366F1]/5">
            <i class="fas fa-chart-line text-[#6366F1] text-lg mb-3"></i>
            <p class="font-semibold text-sm">성적 관리 시스템</p>
            <p class="text-[12px] text-[#1E293B]/40 mt-1">실시간 성적 분석</p>
          </div>
          <div class="bg-white rounded-2xl p-5 border border-[#6366F1]/5">
            <i class="fas fa-book-reader text-[#6366F1] text-lg mb-3"></i>
            <p class="font-semibold text-sm">자체 교재 개발</p>
            <p class="text-[12px] text-[#1E293B]/40 mt-1">최신 출제 경향 반영</p>
          </div>
          <div class="bg-white rounded-2xl p-5 border border-[#6366F1]/5">
            <i class="fas fa-headset text-[#6366F1] text-lg mb-3"></i>
            <p class="font-semibold text-sm">학부모 상담</p>
            <p class="text-[12px] text-[#1E293B]/40 mt-1">월 1회 정기 상담</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Curriculum ========== -->
  <section id="curriculum" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-semibold bg-[#6366F1]/5 text-[#6366F1] reveal" style="--delay: 0;">Curriculum</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6 reveal" style="--delay: 1;">
          체계적인 커리큘럼으로<br>확실한 결과를
        </h2>
        <p class="text-[#1E293B]/50 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">
          학년별, 수준별 맞춤 프로그램으로 효율적인 학습을 설계합니다.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="curriculum-card bg-[#F8FAFC] rounded-3xl p-8 border border-[#6366F1]/5 reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#6366F1]/10 rounded-2xl flex items-center justify-center mb-6">
            <i class="fas fa-calculator text-[#6366F1] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">수학 심화반</h3>
          <p class="text-[13px] text-[#1E293B]/50 leading-relaxed mb-4">개념 이해부터 고난도 문제 풀이까지, 수학적 사고력을 키우는 체계적 과정</p>
          <div class="flex items-center gap-2 text-[#6366F1]">
            <span class="text-[11px] font-semibold uppercase tracking-[0.1em]">자세히 보기</span>
            <i class="fas fa-arrow-right text-[9px]"></i>
          </div>
        </div>

        <div class="curriculum-card bg-[#F8FAFC] rounded-3xl p-8 border border-[#6366F1]/5 reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#6366F1]/10 rounded-2xl flex items-center justify-center mb-6">
            <i class="fas fa-language text-[#6366F1] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">국어 독해반</h3>
          <p class="text-[13px] text-[#1E293B]/50 leading-relaxed mb-4">비문학 독해와 문학 감상력을 동시에 향상시키는 통합 국어 프로그램</p>
          <div class="flex items-center gap-2 text-[#6366F1]">
            <span class="text-[11px] font-semibold uppercase tracking-[0.1em]">자세히 보기</span>
            <i class="fas fa-arrow-right text-[9px]"></i>
          </div>
        </div>

        <div class="curriculum-card bg-[#F8FAFC] rounded-3xl p-8 border border-[#6366F1]/5 reveal" style="--delay: 2;">
          <div class="w-14 h-14 bg-[#6366F1]/10 rounded-2xl flex items-center justify-center mb-6">
            <i class="fas fa-flask text-[#6366F1] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">과학 탐구반</h3>
          <p class="text-[13px] text-[#1E293B]/50 leading-relaxed mb-4">실험과 탐구 활동 중심의 과학 수업으로 원리를 직접 체험하는 학습</p>
          <div class="flex items-center gap-2 text-[#6366F1]">
            <span class="text-[11px] font-semibold uppercase tracking-[0.1em]">자세히 보기</span>
            <i class="fas fa-arrow-right text-[9px]"></i>
          </div>
        </div>

        <div class="curriculum-card bg-[#F8FAFC] rounded-3xl p-8 border border-[#6366F1]/5 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#6366F1]/10 rounded-2xl flex items-center justify-center mb-6">
            <i class="fas fa-globe-americas text-[#6366F1] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">영어 집중반</h3>
          <p class="text-[13px] text-[#1E293B]/50 leading-relaxed mb-4">내신과 수능을 동시에 대비하는 통합 영어 커리큘럼으로 실력 완성</p>
          <div class="flex items-center gap-2 text-[#6366F1]">
            <span class="text-[11px] font-semibold uppercase tracking-[0.1em]">자세히 보기</span>
            <i class="fas fa-arrow-right text-[9px]"></i>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Instructors ========== -->
  <section id="instructors" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
        <div>
          <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-semibold bg-[#6366F1]/5 text-[#6366F1] reveal" style="--delay: 0;">Instructors</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6 reveal" style="--delay: 1;">검증된 강사진</h2>
        </div>
        <p class="text-[#1E293B]/50 text-base max-w-md reveal" style="--delay: 2;">
          명문대 출신, 평균 경력 10년 이상의 전문 강사가 직접 가르칩니다.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="instructor-card bg-white rounded-3xl overflow-hidden border border-[#6366F1]/5 reveal" style="--delay: 0;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=600" alt="김서연 선생님" class="w-full aspect-[4/5] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <h3 class="font-bold text-lg">김서연 선생님</h3>
            <p class="text-[#6366F1] text-[12px] font-semibold mt-1">수학 | 서울대 수학교육과</p>
            <p class="text-[12px] text-[#1E293B]/40 mt-2">경력 12년, 수능 만점자 다수 배출</p>
          </div>
        </div>
        <div class="instructor-card bg-white rounded-3xl overflow-hidden border border-[#6366F1]/5 reveal" style="--delay: 1;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=600" alt="박준혁 선생님" class="w-full aspect-[4/5] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <h3 class="font-bold text-lg">박준혁 선생님</h3>
            <p class="text-[#6366F1] text-[12px] font-semibold mt-1">국어 | 고려대 국어국문학과</p>
            <p class="text-[12px] text-[#1E293B]/40 mt-2">경력 10년, 비문학 독해 전문가</p>
          </div>
        </div>
        <div class="instructor-card bg-white rounded-3xl overflow-hidden border border-[#6366F1]/5 reveal" style="--delay: 2;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1580894732444-8ecded7900cd?q=80&w=600" alt="이지은 선생님" class="w-full aspect-[4/5] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <h3 class="font-bold text-lg">이지은 선생님</h3>
            <p class="text-[#6366F1] text-[12px] font-semibold mt-1">과학 | KAIST 생명과학과</p>
            <p class="text-[12px] text-[#1E293B]/40 mt-2">경력 8년, 과학 올림피아드 지도</p>
          </div>
        </div>
        <div class="instructor-card bg-white rounded-3xl overflow-hidden border border-[#6366F1]/5 reveal" style="--delay: 3;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=600" alt="최민수 선생님" class="w-full aspect-[4/5] object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <h3 class="font-bold text-lg">최민수 선생님</h3>
            <p class="text-[#6366F1] text-[12px] font-semibold mt-1">영어 | 연세대 영어영문학과</p>
            <p class="text-[12px] text-[#1E293B]/40 mt-2">경력 11년, 원어민급 발음 교정</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Reviews ========== -->
  <section id="reviews" class="py-24 md:py-32 bg-[#6366F1]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-semibold bg-white/10 text-white reveal" style="--delay: 0;">Reviews</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6 text-white reveal" style="--delay: 1;">수강생들의 진짜 이야기</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white/10 backdrop-blur-sm rounded-3xl p-8 border border-white/10 reveal" style="--delay: 0;">
