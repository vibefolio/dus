<%# Kkang Template - 바다꽃게 %>

<style>
  /* Supanova Design — Seafood Restaurant Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;500;600;700;900&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-serif-kr { font-family: 'Noto Serif KR', serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 42px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  .menu-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .menu-card:hover { transform: translateY(-8px); }
  .menu-card:hover img { transform: scale(1.05); }

  .gallery-item { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .gallery-item:hover { transform: scale(1.02); }
  .gallery-item:hover img { transform: scale(1.08); }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .wave-pattern {
    background-image: url("https://www.transparenttextures.com/patterns/cream-paper.png");
    opacity: 0.4;
  }
</style>

<div class="bg-[#FFF8F0] text-[#1A1A1A] font-sans selection:bg-[#DC2626] selection:text-white min-h-screen overflow-x-hidden relative">
  <div class="fixed inset-0 wave-pattern pointer-events-none z-[60]"></div>

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#FFF8F0]/80 backdrop-blur-xl border-b border-[#DC2626]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="font-serif-kr text-2xl tracking-tight font-bold text-[#DC2626]">바다꽃게</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1A1A1A]/40">
        <a href="#about" class="hover:text-[#DC2626] transition">소개</a>
        <a href="#menu" class="hover:text-[#DC2626] transition">메뉴</a>
        <a href="#gallery" class="hover:text-[#DC2626] transition">갤러리</a>
        <a href="#location" class="hover:text-[#DC2626] transition">위치</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleKkangModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1A1A1A]/40 hover:text-[#DC2626]" data-mobile-menu-copy="true">회원</button>
        <button class="bg-[#DC2626] text-white px-8 py-3.5 rounded-full font-bold text-[10px] tracking-[0.3em] uppercase hover:bg-[#B91C1C] transition shadow-lg shadow-[#DC2626]/20" data-mobile-menu-copy="true">
          예약하기
        </button>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center justify-center pt-20">
    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-10 text-center lg:text-left">
        <div class="inline-flex items-center gap-5 reveal" style="--delay: 0;">
          <span class="w-10 h-[1px] bg-[#DC2626]"></span>
          <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#DC2626]">Since 1998</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-[5.5rem] font-serif-kr font-bold leading-tight tracking-tight text-[#1A1A1A] mobile-title reveal" style="--delay: 1;">
          바다에서 온<br><span class="text-[#DC2626]">꽃게의 진미.</span>
        </h1>

        <p class="text-[#1A1A1A]/60 text-sm md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          서해안 직송 활꽃게를 25년 전통 비법 양념으로 정성껏 조리합니다. 바다꽃게에서 경험하는 대한민국 최고의 꽃게 요리.
        </p>

        <div class="pt-4 flex flex-col sm:flex-row gap-5 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#menu" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#DC2626] text-white font-bold text-[11px] tracking-[0.3em] uppercase hover:bg-[#B91C1C] rounded-full shadow-xl shadow-[#DC2626]/20">
            대표 메뉴
            <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center">
              <i class="fas fa-arrow-right text-[10px]"></i>
            </span>
          </a>
          <a href="#location" class="inline-flex items-center justify-center px-10 py-5 border border-[#DC2626]/30 text-[#DC2626] font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-white rounded-full">
            오시는 길
          </a>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <div class="absolute -top-12 -right-12 w-72 h-72 bg-[#DC2626]/10 rounded-full blur-[100px]"></div>
        <div class="relative group">
          <img src="https://images.unsplash.com/photo-1559737558-2f5a35f4523b?q=80&w=1200" alt="꽃게찜" class="w-full aspect-[4/5] object-cover rounded-[3rem] shadow-2xl group-hover:shadow-[0_30px_80px_-20px_rgba(220,38,38,0.3)] transition-all duration-700" loading="eager">
          <div class="absolute -bottom-6 -left-6 md:-bottom-8 md:-left-8 bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-[#DC2626]/10 max-w-[260px]" style="animation: float 6s ease-in-out infinite;">
            <p class="text-[10px] font-semibold text-[#DC2626] uppercase tracking-[0.4em] mb-3">오늘의 꽃게</p>
            <p class="text-xl font-serif-kr font-bold text-[#1A1A1A]">서해 직송 활꽃게</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About / 신선함의 비밀 ========== -->
  <section id="about" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative reveal" style="--delay: 0;">
        <div class="absolute -top-8 -left-8 w-60 h-60 bg-[#DC2626]/8 rounded-full blur-[80px]"></div>
        <div class="grid grid-cols-5 gap-4">
          <div class="col-span-3 overflow-hidden rounded-[2rem]">
            <img src="https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?q=80&w=800" alt="수산 시장" class="w-full h-full object-cover aspect-[3/4]" loading="lazy" decoding="async">
          </div>
          <div class="col-span-2 flex flex-col gap-4">
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1615141982883-c7ad0e69fd62?q=80&w=600" alt="해산물" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=600" alt="요리" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-8 reveal" style="--delay: 1;">
        <div class="inline-flex items-center gap-4">
          <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#DC2626]/10 text-[#DC2626]">신선함의 비밀</span>
        </div>

        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif-kr font-bold leading-snug text-[#1A1A1A]">
          매일 새벽,<br>서해에서 식탁까지
        </h2>

        <p class="text-[#1A1A1A]/60 text-base md:text-lg leading-relaxed">
          매일 새벽 4시, 서해안 태안과 인천에서 그날 잡은 활꽃게가 바다꽃게에 도착합니다. 수조에서 살아 움직이는 싱싱한 꽃게만을 엄선하여 25년 전통 비법 양념장으로 조리합니다.
        </p>
        <p class="text-[#1A1A1A]/60 text-base md:text-lg leading-relaxed">
          우리는 냉동 꽃게를 절대 사용하지 않습니다. 손님의 주문이 들어오면 그때서야 활꽃게를 손질하기 시작합니다. 이것이 바다꽃게의 맛의 비밀입니다.
        </p>

        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-[#DC2626]/10">
          <div>
            <p class="text-2xl md:text-3xl font-serif-kr font-bold text-[#DC2626]">25년</p>
            <p class="text-[11px] text-[#1A1A1A]/40 uppercase tracking-[0.1em] mt-1 font-medium">전통의 맛</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-serif-kr font-bold text-[#DC2626]">100%</p>
            <p class="text-[11px] text-[#1A1A1A]/40 uppercase tracking-[0.1em] mt-1 font-medium">서해안 활꽃게</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-serif-kr font-bold text-[#DC2626]">3대</p>
            <p class="text-[11px] text-[#1A1A1A]/40 uppercase tracking-[0.1em] mt-1 font-medium">비법 양념장</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 대표 메뉴 (4개) ========== -->
  <section id="menu" class="py-24 md:py-32 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#DC2626]/10 text-[#DC2626] reveal" style="--delay: 0;">대표 메뉴</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif-kr font-bold leading-snug text-[#1A1A1A] mt-6 reveal" style="--delay: 1;">
          꽃게의 모든 것
        </h2>
        <p class="text-[#1A1A1A]/50 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">
          활꽃게로 만든 정통 꽃게 요리를 만나보세요.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="menu-card bg-[#FFF8F0] rounded-[2rem] overflow-hidden reveal" style="--delay: 0;">
          <div class="overflow-hidden">
            <img src="https://images.unsplash.com/photo-1559737558-2f5a35f4523b?q=80&w=600" alt="양념꽃게찜" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-semibold text-[#DC2626] uppercase tracking-[0.2em]">인기 1위</span>
              <span class="text-lg font-serif-kr font-bold text-[#DC2626]">₩55,000</span>
            </div>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">양념꽃게찜</h3>
            <p class="text-[#1A1A1A]/50 text-sm leading-relaxed">25년 전통 비법 양념장으로 쪄낸 활꽃게. 2인 기준 3마리</p>
          </div>
        </div>

        <div class="menu-card bg-[#FFF8F0] rounded-[2rem] overflow-hidden reveal" style="--delay: 1;">
          <div class="overflow-hidden">
            <img src="https://images.unsplash.com/photo-1565557623262-b51c2513a641?q=80&w=600" alt="간장꽃게" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-semibold text-[#DC2626] uppercase tracking-[0.2em]">시그니처</span>
              <span class="text-lg font-serif-kr font-bold text-[#DC2626]">₩65,000</span>
            </div>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">간장꽃게</h3>
            <p class="text-[#1A1A1A]/50 text-sm leading-relaxed">3일간 숙성시킨 특제 간장에 담근 밥도둑 간장꽃게</p>
          </div>
        </div>

        <div class="menu-card bg-[#FFF8F0] rounded-[2rem] overflow-hidden reveal" style="--delay: 2;">
          <div class="overflow-hidden">
            <img src="https://images.unsplash.com/photo-1534604973900-c43ab4c2e0ab?q=80&w=600" alt="꽃게탕" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-semibold text-[#DC2626] uppercase tracking-[0.2em]">보양</span>
              <span class="text-lg font-serif-kr font-bold text-[#DC2626]">₩45,000</span>
            </div>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">꽃게탕</h3>
            <p class="text-[#1A1A1A]/50 text-sm leading-relaxed">시원한 국물이 일품인 꽃게탕. 미나리, 두부와 함께</p>
          </div>
        </div>

        <div class="menu-card bg-[#FFF8F0] rounded-[2rem] overflow-hidden reveal" style="--delay: 3;">
          <div class="overflow-hidden">
            <img src="https://images.unsplash.com/photo-1563245372-f21724e3856d?q=80&w=600" alt="꽃게볶음밥" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-semibold text-[#DC2626] uppercase tracking-[0.2em]">마무리</span>
              <span class="text-lg font-serif-kr font-bold text-[#DC2626]">₩12,000</span>
            </div>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">꽃게볶음밥</h3>
            <p class="text-[#1A1A1A]/50 text-sm leading-relaxed">꽃게살이 듬뿍 들어간 고소한 볶음밥. 식사의 완벽한 마무리</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Gallery ========== -->
  <section id="gallery" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#DC2626]/10 text-[#DC2626] reveal" style="--delay: 0;">Gallery</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif-kr font-bold leading-snug text-[#1A1A1A] mt-6 reveal" style="--delay: 1;">
          매장 갤러리
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1552566626-52f8b828add9?q=80&w=600" alt="매장 내부" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 1;">
          <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?q=80&w=600" alt="테이블 세팅" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 2;">
          <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=600" alt="주방" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 3;">
          <img src="https://images.unsplash.com/photo-1578474846511-04ba529f0b88?q=80&w=600" alt="해산물" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] col-span-2 reveal" style="--delay: 4;">
          <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=900" alt="단체석" class="w-full aspect-[2/1] object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Location / 영업시간 ========== -->
  <section id="location" class="py-24 md:py-32 bg-[#1A1A1A]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="overflow-hidden rounded-[2rem] reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1514933651103-005eec06c04b?q=80&w=800" alt="매장 외관" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async">
        </div>

        <div class="space-y-8 reveal" style="--delay: 1;">
          <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-white/10 text-[#DC2626]">Location</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif-kr font-bold leading-snug text-white">오시는 길</h2>

          <div class="space-y-6">
            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                <i class="fas fa-map-marker-alt text-[#DC2626] text-sm"></i>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-white/40 mb-2">Address</p>
                <p class="text-white/80 text-base leading-relaxed">서울시 마포구 월드컵북로 12<br>바다꽃게 본점</p>
              </div>
            </div>

            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                <i class="fas fa-clock text-[#DC2626] text-sm"></i>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-white/40 mb-2">Hours</p>
                <p class="text-white/80 text-base leading-relaxed">점심 11:30 – 15:00<br>저녁 17:00 – 22:00 (라스트오더 21:00)<br>매주 월요일 휴무</p>
              </div>
            </div>

            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                <i class="fas fa-subway text-[#DC2626] text-sm"></i>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-white/40 mb-2">Transport</p>
                <p class="text-white/80 text-base leading-relaxed">마포구청역 1번 출구에서 도보 5분<br>전용 주차장 20대 보유</p>
              </div>
            </div>

            <div class="flex gap-5">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 mt-0.5">
                <i class="fas fa-phone text-[#DC2626] text-sm"></i>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-white/40 mb-2">Contact</p>
                <p class="text-white/80 text-base">02-3456-7890</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA / 예약 ========== -->
  <section class="py-24 md:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#FFF8F0] via-[#FEF3E2] to-[#FFF8F0]"></div>
