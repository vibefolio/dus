<%# Study Template - Focus Zone (스터디카페) %>

<style>
  /* Supanova Design — Dark Study Cafe Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-space { font-family: 'Space Grotesk', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 36px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .seat-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .seat-card:hover { transform: translateY(-8px); border-color: #E2B714; }
  .gallery-item { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .gallery-item:hover { transform: scale(1.02); }
  .gallery-item:hover img { transform: scale(1.08); }

  @keyframes glow { 0%, 100% { box-shadow: 0 0 20px rgba(226, 183, 20, 0.1); } 50% { box-shadow: 0 0 40px rgba(226, 183, 20, 0.2); } }
</style>

<div class="bg-[#1A1A2E] text-white font-sans selection:bg-[#E2B714] selection:text-[#1A1A2E] min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#1A1A2E]/80 backdrop-blur-xl border-b border-[#E2B714]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <div class="w-8 h-8 bg-[#E2B714] rounded-lg flex items-center justify-center">
          <i class="fas fa-bolt text-[#1A1A2E] text-sm"></i>
        </div>
        <span class="font-space text-xl font-bold tracking-tight">Focus Zone</span>
      </a>

      <div class="hidden md:flex gap-10 text-[11px] font-semibold uppercase tracking-[0.3em] text-white/30">
        <a href="#seats" class="hover:text-[#E2B714] transition">좌석</a>
        <a href="#gallery" class="hover:text-[#E2B714] transition">시설</a>
        <a href="#pricing" class="hover:text-[#E2B714] transition">요금</a>
        <a href="#location" class="hover:text-[#E2B714] transition">위치</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center shrink-0">
        <button onclick="toggleStudyModal()" class="text-[11px] font-semibold text-white/30 hover:text-[#E2B714] tracking-[0.2em] uppercase" data-mobile-menu-copy="true">로그인</button>
        <a href="#pricing" class="bg-[#E2B714] text-[#1A1A2E] px-7 py-3 rounded-full font-bold text-[11px] tracking-[0.2em] uppercase hover:bg-[#d4a912] shadow-lg shadow-[#E2B714]/20" data-mobile-menu-copy="true">좌석 예약</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1600" alt="스터디카페 배경" class="w-full h-full object-cover opacity-20" loading="eager">
      <div class="absolute inset-0 bg-gradient-to-b from-[#1A1A2E]/80 via-[#1A1A2E]/60 to-[#1A1A2E]"></div>
    </div>
    <div class="absolute top-40 right-20 w-80 h-80 bg-[#E2B714]/5 rounded-full blur-[120px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-3 bg-[#E2B714]/10 rounded-full px-5 py-2 mb-8 reveal" style="--delay: 0;">
        <span class="w-2 h-2 bg-[#E2B714] rounded-full animate-pulse"></span>
        <span class="text-[11px] font-bold tracking-[0.3em] uppercase text-[#E2B714]">24시간 운영</span>
      </div>

      <h1 class="text-4xl md:text-6xl lg:text-[5.5rem] font-bold leading-tight tracking-tight mobile-title reveal" style="--delay: 1;">
        집중의 시간,<br><span class="text-[#E2B714] font-space">Focus Zone.</span>
      </h1>

      <p class="text-white/40 text-base md:text-lg leading-relaxed max-w-xl mx-auto mt-8 mobile-desc reveal" style="--delay: 2;">
        완벽한 집중 환경을 제공하는 프리미엄 스터디카페. 나만의 공간에서 목표에 한 발짝 더 가까워지세요.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 reveal" style="--delay: 3;">
        <a href="#pricing" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#E2B714] text-[#1A1A2E] font-bold text-[12px] tracking-[0.2em] uppercase hover:bg-[#d4a912] rounded-full shadow-xl shadow-[#E2B714]/20">
          좌석 예약하기 <i class="fas fa-arrow-right text-[10px]"></i>
        </a>
        <a href="#seats" class="inline-flex items-center justify-center gap-3 px-10 py-5 border border-white/10 text-white/60 font-semibold text-[12px] tracking-[0.2em] uppercase hover:border-[#E2B714]/30 rounded-full">
          시설 둘러보기
        </a>
      </div>

      <div class="grid grid-cols-4 gap-8 max-w-2xl mx-auto mt-16 reveal" style="--delay: 4;">
        <div><p class="text-2xl md:text-3xl font-bold text-[#E2B714] font-space">24h</p><p class="text-[11px] text-white/30 mt-1">연중무휴</p></div>
        <div><p class="text-2xl md:text-3xl font-bold text-[#E2B714] font-space">200+</p><p class="text-[11px] text-white/30 mt-1">좌석 수</p></div>
        <div><p class="text-2xl md:text-3xl font-bold text-[#E2B714] font-space">30dB</p><p class="text-[11px] text-white/30 mt-1">정숙 환경</p></div>
        <div><p class="text-2xl md:text-3xl font-bold text-[#E2B714] font-space">FREE</p><p class="text-[11px] text-white/30 mt-1">음료 무제한</p></div>
      </div>
    </div>
  </header>

  <!-- ========== About ========== -->
  <section id="about" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="space-y-8 reveal" style="--delay: 0;">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#E2B714]/10 text-[#E2B714]">About</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug">
          당신만의<br>완벽한 집중 공간
        </h2>
        <p class="text-white/40 text-base md:text-lg leading-relaxed">
          Focus Zone은 학습에 최적화된 환경을 설계합니다. 방음 시설, 개인 조명, 고속 와이파이, 무료 음료까지. 오직 당신의 집중에만 신경 쓸 수 있도록 모든 것을 준비했습니다.
        </p>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/5 rounded-2xl p-5 border border-white/5">
            <i class="fas fa-wifi text-[#E2B714] text-lg mb-3"></i>
            <p class="font-semibold text-sm">초고속 와이파이</p>
            <p class="text-[12px] text-white/30 mt-1">1Gbps 광랜</p>
          </div>
          <div class="bg-white/5 rounded-2xl p-5 border border-white/5">
            <i class="fas fa-plug text-[#E2B714] text-lg mb-3"></i>
            <p class="font-semibold text-sm">개인 콘센트</p>
            <p class="text-[12px] text-white/30 mt-1">좌석별 2구 이상</p>
          </div>
          <div class="bg-white/5 rounded-2xl p-5 border border-white/5">
            <i class="fas fa-coffee text-[#E2B714] text-lg mb-3"></i>
            <p class="font-semibold text-sm">무료 음료</p>
            <p class="text-[12px] text-white/30 mt-1">커피, 차 무제한</p>
          </div>
          <div class="bg-white/5 rounded-2xl p-5 border border-white/5">
            <i class="fas fa-print text-[#E2B714] text-lg mb-3"></i>
            <p class="font-semibold text-sm">복합기 이용</p>
            <p class="text-[12px] text-white/30 mt-1">흑백/컬러 출력</p>
          </div>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 1;">
        <div class="rounded-[2rem] overflow-hidden" style="animation: glow 4s ease-in-out infinite;">
          <img src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?q=80&w=800" alt="스터디카페 내부" class="w-full aspect-[4/5] object-cover" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Seat Types ========== -->
  <section id="seats" class="py-24 md:py-32 bg-[#16213E]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#E2B714]/10 text-[#E2B714] reveal" style="--delay: 0;">Seats</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6 reveal" style="--delay: 1;">
          나에게 맞는<br>좌석을 선택하세요
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="seat-card bg-[#1A1A2E] rounded-3xl p-8 border border-white/5 reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#E2B714]/10 rounded-2xl flex items-center justify-center mb-6">
            <i class="fas fa-chair text-[#E2B714] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-2">오픈석</h3>
          <p class="text-white/30 text-[13px] leading-relaxed mb-4">넓은 공용 공간에서 자유롭게 이용하는 기본 좌석. 개인 조명과 콘센트 제공</p>
          <p class="text-[#E2B714] font-bold text-lg font-space">시간당 1,500원</p>
        </div>

        <div class="seat-card bg-[#1A1A2E] rounded-3xl p-8 border border-white/5 reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#E2B714]/10 rounded-2xl flex items-center justify-center mb-6">
            <i class="fas fa-user-shield text-[#E2B714] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-2">반개인석</h3>
          <p class="text-white/30 text-[13px] leading-relaxed mb-4">파티션으로 분리된 반독립 공간. 집중도를 높이면서 적당한 개방감 유지</p>
          <p class="text-[#E2B714] font-bold text-lg font-space">시간당 2,000원</p>
        </div>

        <div class="seat-card bg-[#1A1A2E] rounded-3xl p-8 border border-[#E2B714]/30 ring-1 ring-[#E2B714]/20 reveal" style="--delay: 2;">
          <div class="inline-block bg-[#E2B714] text-[#1A1A2E] text-[10px] font-bold uppercase tracking-[0.15em] px-3 py-1 rounded-full mb-4">인기</div>
          <div class="w-14 h-14 bg-[#E2B714]/10 rounded-2xl flex items-center justify-center mb-6">
            <i class="fas fa-door-closed text-[#E2B714] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-2">1인 독립실</h3>
          <p class="text-white/30 text-[13px] leading-relaxed mb-4">완전히 독립된 나만의 공간. 최고의 집중 환경과 프라이버시를 보장</p>
          <p class="text-[#E2B714] font-bold text-lg font-space">시간당 3,000원</p>
        </div>

        <div class="seat-card bg-[#1A1A2E] rounded-3xl p-8 border border-white/5 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#E2B714]/10 rounded-2xl flex items-center justify-center mb-6">
            <i class="fas fa-users text-[#E2B714] text-xl"></i>
          </div>
          <h3 class="text-lg font-bold mb-2">그룹 스터디룸</h3>
          <p class="text-white/30 text-[13px] leading-relaxed mb-4">2~6인용 그룹 스터디룸. 화이트보드와 대형 모니터 구비</p>
          <p class="text-[#E2B714] font-bold text-lg font-space">시간당 8,000원</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Gallery ========== -->
  <section id="gallery" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-14 gap-6">
        <div>
          <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#E2B714]/10 text-[#E2B714] reveal" style="--delay: 0;">Gallery</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6 reveal" style="--delay: 1;">시설 갤러리</h2>
        </div>
        <p class="text-white/30 text-base max-w-sm reveal" style="--delay: 2;">최신 인테리어와 쾌적한 환경을 직접 확인하세요.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
        <div class="gallery-item overflow-hidden rounded-2xl reveal" style="--delay: 0;"><img src="https://images.unsplash.com/photo-1497366811353-6870744d04b2?q=80&w=800" alt="오픈석 전경" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
        <div class="gallery-item overflow-hidden rounded-2xl md:row-span-2 reveal" style="--delay: 1;"><img src="https://images.unsplash.com/photo-1497215842964-222b430dc094?q=80&w=800" alt="독립실" class="w-full h-full object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
        <div class="gallery-item overflow-hidden rounded-2xl reveal" style="--delay: 2;"><img src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?q=80&w=800" alt="음료 코너" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
        <div class="gallery-item overflow-hidden rounded-2xl reveal" style="--delay: 3;"><img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?q=80&w=800" alt="스터디룸" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
        <div class="gallery-item overflow-hidden rounded-2xl col-span-2 md:col-span-1 reveal" style="--delay: 4;"><img src="https://images.unsplash.com/photo-1416339306562-f3d12fefd36f?q=80&w=800" alt="복도" class="w-full aspect-[2/1] md:aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
      </div>
    </div>
  </section>

  <!-- ========== Pricing ========== -->
  <section id="pricing" class="py-24 md:py-32 bg-[#16213E]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#E2B714]/10 text-[#E2B714] reveal" style="--delay: 0;">Pricing</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-snug mt-6 reveal" style="--delay: 1;">합리적인 요금제</h2>
        <p class="text-white/30 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">기간이 길수록 더 합리적인 가격으로 이용하세요.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-[#1A1A2E] rounded-3xl p-8 border border-white/5 text-center reveal" style="--delay: 0;">
          <p class="text-[11px] font-bold text-white/30 uppercase tracking-[0.2em] mb-4">시간권</p>
          <p class="text-4xl font-bold text-[#E2B714] font-space">1,500<span class="text-lg text-white/30">원~</span></p>
          <p class="text-white/30 text-[13px] mt-4 mb-6">시간당 / 좌석 유형별 차등</p>
          <ul class="space-y-3 text-left text-[13px] text-white/50 mb-8">
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 원하는 시간만큼 이용</li>
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 무료 음료 포함</li>
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 좌석 자유 선택</li>
          </ul>
          <a href="#" class="block w-full py-4 border border-[#E2B714]/30 rounded-full text-[#E2B714] font-semibold text-[12px] uppercase tracking-[0.15em] hover:bg-[#E2B714]/10">선택하기</a>
        </div>

        <div class="bg-[#1A1A2E] rounded-3xl p-8 border border-[#E2B714]/30 text-center ring-1 ring-[#E2B714]/20 reveal" style="--delay: 1;">
          <div class="inline-block bg-[#E2B714] text-[#1A1A2E] text-[10px] font-bold uppercase tracking-[0.15em] px-3 py-1 rounded-full mb-4">추천</div>
          <p class="text-[11px] font-bold text-white/30 uppercase tracking-[0.2em] mb-4">정기권 (1개월)</p>
          <p class="text-4xl font-bold text-[#E2B714] font-space">89,000<span class="text-lg text-white/30">원</span></p>
          <p class="text-white/30 text-[13px] mt-4 mb-6">오픈석 기준 / 월</p>
          <ul class="space-y-3 text-left text-[13px] text-white/50 mb-8">
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 하루 최대 12시간 이용</li>
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 무료 음료 무제한</li>
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 사물함 무료 제공</li>
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 독립실 할인 10%</li>
          </ul>
          <a href="#" class="block w-full py-4 bg-[#E2B714] rounded-full text-[#1A1A2E] font-bold text-[12px] uppercase tracking-[0.15em] hover:bg-[#d4a912] shadow-lg shadow-[#E2B714]/20">선택하기</a>
        </div>

        <div class="bg-[#1A1A2E] rounded-3xl p-8 border border-white/5 text-center reveal" style="--delay: 2;">
          <p class="text-[11px] font-bold text-white/30 uppercase tracking-[0.2em] mb-4">정기권 (3개월)</p>
          <p class="text-4xl font-bold text-[#E2B714] font-space">229,000<span class="text-lg text-white/30">원</span></p>
          <p class="text-white/30 text-[13px] mt-4 mb-6">오픈석 기준 / 3개월</p>
          <ul class="space-y-3 text-left text-[13px] text-white/50 mb-8">
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 하루 무제한 이용</li>
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 무료 음료 무제한</li>
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 사물함 + 프린터 무료</li>
            <li class="flex items-center gap-2"><i class="fas fa-check text-[#E2B714] text-[10px]"></i> 독립실 할인 20%</li>
          </ul>
          <a href="#" class="block w-full py-4 border border-[#E2B714]/30 rounded-full text-[#E2B714] font-semibold text-[12px] uppercase tracking-[0.15em] hover:bg-[#E2B714]/10">선택하기</a>
