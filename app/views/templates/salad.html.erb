<%# Salad Template - 그린볼 (GREEN BOWL) %>

<style>
  /* Supanova Design — Fresh Health Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-dm { font-family: 'DM Sans', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 42px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }

  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  .menu-card {
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .menu-card:hover {
    transform: translateY(-8px);
  }
  .menu-card:hover img {
    transform: scale(1.05);
  }

  .gallery-item {
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-item:hover {
    transform: scale(1.02);
  }
  .gallery-item:hover img {
    transform: scale(1.08);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .leaf-pattern {
    background-image: url("https://www.transparenttextures.com/patterns/light-paper-fibers.png");
    opacity: 0.3;
  }
</style>

<div class="bg-[#F0FDF4] text-[#1A1A1A] font-sans selection:bg-[#16A34A] selection:text-white min-h-screen overflow-x-hidden relative">
  <div class="fixed inset-0 leaf-pattern pointer-events-none z-[60]"></div>

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#F0FDF4]/80 backdrop-blur-xl border-b border-[#16A34A]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="w-8 h-8 bg-[#16A34A] rounded-full flex items-center justify-center">
          <i class="fas fa-leaf text-white text-xs"></i>
        </span>
        <span class="font-dm text-2xl tracking-tight font-bold text-[#16A34A]">GREEN BOWL</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1A1A1A]/40">
        <a href="#about" class="hover:text-[#16A34A] transition">About</a>
        <a href="#menu" class="hover:text-[#16A34A] transition">Menu</a>
        <a href="#nutrition" class="hover:text-[#16A34A] transition">Nutrition</a>
        <a href="#subscribe" class="hover:text-[#16A34A] transition">Subscribe</a>
        <a href="#location" class="hover:text-[#16A34A] transition">Location</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleSaladModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#1A1A1A]/40 hover:text-[#16A34A]" data-mobile-menu-copy="true">Members</button>
        <button class="bg-[#16A34A] text-white px-8 py-3.5 rounded-full font-semibold text-[10px] tracking-[0.3em] uppercase hover:bg-[#15803D] transition shadow-lg shadow-[#16A34A]/20" data-mobile-menu-copy="true">
          Order Now
        </button>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center justify-center pt-20">
    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-10 text-center lg:text-left">
        <div class="inline-flex items-center gap-5 reveal" style="--delay: 0;">
          <span class="w-10 h-[1px] bg-[#16A34A]"></span>
          <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#16A34A]">Fresh &amp; Healthy</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-[5.5rem] font-dm font-bold leading-tight tracking-tight text-[#1A1A1A] mobile-title reveal" style="--delay: 1;">
          신선한 한 끼,<br><span class="text-[#16A34A]">매일의 활력.</span>
        </h1>

        <p class="text-[#1A1A1A]/60 text-sm md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          유기농 채소와 슈퍼푸드로 만든 프리미엄 샐러드. 그린볼은 바쁜 일상 속에서도 건강한 식사를 포기하지 않는 당신을 위해 존재합니다.
        </p>

        <div class="pt-4 flex flex-col sm:flex-row gap-5 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#menu" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#16A34A] text-white font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-[#15803D] rounded-full shadow-xl shadow-[#16A34A]/20">
            메뉴 보기
            <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center">
              <i class="fas fa-arrow-right text-[10px]"></i>
            </span>
          </a>
          <a href="#subscribe" class="inline-flex items-center justify-center px-10 py-5 border border-[#16A34A]/30 text-[#16A34A] font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-white rounded-full">
            정기배송 시작
          </a>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <div class="absolute -top-12 -right-12 w-72 h-72 bg-[#16A34A]/10 rounded-full blur-[100px]"></div>
        <div class="relative group">
          <img src="https://images.unsplash.com/photo-1512621776951-a57141f2eefd?q=80&w=1200" alt="신선한 샐러드 볼" class="w-full aspect-[4/5] object-cover rounded-[3rem] shadow-2xl group-hover:shadow-[0_30px_80px_-20px_rgba(22,163,74,0.3)] transition-all duration-700" loading="eager">
          <div class="absolute -bottom-6 -left-6 md:-bottom-8 md:-left-8 bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-[#16A34A]/10 max-w-[260px]" style="animation: float 6s ease-in-out infinite;">
            <p class="text-[10px] font-semibold text-[#16A34A] uppercase tracking-[0.4em] mb-3">Farm to Bowl</p>
            <p class="text-xl font-dm font-bold text-[#1A1A1A]">오늘 아침 수확한 재료</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About / 재료 철학 ========== -->
  <section id="about" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative reveal" style="--delay: 0;">
        <div class="absolute -top-8 -left-8 w-60 h-60 bg-[#16A34A]/8 rounded-full blur-[80px]"></div>
        <div class="grid grid-cols-5 gap-4">
          <div class="col-span-3 overflow-hidden rounded-[2rem]">
            <img src="https://images.unsplash.com/photo-1540420773420-3366772f4999?q=80&w=800" alt="유기농 농장" class="w-full h-full object-cover aspect-[3/4]" loading="lazy" decoding="async">
          </div>
          <div class="col-span-2 flex flex-col gap-4">
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1498837167922-ddd27525d352?q=80&w=600" alt="신선한 재료" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
            <div class="overflow-hidden rounded-[1.5rem] flex-1">
              <img src="https://images.unsplash.com/photo-1607532941433-304659e8198a?q=80&w=600" alt="샐러드 준비" class="w-full h-full object-cover" loading="lazy" decoding="async">
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-8 reveal" style="--delay: 1;">
        <div class="inline-flex items-center gap-4">
          <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#16A34A]/10 text-[#16A34A]">Our Philosophy</span>
        </div>

        <h2 class="text-3xl md:text-4xl lg:text-5xl font-dm font-bold leading-snug text-[#1A1A1A]">
          좋은 재료가<br>좋은 한 끼를 만듭니다
        </h2>

        <p class="text-[#1A1A1A]/60 text-base md:text-lg leading-relaxed">
          그린볼은 전국 30여 곳의 유기농 농가와 직접 계약하여 매일 아침 수확한 채소만을 사용합니다. 화학 비료와 농약 없이 자란 건강한 식재료로 만든 샐러드를 약속합니다.
        </p>
        <p class="text-[#1A1A1A]/60 text-base md:text-lg leading-relaxed">
          드레싱 하나까지도 직접 만듭니다. 설탕 대신 유기농 꿀, 인공 첨가물 대신 레몬과 허브. 자연 그대로의 맛을 담았습니다.
        </p>

        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-[#16A34A]/10">
          <div>
            <p class="text-2xl md:text-3xl font-dm font-bold text-[#16A34A]">30+</p>
            <p class="text-[11px] text-[#1A1A1A]/40 uppercase tracking-[0.1em] mt-1 font-medium">계약 유기농 농가</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-dm font-bold text-[#16A34A]">100%</p>
            <p class="text-[11px] text-[#1A1A1A]/40 uppercase tracking-[0.1em] mt-1 font-medium">무농약 채소</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-dm font-bold text-[#16A34A]">0</p>
            <p class="text-[11px] text-[#1A1A1A]/40 uppercase tracking-[0.1em] mt-1 font-medium">인공 첨가물</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Signature Menu (4개) ========== -->
  <section id="menu" class="py-24 md:py-32 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#16A34A]/10 text-[#16A34A] reveal" style="--delay: 0;">Signature</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-dm font-bold leading-snug text-[#1A1A1A] mt-6 reveal" style="--delay: 1;">
          시그니처 메뉴
        </h2>
        <p class="text-[#1A1A1A]/50 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">
          그린볼의 베스트셀러. 매일 신선하게 준비됩니다.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="menu-card bg-[#F0FDF4] rounded-[2rem] overflow-hidden reveal" style="--delay: 0;">
          <div class="overflow-hidden">
            <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=600" alt="아보카도 파워볼" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-semibold text-[#16A34A] uppercase tracking-[0.2em]">Best</span>
              <span class="text-lg font-dm font-bold text-[#16A34A]">₩12,900</span>
            </div>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">아보카도 파워볼</h3>
            <p class="text-[#1A1A1A]/50 text-sm leading-relaxed">아보카도, 퀴노아, 병아리콩, 케일, 방울토마토와 레몬 타히니 드레싱</p>
          </div>
        </div>

        <div class="menu-card bg-[#F0FDF4] rounded-[2rem] overflow-hidden reveal" style="--delay: 1;">
          <div class="overflow-hidden">
            <img src="https://images.unsplash.com/photo-1604497181015-76590d828b75?q=80&w=600" alt="치킨 시저볼" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-semibold text-[#16A34A] uppercase tracking-[0.2em]">Popular</span>
              <span class="text-lg font-dm font-bold text-[#16A34A]">₩13,500</span>
            </div>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">치킨 시저볼</h3>
            <p class="text-[#1A1A1A]/50 text-sm leading-relaxed">그릴드 치킨, 로메인, 파르메산, 크루통, 홈메이드 시저 드레싱</p>
          </div>
        </div>

        <div class="menu-card bg-[#F0FDF4] rounded-[2rem] overflow-hidden reveal" style="--delay: 2;">
          <div class="overflow-hidden">
            <img src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?q=80&w=600" alt="연어 포케볼" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-semibold text-[#16A34A] uppercase tracking-[0.2em]">Premium</span>
              <span class="text-lg font-dm font-bold text-[#16A34A]">₩15,900</span>
            </div>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">연어 포케볼</h3>
            <p class="text-[#1A1A1A]/50 text-sm leading-relaxed">노르웨이 연어, 현미밥, 에다마메, 망고, 간장 와사비 소스</p>
          </div>
        </div>

        <div class="menu-card bg-[#F0FDF4] rounded-[2rem] overflow-hidden reveal" style="--delay: 3;">
          <div class="overflow-hidden">
            <img src="https://images.unsplash.com/photo-1511690743698-d9d18f7e20f1?q=80&w=600" alt="비건 그린볼" class="w-full aspect-[4/3] object-cover transition-transform duration-700" loading="lazy" decoding="async">
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-semibold text-[#16A34A] uppercase tracking-[0.2em]">Vegan</span>
              <span class="text-lg font-dm font-bold text-[#16A34A]">₩11,900</span>
            </div>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">비건 그린볼</h3>
            <p class="text-[#1A1A1A]/50 text-sm leading-relaxed">두부, 렌틸콩, 비트, 당근, 시금치, 발사믹 비네그레트</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Nutrition 영양 정보 ========== -->
  <section id="nutrition" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#16A34A]/10 text-[#16A34A] reveal" style="--delay: 0;">Nutrition</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-dm font-bold leading-snug text-[#1A1A1A] mt-6 reveal" style="--delay: 1;">
          투명하게 공개하는<br>영양 정보
        </h2>
        <p class="text-[#1A1A1A]/50 text-base md:text-lg mt-4 max-w-xl mx-auto reveal" style="--delay: 2;">
          모든 메뉴의 칼로리와 영양 성분을 공개합니다.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white rounded-[2rem] p-8 text-center reveal" style="--delay: 0;">
          <div class="w-16 h-16 bg-[#16A34A]/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-fire text-[#16A34A] text-xl"></i>
          </div>
          <p class="text-3xl font-dm font-bold text-[#16A34A] mb-2">350–520</p>
          <p class="text-sm text-[#1A1A1A]/60 font-medium">kcal per bowl</p>
          <p class="text-xs text-[#1A1A1A]/40 mt-3 leading-relaxed">한 끼에 필요한 적정 칼로리를 정확하게 계산했습니다</p>
        </div>

        <div class="bg-white rounded-[2rem] p-8 text-center reveal" style="--delay: 1;">
          <div class="w-16 h-16 bg-[#16A34A]/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-dumbbell text-[#16A34A] text-xl"></i>
          </div>
          <p class="text-3xl font-dm font-bold text-[#16A34A] mb-2">25g+</p>
          <p class="text-sm text-[#1A1A1A]/60 font-medium">단백질 함량</p>
          <p class="text-xs text-[#1A1A1A]/40 mt-3 leading-relaxed">운동 후에도 충분한 고단백 식사를 보장합니다</p>
        </div>

        <div class="bg-white rounded-[2rem] p-8 text-center reveal" style="--delay: 2;">
          <div class="w-16 h-16 bg-[#16A34A]/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-seedling text-[#16A34A] text-xl"></i>
          </div>
          <p class="text-3xl font-dm font-bold text-[#16A34A] mb-2">12+</p>
          <p class="text-sm text-[#1A1A1A]/60 font-medium">슈퍼푸드 종류</p>
          <p class="text-xs text-[#1A1A1A]/40 mt-3 leading-relaxed">퀴노아, 치아씨드, 아마씨 등 다양한 슈퍼푸드를 담았습니다</p>
        </div>

        <div class="bg-white rounded-[2rem] p-8 text-center reveal" style="--delay: 3;">
          <div class="w-16 h-16 bg-[#16A34A]/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-heart text-[#16A34A] text-xl"></i>
          </div>
          <p class="text-3xl font-dm font-bold text-[#16A34A] mb-2">저당</p>
          <p class="text-sm text-[#1A1A1A]/60 font-medium">Low Sugar Recipe</p>
          <p class="text-xs text-[#1A1A1A]/40 mt-3 leading-relaxed">정제당 제로. 천연 감미료만 사용한 건강한 드레싱</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Gallery ========== -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <span class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-medium bg-[#16A34A]/10 text-[#16A34A] reveal" style="--delay: 0;">Gallery</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-dm font-bold leading-snug text-[#1A1A1A] mt-6 reveal" style="--delay: 1;">
          눈으로 먼저 맛보세요
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1543339308-d595c4f5cf98?q=80&w=600" alt="매장 내부" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
        </div>
        <div class="gallery-item overflow-hidden rounded-[1.5rem] reveal" style="--delay: 1;">
          <img src="https://images.unsplash.com/photo-1572449043416-55f4685c9bb7?q=80&w=600" alt="샐러드 준비" class="w-full aspect-square object-cover transition-transform duration-700" loading="lazy" decoding="async">
