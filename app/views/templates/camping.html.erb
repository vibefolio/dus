<%# Camping Template — WILDCAMP (캠핑장/글램핑) %>

<style>
  /* Supanova Design — Dark Outdoor Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

  .font-sans { font-family: 'Space Grotesk', 'Pretendard Variable', -apple-system, sans-serif; }
  .font-display { font-family: 'Bebas Neue', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 42px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2.5rem); filter: blur(6px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(2.5rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 120ms);
  }

  .camp-card { transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
  .camp-card:hover { transform: translateY(-10px); }
  .camp-card:hover img { transform: scale(1.08); }

  .gallery-item { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .gallery-item:hover { transform: scale(1.02); }
  .gallery-item:hover img { transform: scale(1.06); }

  .glow-yellow { text-shadow: 0 0 40px rgba(232, 185, 49, 0.3); }
</style>

<div class="bg-[#1B2420] text-[#F5F0E0] font-sans selection:bg-[#E8B931] selection:text-[#1B2420] min-h-screen overflow-x-hidden relative">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-10 py-5 bg-[#1B2420]/80 backdrop-blur-2xl border-b border-[#E8B931]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="font-display text-3xl tracking-wider text-[#E8B931]">WILDCAMP</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#F5F0E0]/30">
        <a href="#sites" class="hover:text-[#E8B931] transition">Sites</a>
        <a href="#facilities" class="hover:text-[#E8B931] transition">Facilities</a>
        <a href="#gallery" class="hover:text-[#E8B931] transition">Gallery</a>
        <a href="#directions" class="hover:text-[#E8B931] transition">Access</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none text-[#E8B931]">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleCampModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#F5F0E0]/30 hover:text-[#E8B931]" data-mobile-menu-copy="true">Member</button>
        <a href="#booking" class="bg-[#E8B931] text-[#1B2420] px-8 py-3.5 rounded-none font-bold text-[10px] tracking-[0.3em] uppercase hover:bg-[#F5F0E0] transition shadow-lg shadow-[#E8B931]/20" data-mobile-menu-copy="true">
          예약하기
        </a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== 1. Hero ========== -->
  <header class="min-h-screen relative flex items-center justify-center">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1504851149312-7a075b496cc7?q=80&w=2000&auto=format" alt="WILDCAMP" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-[#1B2420]/60"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#1B2420] via-transparent to-[#1B2420]/30"></div>
    </div>

    <div class="relative z-10 text-center px-6 max-w-4xl">
      <div class="reveal">
        <span class="text-[10px] font-semibold tracking-[0.8em] uppercase text-[#E8B931]">Premium Camping & Glamping</span>
      </div>

      <h1 class="reveal font-display text-6xl md:text-[10rem] leading-none tracking-wider text-[#F5F0E0] mt-6 glow-yellow mobile-title" style="--delay:1">
        WILDCAMP
      </h1>

      <p class="reveal text-[#F5F0E0]/50 text-sm md:text-lg leading-[2] mt-8 max-w-lg mx-auto mobile-desc" style="--delay:2">
        별이 쏟아지는 가평의 밤, 자연 그대로의 캠핑.<br class="hidden md:block">
        도심을 떠나 진짜 아웃도어를 경험하세요.
      </p>

      <div class="reveal flex flex-wrap justify-center gap-4 mt-10" style="--delay:3">
        <a href="#sites" class="bg-[#E8B931] text-[#1B2420] px-10 py-4 font-bold text-[11px] tracking-[0.3em] uppercase hover:bg-[#F5F0E0] transition">
          사이트 보기
        </a>
        <a href="#booking" class="border border-[#E8B931]/40 text-[#E8B931] px-10 py-4 font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-[#E8B931]/10 transition">
          예약하기
        </a>
      </div>

      <div class="reveal absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3" style="--delay:5">
        <span class="text-[9px] tracking-[0.5em] uppercase text-[#F5F0E0]/20">Scroll</span>
        <div class="w-[1px] h-8 bg-gradient-to-b from-[#E8B931]/50 to-transparent"></div>
      </div>
    </div>
  </header>

  <!-- ========== 2. 사이트 소개 (4종) ========== -->
  <section id="sites" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#E8B931]">Camp Sites</span>
        <h2 class="font-display text-4xl md:text-6xl tracking-wider mt-4">CHOOSE YOUR SITE</h2>
        <div class="w-16 h-[2px] bg-[#E8B931] mx-auto mt-8"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8">
        <!-- 오토캠핑 -->
        <div class="camp-card group relative overflow-hidden reveal" style="--delay:0">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1478131143081-80f7f84ca84d?q=80&w=1200&auto=format" alt="오토캠핑" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-8 bg-[#1B2420] border border-[#E8B931]/10 border-t-0">
            <div class="flex justify-between items-start">
              <div>
                <span class="font-display text-lg tracking-wider text-[#E8B931]">AUTO CAMPING</span>
                <h3 class="text-xl font-bold mt-1">오토캠핑 사이트</h3>
                <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">10m x 10m · 전기 30A · 개수대 · 차량 진입 가능</p>
              </div>
              <div class="text-right">
                <span class="font-display text-2xl text-[#E8B931]">₩40,000</span>
                <span class="block text-[10px] text-[#F5F0E0]/30">평일 기준</span>
              </div>
            </div>
            <div class="flex gap-3 mt-5 flex-wrap">
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">전기</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">차량</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">개수대</span>
            </div>
          </div>
        </div>

        <!-- 글램핑 -->
        <div class="camp-card group relative overflow-hidden reveal" style="--delay:1">
          <div class="aspect-[16/10] overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1510672981848-a1c4f1cb5ccf?q=80&w=1200&auto=format" alt="글램핑" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute top-4 right-4 bg-[#E8B931] text-[#1B2420] px-4 py-1.5 text-[10px] font-bold tracking-wider">BEST</div>
          </div>
          <div class="p-8 bg-[#1B2420] border border-[#E8B931]/10 border-t-0">
            <div class="flex justify-between items-start">
              <div>
                <span class="font-display text-lg tracking-wider text-[#E8B931]">GLAMPING</span>
                <h3 class="text-xl font-bold mt-1">글램핑 텐트</h3>
                <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">30m² · 에어컨 · 더블베드 · 전용 바베큐 · 최대 4인</p>
              </div>
              <div class="text-right">
                <span class="font-display text-2xl text-[#E8B931]">₩120,000</span>
                <span class="block text-[10px] text-[#F5F0E0]/30">평일 기준</span>
              </div>
            </div>
            <div class="flex gap-3 mt-5 flex-wrap">
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">침구</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">에어컨</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">바베큐</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">화장실</span>
            </div>
          </div>
        </div>

        <!-- 카라반 -->
        <div class="camp-card group relative overflow-hidden reveal" style="--delay:2">
          <div class="aspect-[16/10] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1523987355523-c7b5b0dd90a7?q=80&w=1200&auto=format" alt="카라반" class="w-full h-full object-cover transition-transform duration-700">
          </div>
          <div class="p-8 bg-[#1B2420] border border-[#E8B931]/10 border-t-0">
            <div class="flex justify-between items-start">
              <div>
                <span class="font-display text-lg tracking-wider text-[#E8B931]">CARAVAN</span>
                <h3 class="text-xl font-bold mt-1">카라반</h3>
                <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">24m² · 퀸베드 · 미니 주방 · 전용 데크 · 최대 3인</p>
              </div>
              <div class="text-right">
                <span class="font-display text-2xl text-[#E8B931]">₩150,000</span>
                <span class="block text-[10px] text-[#F5F0E0]/30">평일 기준</span>
              </div>
            </div>
            <div class="flex gap-3 mt-5 flex-wrap">
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">주방</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">화장실</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">데크</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">냉난방</span>
            </div>
          </div>
        </div>

        <!-- 프리미엄 글램핑 -->
        <div class="camp-card group relative overflow-hidden reveal" style="--delay:3">
          <div class="aspect-[16/10] overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1618767689160-da18bc673e8c?q=80&w=1200&auto=format" alt="프리미엄 글램핑" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute top-4 right-4 bg-[#F5F0E0] text-[#1B2420] px-4 py-1.5 text-[10px] font-bold tracking-wider">PREMIUM</div>
          </div>
          <div class="p-8 bg-[#1B2420] border border-[#E8B931]/10 border-t-0">
            <div class="flex justify-between items-start">
              <div>
                <span class="font-display text-lg tracking-wider text-[#E8B931]">PREMIUM GLAMPING</span>
                <h3 class="text-xl font-bold mt-1">프리미엄 글램핑</h3>
                <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">42m² · 킹베드 · 전용 풀장 · 프라이빗 가든 · 최대 4인</p>
              </div>
              <div class="text-right">
                <span class="font-display text-2xl text-[#E8B931]">₩250,000</span>
                <span class="block text-[10px] text-[#F5F0E0]/30">평일 기준</span>
              </div>
            </div>
            <div class="flex gap-3 mt-5 flex-wrap">
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">풀장</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">가든</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">파이어핏</span>
              <span class="px-3 py-1 border border-[#E8B931]/20 text-[#E8B931] text-[10px]">조식</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 3. 시설 안내 ========== -->
  <section id="facilities" class="py-24 md:py-40 px-6 md:px-10 bg-[#141C18]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#E8B931]">Facilities</span>
        <h2 class="font-display text-4xl md:text-6xl tracking-wider mt-4">BASE CAMP GEAR</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-[#1B2420] border border-[#E8B931]/10 p-8 reveal hover:border-[#E8B931]/30 transition" style="--delay:0">
          <span class="text-3xl text-[#E8B931]"><i class="fas fa-restroom"></i></span>
          <h4 class="font-bold text-lg mt-4">샤워실 & 화장실</h4>
          <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">24시간 온수 샤워 · 남녀 분리 · 장애인 시설 완비</p>
        </div>

        <div class="bg-[#1B2420] border border-[#E8B931]/10 p-8 reveal hover:border-[#E8B931]/30 transition" style="--delay:1">
          <span class="text-3xl text-[#E8B931]"><i class="fas fa-fire"></i></span>
          <h4 class="font-bold text-lg mt-4">캠프파이어</h4>
          <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">매일 저녁 8시 공용 캠프파이어 · 마시멜로 무료 제공</p>
        </div>

        <div class="bg-[#1B2420] border border-[#E8B931]/10 p-8 reveal hover:border-[#E8B931]/30 transition" style="--delay:2">
          <span class="text-3xl text-[#E8B931]"><i class="fas fa-store"></i></span>
          <h4 class="font-bold text-lg mt-4">매점 & 장비 대여</h4>
          <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">그릴·테이블·랜턴 대여 · 숯·식재료·음료 판매</p>
        </div>

        <div class="bg-[#1B2420] border border-[#E8B931]/10 p-8 reveal hover:border-[#E8B931]/30 transition" style="--delay:3">
          <span class="text-3xl text-[#E8B931]"><i class="fas fa-swimmer"></i></span>
          <h4 class="font-bold text-lg mt-4">물놀이장</h4>
          <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">여름 시즌 한정 · 어린이 물놀이장 + 워터슬라이드</p>
        </div>

        <div class="bg-[#1B2420] border border-[#E8B931]/10 p-8 reveal hover:border-[#E8B931]/30 transition" style="--delay:4">
          <span class="text-3xl text-[#E8B931]"><i class="fas fa-hiking"></i></span>
          <h4 class="font-bold text-lg mt-4">트레일 코스</h4>
          <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">캠핑장 내 숲속 산책로 2km · 전망대 코스 30분</p>
        </div>

        <div class="bg-[#1B2420] border border-[#E8B931]/10 p-8 reveal hover:border-[#E8B931]/30 transition" style="--delay:5">
          <span class="text-3xl text-[#E8B931]"><i class="fas fa-dog"></i></span>
          <h4 class="font-bold text-lg mt-4">반려동물 동반</h4>
          <p class="text-[#F5F0E0]/40 text-sm mt-3 leading-relaxed">오토캠핑 구역 허용 · 목줄 필수 · 배변봉투 제공</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 4. 갤러리 ========== -->
  <section id="gallery" class="py-24 md:py-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 reveal">
        <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#E8B931]">Gallery</span>
        <h2 class="font-display text-4xl md:text-6xl tracking-wider mt-4">WILD MOMENTS</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        <div class="gallery-item overflow-hidden col-span-2 row-span-2 reveal" style="--delay:0">
          <div class="aspect-square overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1533873984035-25970ab07461?q=80&w=1200&auto=format" alt="캠프파이어" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#1B2420]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-8">
              <span class="font-display text-xl tracking-wider text-[#E8B931]">CAMPFIRE NIGHT</span>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden reveal" style="--delay:1">
          <div class="aspect-square overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1445308394109-4ec2920981b1?q=80&w=600&auto=format" alt="별" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#1B2420]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-4">
              <span class="text-[#E8B931] text-xs font-bold tracking-wider">STARGAZING</span>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden reveal" style="--delay:2">
          <div class="aspect-square overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1528823872057-9c018a7a7553?q=80&w=600&auto=format" alt="바베큐" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#1B2420]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-4">
              <span class="text-[#E8B931] text-xs font-bold tracking-wider">BBQ TIME</span>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden reveal" style="--delay:3">
          <div class="aspect-square overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1487730116645-74489c95b41b?q=80&w=600&auto=format" alt="아침" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#1B2420]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-4">
              <span class="text-[#E8B931] text-xs font-bold tracking-wider">MORNING LIGHT</span>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden reveal" style="--delay:4">
          <div class="aspect-square overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1471115853179-bb1d604434e0?q=80&w=600&auto=format" alt="숲" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#1B2420]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-4">
              <span class="text-[#E8B931] text-xs font-bold tracking-wider">FOREST WALK</span>
            </div>
          </div>
        </div>

        <div class="gallery-item overflow-hidden col-span-2 reveal" style="--delay:5">
          <div class="aspect-[2/1] overflow-hidden relative group">
            <img src="https://images.unsplash.com/photo-1517824806704-9040b037703b?q=80&w=1200&auto=format" alt="글램핑 내부" class="w-full h-full object-cover transition-transform duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-[#1B2420]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-8">
