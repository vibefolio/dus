<%# Law Template - 법무법인 정의 (JUSTICE LAW) — 법률 사무소 %>

<style>
  /* Supanova Design Upgrade */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

  .font-display { font-family: 'Playfair Display', serif; }
  .font-body { font-family: 'Noto Sans KR', -apple-system, sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 32px !important; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(2rem);
  }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .gold-gradient {
    background: linear-gradient(135deg, #8B7355 0%, #C4A87C 50%, #8B7355 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

<div class="bg-[#FDFCFB] text-[#3D3D3D] font-body selection:bg-[#1C3D5A] selection:text-white min-h-screen overflow-x-hidden relative">

  <!-- Nav -->
  <nav class="fixed w-full z-50 px-6 py-5 bg-[#FDFCFB]/95 backdrop-blur-xl border-b border-[#8B7355]/10 shadow-sm">
    <div class="container mx-auto px-4 md:px-6 flex justify-between items-center flex-nowrap">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-[#1C3D5A] rounded flex items-center justify-center">
          <svg class="w-5 h-5 text-[#8B7355]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
        </div>
        <div>
          <span class="font-display text-xl font-bold tracking-tight text-[#1C3D5A]">JUSTICE</span>
          <span class="text-[10px] text-[#8B7355] block -mt-1 tracking-[0.2em] font-medium">LAW FIRM</span>
        </div>
      </div>

      <div class="hidden md:flex gap-10 text-[13px] font-medium text-[#3D3D3D]/60">
        <a href="#about" class="hover:text-[#1C3D5A] transition">소개</a>
        <a href="#practice" class="hover:text-[#1C3D5A] transition">업무 분야</a>
        <a href="#lawyers" class="hover:text-[#1C3D5A] transition">변호사 소개</a>
        <a href="#consult" class="hover:text-[#1C3D5A] transition">상담 예약</a>
        <a href="#location" class="hover:text-[#1C3D5A] transition">오시는 길</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: #1C3D5A;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="flex-nowrap shrink-0 flex gap-4 items-center">
        <button onclick="toggleLawModal()" class="hidden md:block text-[13px] font-medium text-[#3D3D3D]/60 hover:text-[#1C3D5A]" data-mobile-menu-copy="true">로그인</button>
        <button class="hidden md:inline-flex bg-[#1C3D5A] text-white px-5 py-2.5 rounded font-semibold text-[13px] hover:bg-[#2A5070] transition shadow-lg shadow-[#1C3D5A]/15" data-mobile-menu-copy="true">
          상담 예약
        </button>
      </div>
    </div>
    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- Hero -->
  <header class="min-h-screen relative flex items-center pt-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=1400&h=900&fit=crop" alt="법률 사무소" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-gradient-to-r from-[#1C3D5A]/90 via-[#1C3D5A]/70 to-[#1C3D5A]/40"></div>
    </div>
    <div class="container mx-auto px-6 md:px-12 relative z-10 py-20">
      <div class="max-w-2xl space-y-8">
        <div class="inline-flex items-center gap-3">
          <div class="w-12 h-px bg-[#8B7355]"></div>
          <span class="text-[12px] font-semibold text-[#8B7355] uppercase tracking-[0.2em]">Since 2005</span>
        </div>

        <h1 class="text-4xl md:text-6xl font-display font-bold leading-[1.15] text-white mobile-title">
          정의로운 법률,<br>
          <span class="text-[#8B7355]">신뢰</span>의 동반자
        </h1>

        <p class="text-lg md:text-xl text-white/70 leading-relaxed max-w-lg mobile-desc">
          법무법인 정의는 20년의 전문성과 진정성 있는 법률 서비스로
          의뢰인의 권리를 지켜드립니다.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#consult" class="px-8 py-4 bg-[#8B7355] text-white font-semibold text-[15px] rounded hover:bg-[#A08B6D] transition shadow-lg">
            무료 법률 상담
          </a>
          <a href="#practice" class="px-8 py-4 border border-white/30 text-white font-semibold text-[15px] rounded hover:bg-white/10 transition">
            업무 분야 보기
          </a>
        </div>

        <div class="flex items-center gap-8 pt-6">
          <div>
            <div class="text-3xl font-display font-bold text-white">2,500+</div>
            <div class="text-[12px] text-white/50">승소 사건</div>
          </div>
          <div class="w-px h-12 bg-white/20"></div>
          <div>
            <div class="text-3xl font-display font-bold text-white">20년</div>
            <div class="text-[12px] text-white/50">법률 경력</div>
          </div>
          <div class="w-px h-12 bg-white/20"></div>
          <div>
            <div class="text-3xl font-display font-bold text-white">94%</div>
            <div class="text-[12px] text-white/50">승소율</div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- About -->
  <section id="about" class="py-24 md:py-32">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=450&fit=crop" alt="법률 상담" class="rounded-lg shadow-xl w-full object-cover aspect-[4/3]">
        </div>
        <div class="space-y-6 reveal" style="--delay: 2;">
          <div class="inline-flex items-center gap-3">
            <div class="w-8 h-px bg-[#8B7355]"></div>
            <span class="text-[12px] font-semibold text-[#8B7355] uppercase tracking-[0.2em]">About</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-[#1C3D5A]">
            법률의 가치를<br>올바르게 실현합니다
          </h2>
          <p class="text-[#3D3D3D]/70 leading-relaxed">
            법무법인 정의는 2005년 설립 이래, 기업 법무, 민사, 형사, 부동산, 가사 분야에서
            탁월한 법률 서비스를 제공해왔습니다. 대법원 판례를 이끌어낸 경험과 깊이 있는 법률 지식을 바탕으로
            의뢰인에게 최선의 결과를 만들어 드립니다.
          </p>
          <p class="text-[#3D3D3D]/70 leading-relaxed">
            각 분야의 전문 변호사가 사건의 시작부터 종결까지
            책임감 있게 대리하며, 의뢰인의 이익을 최우선으로 생각합니다.
          </p>
          <div class="flex items-center gap-6 pt-2">
            <div class="flex items-center gap-2 text-sm text-[#1C3D5A]">
              <svg class="w-5 h-5 text-[#8B7355]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              대한변호사협회 등록
            </div>
            <div class="flex items-center gap-2 text-sm text-[#1C3D5A]">
              <svg class="w-5 h-5 text-[#8B7355]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              법률구조 지정 기관
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Practice Areas -->
  <section id="practice" class="py-24 md:py-32 bg-[#F5F3F0]">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 reveal">
        <div class="inline-flex items-center gap-3 justify-center mb-4">
          <div class="w-8 h-px bg-[#8B7355]"></div>
          <span class="text-[12px] font-semibold text-[#8B7355] uppercase tracking-[0.2em]">Practice Areas</span>
          <div class="w-8 h-px bg-[#8B7355]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-[#1C3D5A]">업무 분야</h2>
        <p class="text-[#3D3D3D]/50 mt-4 max-w-xl mx-auto">각 분야 전문 변호사가 최적의 법률 솔루션을 제공합니다</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="reveal bg-white rounded-lg p-8 border border-[#8B7355]/10 hover:shadow-lg hover:shadow-[#1C3D5A]/5 transition-all duration-500 group" style="--delay: 1;">
          <div class="w-12 h-12 bg-[#1C3D5A]/5 rounded-lg flex items-center justify-center mb-5 group-hover:bg-[#1C3D5A] transition-colors duration-500">
            <svg class="w-6 h-6 text-[#1C3D5A] group-hover:text-[#8B7355] transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <h3 class="font-display font-bold text-[#1C3D5A] text-lg mb-2">기업 법무</h3>
          <p class="text-[#3D3D3D]/55 text-sm leading-relaxed">기업 설립, 계약 검토, 노동법, 지적재산권 등 기업 활동 전반의 법률 자문을 제공합니다.</p>
        </div>

        <div class="reveal bg-white rounded-lg p-8 border border-[#8B7355]/10 hover:shadow-lg hover:shadow-[#1C3D5A]/5 transition-all duration-500 group" style="--delay: 2;">
          <div class="w-12 h-12 bg-[#1C3D5A]/5 rounded-lg flex items-center justify-center mb-5 group-hover:bg-[#1C3D5A] transition-colors duration-500">
            <svg class="w-6 h-6 text-[#1C3D5A] group-hover:text-[#8B7355] transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="font-display font-bold text-[#1C3D5A] text-lg mb-2">민사 소송</h3>
          <p class="text-[#3D3D3D]/55 text-sm leading-relaxed">손해배상, 채권추심, 계약 분쟁 등 민사 전반에 걸친 소송 및 조정 대리 서비스를 제공합니다.</p>
        </div>

        <div class="reveal bg-white rounded-lg p-8 border border-[#8B7355]/10 hover:shadow-lg hover:shadow-[#1C3D5A]/5 transition-all duration-500 group" style="--delay: 3;">
          <div class="w-12 h-12 bg-[#1C3D5A]/5 rounded-lg flex items-center justify-center mb-5 group-hover:bg-[#1C3D5A] transition-colors duration-500">
            <svg class="w-6 h-6 text-[#1C3D5A] group-hover:text-[#8B7355] transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h3 class="font-display font-bold text-[#1C3D5A] text-lg mb-2">형사 변호</h3>
          <p class="text-[#3D3D3D]/55 text-sm leading-relaxed">수사 단계부터 재판까지, 형사 사건 전 과정에서 의뢰인의 권리를 적극 보호합니다.</p>
        </div>

        <div class="reveal bg-white rounded-lg p-8 border border-[#8B7355]/10 hover:shadow-lg hover:shadow-[#1C3D5A]/5 transition-all duration-500 group" style="--delay: 4;">
          <div class="w-12 h-12 bg-[#1C3D5A]/5 rounded-lg flex items-center justify-center mb-5 group-hover:bg-[#1C3D5A] transition-colors duration-500">
            <svg class="w-6 h-6 text-[#1C3D5A] group-hover:text-[#8B7355] transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          </div>
          <h3 class="font-display font-bold text-[#1C3D5A] text-lg mb-2">부동산 / 건설</h3>
          <p class="text-[#3D3D3D]/55 text-sm leading-relaxed">매매, 임대차, 재개발, 건설 분쟁 등 부동산 관련 법률 문제를 종합적으로 해결합니다.</p>
        </div>

        <div class="reveal bg-white rounded-lg p-8 border border-[#8B7355]/10 hover:shadow-lg hover:shadow-[#1C3D5A]/5 transition-all duration-500 group" style="--delay: 5;">
          <div class="w-12 h-12 bg-[#1C3D5A]/5 rounded-lg flex items-center justify-center mb-5 group-hover:bg-[#1C3D5A] transition-colors duration-500">
            <svg class="w-6 h-6 text-[#1C3D5A] group-hover:text-[#8B7355] transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="font-display font-bold text-[#1C3D5A] text-lg mb-2">가사 / 상속</h3>
          <p class="text-[#3D3D3D]/55 text-sm leading-relaxed">이혼, 양육권, 재산분할, 상속, 유언 등 가족 관련 법률 사안을 섬세하게 다룹니다.</p>
        </div>

        <div class="reveal bg-white rounded-lg p-8 border border-[#8B7355]/10 hover:shadow-lg hover:shadow-[#1C3D5A]/5 transition-all duration-500 group" style="--delay: 6;">
          <div class="w-12 h-12 bg-[#1C3D5A]/5 rounded-lg flex items-center justify-center mb-5 group-hover:bg-[#1C3D5A] transition-colors duration-500">
            <svg class="w-6 h-6 text-[#1C3D5A] group-hover:text-[#8B7355] transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-display font-bold text-[#1C3D5A] text-lg mb-2">금융 / 세무</h3>
          <p class="text-[#3D3D3D]/55 text-sm leading-relaxed">금융 규제, 세무 분쟁, 조세 불복 등 전문적인 금융 법률 서비스를 제공합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Lawyers -->
  <section id="lawyers" class="py-24 md:py-32">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 reveal">
        <div class="inline-flex items-center gap-3 justify-center mb-4">
          <div class="w-8 h-px bg-[#8B7355]"></div>
          <span class="text-[12px] font-semibold text-[#8B7355] uppercase tracking-[0.2em]">Our Lawyers</span>
          <div class="w-8 h-px bg-[#8B7355]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-[#1C3D5A]">변호사 소개</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <div class="reveal text-center" style="--delay: 1;">
          <div class="relative mb-6 inline-block">
            <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&h=500&fit=crop&crop=top" alt="김정의 변호사" class="w-full max-w-[280px] mx-auto rounded-lg shadow-lg object-cover aspect-[3/4]">
            <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-[#1C3D5A] text-white px-4 py-1.5 rounded text-[11px] font-semibold tracking-wide">대표 변호사</div>
          </div>
          <h3 class="font-display font-bold text-[#1C3D5A] text-xl mt-6 mb-1">김정의</h3>
          <p class="text-[#8B7355] text-sm font-medium mb-4">서울대 법학과 / 사법연수원 35기</p>
          <div class="text-[#3D3D3D]/55 text-sm leading-relaxed max-w-xs mx-auto space-y-1">
            <p>前 서울중앙지방법원 판사</p>
            <p>前 대한변호사협회 이사</p>
            <p>기업 법무, 민사 소송 전문</p>
          </div>
        </div>

        <div class="reveal text-center" style="--delay: 2;">
          <div class="relative mb-6 inline-block">
            <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&h=500&fit=crop&crop=top" alt="박윤서 변호사" class="w-full max-w-[280px] mx-auto rounded-lg shadow-lg object-cover aspect-[3/4]">
            <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-[#8B7355] text-white px-4 py-1.5 rounded text-[11px] font-semibold tracking-wide">파트너 변호사</div>
          </div>
          <h3 class="font-display font-bold text-[#1C3D5A] text-xl mt-6 mb-1">박윤서</h3>
          <p class="text-[#8B7355] text-sm font-medium mb-4">고려대 법학과 / 변호사시험 5회</p>
          <div class="text-[#3D3D3D]/55 text-sm leading-relaxed max-w-xs mx-auto space-y-1">
            <p>前 법무법인 율촌 소속</p>
            <p>한국여성변호사회 회원</p>
            <p>가사, 상속, 부동산 전문</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Consultation Booking -->
  <section id="consult" class="py-24 md:py-32 bg-[#F5F3F0]">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="reveal">
          <div class="inline-flex items-center gap-3 mb-4">
            <div class="w-8 h-px bg-[#8B7355]"></div>
