<%# LearnHub Template - LearnHub (온라인 교육 플랫폼) %>

<style>
  /* Supanova Design — Online Education Platform Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 36px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .course-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .course-card:hover { transform: translateY(-8px); box-shadow: 0 25px 60px -15px rgba(22, 163, 74, 0.15); }
  .course-card:hover img { transform: scale(1.05); }
</style>

<div class="bg-[#F0FDF4] text-[#111827] font-sans selection:bg-[#16A34A] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#F0FDF4]/80 backdrop-blur-xl border-b border-[#16A34A]/5">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-[#16A34A] rounded-lg flex items-center justify-center">
          <i class="fas fa-play text-white text-xs"></i>
        </div>
        <span class="font-jakarta text-xl font-extrabold tracking-tight text-[#111827]">LearnHub</span>
      </a>

      <div class="hidden md:flex gap-10 text-[11px] font-semibold uppercase tracking-[0.3em] text-[#111827]/40">
        <a href="#courses" class="hover:text-[#16A34A] transition">강좌</a>
        <a href="#features" class="hover:text-[#16A34A] transition">특징</a>
        <a href="#pricing" class="hover:text-[#16A34A] transition">가격</a>
        <a href="#start" class="hover:text-[#16A34A] transition">시작하기</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center shrink-0">
        <button onclick="toggleLearnhubModal()" class="text-[11px] font-semibold text-[#111827]/40 hover:text-[#16A34A] tracking-[0.2em] uppercase" data-mobile-menu-copy="true">로그인</button>
        <a href="#start" class="bg-[#16A34A] text-white px-7 py-3 rounded-full font-semibold text-[11px] tracking-[0.2em] uppercase hover:bg-[#15803D] shadow-lg shadow-[#16A34A]/20" data-mobile-menu-copy="true">무료 시작</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-[#16A34A]/5 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-20 w-[300px] h-[300px] bg-[#4ADE80]/10 rounded-full blur-[80px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-3 bg-[#16A34A]/5 rounded-full px-5 py-2 reveal" style="--delay: 0;">
          <i class="fas fa-fire text-[#16A34A] text-sm"></i>
          <span class="text-[11px] font-bold tracking-[0.15em] uppercase text-[#16A34A]">10만+ 수강생이 선택한 플랫폼</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-[4.5rem] font-extrabold leading-tight tracking-tight mobile-title reveal" style="--delay: 1;">
          배움에는<br><span class="text-[#16A34A]">한계가 없다.</span>
        </h1>

        <p class="text-[#111827]/50 text-base md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          프로그래밍, 디자인, 마케팅, 비즈니스까지. 업계 최고의 전문가가 만든 온라인 강좌로 어디서든 성장하세요.
        </p>

        <div class="pt-2 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#start" class="inline-flex items-center justify-center gap-3 px-9 py-4 bg-[#16A34A] text-white font-bold text-[12px] tracking-[0.15em] uppercase hover:bg-[#15803D] rounded-2xl shadow-xl shadow-[#16A34A]/20">
            무료로 시작하기 <i class="fas fa-arrow-right text-[10px]"></i>
          </a>
          <a href="#courses" class="inline-flex items-center justify-center gap-2 px-9 py-4 border border-[#16A34A]/20 text-[#16A34A] font-semibold text-[12px] tracking-[0.15em] uppercase hover:bg-[#16A34A]/5 rounded-2xl">
            <i class="fas fa-play-circle"></i> 강좌 둘러보기
          </a>
        </div>

        <div class="flex items-center gap-4 pt-4 justify-center lg:justify-start reveal" style="--delay: 4;">
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-[#16A34A] border-2 border-[#F0FDF4] flex items-center justify-center text-white text-[10px] font-bold">K</div>
            <div class="w-8 h-8 rounded-full bg-[#4ADE80] border-2 border-[#F0FDF4] flex items-center justify-center text-white text-[10px] font-bold">L</div>
            <div class="w-8 h-8 rounded-full bg-[#15803D] border-2 border-[#F0FDF4] flex items-center justify-center text-white text-[10px] font-bold">P</div>
            <div class="w-8 h-8 rounded-full bg-[#111827] border-2 border-[#F0FDF4] flex items-center justify-center text-white text-[10px] font-bold">+</div>
          </div>
          <div>
            <div class="flex gap-0.5 text-[#16A34A]"><i class="fas fa-star text-[10px]"></i><i class="fas fa-star text-[10px]"></i><i class="fas fa-star text-[10px]"></i><i class="fas fa-star text-[10px]"></i><i class="fas fa-star text-[10px]"></i></div>
            <p class="text-[11px] text-[#111827]/40 mt-0.5">4.9/5 (12,000+ 리뷰)</p>
          </div>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <div class="bg-white rounded-[2rem] p-3 shadow-2xl shadow-[#16A34A]/5">
          <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200" alt="온라인 학습" class="w-full aspect-[4/3] object-cover rounded-[1.5rem]" loading="eager">
          <div class="p-5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-[#16A34A] rounded-full flex items-center justify-center text-white text-xs"><i class="fas fa-play"></i></div>
                <div><p class="text-sm font-bold">React 완벽 마스터</p><p class="text-[11px] text-[#111827]/40">김개발 강사</p></div>
              </div>
              <span class="text-[#16A34A] font-bold text-sm font-jakarta">4.9</span>
            </div>
            <div class="mt-3 bg-[#F0FDF4] rounded-full h-2"><div class="bg-[#16A34A] h-2 rounded-full" style="width: 73%;"></div></div>
            <p class="text-[11px] text-[#111827]/40 mt-1">73% 완료</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== About ========== -->
  <section id="about" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8 text-center">
      <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#16A34A]/5 text-[#16A34A] reveal" style="--delay: 0;">Why LearnHub</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-snug mt-6 reveal" style="--delay: 1;">
        왜 LearnHub인가요?
      </h2>
      <p class="text-[#111827]/50 text-base md:text-lg mt-4 max-w-2xl mx-auto reveal" style="--delay: 2;">
        단순한 동영상 강의가 아닙니다. 실습, 프로젝트, 커뮤니티가 결합된 완전한 학습 경험을 제공합니다.
      </p>

      <div class="grid md:grid-cols-4 gap-6 mt-16">
        <div class="p-8 rounded-3xl bg-[#F0FDF4] reveal" style="--delay: 0;">
          <div class="w-14 h-14 bg-[#16A34A] rounded-2xl flex items-center justify-center mx-auto mb-5"><i class="fas fa-laptop-code text-white text-xl"></i></div>
          <h3 class="font-bold text-lg mb-2">실습 중심</h3>
          <p class="text-[13px] text-[#111827]/50">이론보다 실습. 매 강의마다 직접 코딩하고 결과물을 만듭니다.</p>
        </div>
        <div class="p-8 rounded-3xl bg-[#F0FDF4] reveal" style="--delay: 1;">
          <div class="w-14 h-14 bg-[#16A34A] rounded-2xl flex items-center justify-center mx-auto mb-5"><i class="fas fa-certificate text-white text-xl"></i></div>
          <h3 class="font-bold text-lg mb-2">수료증 발급</h3>
          <p class="text-[13px] text-[#111827]/50">과정 완료 시 업계에서 인정받는 디지털 수료증을 발급합니다.</p>
        </div>
        <div class="p-8 rounded-3xl bg-[#F0FDF4] reveal" style="--delay: 2;">
          <div class="w-14 h-14 bg-[#16A34A] rounded-2xl flex items-center justify-center mx-auto mb-5"><i class="fas fa-users text-white text-xl"></i></div>
          <h3 class="font-bold text-lg mb-2">학습 커뮤니티</h3>
          <p class="text-[13px] text-[#111827]/50">함께 배우는 동료들과 질문하고, 토론하고, 성장하세요.</p>
        </div>
        <div class="p-8 rounded-3xl bg-[#F0FDF4] reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#16A34A] rounded-2xl flex items-center justify-center mx-auto mb-5"><i class="fas fa-infinity text-white text-xl"></i></div>
          <h3 class="font-bold text-lg mb-2">무제한 복습</h3>
          <p class="text-[13px] text-[#111827]/50">한 번 구매하면 영구적으로 접근. 원하는 만큼 반복 학습하세요.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Popular Courses ========== -->
  <section id="courses" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#16A34A]/5 text-[#16A34A] reveal" style="--delay: 0;">Popular</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-snug mt-6 reveal" style="--delay: 1;">인기 강좌</h2>
        <p class="text-[#111827]/50 text-base md:text-lg mt-4 reveal" style="--delay: 2;">이번 달 가장 많은 수강생이 선택한 강좌</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="course-card bg-white rounded-3xl overflow-hidden shadow-sm border border-[#16A34A]/5 reveal" style="--delay: 0;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?q=80&w=600" alt="웹 개발" class="w-full aspect-video object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[10px] font-bold bg-[#16A34A]/10 text-[#16A34A] px-2 py-0.5 rounded-full uppercase">개발</span>
              <span class="text-[10px] text-[#111827]/30 font-medium">24시간 분량</span>
            </div>
            <h3 class="font-bold text-base mb-2">웹 개발 부트캠프 2026</h3>
            <p class="text-[12px] text-[#111827]/40 mb-4">HTML, CSS, JS부터 React까지 풀스택 개발 완성</p>
            <div class="flex items-center justify-between">
              <p class="text-[#16A34A] font-bold font-jakarta">149,000원</p>
              <div class="flex items-center gap-1 text-[#16A34A]"><i class="fas fa-star text-[10px]"></i><span class="text-[12px] font-bold">4.9</span></div>
            </div>
          </div>
        </div>

        <div class="course-card bg-white rounded-3xl overflow-hidden shadow-sm border border-[#16A34A]/5 reveal" style="--delay: 1;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1558655146-9f40138edfeb?q=80&w=600" alt="UI/UX 디자인" class="w-full aspect-video object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[10px] font-bold bg-purple-100 text-purple-600 px-2 py-0.5 rounded-full uppercase">디자인</span>
              <span class="text-[10px] text-[#111827]/30 font-medium">18시간 분량</span>
            </div>
            <h3 class="font-bold text-base mb-2">UI/UX 디자인 마스터</h3>
            <p class="text-[12px] text-[#111827]/40 mb-4">Figma를 활용한 실무 중심 UI/UX 디자인 과정</p>
            <div class="flex items-center justify-between">
              <p class="text-[#16A34A] font-bold font-jakarta">129,000원</p>
              <div class="flex items-center gap-1 text-[#16A34A]"><i class="fas fa-star text-[10px]"></i><span class="text-[12px] font-bold">4.8</span></div>
            </div>
          </div>
        </div>

        <div class="course-card bg-white rounded-3xl overflow-hidden shadow-sm border border-[#16A34A]/5 reveal" style="--delay: 2;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1432888622747-4eb9a8efeb07?q=80&w=600" alt="디지털 마케팅" class="w-full aspect-video object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[10px] font-bold bg-orange-100 text-orange-600 px-2 py-0.5 rounded-full uppercase">마케팅</span>
              <span class="text-[10px] text-[#111827]/30 font-medium">16시간 분량</span>
            </div>
            <h3 class="font-bold text-base mb-2">디지털 마케팅 A to Z</h3>
            <p class="text-[12px] text-[#111827]/40 mb-4">SEO, 광고, SNS 마케팅 실전 전략 완벽 가이드</p>
            <div class="flex items-center justify-between">
              <p class="text-[#16A34A] font-bold font-jakarta">99,000원</p>
              <div class="flex items-center gap-1 text-[#16A34A]"><i class="fas fa-star text-[10px]"></i><span class="text-[12px] font-bold">4.7</span></div>
            </div>
          </div>
        </div>

        <div class="course-card bg-white rounded-3xl overflow-hidden shadow-sm border border-[#16A34A]/5 reveal" style="--delay: 3;">
          <div class="overflow-hidden"><img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=600" alt="데이터 분석" class="w-full aspect-video object-cover transition-transform duration-700" loading="lazy" decoding="async"></div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[10px] font-bold bg-blue-100 text-blue-600 px-2 py-0.5 rounded-full uppercase">데이터</span>
              <span class="text-[10px] text-[#111827]/30 font-medium">20시간 분량</span>
            </div>
            <h3 class="font-bold text-base mb-2">Python 데이터 분석</h3>
            <p class="text-[12px] text-[#111827]/40 mb-4">Pandas, NumPy로 시작하는 데이터 사이언스 입문</p>
            <div class="flex items-center justify-between">
              <p class="text-[#16A34A] font-bold font-jakarta">139,000원</p>
              <div class="flex items-center gap-1 text-[#16A34A]"><i class="fas fa-star text-[10px]"></i><span class="text-[12px] font-bold">4.9</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Features ========== -->
  <section id="features" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative reveal" style="--delay: 0;">
        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=800" alt="학습 환경" class="w-full aspect-[4/3] object-cover rounded-3xl" loading="lazy" decoding="async">
      </div>
      <div class="space-y-8 reveal" style="--delay: 1;">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#16A34A]/5 text-[#16A34A]">Features</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-snug">플랫폼 특징</h2>
        <div class="space-y-6">
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 bg-[#16A34A] rounded-xl flex items-center justify-center shrink-0 text-white"><i class="fas fa-mobile-alt"></i></div>
            <div><p class="font-bold">모바일 학습</p><p class="text-[13px] text-[#111827]/50 mt-1">앱으로 언제 어디서나 강의 수강. 오프라인 다운로드 지원</p></div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 bg-[#16A34A] rounded-xl flex items-center justify-center shrink-0 text-white"><i class="fas fa-robot"></i></div>
            <div><p class="font-bold">AI 학습 어시스턴트</p><p class="text-[13px] text-[#111827]/50 mt-1">AI가 학습 패턴을 분석하고 최적의 복습 일정을 추천합니다</p></div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 bg-[#16A34A] rounded-xl flex items-center justify-center shrink-0 text-white"><i class="fas fa-code"></i></div>
            <div><p class="font-bold">브라우저 내 코딩 환경</p><p class="text-[13px] text-[#111827]/50 mt-1">별도 설치 없이 브라우저에서 바로 코드 실행 및 실습</p></div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 bg-[#16A34A] rounded-xl flex items-center justify-center shrink-0 text-white"><i class="fas fa-comments"></i></div>
            <div><p class="font-bold">실시간 Q&A</p><p class="text-[13px] text-[#111827]/50 mt-1">강사에게 직접 질문하고 24시간 내 답변을 받으세요</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Pricing ========== -->
  <section id="pricing" class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="inline-block rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.15em] font-bold bg-[#16A34A]/5 text-[#16A34A] reveal" style="--delay: 0;">Pricing</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-snug mt-6 reveal" style="--delay: 1;">심플한 가격</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-3xl p-8 border border-[#16A34A]/5 text-center reveal" style="--delay: 0;">
          <p class="text-[11px] font-bold text-[#111827]/30 uppercase tracking-[0.2em] mb-4">무료</p>
          <p class="text-4xl font-extrabold text-[#111827] font-jakarta">0<span class="text-lg text-[#111827]/30">원</span></p>
