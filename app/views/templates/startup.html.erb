      </div>

      <div class="flex items-center gap-6 justify-center mt-12 reveal" style="--delay: 4;">
        <div class="flex -space-x-3">
          <div class="w-10 h-10 bg-slate-200 rounded-full border-2 border-white"></div>
          <div class="w-10 h-10 bg-slate-300 rounded-full border-2 border-white"></div>
          <div class="w-10 h-10 bg-slate-400 rounded-full border-2 border-white"></div>
          <div class="w-10 h-10 bg-[#4F46E5] rounded-full border-2 border-white flex items-center justify-center text-white text-xs font-bold">+</div>
