<%# Startup Template - LAUNCHPAD %>

<style>
  /* Supanova Design — Bold Startup Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }
  .font-display { font-family: 'Inter', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 34px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .feature-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .feature-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(79,70,229,0.1); }
</style>

<div class="bg-[#FFFFFF] text-[#1E293B] font-sans selection:bg-[#4F46E5] selection:text-white min-h-screen overflow-x-hidden">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-4 bg-white/80 backdrop-blur-xl border-b border-slate-100">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-gradient-to-br from-[#4F46E5] to-[#7C3AED] rounded-lg flex items-center justify-center">
          <i class="fas fa-rocket text-white text-xs"></i>
        </div>
        <span class="font-display font-bold text-xl tracking-tight">LAUNCH<span class="text-[#4F46E5]">PAD</span></span>
      </a>

      <div class="hidden md:flex gap-10 text-sm font-medium text-slate-400">
        <a href="#product" class="hover:text-[#4F46E5] transition">제품</a>
        <a href="#team" class="hover:text-[#4F46E5] transition">팀</a>
        <a href="#investors" class="hover:text-[#4F46E5] transition">투자자</a>
        <a href="#contact" class="hover:text-[#4F46E5] transition">문의</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="#" class="text-sm font-medium text-slate-500 hover:text-[#4F46E5]">로그인</a>
        <a href="#contact" class="bg-[#4F46E5] text-white px-6 py-2.5 rounded-lg text-sm font-semibold hover:bg-[#4338CA] shadow-lg shadow-[#4F46E5]/20" data-mobile-menu-copy="true">데모 요청</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#EEF2FF] via-white to-[#E0E7FF]"></div>
    <div class="absolute top-20 left-1/4 w-[500px] h-[500px] bg-[#4F46E5]/5 rounded-full blur-[150px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 text-center w-full py-20">
