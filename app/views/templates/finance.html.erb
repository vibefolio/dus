            <div class="flex-1 bg-gradient-to-t from-[#00D4AA]/20 to-[#00D4AA]/60 rounded-t-sm chart-bar" style="height: 60%"></div>
            <div class="flex-1 bg-gradient-to-t from-[#00D4AA]/20 to-[#00D4AA]/60 rounded-t-sm chart-bar" style="height: 35%"></div>
            <div class="flex-1 bg-gradient-to-t from-[#00D4AA]/20 to-[#00D4AA]/60 rounded-t-sm chart-bar" style="height: 75%"></div>
            <div class="flex-1 bg-gradient-to-t from-[#00D4AA]/20 to-[#00D4AA]/60 rounded-t-sm chart-bar" style="height: 55%"></div>
            <div class="flex-1 bg-gradient-to-t from-[#00D4AA]/20 to-[#00D4AA]/60 rounded-t-sm chart-bar" style="height: 80%"></div>
            <div class="flex-1 bg-gradient-to-t from-[#00D4AA]/20 to-[#00D4AA]/60 rounded-t-sm chart-bar" style="height: 65%"></div>
            <div class="flex-1 bg-gradient-to-t from-[#00D4AA]/20 to-[#00D4AA] rounded-t-sm chart-bar" style="height: 90%"></div>
          </div>
          <div class="flex justify-between mt-3 text-[10px] text-white/30 font-display">
            <span>1월</span><span>3월</span><span>5월</span><span>7월</span><span>9월</span><span>11월</span>
          </div>
          <div class="grid grid-cols-3 gap-4 mt-6 pt-6 border-t border-white/5">
            <div>
              <div class="text-[10px] text-white/30 font-display">운용 자산</div>
