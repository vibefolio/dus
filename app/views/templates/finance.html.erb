        </div>

        <div class="reveal bg-[#0F1A2E] rounded-2xl p-8 border border-white/5 hover:border-[#00D4AA]/20 transition-all duration-500 group" style="--delay: 2;">
          <div class="w-12 h-12 bg-[#00D4AA]/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#00D4AA]/20 transition">
            <svg class="w-6 h-6 text-[#00D4AA]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
          </div>
