        </div>

        <div class="solution-card bg-[#F8FAFC] rounded-[2rem] p-8 border border-[#3B82F6]/5 reveal" style="--delay: 3;">
          <div class="w-14 h-14 bg-[#3B82F6]/10 rounded-2xl flex items-center justify-center mb-6"><i class="fas fa-shield-alt text-[#3B82F6] text-xl"></i></div>
