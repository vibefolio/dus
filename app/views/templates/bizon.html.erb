<%# Bizon Template - 비즈온 (BIZON) %>

<style>
  /* Supanova Design — Business Solution Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
  .font-inter { font-family: 'Inter', sans-serif; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 42px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay, 0) * 100ms);
  }

  .solution-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .solution-card:hover { transform: translateY(-8px); }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @keyframes countUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="bg-[#F8FAFC] text-[#0F172A] font-sans selection:bg-[#3B82F6] selection:text-white min-h-screen overflow-x-hidden relative">

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#F8FAFC]/80 backdrop-blur-xl border-b border-[#3B82F6]/10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3">
        <span class="font-inter text-2xl tracking-tight font-extrabold text-[#0F172A]">BIZON</span>
      </a>

      <div class="hidden md:flex gap-12 text-[10px] font-semibold uppercase tracking-[0.4em] text-[#0F172A]/40">
        <a href="#solutions" class="hover:text-[#3B82F6] transition">Solutions</a>
        <a href="#impact" class="hover:text-[#3B82F6] transition">Impact</a>
        <a href="#clients" class="hover:text-[#3B82F6] transition">Clients</a>
        <a href="#demo" class="hover:text-[#3B82F6] transition">Demo</a>
        <a href="#contact" class="hover:text-[#3B82F6] transition">Contact</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-6 items-center shrink-0">
        <button onclick="toggleBizonModal()" class="text-[10px] font-semibold uppercase tracking-[0.4em] text-[#0F172A]/40 hover:text-[#3B82F6]" data-mobile-menu-copy="true">Login</button>
        <button class="bg-[#3B82F6] text-white px-8 py-3.5 rounded-full font-bold text-[10px] tracking-[0.3em] uppercase hover:bg-[#2563EB] transition shadow-lg shadow-[#3B82F6]/20" data-mobile-menu-copy="true">
          데모 신청
        </button>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center justify-center pt-20">
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-[#3B82F6]/10 rounded-full blur-[150px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-10 text-center lg:text-left">
        <div class="inline-flex items-center gap-5 reveal" style="--delay: 0;">
          <span class="w-10 h-[1px] bg-[#3B82F6]"></span>
          <span class="text-[10px] font-semibold tracking-[0.6em] uppercase text-[#3B82F6]">Business Solution</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-[5.5rem] font-inter font-extrabold leading-tight tracking-tight text-[#0F172A] mobile-title reveal" style="--delay: 1;">
          비즈니스를<br><span class="text-[#3B82F6]">더 스마트하게.</span>
        </h1>

        <p class="text-[#0F172A]/50 text-sm md:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mobile-desc reveal" style="--delay: 2;">
          데이터 기반 의사결정, 업무 자동화, 성과 분석까지. BIZON은 기업의 디지털 전환을 원스톱으로 지원하는 올인원 비즈니스 솔루션입니다.
        </p>

        <div class="pt-4 flex flex-col sm:flex-row gap-5 justify-center lg:justify-start reveal" style="--delay: 3;">
          <a href="#demo" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#3B82F6] text-white font-bold text-[11px] tracking-[0.3em] uppercase hover:bg-[#2563EB] rounded-full shadow-xl shadow-[#3B82F6]/20">
            무료 데모 신청
            <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center"><i class="fas fa-arrow-right text-[10px]"></i></span>
          </a>
          <a href="#solutions" class="inline-flex items-center justify-center px-10 py-5 border border-[#3B82F6]/20 text-[#3B82F6] font-semibold text-[11px] tracking-[0.3em] uppercase hover:bg-white rounded-full">
            솔루션 보기
          </a>
        </div>
      </div>

      <div class="relative reveal" style="--delay: 2;">
        <div class="absolute -top-12 -right-12 w-72 h-72 bg-[#3B82F6]/10 rounded-full blur-[100px]"></div>
        <div class="relative group">
          <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=800&auto=format&fit=crop" alt="비즈니스 대시보드" class="w-full aspect-[4/5] object-cover rounded-[3rem] shadow-2xl group-hover:shadow-[0_30px_80px_-20px_rgba(59,130,246,0.3)] transition-all duration-700" loading="lazy" decoding="async">
