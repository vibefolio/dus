        <div class="reveal" style="--delay: 0;">
          <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=800&auto=format&fit=crop" alt="팀 협업" class="w-full aspect-[4/3] object-cover rounded-[2rem] shadow-xl" loading="lazy" decoding="async">
