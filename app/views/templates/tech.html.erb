<%# Tech Template - NEXON TECH %>

<style>
  /* Supanova Design — Dark Tech Archetype */
  * { word-break: keep-all; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3, h4 { text-wrap: balance; letter-spacing: -0.02em; line-height: 1.3; }
  a, button { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  a:hover, button:hover { transform: scale(1.02); }
  a:active, button:active { transform: scale(0.98); }

  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

  .font-sans { font-family: 'Pretendard Variable', 'Pretendard', -apple-system, sans-serif; }
  .font-mono { font-family: 'Space Grotesk', monospace; }

  @media (max-width: 768px) {
    .mobile-desc { font-size: 14px !important; line-height: 1.8; }
    .mobile-title { font-size: 36px !important; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .reveal { opacity: 0; transform: translateY(2rem); }
  .reveal.is-visible { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: calc(var(--delay, 0) * 100ms); }

  .tech-card { transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .tech-card:hover { transform: translateY(-8px); border-color: rgba(139,92,246,0.3); }

  .grid-bg {
    background-image: linear-gradient(rgba(139,92,246,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(139,92,246,0.05) 1px, transparent 1px);
    background-size: 60px 60px;
  }
</style>

<div class="bg-[#09090B] text-white font-sans selection:bg-[#8B5CF6] selection:text-white min-h-screen overflow-x-hidden relative">
  <div class="fixed inset-0 grid-bg pointer-events-none"></div>

  <!-- ========== Nav ========== -->
  <nav class="fixed w-full z-50 px-4 md:px-8 py-5 bg-[#09090B]/80 backdrop-blur-xl border-b border-white/5">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-gradient-to-br from-[#8B5CF6] to-[#A78BFA] rounded-lg flex items-center justify-center">
          <span class="font-mono font-bold text-white text-sm">N</span>
        </div>
        <span class="font-mono font-bold text-lg tracking-tight">NEXON<span class="text-[#8B5CF6]">TECH</span></span>
      </a>

      <div class="hidden md:flex gap-10 text-sm font-medium text-white/30 font-mono">
        <a href="#services" class="hover:text-[#8B5CF6] transition">Services</a>
        <a href="#portfolio" class="hover:text-[#8B5CF6] transition">Work</a>
        <a href="#about" class="hover:text-[#8B5CF6] transition">About</a>
        <a href="#contact" class="hover:text-[#8B5CF6] transition">Contact</a>
      </div>

      <button class="mobile-menu-trigger md:hidden ml-auto text-2xl focus:outline-none" style="color: inherit;">
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden md:flex gap-4 items-center">
        <a href="#contact" class="bg-[#8B5CF6] text-white px-6 py-2.5 rounded-lg text-sm font-mono font-semibold hover:bg-[#7C3AED] shadow-lg shadow-[#8B5CF6]/20" data-mobile-menu-copy="true">프로젝트 문의</a>
      </div>
    </div>

    <%= render partial: 'templates/shared/mobile_menu_overlay' %>
  </nav>

  <!-- ========== Hero ========== -->
  <header class="min-h-[100dvh] relative flex items-center pt-20 overflow-hidden">
    <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-[#8B5CF6]/10 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[300px] h-[300px] bg-[#A78BFA]/10 rounded-full blur-[100px]"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 text-center w-full py-20">
      <div class="inline-flex items-center gap-2 bg-white/5 px-4 py-2 rounded-full border border-[#8B5CF6]/20 reveal" style="--delay: 0;">
        <span class="w-2 h-2 bg-[#8B5CF6] rounded-full animate-pulse"></span>
        <span class="text-sm font-mono text-[#8B5CF6]">We Build Digital Futures</span>
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-8xl font-bold leading-tight mt-8 mobile-title reveal" style="--delay: 1;">
        기술로<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#8B5CF6] to-[#A78BFA]">미래를 만듭니다</span>
      </h1>

      <p class="text-white/30 text-base md:text-lg leading-relaxed max-w-lg mx-auto mt-8 mobile-desc reveal" style="--delay: 2;">
        NEXON TECH는 AI, 클라우드, 풀스택 개발 전문 기업입니다. 혁신적인 기술로 비즈니스의 디지털 전환을 이끕니다.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 reveal" style="--delay: 3;">
        <a href="#contact" class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-[#8B5CF6] text-white rounded-lg font-mono font-semibold shadow-lg shadow-[#8B5CF6]/25 hover:bg-[#7C3AED]">
          프로젝트 시작하기
        </a>
        <a href="#services" class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-white/10 rounded-lg font-mono font-semibold text-white/60 hover:border-[#8B5CF6] hover:text-[#8B5CF6]">
          서비스 보기
        </a>
      </div>

      <div class="flex items-center gap-12 justify-center pt-12 reveal" style="--delay: 4;">
        <div class="text-center">
          <p class="text-3xl font-mono font-bold text-[#8B5CF6]">200+</p>
          <p class="text-xs text-white/20 mt-1 font-mono">완료 프로젝트</p>
        </div>
        <div class="w-px h-10 bg-white/5"></div>
        <div class="text-center">
          <p class="text-3xl font-mono font-bold text-[#8B5CF6]">50+</p>
          <p class="text-xs text-white/20 mt-1 font-mono">엔지니어</p>
        </div>
        <div class="w-px h-10 bg-white/5"></div>
        <div class="text-center">
          <p class="text-3xl font-mono font-bold text-[#8B5CF6]">99.9%</p>
          <p class="text-xs text-white/20 mt-1 font-mono">서비스 안정성</p>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== 서비스 ========== -->
  <section id="services" class="py-24 md:py-32 relative">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-mono font-semibold text-[#8B5CF6] tracking-wider uppercase reveal" style="--delay: 0;">Services</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 reveal" style="--delay: 1;">핵심 서비스</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="tech-card bg-white/[0.03] p-8 rounded-xl border border-white/5 reveal" style="--delay: 0;">
          <div class="w-12 h-12 bg-[#8B5CF6]/10 rounded-lg flex items-center justify-center mb-6">
            <i class="fas fa-brain text-[#8B5CF6] text-lg"></i>
          </div>
          <h3 class="text-lg font-bold mb-3 font-mono">AI / ML</h3>
          <p class="text-sm text-white/30 leading-relaxed">맞춤형 AI 모델 개발, 자연어 처리, 컴퓨터 비전, 추천 시스템 구축.</p>
        </div>

        <div class="tech-card bg-white/[0.03] p-8 rounded-xl border border-white/5 reveal" style="--delay: 1;">
          <div class="w-12 h-12 bg-[#8B5CF6]/10 rounded-lg flex items-center justify-center mb-6">
            <i class="fas fa-cloud text-[#8B5CF6] text-lg"></i>
          </div>
          <h3 class="text-lg font-bold mb-3 font-mono">Cloud</h3>
          <p class="text-sm text-white/30 leading-relaxed">AWS, GCP, Azure 기반 인프라 설계, DevOps, 마이크로서비스 아키텍처.</p>
        </div>

        <div class="tech-card bg-white/[0.03] p-8 rounded-xl border border-white/5 reveal" style="--delay: 2;">
          <div class="w-12 h-12 bg-[#8B5CF6]/10 rounded-lg flex items-center justify-center mb-6">
            <i class="fas fa-code text-[#8B5CF6] text-lg"></i>
          </div>
          <h3 class="text-lg font-bold mb-3 font-mono">Web / App</h3>
          <p class="text-sm text-white/30 leading-relaxed">React, Next.js, Flutter 기반 풀스택 웹/앱 개발. API 설계 및 구축.</p>
        </div>

        <div class="tech-card bg-white/[0.03] p-8 rounded-xl border border-white/5 reveal" style="--delay: 3;">
          <div class="w-12 h-12 bg-[#8B5CF6]/10 rounded-lg flex items-center justify-center mb-6">
