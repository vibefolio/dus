      <a href="#contact" class="inline-flex items-center justify-center gap-2 px-12 py-5 bg-[#8B5CF6] text-white rounded-lg font-mono font-bold text-lg shadow-lg shadow-[#8B5CF6]/25 hover:bg-[#7C3AED] mt-10 reveal" style="--delay: 2;">
        무료 상담 신청
      </a>
    </div>
  </section>

