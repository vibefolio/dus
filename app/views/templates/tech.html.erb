            <ul class="space-y-2.5">
              <li><a href="#about" class="text-white/30 text-sm hover:text-[#8B5CF6] transition font-mono">About</a></li>
              <li><a href="#portfolio" class="text-white/30 text-sm hover:text-[#8B5CF6] transition font-mono">Work</a></li>
