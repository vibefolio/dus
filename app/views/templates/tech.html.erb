            </select>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-mono text-white/50 mb-2">프로젝트 설명</label>
            <textarea rows="4" placeholder="프로젝트에 대해 설명해주세요" class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-3.5 text-white placeholder-white/20 outline-none focus:border-[#8B5CF6]/50 transition font-mono resize-none"></textarea>
          </div>
        </div>
        <button class="w-full mt-8 bg-[#8B5CF6] text-white py-4 rounded-lg font-mono font-bold text-lg hover:bg-[#7C3AED] shadow-lg shadow-[#8B5CF6]/20">문의 보내기</button>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-4 md:px-8 text-center">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold reveal" style="--delay: 0;">
        다음 프로젝트,<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#8B5CF6] to-[#A78BFA]">함께 시작하세요.</span>
