            <input type="text" placeholder="이름" class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-3.5 text-white placeholder-white/20 outline-none focus:border-[#8B5CF6]/50 transition font-mono">
          </div>
          <div>
            <label class="block text-sm font-mono text-white/50 mb-2">이메일</label>
            <input type="email" placeholder="email@company.com" class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-3.5 text-white placeholder-white/20 outline-none focus:border-[#8B5CF6]/50 transition font-mono">
          </div>
          <div>
            <label class="block text-sm font-mono text-white/50 mb-2">예산 규모</label>
            <select class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-3.5 text-white outline-none focus:border-[#8B5CF6]/50 transition font-mono">
