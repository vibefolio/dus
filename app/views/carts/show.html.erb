<% content_for :title, "장바구니 - 디어스" %>

<div class="container" style="padding-top: 60px; padding-bottom: 80px; min-height: 60vh;">
  <div style="margin-bottom: 32px;">
    <span class="eyebrow" style="margin-bottom: 12px; display: inline-block;">Shopping Cart</span>
    <h1 style="font-size: 32px; font-weight: 800; color: #111;">장바구니</h1>
  </div>

  <% if @items.any? %>
    <div style="display: flex; flex-direction: column; gap: 24px;">
      <!-- Item List -->
      <div class="card-premium">
        <div class="card-premium-inner" style="padding: 0; overflow: hidden;">
          <% @items.each do |item| %>
            <div style="display: flex; align-items: center; padding: 24px; border-bottom: 1px solid #f3f4f6; transition: background 0.3s;" class="cart-item-row">
              <!-- Placeholder Image -->
              <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #f0fdf4, #dcfce7); border-radius: 16px; margin-right: 20px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="32" height="32" fill="none" stroke="#00a859" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>

              <div style="flex: 1;">
                <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 4px; color: #111;"><%= item.item.try(:title) || item.item.try(:name) || "상품명 없음" %></h3>
                <p style="color: #6b7280; font-size: 14px;"><%= number_to_currency(item.item.try(:price) || 0, unit: "원", format: "%n%u", precision: 0) %></p>
              </div>

              <div style="display: flex; align-items: center; gap: 16px;">
                <span style="font-weight: 600; color: #374151; font-size: 15px;">수량: <%= item.quantity %></span>
                <%= button_to "삭제", remove_item_cart_path(item), method: :delete, style: "padding: 8px 16px; border: 1px solid #fca5a5; border-radius: 9999px; background: transparent; color: #ef4444; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);", class: "cart-delete-btn" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Summary -->
      <div class="card-premium">
        <div class="card-premium-inner" style="padding: 32px; text-align: right;">
          <p style="font-size: 16px; color: #6b7280; margin-bottom: 10px;">총 결제 예정 금액</p>
          <p style="font-size: 36px; font-weight: 900; color: var(--color-primary); margin-bottom: 32px;">
            <%= number_to_currency(@cart.total_price, unit: "원", format: "%n%u", precision: 0) %>
          </p>

          <button onclick="requestPayment()" style="width: 100%; max-width: 300px; padding: 16px 32px; background: linear-gradient(135deg, #00a859, #00d670); color: white; font-weight: 800; border: none; border-radius: 9999px; cursor: pointer; font-size: 18px; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 4px 16px rgba(0, 168, 89, 0.2); margin-left: auto; display: flex; align-items: center; justify-content: center; gap: 8px;" class="cart-pay-btn">
            포트원 결제하기
            <span style="width: 32px; height: 32px; border-radius: 9999px; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center;">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
            </span>
          </button>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="card-premium" style="text-align: center;">
      <div class="card-premium-inner" style="padding: 80px 32px;">
        <div style="width: 80px; height: 80px; background: #f3f4f6; border-radius: 9999px; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
          <svg width="40" height="40" fill="none" stroke="#9ca3af" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 style="font-size: 22px; font-weight: 700; color: #374151; margin-bottom: 8px;">장바구니가 비어있습니다</h3>
        <p style="color: #9ca3af; margin-bottom: 24px;">마음에 드는 템플릿을 담아보세요</p>
        <%= link_to "쇼핑 계속하기", products_path, style: "display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; border: 2px solid #e5e7eb; border-radius: 9999px; color: #374151; font-weight: 600; text-decoration: none; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);", class: "cart-continue-btn" %>
      </div>
    </div>
  <% end %>
</div>

<style>
  .cart-item-row:hover { background: #f9fafb; }
  .cart-item-row:last-child { border-bottom: none !important; }
  .cart-delete-btn:hover { background: #fef2f2 !important; border-color: #ef4444 !important; }
  .cart-pay-btn:hover { transform: scale(1.02); box-shadow: 0 8px 24px rgba(0, 168, 89, 0.4) !important; }
  .cart-pay-btn:active { transform: scale(0.98); }
  .cart-pay-btn:hover span { transform: translateX(4px); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .cart-continue-btn:hover { border-color: var(--color-primary) !important; color: var(--color-primary) !important; }
</style>

<script>
  async function requestPayment() {
    const storeId = "<%= ENV['PORTONE_STORE_ID'] || 'store-id-placeholder' %>";
    const channelKey = "<%= ENV['PORTONE_CHANNEL_KEY'] || 'channel-key-placeholder' %>";

    if (!storeId || storeId === 'store-id-placeholder') {
      alert("포트원 Store ID가 설정되지 않았습니다. 관리자에게 문의하세요.");
      return;
    }

    try {
      const paymentId = `payment-${crypto.randomUUID()}`;

      const response = await PortOne.requestPayment({
        storeId: storeId,
        channelKey: channelKey,
        paymentId: paymentId,
        orderName: "<%= @items.first&.product&.name %> 외 <%= @items.count - 1 %>건",
        totalAmount: <%= @cart.total_price %>,
        currency: "CURRENCY_KRW",
        payMethod: "CARD",
        customer: {
          fullName: "<%= current_user&.name || '방문자' %>",
          email: "<%= current_user&.email %>",
          phoneNumber: "010-0000-0000",
        },
        redirectUrl: window.location.origin + "/orders/complete",
      });

      if (response.code != null) {
        alert(`결제 실패: ${response.message}`);
      } else {
        alert("결제가 완료되었습니다! (서버 검증은 별도 구현 필요)");
      }
    } catch (e) {
      console.error(e);
      alert("결제 요청 중 오류가 발생했습니다.");
    }
  }
</script>
