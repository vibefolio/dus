<div style="margin-bottom: var(--space-8); display: flex; justify-content: space-between; align-items: center;">
  <div>
    <h1 style="font-size: var(--text-4xl); margin-bottom: var(--space-2);">파트너 관리</h1>
    <p class="text-gray">세무사, 법무사 등 전문가 파트너를 관리하세요</p>
  </div>
  <%= link_to "새 파트너 추가", new_admin_partner_path, class: "btn btn-primary" %>
</div>

<!-- 유형별 요약 -->
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-bottom: var(--space-8);">
  <% Partner::TYPES.each do |type_key, type_label| %>
    <div class="card" style="padding: var(--space-4); text-align: center;">
      <p style="font-size: 24px; font-weight: 700;"><%= Partner.where(partner_type: type_key).count %></p>
      <p style="color: var(--color-gray-500); font-size: 14px;"><%= type_label %> 파트너</p>
    </div>
  <% end %>
</div>

<div style="background: white; border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-sm);">
  <table style="width: 100%; border-collapse: collapse;">
    <thead style="background: var(--color-gray-50); border-bottom: 2px solid var(--color-gray-200);">
      <tr>
        <th style="padding: var(--space-4); text-align: left;">이름</th>
        <th style="padding: var(--space-4); text-align: left;">유형</th>
        <th style="padding: var(--space-4); text-align: left;">이메일</th>
        <th style="padding: var(--space-4); text-align: left;">소속 에이전시</th>
        <th style="padding: var(--space-4); text-align: center;">누적 리드</th>
        <th style="padding: var(--space-4); text-align: center;">상태</th>
        <th style="padding: var(--space-4); text-align: center;">관리</th>
      </tr>
    </thead>
    <tbody>
      <% if @partners.any? %>
        <% @partners.each do |partner| %>
          <tr style="border-bottom: 1px solid var(--color-gray-100);">
            <td style="padding: var(--space-4);"><strong><%= partner.name %></strong></td>
            <td style="padding: var(--space-4);">
              <span style="padding: 2px 10px; border-radius: 9999px; font-size: 12px; font-weight: 600; background: #e0f2fe; color: #0369a1;">
                <%= partner.type_label %>
              </span>
            </td>
            <td style="padding: var(--space-4); font-size: 14px;"><%= partner.email %></td>
            <td style="padding: var(--space-4); font-size: 14px; color: var(--color-gray-500);">
              <%= partner.agency&.name || "-" %>
            </td>
            <td style="padding: var(--space-4); text-align: center; font-weight: 700; color: var(--color-primary);">
              <%= partner.lead_count %>
            </td>
            <td style="padding: var(--space-4); text-align: center;">
              <span style="padding: 4px 8px; border-radius: 9999px; font-size: 12px; <%= partner.active ? 'background: #dcfce7; color: #166534;' : 'background: #f3f4f6; color: #374151;' %>">
                <%= partner.active ? '활성' : '비활성' %>
              </span>
            </td>
            <td style="padding: var(--space-4); text-align: center;">
              <%= link_to "수정", edit_admin_partner_path(partner), class: "btn btn-sm btn-outline" %>
              <%= button_to "삭제", admin_partner_path(partner), method: :delete,
                  class: "btn btn-sm",
                  style: "margin-left: 4px; background: #fee2e2; color: #dc2626;",
                  data: { confirm: "#{partner.name} 파트너를 삭제하시겠습니까?" } %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="7" style="padding: var(--space-10); text-align: center; color: var(--color-gray-500);">
            등록된 파트너가 없습니다.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
